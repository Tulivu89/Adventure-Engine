// ============================================================================
// SECTION 3 — SCRIPT-LEVEL STATE VARIABLES
// All mutable module-level state. Declared here so the full state surface is
// visible in one place. Never rely on implicit global declaration.
// ============================================================================

// ── Engine State ──────────────────────────────────────────────────────────────
// ae_lock: probability engine mutex — prevents double-rolling on a single player input.
var ae_lock = false;
var ae_genInFlight = false;  // [v0.9.36] an editor.generate() is active (cleared in onGenerationEnd)

// ── Editor Yoink generation (budget-free) ────────────────────────────────────
// [vNEXT] The World-Build Wizard's chats and field generators must not draw on the
// script generation budget. Instead of api.v1.generate(), we hijack the normal
// editor generation path (the "yoink" method, per Yoink Editor Gen / Brainstorming
// Partner): set _yoinkState.active, swap our prompt in via onContextBuilt, capture
// + swallow the output via onResponse, and resolve the promise in onGenerationEnd.
// While active, the engine's normal context/response/end logic early-returns so a
// yoink gen never injects world-state, ticks the story counter, or fires triggers.
interface AEYoinkState {
    active: boolean;
    messages: any[];
    responseText: string;
    resolve: ((value: string) => void) | null;
    reject: ((reason: any) => void) | null;
}
var _aeYoink: AEYoinkState = { active: false, messages: [], responseText: '', resolve: null, reject: null };

// [vNEXT] Run a budget-free generation against a custom message array. Resolves with
// the captured response text. Guards against overlapping with any in-flight gen.
// [v0.9.7.12] editor.generate() shares the same script-level rate limit as
// api.v1.generate(). Long wizard sessions can exhaust this budget. Added:
//   - api.v1.editor.isBlocked() check (editor already mid-generation)
//   - api.v1.script.getAllowedOutput() floor (< 80 tokens = budget near empty)
//   - friendly error surfaced as toast when the rate limit is hit
function executeYoinkGeneration(messages: any[]): Promise<string> {
    return new Promise(function(resolve, reject) {
        if (_aeYoink.active) { reject(new Error('A yoink generation is already in progress')); return; }
        if (ae_genInFlight || ae_lock) { reject(new Error('Editor is busy; try again in a moment')); return; }
        // [v0.9.7.12] Budget floor: < 80 tokens remaining = rate limit imminent.
        // The runtime state generators already guard at 220; 80 is a softer floor for
        // interactive wizard calls so the user gets a clear message, not a raw API error.
        const ygBudget = api.v1.script.getAllowedOutput ? api.v1.script.getAllowedOutput() : 9999;
        if (ygBudget < 80) {
            const ygMsg = 'Script generation budget is low. Wait a moment, then try again.';
            api.v1.ui.toast(ygMsg, { type: 'warning', autoClose: 4000 });
            reject(new Error(ygMsg)); return;
        }
        _aeYoink.active = true;
        _aeYoink.messages = messages;
        _aeYoink.responseText = '';
        _aeYoink.resolve = resolve;
        _aeYoink.reject = reject;
        api.v1.editor.generate().catch(function(ygErr) {
            _aeYoink.active = false;
            _aeYoink.resolve = null;
            _aeYoink.reject = null;
            // [v0.9.7.12] Surface rate-limit errors as a human-readable toast rather
            // than letting the raw NAI error bubble silently to the log.
            const ygEMsg = String((ygErr && ygErr.message) || ygErr || '');
            if (ygEMsg.toLowerCase().indexOf('limit') >= 0 || ygEMsg.toLowerCase().indexOf('budget') >= 0) {
                api.v1.ui.toast('Generation limit reached. Wait a moment before retrying.', { type: 'warning', autoClose: 5000 });
            }
            reject(ygErr);
        });
    });
}
var ae_sbcInFlight = false;  // [v0.9.36] a scene-state broadcast is running
var ae_sbcPending  = false;  // [v0.9.36] another scene-state broadcast was requested while one ran
var ae_cdbInFlight = false;  // [v0.9.36] a character-data broadcast is running
var ae_cdbPending  = false;  // [v0.9.36] another character-data broadcast was requested while one ran
var ae_pendingGenerate = false; // [v0.9.37] a move effect requested generation; the top-level handler fires it once after ALL effects

// ── Bridge Communication State ────────────────────────────────────────────────
// isBridgeReady: set true after first successful EVT_HANDSHAKE_ACK.
// engineScriptId is not stored here (this IS the engine); the bridge stores it.
var isBridgeReady = false;

// Debounce timers for broadcast functions (Section 18).
// Both functions are called frequently (on every save); debouncing prevents storms.
var _sceneBroadcastTimeout: any = null;
var _charDataBroadcastTimeout: any = null;

// ── Character Visual Cache ────────────────────────────────────────────────────
// [CHANGE] Renamed from cachedCharConfigs (bridge roster data) to cachedCharVisuals
// (engine character visual fields). Now populated TWO ways:
//   1. On init: seeded from storyStorage so the HUD has data before the bridge connects.
//   2. On EVT_CHAR_SYNC_PUSH: bridge can push overrides (kept for legacy compat).
// getCharacterData() reads from this cache. Bridge reads it via EVT_CHAR_DATA_SYNC.
var cachedCharVisuals: CharacterVisualRecord[] = [];

// ── Image Settings State ──────────────────────────────────────────────────────
// Loaded from api.v1.storage (global, not story-bound) by loadImageSettings().
var profiles: ImagePreset[]             = [];
var activeIndex: number                 = 0;
var globalSettings: GlobalImageSettings = {
    autoDownload: false,
    contextSize: DEFAULT_CTX,
    architectPrompt: DEFAULT_ARCH,
    architectAutoSnap: true
};

// ── NAI Sidebar Modal Handles ─────────────────────────────────────────────────
// Handles for the NAI-side modal windows (GM authoring tools).
// Each is set when a modal opens and nulled when it closes.
var charEditModalHandle: any   = null;   // character editor modal
var configModalHandle: any     = null;   // global config/settings modal
var entityEditModalHandle: any = null;   // entity/location editor modal
var editingCharId: string | null   = null;  // ID of the character currently open in charEditModal
var editingEntityId: string | null = null;  // ID of the entity currently open in entityEditModal
var currentActionWidget: any   = null;   // active action widget handle (entity action buttons)

// ============================================================================
// SECTION 4 — UTILITY FUNCTIONS
// Pure helpers and factory functions with no side effects.
// These are called throughout the script and must be defined before first use.
// ============================================================================

function mirrorGlobalResourcesToCharacter(char: CharacterRecord, cfg: GlobalConfig): CharacterRecord {
    // Ensures a character has definitions for all global resources.
    // Adds any that are missing without overwriting existing ones.
    if (!cfg.resources || cfg.resources.length === 0) return char;

    if (!char.charResourceDefs) char.charResourceDefs = [];
    if (!char.charResourceValues) char.charResourceValues = {};
    const existingTags = new Set(char.charResourceDefs.map(r => r.tag));

    for (const globalRes of cfg.resources) {
        if (existingTags.has(globalRes.tag)) continue;

        const newId = generateId();
        const newDef: CharResourceDef = {
            id: newId,
            name: globalRes.name,
            tag: globalRes.tag,
            type: globalRes.type,
            hasBounds: globalRes.hasBounds,
            min: globalRes.min,
            max: globalRes.max,
            states: globalRes.states ? [...globalRes.states] : undefined
        };
        char.charResourceDefs.push(newDef);
        char.charResourceValues[newId] = 0; // Initialize value
    }
    return char;
}

function seedPersonalResourcesToCharacter(char: CharacterRecord, cfg: GlobalConfig): CharacterRecord {
    // [v0.9.63] Adds personal resource defaults (gold/luck/health) to a character — but
    // only in new-model worlds. Gated on the tag being ABSENT from cfg.resources globals:
    // in legacy worlds these are still global/party, so seeding is skipped to avoid a
    // confusing personal+global duplicate. Idempotent by tag.
    if (!char.charResourceDefs) char.charResourceDefs = [];
    if (!char.charResourceValues) char.charResourceValues = {};
    const seedGlobalTags = new Set((cfg.resources || []).map(function(r) { return r.tag; }));
    const seedExistingTags = new Set(char.charResourceDefs.map(function(r) { return r.tag; }));
    for (const pdef of (cfg.characterResourceDefs || DEFAULT_CHAR_RESOURCES)) {   // [v0.9.69] configurable template
        if (seedGlobalTags.has(pdef.tag)) continue;   // legacy world — keep it global
        if (seedExistingTags.has(pdef.tag)) continue; // already present — idempotent
        const seedId = generateId();
        const seedDef: CharResourceDef = {
            id: seedId,
            name: pdef.name,
            tag: pdef.tag,
            type: pdef.type,
            hasBounds: pdef.hasBounds,
            min: pdef.min,
            max: pdef.max,
            states: pdef.states ? pdef.states.slice() : undefined
        };
        char.charResourceDefs.push(seedDef);
        // Starting values: currency empty (earned), luck full (spendable), health top (Healthy), attitude neutral.
        if (pdef.type === 'pool') {
            char.charResourceValues[seedId] = (pdef.tag === '#currency') ? 0 : (pdef.max !== undefined ? pdef.max : 0);
        } else {
            char.charResourceValues[seedId] = pdef.states ? (pdef.states.length - 1) : 0;
        }
    }
    return char;
}

// ── ID Generation ─────────────────────────────────────────────────────────────

function generateId(): string {
    // Generates a collision-resistant ID from timestamp + random suffix.
    // Used for all new records (characters, entities, rules, milestones, etc.).
    return Date.now().toString(36) + Math.random().toString(36).substring(2);
}

// [v1.6.3 ICON-LIB] The entity `icon` field is free text shared by the engine and the bridge.
// The bridge can resolve a bare library name (e.g. "crown") to an SVG glyph; the engine's
// native labels can't, and would render the literal word ("crown Cave"). aeIconPfx returns a
// label prefix ONLY for glyph icons (emoji / non-ASCII symbols), suppressing bare ASCII
// library-name icons so native labels stay clean while the bridge shows the SVG. Returns the
// icon plus a trailing space, or '' when there is no glyph to show.
function aeIconPfx(icon?: string): string {
    if (!icon) return '';
    let s = String(icon).trim();
    if (!s) return '';
    // A library name is plain ASCII word characters (letters/digits/underscore/hyphen). Any
    // codepoint outside ASCII (emoji, arrows, symbols) marks a real glyph and is kept.
    let isBareName = /^[A-Za-z0-9_-]+$/.test(s);
    return isBareName ? '' : (s + ' ');
}

// ── World-Build Wizard: assemble + commit the Memory block ───────────────────
// [vNEXT] Assembles enabled, non-blank, memory-targeted sections into the static
// Memory block ("[ Label ]\n<content>", blank-separated) and returns it. Style and
// any other 'an'-targeted sections are NOT included here — they commit separately.
function assembleWizardMemory(sections: WizardMemorySection[]): string {
    let blocks: string[] = [];
    for (let s of (sections || [])) {
        if (!s || s.target !== 'memory') continue;
        if (!s.enabled) continue;
        let body = (s.content || '').trim();
        if (!body) continue;
        blocks.push('[ ' + s.label + ' ]\n' + body);
    }
    return blocks.join('\n\n');
}

// [vNEXT] Assembles 'an'-targeted sections (e.g. Style) into an Author's Note body.
function assembleWizardAuthorNote(sections: WizardMemorySection[]): string {
    let blocks: string[] = [];
    for (let s of (sections || [])) {
        if (!s || s.target !== 'an') continue;
        if (!s.enabled) continue;
        let body = (s.content || '').trim();
        if (!body) continue;
        blocks.push('[ ' + s.label + ': ' + body + ' ]');
    }
    return blocks.join('\n\n');
}

// [v0.9.7.3 AN-FIX] Commits the assembled wizard sections to the real NAI surfaces.
// Memory sections OVERWRITE the Memory field (static world canon — stable, written once).
// AN sections (Style, etc.) are written into a NAMED REGION of the Author's Note using
// AE_WIZ_AN_SENTINEL so they coexist with the scene-state block injected at generation
// time by onBeforeContextBuild. The scene block is NEVER stored in the persisted AN —
// it is appended ephemerally per-generation. The wizard region always sits FIRST in the
// persisted AN; the scene block is appended AFTER it at generation time so it has the
// highest recency weight in the AN slot.
async function commitWizardMemory(cfg: GlobalConfig): Promise<boolean> {
    try {
        let mem = assembleWizardMemory(cfg.wizardSections || []);
        await api.v1.memory.set(mem);

        let wizAN = assembleWizardAuthorNote(cfg.wizardSections || []);

        // Read the current persisted AN and strip both managed regions before rewriting.
        // Safe to call repeatedly (idempotent). Strip scene sentinel first (defensive),
        // then strip any prior wizard region.
        let existingAN = '';
        try { existingAN = (await api.v1.an.get()) || ''; } catch (_eRead) {}

        // Strip stale scene block (defensive — should never be persisted).
        let sceneMarker = '\n\n' + AE_AN_SENTINEL;
        let sceneIdx = existingAN.lastIndexOf(sceneMarker);
        if (sceneIdx >= 0) {
            existingAN = existingAN.substring(0, sceneIdx);
        } else if (existingAN.indexOf(AE_AN_SENTINEL) === 0) {
            existingAN = '';
        }
        existingAN = existingAN.replace(/\s+$/, '');

        // Strip any prior wizard region.
        let wizMarker = '\n\n' + AE_WIZ_AN_SENTINEL;
        let wizIdx = existingAN.lastIndexOf(wizMarker);
        if (wizIdx >= 0) {
            existingAN = existingAN.substring(0, wizIdx);
        } else if (existingAN.indexOf(AE_WIZ_AN_SENTINEL) === 0) {
            existingAN = '';
        }
        existingAN = existingAN.replace(/\s+$/, '');

        // Re-assemble: any non-AE base content + wizard region (if any AN sections enabled).
        let finalAN: string;
        if (wizAN.trim()) {
            let wizRegion = AE_WIZ_AN_SENTINEL + '\n' + wizAN.trim();
            finalAN = existingAN ? (existingAN + '\n\n' + wizRegion) : wizRegion;
        } else {
            finalAN = existingAN;
        }

        await api.v1.an.set(finalAN);
        return true;
    } catch (e) {
        api.v1.error('[AE:wizard] commitWizardMemory error:', e);
        return false;
    }
}

// ── World-Build Wizard: context assembly ─────────────────────────────────────
// [vNEXT] Builds the read-only context preamble for a wizard chat from its selected
// sources: project concept fields, other wizard chats, lorebook entries, and recent
// story text. Each source is clearly delimited so the model treats it as reference.
async function buildWizardContext(chat: WizardChat, cfg: GlobalConfig): Promise<string> {
    let parts: string[] = [];

    let pName = (cfg.projectName || '').trim();
    let pGenre = (cfg.projectGenre || '').trim();
    let pConcept = (cfg.projectConcept || '').trim();
    if (pName || pGenre || pConcept) {
        let head: string[] = [];
        if (pName)    head.push('Project: ' + pName);
        if (pGenre)   head.push('Genre: ' + pGenre);
        if (pConcept) head.push('Concept: ' + pConcept);
        parts.push('--- PROJECT ---\n' + head.join('\n'));
    }

    let ctxIds = chat.contextChatIds || [];
    if (ctxIds.length > 0) {
        let allChats = await loadWizardChats();
        for (let cid of ctxIds) {
            let oc = allChats.find(function(c) { return c.id === cid; });
            if (!oc || !oc.messages || oc.messages.length === 0) continue;
            let transcript = oc.messages.map(function(m) { return '[' + m.role.toUpperCase() + '] ' + m.content; }).join('\n');
            parts.push('--- CHAT: ' + oc.title + ' ---\n' + transcript);
        }
    }

    let loreIds = chat.lorebookEntryIds || [];
    for (let lid of loreIds) {
        try {
            let entry = await api.v1.lorebook.entry(lid);
            if (entry && entry.text && entry.text.trim()) {
                let lname = (entry as any).displayName || (entry as any).name || 'Lorebook Entry';
                parts.push('--- LOREBOOK: ' + lname + ' ---\n' + entry.text.trim());
            }
        } catch (e) { api.v1.log('[AE:wizard] lorebook context read failed for ' + lid); }
    }

    // [v0.9.99] Per-chat character context — the chat decides, independent of each
    // character's global charContextEnabled flag. Formatted straight from the record.
    let charCtxIds = chat.characterIds || [];
    for (let chCid of charCtxIds) {
        try {
            let cc = await loadCharacter(chCid);
            if (!cc) continue;
            let ccLines: string[] = [];
            if (cc.briefDescription) ccLines.push(cc.briefDescription);
            if (cc.species || cc.age || cc.gender || cc.occupationRole) ccLines.push([cc.species, cc.age, cc.gender, cc.occupationRole].filter(Boolean).join(', '));
            if (cc.personalityCore) ccLines.push('Personality: ' + cc.personalityCore);
            if (cc.background) ccLines.push('Background: ' + cc.background);
            if (ccLines.length) parts.push('--- CHARACTER: ' + cc.name + ' ---\n' + ccLines.join('\n'));
        } catch (eCc) { api.v1.log('[AE:wizard] character context read failed for ' + chCid); }
    }

    if (chat.includeStory) {
        let story = await getRecentStoryText(2000);
        if (story.trim()) parts.push('--- RECENT STORY ---\n' + story.trim());
    }

    return parts.join('\n\n');
}

// ── World-Build Wizard: chat turn (yoink) ────────────────────────────────────
// [vNEXT] Appends the user's message, runs a budget-free yoink generation against
// the topic persona + assembled context + transcript, appends the assistant reply,
// and persists the chat. Returns the assistant text (or null on failure).
async function runWizardChatTurn(chatId: string, userText: string): Promise<string | null> {
    let cfg = await loadConfig();
    let chat = await loadWizardChat(chatId);
    if (!chat) return null;
    let topic = getWizardTopic(cfg, chat.topicId);
    let persona = topic ? topic.instructions : 'You are a helpful worldbuilding assistant. Keep replies short and conversational.';

    if (userText && userText.trim()) {
        chat.messages.push({ role: 'user', content: userText.trim() });
    }

    let ctx = await buildWizardContext(chat, cfg);
    let sysParts: string[] = [persona];
    if (ctx.trim()) {
        sysParts.push('The following is READ-ONLY reference context. Use it to inform your replies, but do not quote it back verbatim.\n\n' + ctx);
    }

    let msgs: any[] = [{ role: 'system', content: sysParts.join('\n\n') }];
    for (let m of chat.messages) {
        msgs.push({ role: m.role, content: m.content });
    }

    let reply = '';
    try {
        reply = await executeYoinkGeneration(msgs);
    } catch (e) {
        api.v1.error('[AE:wizard] chat turn generation failed:', e);
        return null;
    }
    reply = (reply || '').trim();
    if (!reply) return null;

    chat.messages.push({ role: 'assistant', content: reply });
    await saveWizardChat(chat);
    return reply;
}

// ── World-Build Wizard: per-section generation (yoink) ───────────────────────
// [vNEXT] Generates ONE memory section's content from a chat transcript, scoped hard
// to that section's instructions so sections never bleed into each other. Already-
// written sections are passed as read-only context to avoid overlap. Returns the
// generated text (or null on failure).
async function generateWizardSection(section: WizardMemorySection, chat: WizardChat, cfg: GlobalConfig, priorSections: WizardMemorySection[], hint?: string): Promise<string | null> {
    let sys = [
        'You are writing the "' + section.label + '" section of a story\'s static world canon.',
        section.instructions,
        'CONSTRAINT: Write ONLY the content of this section. Do not begin with a label, heading, or the section name. Do not write any other section\'s content. Be concise and concrete. Your first word must be content.',
        'CRITICAL RULE: DO NOT use any markdown, bolding, italics, or bullet points. Output plain text only.'
    ].join('\n\n');

    let priorLines: string[] = [];
    for (let ps of (priorSections || [])) {
        if (ps.id === section.id) continue;
        let body = (ps.content || '').trim();
        if (body) priorLines.push('[' + ps.label + '] ' + body);
    }

    let transcript = (chat.messages || []).map(function(m) { return '[' + m.role.toUpperCase() + '] ' + m.content; }).join('\n');
    let extraCtx = await buildWizardContext(chat, cfg);

    let usrParts: string[] = [];
    if (extraCtx.trim()) usrParts.push(extraCtx);
    if (priorLines.length > 0) usrParts.push('--- ALREADY-WRITTEN SECTIONS (do not repeat these; stay in your own scope) ---\n' + priorLines.join('\n'));
    if (transcript.trim()) usrParts.push('--- BRAINSTORMING CHAT ---\n' + transcript);
    if (hint && hint.trim()) usrParts.push('--- EXTRA GUIDANCE FOR THIS REGENERATION ---\n' + hint.trim());
    usrParts.push('Now write the "' + section.label + '" section.');

    let msgs: any[] = [
        { role: 'system', content: sys },
        { role: 'user', content: usrParts.join('\n\n') }
    ];

    let result = '';
    try {
        result = await executeYoinkGeneration(msgs);
    } catch (e) {
        api.v1.error('[AE:wizard] section generation failed (' + section.label + '):', e);
        return null;
    }
    return (result || '').trim() || null;
}

// [vNEXT] Regenerate ONE section in place (does not commit memory). Uses the given
// chat as transcript source when provided, else a transient empty chat so project
// fields + hint still drive generation. Writes the result into cfg.wizardSections.
async function regenerateWizardSection(sectionId: string, sourceChatId: string, hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let section = (cfg.wizardSections || []).find(function(s) { return s.id === sectionId; });
    if (!section) return null;
    let chat: WizardChat | null = sourceChatId ? await loadWizardChat(sourceChatId) : null;
    if (!chat) {
        chat = { id: 'transient', topicId: '', title: '', messages: [], contextChatIds: [], includeStory: false, lorebookEntryIds: [], createdAt: 0, updatedAt: 0 };
    }
    let prior = cfg.wizardSections || [];
    let gen = await generateWizardSection(section, chat, cfg, prior, hint);
    if (!gen) return null;
    await mutConfig(function(c) {
        let target = (c.wizardSections || []).find(function(s) { return s.id === sectionId; });
        if (target) target.content = gen;
    });
    return gen;
}

// [v0.9.81] Build wizard context from MULTIPLE source chats (multi-select). Constructs a
// synthetic chat whose contextChatIds are the selected chats, so buildWizardContext pulls
// each selected chat's transcript (as a "--- CHAT: title ---" block) plus the project header.
// includeStory is on if ANY selected chat has it; selected chats' lorebook links are unioned.
async function buildWizardMultiContext(chatIds: string[], cfg: GlobalConfig): Promise<string> {
    let selIds = (chatIds || []).filter(Boolean);
    let allMultiChats = await loadWizardChats();
    let anyMultiStory = false;
    let unionLore: string[] = [];
    for (let sid of selIds) {
        let sc = allMultiChats.find(function(c) { return c.id === sid; });
        if (!sc) continue;
        if (sc.includeStory) anyMultiStory = true;
        for (let lid of (sc.lorebookEntryIds || [])) { if (unionLore.indexOf(lid) < 0) unionLore.push(lid); }
    }
    let synthChat: WizardChat = { id: 'transient', topicId: '', title: '', messages: [], contextChatIds: selIds, includeStory: anyMultiStory, lorebookEntryIds: unionLore, createdAt: 0, updatedAt: 0 };
    return await buildWizardContext(synthChat, cfg);
}

// ── World-Build Wizard: species / faction batch generation (yoink) ───────────
// [vNEXT] Generate a batch of named items (species or factions), each with a short
// lore description, in one budget-free pass. Output is parsed from a simple
// NAME:/LORE: block format. Returns an array of {name, description} (may be < count
// if the model returns fewer). kind is 'species' or 'faction' for prompt phrasing.
async function generateEntityBatch(kind: string, count: number, sourceChatIds: string[]): Promise<{ name: string; description: string }[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let noun = (kind === 'faction') ? 'factions (organizations, powers, or groups)' : 'species (peoples or creature-types)';

    // [v0.9.80] Feed existing same-kind names in so the batch never recreates them.
    let batchExistingNames = ((kind === 'faction') ? (cfg.factions || []) : (cfg.species || []))
        .map(function(x: any) { return (x && x.name) ? String(x.name).trim() : ''; })
        .filter(Boolean);

    let batchSysLines: string[] = [
        'You are generating ' + noun + ' for a story world.',
        'Produce EXACTLY ' + count + ' distinct entries that fit the world and feel like they belong together without being repetitive.',
        'CRITICAL RULE: DO NOT use any markdown. DO NOT bold headers or names. Output plain text only.'
    ];
    if (batchExistingNames.length) {
        batchSysLines.push('These ' + (kind === 'faction' ? 'factions' : 'species') + ' ALREADY EXIST — do NOT recreate, rename, or duplicate any of them. Generate entirely new, distinct entries:\n' + batchExistingNames.map(function(bn) { return '- ' + bn; }).join('\n'));
    }
    batchSysLines.push('FORMAT: For each entry output exactly:\nNAME: <short proper name>\nLORE: <a full, substantial description (roughly 5-8 sentences, one or two solid paragraphs) covering what it is, what matters about it, and the specific details that distinguish it>\nSeparate entries with a line containing only ---');
    batchSysLines.push('Draw on the specific names, ideas, and details raised in the brainstorming chat below — do not stay generic.');
    batchSysLines.push('Output ONLY the entries in that format. No preamble, no numbering, no extra commentary.');
    let sys = batchSysLines.join('\n\n');

    let usrParts: string[] = [];
    if (ctx.trim()) usrParts.push(ctx);
    usrParts.push('Generate ' + count + ' ' + (kind === 'faction' ? 'factions' : 'species') + ' now.');

    let raw = '';
    try {
        raw = await executeYoinkGeneration([{ role: 'system', content: sys }, { role: 'user', content: usrParts.join('\n\n') }]);
    } catch (e) {
        api.v1.error('[AE:wizard] batch generation failed (' + kind + '):', e);
        return [];
    }

    // Parse NAME:/LORE: blocks split on --- lines.
    let out: { name: string; description: string }[] = [];
    let chunks = (raw || '').split(/\n-{3,}\n/);
    for (let ch of chunks) {
        let nameMatch = ch.match(/NAME:\s*(.+)/i);
        let loreMatch = ch.match(/LORE:\s*([\s\S]+)/i);
        if (!nameMatch) continue;
        let nm = nameMatch[1].trim();
        let lore = loreMatch ? loreMatch[1].trim() : '';
        // Trim a trailing stray --- or NAME: bleed if the split missed.
        lore = lore.replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        if (nm) out.push({ name: nm, description: lore });
    }
    return out;
}

// [vNEXT] Generate (or regenerate) the lore description for ONE named species/faction,
// scoped to that single item, with optional hint. Returns description text or null.
async function generateEntityLore(kind: string, name: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let kindNoun = (kind === 'faction') ? 'faction' : 'species';
    let sys = [
        'You are writing the lore description for a single ' + kindNoun + ' named "' + name + '" in a story world.',
        'Write a full, substantial description (roughly 5-8 sentences, one or two solid paragraphs) covering what it is, what matters about it, and the specific details that distinguish it. Stay focused on THIS ' + kindNoun + ' only, and draw on the specific ideas and details in the reference context rather than staying generic.',
        'Output ONLY the description prose. Do not begin with the name or a label.'
    ].join('\n\n');
    let usrParts: string[] = [];
    if (ctx.trim()) usrParts.push(ctx);
    if (hint && hint.trim()) usrParts.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    usrParts.push('Write the description for "' + name + '" now.');
    let result = '';
    try {
        result = await executeYoinkGeneration([{ role: 'system', content: sys }, { role: 'user', content: usrParts.join('\n\n') }]);
    } catch (e) {
        api.v1.error('[AE:wizard] entity lore generation failed (' + name + '):', e);
        return null;
    }
    return (result || '').trim() || null;
}

// [vNEXT] Batch-create species records from a chat: generate, push records, and
// create+link a lorebook entry (with tags = name) for each. Returns count created.
async function runWizardSpeciesBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let items = await generateEntityBatch('species', count, sourceChatIds);
    let created = 0;
    for (let it of items) {
        let newId = 'sp_' + generateId();
        await mutConfig(function(c) {
            if (!c.species) c.species = [];
            c.species.push({ id: newId, name: it.name, description: it.description, lorebookTags: [] });
        });
        await createLinkedSpeciesLorebookEntry(newId).catch(function() {});
        created++;
    }
    return created;
}

// [vNEXT] Batch-create faction records from a chat. Factions also get the default
// standing track (relationshipStates) so the existing index-based standing works.
async function runWizardFactionsBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let items = await generateEntityBatch('faction', count, sourceChatIds);
    let created = 0;
    for (let it of items) {
        let newId = 'fac_' + generateId();
        await mutConfig(function(c) {
            if (!c.factions) c.factions = [];
            c.factions.push({ id: newId, name: it.name, description: it.description, relationshipStates: ['Hostile', 'Wary', 'Neutral', 'Friendly', 'Allied'], lorebookTags: [] });
        });
        await createLinkedFactionLorebookEntry(newId).catch(function() {});
        created++;
    }
    return created;
}

// [vNEXT] Batch-create minor-NPC archetypes from a wizard chat: generate NAME +
// one-line BRIEF pairs and push NpcArchetypeDef records to cfg.npcArchetypes.
// Resources/tags start empty (edit in the Bestiary: "+ Default Resources", tags);
// no lorebook entry — archetypes are spawn templates, not world lore. Returns count.
async function runWizardArchetypesBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);

    let existing = (((cfg as any).npcArchetypes || []) as any[])
        .map(function(a: any) { return (a && a.name) ? String(a.name).trim() : ''; })
        .filter(Boolean);

    let sysLines: string[] = [
        'You are generating minor-NPC archetypes for a story world: lightweight, drop-in figures a player briefly encounters and deals with \u2014 creatures to fight, folk to bargain with or seduce, ambient background people. They are NOT deep, named main characters.',
        'Produce EXACTLY ' + count + ' distinct archetypes that fit the world and feel like they belong together without being repetitive.',
        'CRITICAL RULE: DO NOT use any markdown. DO NOT bold headers or names. Output plain text only.'
    ];
    if (existing.length) {
        sysLines.push('These archetypes ALREADY EXIST \u2014 do NOT recreate, rename, or duplicate any of them. Generate entirely new, distinct ones:\n' + existing.map(function(e) { return '- ' + e; }).join('\n'));
    }
    sysLines.push('FORMAT: For each archetype output exactly:\nNAME: <a short label, e.g. Rattling Skeleton, Gate Guard, Fruit Vendor; you may use {a|b|c} alternation for spawn-time variety, e.g. {Brittle|Ancient} Skeleton>\nBRIEF: <ONE present-tense sentence describing what they are doing here and why they are in the scene>\nSeparate entries with a line containing only ---');
    sysLines.push('Keep them shallow by design: no backstory, no arc, no inner life. Draw on the specific names, ideas, and details raised in the brainstorming chat below \u2014 do not stay generic.');
    sysLines.push('Output ONLY the entries in that format. No preamble, no numbering, no extra commentary.');
    let sys = sysLines.join('\n\n');

    let usrParts: string[] = [];
    if (ctx.trim()) usrParts.push(ctx);
    usrParts.push('Generate ' + count + ' minor-NPC archetypes now.');

    let raw = '';
    try {
        raw = await executeYoinkGeneration([{ role: 'system', content: sys }, { role: 'user', content: usrParts.join('\n\n') }]);
    } catch (e) {
        api.v1.error('[AE:wizard] archetype batch generation failed:', e);
        return 0;
    }

    let created = 0;
    let chunks = (raw || '').split(/\n-{3,}\n/);
    for (let ch of chunks) {
        let nameMatch = ch.match(/NAME:\s*(.+)/i);
        let briefMatch = ch.match(/BRIEF:\s*([\s\S]+)/i);
        if (!nameMatch) continue;
        let nm = nameMatch[1].trim();
        let brief = briefMatch ? briefMatch[1].trim() : '';
        brief = brief.replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        if (!nm) continue;
        let newId = 'arch_' + generateId();
        await mutConfig(function(c) {
            if (!(c as any).npcArchetypes) (c as any).npcArchetypes = [];
            (c as any).npcArchetypes.push({ id: newId, name: nm, briefTemplate: brief, charResourceDefs: [], actionInstances: [], tagSubscriptions: [] });
        });
        created++;
    }
    return created;
}

// [v0.9.80] Manually add a single blank species/faction record (default name, empty
// lore) and link a lorebook entry, so the user can rename it and then ⚡ Regen its
// fields — the regen path re-syncs the existing entry. Returns the new record id.
async function addBlankWizardEntity(kind: string): Promise<string> {
    let blankId = ((kind === 'faction') ? 'fac_' : 'sp_') + generateId();
    let blankName = (kind === 'faction') ? 'New Faction' : 'New Species';
    await mutConfig(function(c) {
        if (kind === 'faction') {
            if (!c.factions) c.factions = [];
            c.factions.push({ id: blankId, name: blankName, description: '', relationshipStates: ['Hostile', 'Wary', 'Neutral', 'Friendly', 'Allied'], lorebookTags: [] });
        } else {
            if (!c.species) c.species = [];
            c.species.push({ id: blankId, name: blankName, description: '', lorebookTags: [] });
        }
    });
    if (kind === 'faction') await createLinkedFactionLorebookEntry(blankId).catch(function() {});
    else await createLinkedSpeciesLorebookEntry(blankId).catch(function() {});
    return blankId;
}

// [vNEXT] Regenerate one species/faction's description in place and re-sync its
// lorebook entry. kind is 'species' or 'faction'. Returns the new text or null.
async function regenerateWizardEntity(kind: string, itemId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let list: any[] = (kind === 'faction') ? (cfg.factions || []) : (cfg.species || []);
    let item = list.find(function(x) { return x.id === itemId; });
    if (!item) return null;
    let gen = await generateEntityLore(kind, item.name, sourceChatIds, hint);
    if (!gen) return null;
    await mutConfig(function(c) {
        let arr: any[] = (kind === 'faction') ? (c.factions || []) : (c.species || []);
        let t = arr.find(function(x) { return x.id === itemId; });
        if (t) t.description = gen;
    });
    if (kind === 'faction') await syncFactionLorebookEntry(itemId).catch(function() {});
    else await syncSpeciesLorebookEntry(itemId).catch(function() {});
    return gen;
}

// ── World-Build Wizard: Locations (tier model + generators) ───────────
// [v0.9.82] Depth of an entity from the world root (top-level/parentId-null = 0).
async function computeEntityTier(entityId: string): Promise<number> {
    let tierIdx = await loadEntityIndex();
    let depth = 0; let cur: string | null = entityId; let guard = 0;
    while (cur && guard < 64) {
        let tm = tierIdx.find(function(m) { return m.id === cur; });
        if (!tm || !tm.parentId) break;
        depth++; cur = tm.parentId; guard++;
    }
    return depth;
}

// [v0.9.82] Band index for a depth: 0 = top-level, 1 = sub-location, 2 = deeper/default.
function tierBandIndexForDepth(depth: number): number {
    return depth <= 0 ? 0 : (depth === 1 ? 1 : 2);
}

// [v0.9.82] The entryActionId a new location at this depth should carry (its tier template).
function entryActionIdForDepth(depth: number, cfg: GlobalConfig): string {
    let bands = cfg.tierTravelDefaults || DEFAULT_TIER_TRAVEL;
    let band = bands[tierBandIndexForDepth(depth)];
    return band ? band.templateId : 'sys_default_travel';
}

// [v0.9.82] Write a tier band's cost (modify_resource subtract, marker id '_tier_cost') and
// silent flag into its travel template. Mutates the passed config; callers wrap in mutConfig.
function syncTierTemplate(c: GlobalConfig, bandIndex: number): void {
    let bands = c.tierTravelDefaults || [];
    let band = bands[bandIndex];
    if (!band) return;
    let tmpl = (c.actionTemplates || []).find(function(t: any) { return t.id === band.templateId; });
    if (!tmpl) return;
    tmpl.successEffects = (tmpl.successEffects || []).filter(function(e: any) { return e.id !== '_tier_cost' && e.id !== '_tier_time'; });
    if (band.costTag && band.costAmount > 0) {
        tmpl.successEffects.unshift({ id: '_tier_cost', type: 'modify_resource', args: { tag: band.costTag, op: 'subtract', amount: band.costAmount } } as any);
    }
    if (band.timeCostHours && band.timeCostHours > 0) {
        tmpl.successEffects.unshift({ id: '_tier_time', type: 'advance_time', args: { hours: Math.floor(band.timeCostHours) } } as any);
    }
    (tmpl as any).silent = !band.narrated;
}

// [v0.9.82] Yoink-generate a batch of locations as {name, description}. parentId null =
// top-level. Existing sibling names are fed in to avoid duplicates; the parent's own
// description anchors children. Multi-chat context via buildWizardMultiContext.
async function generateLocationBatch(count: number, parentId: string | null, sourceChatIds: string[]): Promise<{ name: string; description: string; lore: string }[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let parentEnt = parentId ? await loadEntity(parentId) : null;
    let locIdx = await loadEntityIndex();
    let existingLoc = locIdx.filter(function(m) { return m.type === 'location' && m.parentId === (parentId || null); }).map(function(m) { return m.name; }).filter(Boolean);
    let scopeNoun = parentEnt ? ('sub-locations inside "' + parentEnt.name + '"') : 'top-level locations (regions / major places) of the world';

    let locSysLines: string[] = [
        'You are generating ' + scopeNoun + ' for a story world.',
        'Produce EXACTLY ' + count + ' distinct locations that fit the world and belong together without being repetitive.',
        'CRITICAL RULE: DO NOT use any markdown. DO NOT bold headers or names. Output plain text only.'
    ];
    if (parentEnt && (parentEnt.description || '').trim()) {
        locSysLines.push('They are all inside this parent location:\n' + parentEnt.name + ': ' + parentEnt.description.trim());
    }
    if (existingLoc.length) {
        locSysLines.push('These locations ALREADY EXIST here — do NOT recreate or duplicate them. Generate entirely new, distinct ones:\n' + existingLoc.map(function(ln) { return '- ' + ln; }).join('\n'));
    }
    locSysLines.push('FORMAT: For each location output exactly:\nNAME: <short place name>\nDESC: <1-2 sentences capturing ONLY what a camera physically senses on arrival (light, texture, scale). No history.>\nLORE: <a full, comprehensive entry (roughly 5-8 sentences) covering history, significance, culture, and tensions>\nSeparate entries with a line containing only ---');
    locSysLines.push('Extract concepts strictly from the brainstorming chat. Output ONLY the entries in the exact format requested. No preamble, no numbering, no commentary.');
    let locSys = locSysLines.join('\n\n');

    let locUsr: string[] = [];
    if (ctx.trim()) locUsr.push(ctx);
    locUsr.push('Generate ' + count + ' locations now.');

    let locRaw = '';
    try {
        locRaw = await executeYoinkGeneration([{ role: 'system', content: locSys }, { role: 'user', content: locUsr.join('\n\n') }]);
    } catch (eLocGen) {
        api.v1.error('[AE:wizard] location batch generation failed:', eLocGen);
        return [];
    }

    let locOut: { name: string; description: string; lore: string }[] = [];
    let locChunks = (locRaw || '').split(/\n-{3,}\n/);
    for (let lch of locChunks) {
        let lnm = lch.match(/NAME:\s*(.+)/i);
        let lde = lch.match(/DESC:\s*([\s\S]+?)(?:\nLORE:|$)/i);
        let llo = lch.match(/LORE:\s*([\s\S]+)/i);
        if (!lnm) continue;
        let lName = lnm[1].trim();
        let lDesc = lde ? lde[1].trim() : '';
        lDesc = lDesc.replace(/\nLORE:[\s\S]*$/i, '').replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        let lLore = llo ? llo[1].trim() : '';
        lLore = lLore.replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        if (lName) locOut.push({ name: lName, description: lDesc, lore: lLore });
    }
    return locOut;
}

// [v0.9.82] Batch-create location entities under parentId, stamping each with the tier
// template for its depth. Returns the count created.
async function runWizardLocationsBatch(count: number, parentId: string | null, sourceChatIds: string[]): Promise<number> {
    let cfg = await loadConfig();
    let childDepth = parentId ? (await computeEntityTier(parentId)) + 1 : 0;
    let entryAid = entryActionIdForDepth(childDepth, cfg);
    let items = await generateLocationBatch(count, parentId, sourceChatIds);
    let made = 0;
    for (let it of items) {
        let le = makeDefaultEntity(it.name);
        le.type = 'location';
        le.parentId = parentId || null;
        le.description = it.description || '';
        (le as any).lorebookText = it.lore || '';
        (le as any).entryActionId = entryAid;
        await saveEntity(le);
        if ((it.lore || '').trim()) { await createLinkedEntityLorebookEntry(le.id).catch(function() {}); }
        made++;
    }
    return made;
}

// [v0.9.82] Create one blank location under parentId (tier template stamped). Returns id.
async function addBlankWizardLocation(parentId: string | null): Promise<string> {
    let cfg = await loadConfig();
    let childDepth = parentId ? (await computeEntityTier(parentId)) + 1 : 0;
    let entryAid = entryActionIdForDepth(childDepth, cfg);
    let le = makeDefaultEntity('New Location');
    le.type = 'location';
    le.parentId = parentId || null;
    (le as any).entryActionId = entryAid;
    await saveEntity(le);
    return le.id;
}

// [v0.9.83] Regenerate one location's short description AND comprehensive lorebook in a
// single pass; updates both fields and re-syncs (or creates) its lorebook entry.
async function regenerateWizardLocation(locId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let ent = await loadEntity(locId);
    if (!ent) return null;
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let parentEnt = ent.parentId ? await loadEntity(ent.parentId) : null;
    let locSys = [
        'You are writing the entry for a single location named "' + ent.name + '"' + (parentEnt ? (' inside "' + parentEnt.name + '"') : '') + ' in a story world.',
        'Output exactly two labelled blocks and nothing else:\nDESC: <1-2 sentences of scene-present description — what a person directly sees, hears, and senses on arrival. Keep it short.>\nLORE: <a full, comprehensive entry (roughly 5-8 sentences) covering history, significance, who or what is here, how it connects to the wider world, and any secrets or tensions>',
        'Stay focused on THIS location, drawing on the specific ideas in the reference context. Do not add any other labels, preamble, or commentary.'
    ].join('\n\n');
    let locUsr: string[] = [];
    if (ctx.trim()) locUsr.push(ctx);
    if (hint && hint.trim()) locUsr.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    locUsr.push('Write the DESC and LORE for "' + ent.name + '" now.');
    let locRes = '';
    try {
        locRes = await executeYoinkGeneration([{ role: 'system', content: locSys }, { role: 'user', content: locUsr.join('\n\n') }]);
    } catch (eLocReg) {
        api.v1.error('[AE:wizard] location regen failed:', eLocReg);
        return null;
    }
    let locOutRaw = (locRes || '').trim();
    if (!locOutRaw) return null;
    let rde = locOutRaw.match(/DESC:\s*([\s\S]+?)(?:\nLORE:|$)/i);
    let rlo = locOutRaw.match(/LORE:\s*([\s\S]+)/i);
    let newDesc = rde ? rde[1].trim() : '';
    newDesc = newDesc.replace(/\nLORE:[\s\S]*$/i, '').trim();
    let newLore = rlo ? rlo[1].trim() : '';
    if (!newDesc && !newLore) { newLore = locOutRaw; }
    let freshEnt = await loadEntity(locId);
    if (!freshEnt) return null;
    if (newDesc) freshEnt.description = newDesc;
    if (newLore) (freshEnt as any).lorebookText = newLore;
    await saveEntity(freshEnt);
    if (newLore) {
        if ((freshEnt as any).lorebookEntryId) await syncEntityLorebookEntry(locId, true).catch(function() {});
        else await createLinkedEntityLorebookEntry(locId).catch(function() {});
    }
    return newLore || newDesc;
}

// ── World-Build Wizard: Characters (seed-and-go via comprehensive concept dump) ──
// [v0.9.84] Flow: generate names from chat (dedup) -> per character, generate a
// comprehensive concept dump from chat -> derive all dramatis-personae + static fields
// from THAT dump (not chat) -> create the character (entity body + record + lorebook).
// The dump is the persistent source; later per-field regens in the editor read it.

interface WizardCharFields {
    species: string; age: string; gender: string; occupationRole: string; briefDescription: string;
    physicalDescription: string; personalityCore: string; voiceAndMannerisms: string; background: string;
    coreValues: string[];
}

async function generateCharacterNames(count: number, sourceChatIds: string[]): Promise<string[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let charIdx = await loadIndex();
    let existingNames = charIdx.map(function(m) { return m.name; }).filter(Boolean);
    let nameSys: string[] = [
        'You are identifying distinct CHARACTERS (individual people) for a story world.',
        'Produce EXACTLY ' + count + ' character names that the brainstorming context establishes or clearly implies. Real individuals, not groups, roles, or species.'
    ];
    if (existingNames.length) nameSys.push('These characters ALREADY EXIST \u2014 do NOT repeat them:\n' + existingNames.map(function(n) { return '- ' + n; }).join('\n'));
    nameSys.push('FORMAT: one name per line, each prefixed with "NAME: ". Nothing else \u2014 no descriptions, numbering, or commentary.');
    let nameUsr: string[] = [];
    if (ctx.trim()) nameUsr.push(ctx);
    nameUsr.push('List ' + count + ' character names now.');
    let nameRaw = '';
    try { nameRaw = await executeYoinkGeneration([{ role: 'system', content: nameSys.join('\n\n') }, { role: 'user', content: nameUsr.join('\n\n') }]); }
    catch (eCharNames) { api.v1.error('[AE:wizard] character names failed:', eCharNames); return []; }
    let names: string[] = [];
    let nameLines = (nameRaw || '').split('\n');
    for (let nl of nameLines) {
        let mm = nl.match(/NAME:\s*(.+)/i);
        if (!mm) continue;
        let nm = mm[1].trim().replace(/^[-*0-9.\s]+/, '').trim();
        if (nm && names.indexOf(nm) < 0) names.push(nm);
    }
    return names.slice(0, count);
}

async function generateCharacterDump(name: string, sourceChatIds: string[]): Promise<string> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let dumpSys = [
        'You are assembling a COMPREHENSIVE concept profile (a "concept dump") for a single character named "' + name + '" based entirely on the brainstorming context.',
        'Organize EVERYTHING the context establishes or implies about ' + name + ' into one thorough, well-structured profile: who they are, anatomical appearance, psychological contradictions, vocal timbre, formative history, relationships, and goals.',
        'CRITICAL RULE: Write entirely in plain prose. DO NOT use markdown, bolding, italics, or bullet points. DO NOT invent tragic backstories or cliché tropes unless explicitly stated in the context.',
        'Output ONLY the plain prose profile for ' + name + '. No preamble, no headers, no commentary.'
    ].join('\n\n');
    let dumpUsr: string[] = [];
    if (ctx.trim()) dumpUsr.push(ctx);
    dumpUsr.push('Write the comprehensive concept profile for "' + name + '" now.');
    let dumpRaw = '';
    try { dumpRaw = await executeYoinkGeneration([{ role: 'system', content: dumpSys }, { role: 'user', content: dumpUsr.join('\n\n') }]); }
    catch (eCharDump) { api.v1.error('[AE:wizard] character dump failed:', eCharDump); return ''; }
    return (dumpRaw || '').trim();
}

async function generateCharacterFields(name: string, dump: string): Promise<WizardCharFields | null> {
    if (!(dump || '').trim()) return null;
    let fieldSys = [
        'You are filling structured fields for the character "' + name + '", extracting data ONLY from the concept profile provided. Do not contradict it; where the profile is silent, infer the most fitting objective value.',
        'CRITICAL RULE: DO NOT use any markdown, bolding, or italics. Output EXACTLY these labelled lines, in this exact order, and nothing else:\n' +
        'SPECIES: <one or two words>\n' +
        'AGE: <a number or short phrase>\n' +
        'GENDER: <short>\n' +
        'ROLE: <occupation or role, a few words>\n' +
        'BRIEF: <one tight sentence identifying who they are at a glance>\n' +
        'PHYSICAL: <Camera-view physical anatomy, skin, hair, eyes, and build. Sensual or striking details if applicable. No clothing. No mannerisms.>\n' +
        'PERSONALITY: <Psychological baseline and a core contradiction/hidden facet. No tragic tropes. Declarative.>\n' +
        'VOICE: <Vocal timbre, speech rhythm, and one signature physical mannerism.>\n' +
        'BACKGROUND: <One or two formative past events that shaped their current worldview. Past tense.>\n' +
        'VALUES: <3-5 deeply held values, semicolon-separated>'
    ].join('\n\n');
    let fieldUsr = '--- CONCEPT PROFILE ---\n' + dump.trim() + '\n\nFill the fields for "' + name + '" now.';
    let fieldRaw = '';
    try { fieldRaw = await executeYoinkGeneration([{ role: 'system', content: fieldSys }, { role: 'user', content: fieldUsr }]); }
    catch (eCharFields) { api.v1.error('[AE:wizard] character fields failed:', eCharFields); return null; }

    function parseCharFields(txt: string): Record<string, string> {
        let labels = ['SPECIES', 'AGE', 'GENDER', 'ROLE', 'BRIEF', 'PHYSICAL', 'PERSONALITY', 'VOICE', 'BACKGROUND', 'VALUES'];
        let result: Record<string, string> = {};
        let fLines = (txt || '').split('\n');
        let cur = '';
        for (let fl of fLines) {
            let trimmed = fl.trim();
            let up = trimmed.toUpperCase();
            let hit = '';
            for (let lb of labels) { if (up.indexOf(lb + ':') === 0) { hit = lb; break; } }
            if (hit) { result[hit] = trimmed.slice(hit.length + 1).trim(); cur = hit; }
            else if (cur && trimmed) { result[cur] = (result[cur] ? result[cur] + ' ' : '') + trimmed; }
        }
        return result;
    }

    let parsed = parseCharFields(fieldRaw);
    let valuesRaw = parsed['VALUES'] || '';
    return {
        species: parsed['SPECIES'] || '', age: parsed['AGE'] || '', gender: parsed['GENDER'] || '',
        occupationRole: parsed['ROLE'] || '', briefDescription: parsed['BRIEF'] || '',
        physicalDescription: parsed['PHYSICAL'] || '', personalityCore: parsed['PERSONALITY'] || '',
        voiceAndMannerisms: parsed['VOICE'] || '', background: parsed['BACKGROUND'] || '',
        coreValues: valuesRaw.split(';').map(function(s) { return s.trim(); }).filter(Boolean)
    };
}

async function createWizardCharacter(name: string, dump: string, fields: WizardCharFields | null): Promise<string> {
    let cfg = await loadConfig();
    let body = makeDefaultEntity(name);
    body.type = 'character';
    body.parentId = null;
    await saveEntity(body);
    let ch = makeDefaultCharacter(name, cfg);
    ch.entityId = body.id;
    ch.conceptDump = dump || '';
    if (fields) {
        ch.species = fields.species || '';
        ch.age = fields.age || '';
        ch.gender = fields.gender || '';
        ch.occupationRole = fields.occupationRole || '';
        ch.briefDescription = fields.briefDescription || '';
        ch.physicalDescription = fields.physicalDescription || '';
        ch.personalityCore = fields.personalityCore || '';
        ch.voiceAndMannerisms = fields.voiceAndMannerisms || '';
        ch.background = fields.background || '';
        ch.coreValues = fields.coreValues || [];
    }
    await saveCharacter(ch);
    try { await createLinkedLorebookEntry(ch.id); } catch (eCharLb) { /* non-fatal */ }
    return ch.id;
}

// [v0.9.84] Generate ONE character end-to-end (dump from chat -> fields from dump -> create).
async function runWizardCharacterSingle(name: string, sourceChatIds: string[]): Promise<boolean> {
    let nm = (name || '').trim();
    if (!nm) return false;
    let dump = await generateCharacterDump(nm, sourceChatIds);
    let fields = await generateCharacterFields(nm, dump);
    await createWizardCharacter(nm, dump, fields);
    return true;
}

// [v0.9.84] Batch: names from chat (dedup) -> each character end-to-end. Returns count created.
async function runWizardCharactersBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let names = await generateCharacterNames(count, sourceChatIds);
    let made = 0;
    for (let nm of names) {
        let ok = await runWizardCharacterSingle(nm, sourceChatIds);
        if (ok) made++;
    }
    return made;
}

// ── World-Build Wizard: Intro / Opening scene ────────────────────────────────
// [v0.9.85] Pick where the story opens and who is present; generate the opening
// prose (yoink, budget-free), place the player + cast there, and insert into the editor.

async function generateIntroProse(locationId: string, charIds: string[], sourceChatIds: string[]): Promise<string> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let loc = locationId ? await loadEntity(locationId) : null;
    let allChars = await loadAllCharacters();
    let protag = allChars.find(function(c) { return c.isProtagonist; });
    let castLines: string[] = [];
    for (let cid of (charIds || [])) {
        let ch = allChars.find(function(c) { return c.id === cid; });
        if (!ch) continue;
        castLines.push('- ' + ch.name + (ch.briefDescription ? (': ' + ch.briefDescription) : ''));
    }
    let introSys: string[] = [
        'You are writing the OPENING of an interactive story \u2014 the very first scene, in immersive second-person present tense ("You ...") from the protagonist\'s point of view.',
        'Establish the setting, mood, and immediate situation, and bring any present characters to life through concrete action and detail. Start *in media res* (already in the location, mid-action). End on a beat that invites the player to act; do not resolve the situation.',
        'CRITICAL RULE: Avoid all backstory, lore-dumping, and exposition. DO NOT use any markdown, bolding, italics, or headings.'
    ];
    if (loc) {
        let locLore = ((loc as any).lorebookText || '').trim();
        introSys.push('SETTING (where the scene opens):\n' + loc.name + ((loc.description || '').trim() ? (' \u2014 ' + loc.description.trim()) : '') + (locLore ? ('\nBackground: ' + locLore) : ''));
    }
    if (protag) {
        introSys.push('THE PROTAGONIST ("you"):\n' + protag.name + ((protag.briefDescription || '').trim() ? (': ' + protag.briefDescription.trim()) : ''));
    }
    if (castLines.length) introSys.push('PRESENT IN THE SCENE:\n' + castLines.join('\n'));
    introSys.push('Write 2-4 vivid paragraphs. Output ONLY the opening prose \u2014 no title, headings, labels, or commentary.');
    let introUsr: string[] = [];
    if (ctx.trim()) introUsr.push(ctx);
    introUsr.push('Write the opening scene now.');
    let introRaw = '';
    try { introRaw = await executeYoinkGeneration([{ role: 'system', content: introSys.join('\n\n') }, { role: 'user', content: introUsr.join('\n\n') }]); }
    catch (eIntroGen) { api.v1.error('[AE:wizard] intro generation failed:', eIntroGen); return ''; }
    return (introRaw || '').trim();
}

async function placeIntroCast(locationId: string, charIds: string[]): Promise<void> {
    // Move each chosen character's body into the location and make them active/present.
    for (let cid of (charIds || [])) {
        let ch = await loadCharacter(cid);
        if (!ch || !ch.entityId) continue;
        let body = await loadEntity(ch.entityId);
        if (body) { body.parentId = locationId; await saveEntity(body); }
        let fc = await loadCharacter(cid);
        if (fc) { fc.active = true; fc.scenePresent = true; await saveCharacter(fc); }
    }
    // Move the protagonist (silent); this also recalculates scene presence so the placed
    // cast registers as present in the new room.
    await commitTravel(locationId, true);
}

// [v0.9.85] Generate prose first (so a failure leaves world state untouched), then place
// the cast + player, then insert the prose into the story editor as paragraphs.
// [v1.6.3 INTRO-STAGE] The intro generator now stages its output like the other wizard
// tabs: generate -> review/edit/regenerate -> commit. generateIntroDraft yoinks the opening
// prose and stores it as an editable draft WITHOUT touching the story; commitIntroDraft
// travels the player in and writes the (possibly edited) draft, then clears it.
async function generateIntroDraft(locationId: string, sourceChatIds: string[]): Promise<boolean> {
    if (!locationId) { api.v1.ui.toast('Pick an intro location first.', { type: 'error', autoClose: 2500 }); return false; }
    let loc = await loadEntity(locationId);
    if (!loc) { api.v1.ui.toast('That location no longer exists.', { type: 'error', autoClose: 2500 }); return false; }
    // [v0.9.86] Cast placement removed — characters get intro locations set in their character cards.
    let prose = await generateIntroProse(locationId, [], sourceChatIds);
    if (!(prose || '').trim()) return false;
    await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_DRAFT, { locationId: locationId, prose: prose.trim() }).catch(function() {});
    return true;
}

async function commitIntroDraft(): Promise<boolean> {
    let draft = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_DRAFT, null) as any;
    if (!draft || !draft.locationId || !((draft.prose || '') as string).trim()) { api.v1.ui.toast('No intro draft to commit.', { type: 'error', autoClose: 2500 }); return false; }
    let loc = await loadEntity(draft.locationId);
    if (!loc) { api.v1.ui.toast('That location no longer exists.', { type: 'error', autoClose: 2500 }); return false; }
    await commitTravel(draft.locationId, true);
    let introParas = String(draft.prose).split(/\n\n+/);
    for (let para of introParas) {
        if (para.trim()) { await api.v1.document.appendParagraph({ text: para.trim() }).catch(function() {}); }
    }
    await api.v1.tempStorage.remove(STORAGE_WIZ_INTRO_DRAFT).catch(function() {});
    return true;
}

// [legacy] one-shot generate+insert, retained for any direct/scripted callers. The wizard
// UI now uses the staged path (generateIntroDraft then commitIntroDraft) instead.
async function runWizardIntro(locationId: string, sourceChatIds: string[]): Promise<boolean> {
    let okGen = await generateIntroDraft(locationId, sourceChatIds);
    if (!okGen) return false;
    return await commitIntroDraft();
}

// ── World-Build Wizard: Drama (hooks, NPC web, narrative threads) ─────────────
// [vNEXT] The Drama wizard seeds the three primitives the live Drama tab and the
// dynamic engine maintain: per-character UnresolvedHooks, bilateral WebLinks, and
// narrative-thread entities. Hooks and web links are CHARACTER-AWARE — the generators
// are fed the established roster and must resolve to real records; nothing is written
// against a person who does not exist. Seeded hooks deliberately mirror the dynamic
// engine's spawn shape (pressure 20-50, one concrete directed sentence) so they read
// identically to tension the engine raises later during play.

// Compact cast roster for drama generators: protagonist marked, each active character
// on one identifying line. Shared context so generated tensions reference real people.
function buildWizardCastContext(allChars: CharacterRecord[]): string {
    let castLines: string[] = [];
    let castProtag = allChars.find(function(c) { return c.isProtagonist; });
    if (castProtag) {
        let pBrief = (castProtag.briefDescription || '').trim();
        castLines.push('PROTAGONIST (the player, "you"): ' + castProtag.name + (pBrief ? (' — ' + pBrief) : ''));
    }
    for (let cc of allChars) {
        if (cc.isProtagonist) continue;
        if (!cc.active) continue;
        let ccBrief = (cc.briefDescription || '').trim();
        let ccRole = (cc.occupationRole || '').trim();
        let ccTail = ccBrief ? (' — ' + ccBrief) : (ccRole ? (' — ' + ccRole) : '');
        castLines.push('- ' + cc.name + ccTail);
    }
    if (castLines.length === 0) return '';
    return '--- CAST ---\n' + castLines.join('\n');
}

// Resolve a generated target name to the canonical hook target: the protagonist maps
// to the '__player__' token (the Drama tab and injection logic expect it); an exact
// cast name/nickname maps to that name; anything else is kept verbatim (the engine
// tolerates free-text targets so a near-miss is still editable rather than dropped).
function resolveHookTarget(raw: string, allChars: CharacterRecord[]): string {
    let rt = (raw || '').trim();
    if (!rt) return '';
    let rtLow = rt.toLowerCase();
    if (rtLow === 'none' || rtLow === 'n/a') return '';
    let rtProtag = allChars.find(function(c) { return c.isProtagonist; });
    if (rtProtag && (rtLow === rtProtag.name.toLowerCase() || rtLow === 'the protagonist' || rtLow === 'protagonist' || rtLow === 'you' || rtLow === 'the player' || rtLow === 'player')) return '__player__';
    for (let rc of allChars) {
        if (rc.isProtagonist) continue;
        if (rc.name.toLowerCase() === rtLow) return rc.name;
        if ((rc.nicknames || []).some(function(n) { return (n || '').toLowerCase() === rtLow; })) return rc.name;
    }
    return rt;
}

// Resolve a generated name to an existing character id (protagonist included), or ''.
function findWizardCharIdByName(allChars: CharacterRecord[], raw: string): string {
    let fn = (raw || '').trim().toLowerCase();
    if (!fn) return '';
    let fProtag = allChars.find(function(c) { return c.isProtagonist; });
    if (fProtag && (fn === 'the protagonist' || fn === 'protagonist' || fn === 'you' || fn === 'the player' || fn === 'player')) return fProtag.id;
    for (let fc of allChars) {
        if (fc.name.toLowerCase() === fn) return fc.id;
        if ((fc.nicknames || []).some(function(n) { return (n || '').toLowerCase() === fn; })) return fc.id;
    }
    return '';
}

// [vNEXT] Generate ONE starting hook for a character: a concrete unresolved tension
// directed at another existing cast member or the protagonist. Mirrors the dynamic
// engine's hook-spawn prompt for tonal parity. Returns {targetName, description,
// pressureLevel} (targetName already resolved) or null when no clean tension exists.
async function generateCharacterHook(char: CharacterRecord, sourceChatIds: string[], hint: string): Promise<{ targetName: string; description: string; pressureLevel: number } | null> {
    let cfg = await loadConfig();
    let allChars = await loadAllCharacters();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let cast = buildWizardCastContext(allChars);
    let dump = (char.conceptDump || '').trim();

    let hookSys = [
        'You are a dramaturg seeding the OPENING dramatic tension for the character "' + char.name + '" at the very start of a story.',
        'Identify ONE specific, unresolved tension this character carries toward another person: a conflict, a threat they pose or face, a debt, a secret they guard, a betrayal, or an urgent unfulfilled want. Passive moods and general feelings do NOT qualify. It must be directed at a named person and demand eventual action.',
        'The target MUST be one of the established cast, named EXACTLY as written, OR the protagonist. Do not invent a new person.',
        'Write the hook as a single, punchy sentence naming the core tension in concrete terms: what happened, what is owed, what is at stake.',
        '  Wrong: "feels uneasy about her place in the household"',
        '  Right: "Owes the magister a debt she cannot pay, and the collector arrives within the week"',
        'Set the pressure between 20 and 50 — this is a fresh hook that has not yet escalated.',
        'If this character has no plausible directed tension, set the target to "None".',
        'CRITICAL RULE: DO NOT use any markdown, bolding, italics, or bullet points. Output EXACTLY these three labelled lines and nothing else:\nTARGET: <exact cast name, the protagonist, or None>\nPRESSURE: <a number from 20 to 50>\nHOOK: <one concrete sentence>'
    ].join('\n\n');

    let hookUsr: string[] = [];
    if (cast) hookUsr.push(cast);
    if (dump) hookUsr.push('--- ' + char.name.toUpperCase() + ' (concept profile) ---\n' + dump);
    if (ctx.trim()) hookUsr.push(ctx);
    if (hint && hint.trim()) hookUsr.push('--- EXTRA GUIDANCE FOR THIS REGENERATION ---\n' + hint.trim());
    hookUsr.push('Write the opening hook for "' + char.name + '" now.');

    let hookRaw = '';
    try { hookRaw = await executeYoinkGeneration([{ role: 'system', content: hookSys }, { role: 'user', content: hookUsr.join('\n\n') }]); }
    catch (eHookGen) { api.v1.error('[AE:wizard] hook generation failed (' + char.name + '):', eHookGen); return null; }

    function parseHookFields(txt: string): { target: string; pressure: number; hook: string } {
        let pTarget = ''; let pPressure = 30; let pHookLines: string[] = []; let pCur = '';
        let pLines = (txt || '').split('\n');
        for (let pl of pLines) {
            let pt = pl.trim();
            let pu = pt.toUpperCase();
            if (pu.indexOf('TARGET:') === 0) { pTarget = pt.slice(7).trim(); pCur = 'target'; }
            else if (pu.indexOf('PRESSURE:') === 0) { let pm = pt.slice(9).match(/-?\d+/); if (pm) pPressure = parseInt(pm[0], 10); pCur = 'pressure'; }
            else if (pu.indexOf('HOOK:') === 0) { let hb = pt.slice(5).trim(); if (hb) pHookLines.push(hb); pCur = 'hook'; }
            else if (pCur === 'hook' && pt) { pHookLines.push(pt); }
        }
        return { target: pTarget, pressure: pPressure, hook: pHookLines.join(' ').trim() };
    }

    let parsedHook = parseHookFields(hookRaw);
    let resolvedTarget = resolveHookTarget(parsedHook.target, allChars);
    if (!resolvedTarget || !parsedHook.hook) return null;
    let clampedPressure = Math.min(50, Math.max(20, parsedHook.pressure || 30));
    return { targetName: resolvedTarget, description: parsedHook.hook, pressureLevel: clampedPressure };
}

// [vNEXT] Seed (or reseed) the single starting hook on one character. Replaces hooks[0]
// — the model is one-active-hook-per-character. Stamps lastHookGen with the current
// story gen count so the dynamic engine's escalator picks it up on schedule.
async function runWizardHookSingle(charId: string, sourceChatIds: string[], hint: string): Promise<boolean> {
    let baseChar = await loadCharacter(charId);
    if (!baseChar) return false;
    let gen = await generateCharacterHook(baseChar, sourceChatIds, hint);
    if (!gen) return false;
    let freshHookChar = await loadCharacter(charId);
    if (!freshHookChar) return false;
    let gc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
    freshHookChar.hooks = [{
        id: api.v1.uuid(),
        targetName: gen.targetName,
        description: (gen.description || '').substring(0, 300),
        pressureLevel: Math.min(100, Math.max(0, gen.pressureLevel || 30)),
        developmentNotes: [],
        resolved: false
    }];
    freshHookChar.lastHookGen = Number(gc) || 0;
    await saveCharacter(freshHookChar);
    return true;
}

// [vNEXT] Seed one hook on each selected character. Returns the count successfully seeded.
async function runWizardHooksBatch(charIds: string[], sourceChatIds: string[]): Promise<number> {
    let hookMade = 0;
    for (let hcid of (charIds || [])) {
        let hookOk = await runWizardHookSingle(hcid, sourceChatIds, '');
        if (hookOk) hookMade++;
    }
    return hookMade;
}

// [vNEXT] Generate a batch of bilateral cast dynamics (NPC web). Each names two distinct
// existing people and one concrete charged sentence between them. Parsed from labelled
// A:/B:/DYNAMIC:/PRIORITY: blocks. Mapping to ids + dedup happens in runWizardWebBatch.
async function generateWebBatch(count: number, sourceChatIds: string[]): Promise<{ aName: string; bName: string; dynamic: string; priority: number }[]> {
    let cfg = await loadConfig();
    let allChars = await loadAllCharacters();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let cast = buildWizardCastContext(allChars);
    if (!cast) return [];

    let webSys: string[] = [
        'You are a dramaturg defining the web of bilateral dynamics between the established cast of a story.',
        'Produce EXACTLY ' + count + ' distinct PAIR dynamics. Each names two DIFFERENT people from the cast below (the protagonist may be one of them) and states the charged relationship between them in one concrete sentence.',
        'Focus on friction, history, and asymmetry: rivalries, old debts, unspoken attraction, divided loyalty, mutual dependence. Avoid bland "they are friends" pairings, and do not repeat the same pair twice.',
        'Assign each a priority from 0 to 100: how strongly this dynamic should colour scenes where both are present (default 30; use 70+ only for defining relationships).',
        'CRITICAL RULE: DO NOT use any markdown, bolding, or bullet points. Output plain text only.',
        'FORMAT: for each pair output exactly:\nA: <exact cast name>\nB: <exact cast name>\nDYNAMIC: <one concrete sentence>\nPRIORITY: <a number from 0 to 100>\nSeparate pairs with a line containing only ---',
        'Output ONLY the pairs in that format. No preamble, no numbering, no commentary.'
    ];

    let webUsr: string[] = [];
    if (ctx.trim()) webUsr.push(ctx);
    webUsr.push('Generate ' + count + ' bilateral dynamics now.');

    let webRaw = '';
    try { webRaw = await executeYoinkGeneration([{ role: 'system', content: webSys.join('\n\n') }, { role: 'user', content: webUsr.join('\n\n') }]); }
    catch (eWebGen) { api.v1.error('[AE:wizard] web batch generation failed:', eWebGen); return []; }

    let webOut: { aName: string; bName: string; dynamic: string; priority: number }[] = [];
    let webChunks = (webRaw || '').split(/\n-{3,}\n/);
    for (let wch of webChunks) {
        let aMatch = wch.match(/(?:^|\n)\s*A:\s*(.+)/i);
        let bMatch = wch.match(/(?:^|\n)\s*B:\s*(.+)/i);
        let dMatch = wch.match(/DYNAMIC:\s*([\s\S]+?)(?:\nPRIORITY:|$)/i);
        let pMatch = wch.match(/PRIORITY:\s*(-?\d+)/i);
        if (!aMatch || !bMatch) continue;
        let aNm = aMatch[1].trim();
        let bNm = bMatch[1].trim();
        let dyn = dMatch ? dMatch[1].trim().replace(/\n-{3,}[\s\S]*$/, '').trim() : '';
        let pri = pMatch ? parseInt(pMatch[1], 10) : 30;
        if (aNm && bNm) webOut.push({ aName: aNm, bName: bNm, dynamic: dyn, priority: pri });
    }
    return webOut;
}

// [vNEXT] Generate web dynamics, map names to existing character ids, drop self-pairs,
// unresolved names, and pairs already present (unordered). Returns the count added.
async function runWizardWebBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let allChars = await loadAllCharacters();
    let pairs = await generateWebBatch(count, sourceChatIds);
    if (pairs.length === 0) return 0;
    let web = await loadNpcWeb();
    let webMade = 0;
    for (let wp of pairs) {
        let aId = findWizardCharIdByName(allChars, wp.aName);
        let bId = findWizardCharIdByName(allChars, wp.bName);
        if (!aId || !bId || aId === bId) continue;
        let already = web.some(function(l) { return (l.charA_id === aId && l.charB_id === bId) || (l.charA_id === bId && l.charB_id === aId); });
        if (already) continue;
        web.push({ id: api.v1.uuid(), charA_id: aId, charB_id: bId, dynamic: (wp.dynamic || '').substring(0, 300), priority: Math.min(100, Math.max(0, wp.priority || 30)) });
        webMade++;
    }
    if (webMade > 0) await saveNpcWeb(web);
    return webMade;
}

// [vNEXT] Regenerate the dynamic sentence on ONE existing web link in place (no new link).
async function regenerateWebLink(linkId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let allChars = await loadAllCharacters();
    let web = await loadNpcWeb();
    let link = web.find(function(l) { return l.id === linkId; });
    if (!link) return null;
    let wa = allChars.find(function(c) { return c.id === link.charA_id; });
    let wb = allChars.find(function(c) { return c.id === link.charB_id; });
    if (!wa || !wb) return null;
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let regSys = [
        'You are writing the charged bilateral dynamic between "' + wa.name + '" and "' + wb.name + '" in a story.',
        'State their relationship in one concrete sentence — friction, history, or asymmetry. Avoid bland pairings.',
        'Output ONLY the single sentence. No names prefix, no label, no markdown.'
    ].join('\n\n');
    let regUsr: string[] = [];
    if (ctx.trim()) regUsr.push(ctx);
    if (hint && hint.trim()) regUsr.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    regUsr.push('Write the dynamic between "' + wa.name + '" and "' + wb.name + '" now.');
    let regRaw = '';
    try { regRaw = await executeYoinkGeneration([{ role: 'system', content: regSys }, { role: 'user', content: regUsr.join('\n\n') }]); }
    catch (eWebReg) { api.v1.error('[AE:wizard] web regen failed:', eWebReg); return null; }
    let regTxt = (regRaw || '').trim();
    if (!regTxt) return null;
    let web2 = await loadNpcWeb();
    let t2 = web2.find(function(l) { return l.id === linkId; });
    if (t2) { t2.dynamic = regTxt.substring(0, 300); await saveNpcWeb(web2); }
    return regTxt;
}

// [vNEXT] Generate a batch of narrative-thread descriptors. Each is a short name, a
// story state (locked/active/completed), and a 1-2 sentence current-situation hook.
// Parsed from labelled NAME:/STATE:/DESC: blocks. Records are created in runWizard...Batch.
async function generateNarrativeBatch(count: number, sourceChatIds: string[]): Promise<{ name: string; state: string; description: string }[]> {
    let cfg = await loadConfig();
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let narrIdx = await loadEntityIndex();
    let narrExisting = narrIdx.filter(function(n) { return n.type === 'narrative'; }).map(function(n) { return n.name; }).filter(Boolean);

    let narrSys: string[] = [
        'You are a dramaturg outlining the plot threads of a story — the quests, mysteries, conflicts, and obligations that will drive play.',
        'Produce EXACTLY ' + count + ' distinct narrative threads that fit the world and connect to the established cast and tensions.',
        'For each thread give a short evocative NAME, a STATE, and a DESC of one to two sentences stating the thread\'s current situation and what it pushes the player toward — concrete and unresolved, never a summary of how it ends.',
        'STATE must be exactly one of: locked (set up but not yet in play), active (currently driving the story), completed (already resolved). Most opening threads are "locked" or "active".',
        'CRITICAL RULE: DO NOT use any markdown, bolding, or bullet points. Output plain text only.'
    ];
    if (narrExisting.length) narrSys.push('These threads ALREADY EXIST — do NOT recreate, rename, or duplicate them:\n' + narrExisting.map(function(n) { return '- ' + n; }).join('\n'));
    narrSys.push('FORMAT: for each thread output exactly:\nNAME: <short thread name>\nSTATE: <locked|active|completed>\nDESC: <1-2 concrete sentences>\nSeparate threads with a line containing only ---');
    narrSys.push('Output ONLY the threads in that format. No preamble, no numbering, no commentary.');

    let narrUsr: string[] = [];
    if (ctx.trim()) narrUsr.push(ctx);
    narrUsr.push('Generate ' + count + ' narrative threads now.');

    let narrRaw = '';
    try { narrRaw = await executeYoinkGeneration([{ role: 'system', content: narrSys.join('\n\n') }, { role: 'user', content: narrUsr.join('\n\n') }]); }
    catch (eNarrGen) { api.v1.error('[AE:wizard] narrative batch generation failed:', eNarrGen); return []; }

    let narrOut: { name: string; state: string; description: string }[] = [];
    let narrChunks = (narrRaw || '').split(/\n-{3,}\n/);
    for (let nch of narrChunks) {
        let nNameMatch = nch.match(/NAME:\s*(.+)/i);
        let nStateMatch = nch.match(/STATE:\s*(\w+)/i);
        let nDescMatch = nch.match(/DESC:\s*([\s\S]+)/i);
        if (!nNameMatch) continue;
        let nName = nNameMatch[1].trim();
        let nState = nStateMatch ? nStateMatch[1].trim().toLowerCase() : 'locked';
        let nDesc = nDescMatch ? nDescMatch[1].trim() : '';
        nDesc = nDesc.replace(/\n-{3,}[\s\S]*$/, '').replace(/\nNAME:[\s\S]*$/i, '').trim();
        if (nName) narrOut.push({ name: nName, state: nState, description: nDesc });
    }
    return narrOut;
}

// [vNEXT] Create top-level narrative-thread entities from a generated batch. Mirrors the
// Drama tab's manual "+ New Thread" path exactly (entity only, no lorebook entry). The
// existing narrative tree editor handles nesting and state changes afterward.
async function runWizardNarrativesBatch(count: number, sourceChatIds: string[]): Promise<number> {
    let items = await generateNarrativeBatch(count, sourceChatIds);
    let narrCreated = 0;
    for (let nit of items) {
        if (!nit.name) continue;
        let nEnt = makeDefaultEntity(nit.name);
        nEnt.type = 'narrative';
        let nSt = (nit.state || 'locked');
        nEnt.storyState = (nSt === 'active' || nSt === 'completed') ? nSt as any : 'locked';
        nEnt.description = nit.description || '';
        nEnt.narrativeParentId = null;
        await saveEntity(nEnt);
        narrCreated++;
    }
    return narrCreated;
}

// [vNEXT] Add a single blank top-level narrative thread (rename + ⚡ Regen its situation).
async function addBlankWizardNarrative(): Promise<string> {
    let blankEnt = makeDefaultEntity('New Thread');
    blankEnt.type = 'narrative';
    blankEnt.storyState = 'locked';
    blankEnt.narrativeParentId = null;
    await saveEntity(blankEnt);
    return blankEnt.id;
}

// [vNEXT] Regenerate ONE narrative thread's situation description in place.
async function regenerateNarrativeThread(entId: string, sourceChatIds: string[], hint: string): Promise<string | null> {
    let cfg = await loadConfig();
    let nEntity = await loadEntity(entId);
    if (!nEntity || nEntity.type !== 'narrative') return null;
    let ctx = await buildWizardMultiContext(sourceChatIds, cfg);
    let nSys = [
        'You are writing the current situation of the narrative thread "' + nEntity.name + '" in a story.',
        'State in one to two concrete sentences what this thread is and what it pushes the player toward right now — unresolved, never a summary of how it ends.',
        'Output ONLY the description prose. No name prefix, no label, no markdown.'
    ].join('\n\n');
    let nUsr: string[] = [];
    if (ctx.trim()) nUsr.push(ctx);
    if (hint && hint.trim()) nUsr.push('--- EXTRA GUIDANCE ---\n' + hint.trim());
    nUsr.push('Write the situation for "' + nEntity.name + '" now.');
    let nRaw = '';
    try { nRaw = await executeYoinkGeneration([{ role: 'system', content: nSys }, { role: 'user', content: nUsr.join('\n\n') }]); }
    catch (eNarrReg) { api.v1.error('[AE:wizard] narrative regen failed:', eNarrReg); return null; }
    let nTxt = (nRaw || '').trim();
    if (!nTxt) return null;
    let nFresh = await loadEntity(entId);
    if (nFresh) { nFresh.description = nTxt; await saveEntity(nFresh); }
    return nTxt;
}


// ── World-Build Wizard: memory fan-out commit ────────────────────────────────────────────
// [vNEXT] For a 'memoryFanout' topic chat: regenerate each ENABLED section in its own
// scoped pass (sequential — NAI serializes generation; never parallel), write results
// back into cfg.wizardSections, persist config, then commit to Memory + Author's Note.
// Generation is sequential and order-stable so the "already-written" context grows as
// it goes. Returns the number of sections generated, or -1 on a hard failure.
async function runWizardMemoryFanout(chatId: string): Promise<number> {
    let cfg = await loadConfig();
    let chat = await loadWizardChat(chatId);
    if (!chat) return -1;

    let sections = cfg.wizardSections || [];
    let enabled = sections.filter(function(s) { return s.enabled; });
    let written = 0;

    for (let i = 0; i < enabled.length; i++) {
        let sec = enabled[i];
        // Pass the live (progressively updated) section list as prior context.
        let priorNow = (await loadConfig()).wizardSections || [];
        let gen = await generateWizardSection(sec, chat, cfg, priorNow);
        if (gen) {
            await mutConfig(function(c) {
                let target = (c.wizardSections || []).find(function(s) { return s.id === sec.id; });
                if (target) target.content = gen;
            });
            written++;
        }
    }

    let freshCfg = await loadConfig();
    await commitWizardMemory(freshCfg);
    return written;
}

// ── Emotion Resolution ────────────────────────────────────────────────────────
// [CHANGE] Added from AI engine. Normalises freeform model output to the
// canonical 24-state list used by bridge portrait selection and direct chat.

function resolveEmotion(raw: any): string {
    if (!raw) return 'neutral';
    const key = String(raw).toLowerCase().trim().replace(/[^a-z_]/g, '');
    return EMOTION_MAP[key] || 'neutral';
}

// ── Entity Factory ────────────────────────────────────────────────────────────

function makeDefaultEntity(name: string): EntityRecord {
    // Returns a new EntityRecord with all required fields initialised to safe defaults.
    // callers typically override type, parentId, and description immediately after.
    return {
        id: generateId(),
        name: name,
        type: 'location',
        parentId: null,
        narrativeParentId: null,
        storyState: 'locked',
        description: '',
        atmosphere: '',
        state: 'default',
        stateDescriptions: { 'default': '' },
        connectedEntityIds: [],
        presentCharacterIds: [],
        awareCharacterIds: [],
        actions: [],
        rules: [],
        skillBonuses: [],
        // encounters: removed v0.9.25 E4
        inventoryIds: [],
        showActionWidget: false,
        isVehicle: false,
        gated: false,
        notes: '',
        knowledgeString: '',
        lorebookTags: [],
        lorebookText: '',
        locationVisuals: '',
        questTarget: '',
        createdAt: Date.now(),
        updatedAt: Date.now()
    };
}

// ── Character Factory ─────────────────────────────────────────────────────────

function makeDefaultCharacter(name: string, cfg: GlobalConfig): CharacterRecord {
    // Returns a new CharacterRecord with all required fields initialised.
    // [CHANGE] New visual fields initialised with safe empty/numeric defaults.
    // avatarWidth/Height default to 1024×1024 (square) so new records never have
    // undefined dimensions when the bridge constructs image generation requests.
    const char: CharacterRecord = {
        id: api.v1.uuid(),
        name: name,
        conceptDump: '',
        nicknames: [],
        species: '',
        age: '',
        gender: '',
        occupationRole: '',
        briefDescription: '',
        // [CHANGE] portraitKey omitted — no longer part of CharacterRecord
        // Visual identity (image generation)
        visuals: '',
        uc: '',
        sceneVisuals: '',
        avatarVisuals: '',
        avatarWidth: 1024,
        avatarHeight: 1024,
        avatarSeed: 0,
        // Flags
        scenePresent: false,
        active: true,
        lorebookEntryId: undefined,
        featuredForEphemeral: false,
        // Static narrative
        physicalDescription: '',
        voiceAndMannerisms: '',
        personalityCore: '',
        background: '',
        customFieldValues: {},
        coreValues: [],
        // Relationships and hooks
        primaryRelationship: {
            targetName: '', enabled: false, archetype: '', howItStarted: '',
            threads: [], currentStatus: '', trajectory: '', summary: '', milestones: []
        },
        eventHistory: [],
        hooks: [],
        // Dynamic state
        ephemeral: null,
        ephemeralHistory: [],
        lastEphemeralGen: 0,  // [v0.9.24 E1]
        midRange: null,
        lastMidrangeGen: 0,
        lastArcGen: 0,
        lastHookGen: 0,
        // Equipment and resources
        equippedItemIds: [],
        charResourceDefs: [],
        charResourceValues: {},
        charFactionRelationships: {},
        // Sheet
        sheetValues: {},
        // Engine flags
        charContextEnabled: true,
        autoUpdateEnabled: cfg.autoUpdateDefault,
        autoThoughtsEnabled: cfg.autoThoughtsDefault,
        hooksEnabled: true,
        npcClass: undefined,
        lastTokenEstimate: 0,
        // World graph
        entityId: undefined,
        knownEntities: [],
        createdAt: Date.now(),
        updatedAt: Date.now()
    };

    // [v0.9.69] Personal resources only — global resources (e.g. Time) are world-shared
    // and are no longer mirrored onto each character (mirrorGlobalResourcesToCharacter kept
    // defined, unused, for back-compat reference).
    // [BUGFIX vNEXT] This used to be unreachable: the object literal above had its own
    // `return ... as CharacterRecord;` baked in, so seeding never ran on character/protagonist
    // creation — only the Worldbuilding Sync button added personal resources. Assigning the
    // literal to `char` first makes the seed call actually execute.
    const finalChar = seedPersonalResourcesToCharacter(char as CharacterRecord, cfg);
    return finalChar;
}
// ============================================================================
// SECTION 5 — STORAGE: CHARACTER DATA
// All reads and writes for CharacterRecord and the character index.
// Every function here operates on api.v1.storyStorage.
// ============================================================================

// ── Index (CharacterMeta[]) ───────────────────────────────────────────────────
// The index is the lightweight list used for sidebar rendering and fast lookups.
// Full CharacterRecord data lives in individual keys (STORAGE_CHAR_PFX + id).

async function loadIndex(): Promise<CharacterMeta[]> {
    return await api.v1.storyStorage.getOrDefault(STORAGE_INDEX, []) as CharacterMeta[];
}

async function saveIndex(idx: CharacterMeta[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_INDEX, idx.filter(Boolean));
}

// ── Migration ─────────────────────────────────────────────────────────────────
// migrateCharacter runs every time a CharacterRecord is loaded from storage.
// It forward-migrates old save formats and ensures all required fields exist.
// Safe to call multiple times on the same record.

function migrateCharacter(raw: any, cfg: GlobalConfig): CharacterRecord {
    const d = makeDefaultCharacter('Unnamed', cfg);
    const c = { ...d, ...raw };

    // ── Deprecated field removal ──────────────────────────────────────────────
    delete (c as any).storyRole;
    delete (c as any).conditions;
    delete (c as any).activeConditionId;
    delete (c as any).tier;
    delete (c as any).budgetCap;
    // [CHANGE] portraitKey removed — bridge derives portrait key from char.id directly.
    delete (c as any).portraitKey;
    // [CHANGE] homeLocationId was an unimplemented idea with no read path. Removed.
    delete (c as any).homeLocationId;

    // ── Equipment migration (equippedItemId → equippedItemIds) ────────────────
    if (!c.equippedItemIds) {
        c.equippedItemIds = (c as any).equippedItemId ? [(c as any).equippedItemId] : [];
    }
    delete (c as any).equippedItemId;
    if ('equippedItems' in c) delete (c as any).equippedItems;
    if ('wardrobe' in c) delete (c as any).wardrobe;

    // ── v0.9.3 field guards ───────────────────────────────────────────────────
    if (!c.charResourceDefs) c.charResourceDefs = [];
    if (!c.charResourceValues) c.charResourceValues = {};
    if (!c.charFactionRelationships) c.charFactionRelationships = {};

    // [v0.9.89] Migrate #gold → #currency on existing character resource defs.
    if (Array.isArray(c.charResourceDefs)) {
        c.charResourceDefs = c.charResourceDefs.map(function(r: any) {
            if (r.tag === '#gold') {
                return { ...r, id: r.id === 'cres_gold' ? 'cres_currency' : r.id, name: r.name === 'Wealth' ? 'Currency' : r.name, tag: '#currency' };
            }
            return r;
        });
    }

    // ── Structural guards ─────────────────────────────────────────────────────
    if (!c.hooks) c.hooks = [];
    if (!c.ephemeralHistory) c.ephemeralHistory = [];
    
    // Purge old character arc properties from database memory
    delete (c as any).arcEnabled;
    delete (c as any).arcType;
    delete (c as any).developingAspects;
    delete (c as any).arcCurrentState;
    delete (c as any).arcTrajectory;
    delete (c as any).arcEndState;
    delete (c as any).arcMilestones;

    if (!c.primaryRelationship) c.primaryRelationship = {
        targetName: '', enabled: false, archetype: '', howItStarted: '',
        threads: [], currentStatus: '', trajectory: '', summary: '', milestones: []
    };
    if (c.primaryRelationship.enabled === undefined) c.primaryRelationship.enabled = false;
    if (!c.customFieldValues) c.customFieldValues = {};
    if (!c.sheetValues) c.sheetValues = {};
    if (!c.conceptDump) c.conceptDump = '';
    // [v0.9.24 E1] Remove deprecated token stamps; add gen stamps with 0 defaults
    delete (c as any).lastEphemeralTokens;
    delete (c as any).lastMidrangeTokens;
    delete (c as any).lastArcTokens;
    delete (c as any).lastHookTokens;
    if (c.lastEphemeralGen === undefined) c.lastEphemeralGen = 0;
    if (c.lastMidrangeGen  === undefined) c.lastMidrangeGen  = 0;
    if (c.lastArcGen       === undefined) c.lastArcGen       = 0;
    if (c.lastHookGen      === undefined) c.lastHookGen      = 0;
    if (!c.knownEntities) c.knownEntities = [];
    if (c.charContextEnabled === undefined) c.charContextEnabled = true;
    if (c.hooksEnabled === undefined) c.hooksEnabled = true;

    // ── Visual field guards (v1.0.0) ──────────────────────────────────────────
    // [CHANGE] New fields. Old records won't have these; default to empty strings
    // and safe numeric values so bridge image generation never receives undefined.
    if (!c.visuals)       c.visuals       = '';
    if (!c.uc)            c.uc            = '';
    if (!c.sceneVisuals)  c.sceneVisuals  = '';
    if (!c.avatarVisuals) c.avatarVisuals = '';
    if (c.avatarWidth  === undefined || c.avatarWidth  === null) c.avatarWidth  = 1024;
    if (c.avatarHeight === undefined || c.avatarHeight === null) c.avatarHeight = 1024;
    if (c.avatarSeed   === undefined || c.avatarSeed   === null) c.avatarSeed   = 0;

    return c as CharacterRecord;
}

// ── Load ──────────────────────────────────────────────────────────────────────

async function loadCharacter(id: string): Promise<CharacterRecord | null> {
    const raw = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + id);
    if (!raw) return null;
    const cfg = await loadConfig();
    return migrateCharacter(raw, cfg);
}

async function loadCharacterListForPicker(excludeId?: string): Promise<CharacterMeta[]> {
    // Returns active characters suitable for UI pickers (relationship target, entity link, etc.).
    // Validates that each index entry still has a backing storage record (handles stale entries).
    const idx = await loadIndex();
    const validated: CharacterMeta[] = [];
    for (const m of idx) {
        if (m.id === excludeId) continue;
        if (!m.active && !m.isProtagonist) continue;
        const exists = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + m.id);
        if (exists) validated.push(m);
    }
    return validated;
}

async function loadAllCharacters(): Promise<CharacterRecord[]> {
    // [CHANGE] Performance fix: original called loadCharacter() per character,
    // which called loadConfig() per character — N+1 storage reads for N characters.
    // Now loads config once and passes it into migrateCharacter directly.
    const idx = await loadIndex();
    const cfg = await loadConfig();
    const chars = await Promise.all(
        idx.filter(Boolean).map(async function(m) {
            try {
                const raw = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + m.id);
                return raw ? migrateCharacter(raw, cfg) : null;
            } catch (e) {
                api.v1.error('[AE] loadAllCharacters: failed to load char ' + m.id, e);
                return null;
            }
        })
    );
    return chars.filter(Boolean) as CharacterRecord[];
}

// ── Save ──────────────────────────────────────────────────────────────────────

async function saveCharacter(char: CharacterRecord): Promise<void> {
    const cfg = await loadConfig();

    // Derive equipped item names from equippedItemIds for the index
    const equippedItemNames: string[] = [];
    for (const itemId of (char.equippedItemIds || [])) {
        try {
            const itemEnt = await loadEntity(itemId);
            if (itemEnt) equippedItemNames.push(itemEnt.name);
        } catch (ignoredErr) { /* non-fatal — item may not exist yet */ }
    }

    // Derive the character's current location from their entity body's parentId.
    // This is the single source of truth for character location — not a stored field.
    let currentLocationId: string | undefined = undefined;
    if (char.entityId) {
        try {
            const charEntBody = await loadEntity(char.entityId);
            if (charEntBody) currentLocationId = charEntBody.parentId !== null ? charEntBody.parentId : undefined;
        } catch (ignoredErr) { /* non-fatal — entity may not exist yet */ }
    }

    // Build the lightweight index entry
    // [CHANGE] portraitKey removed from CharacterMeta — bridge derives from char.id
    const meta: CharacterMeta = {
        id: char.id,
        name: char.name,
        isProtagonist: char.isProtagonist,
        entityId: char.entityId,
        hasCriticalHook: !!(char.hooks && char.hooks.some(function(h) { return !h.resolved && h.pressureLevel >= 85; })),
        scenePresent: char.scenePresent,
        active: char.active,
        briefDescription: char.briefDescription,
        species: char.species,
        age: char.age,
        occupationRole: char.occupationRole,
        currentStance: char.midRange ? char.midRange.socialMask : undefined,
        lastThought: char.ephemeral ? char.ephemeral.compressedLine : undefined,
        lastTokenEstimate: char.lastTokenEstimate,
        equippedItemNames: equippedItemNames.length > 0 ? equippedItemNames : undefined,
        currentLocationId: currentLocationId,
        isStatic: !!((char as any).isStatic),   // [v0.9.31 DYN1] propagate so card reads correct state
        npcClass: (char as any).npcClass,      // [vNEXT] propagate minor flag to index
        dynamicPriorityRank: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? (char as any).dynamicPriorityRank : undefined  // [vNEXT] propagate rank so the cap sorts off the index
    };

    const idx = await loadIndex();
    const existingIdx = idx.findIndex(function(m) { return m.id === char.id; });
    if (existingIdx >= 0) { idx[existingIdx] = meta; } else { idx.push(meta); }

    await saveIndex(idx);
    await api.v1.storyStorage.set(STORAGE_CHAR_PFX + char.id, char);

    // Keep cfg.protagonistName in sync so __player__ resolves correctly in injections
    if (char.isProtagonist && char.name) {
        try {
            const cfgSync = await api.v1.storyStorage.get(STORAGE_CONFIG) as any;
            if (cfgSync && cfgSync.protagonistName !== char.name) {
                cfgSync.protagonistName = char.name;
                await api.v1.storyStorage.set(STORAGE_CONFIG, cfgSync);
            }
        } catch (e) { /* non-fatal */ }
    }

    // [CHANGE] Queue a debounced broadcast to keep the bridge's character visual
    // cache in sync. Defined in Section 18. Batches rapid sequential saves.
    queueCharacterDataBroadcast();
}

// ── Delete ────────────────────────────────────────────────────────────────────

async function deleteCharacter(id: string): Promise<void> {
    const char = await loadCharacter(id);
    if (char && char.entityId) {
        await deleteEntity(char.entityId); // Scrub the physical body from the world
    }
    await api.v1.storyStorage.remove(STORAGE_CHAR_PFX + id);
    const idx = await loadIndex();
    await saveIndex(idx.filter(function(m) { return m.id !== id; }));
    
    // Dispatch cascade event to bridge to clean up IndexedDB assets
    await broadcastToTM('AE_DELETE_PORTRAIT_CASCADE', { charId: id });
}


// ============================================================================
// SECTION 6 — STORAGE: ENTITY DATA
// All reads and writes for EntityRecord and the entity index.
// Entities are the world graph: locations, items, narrative nodes, character bodies.
// ============================================================================

// ── Index (EntityMeta[]) ──────────────────────────────────────────────────────

async function loadEntityIndex(): Promise<EntityMeta[]> {
    return await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_INDEX, []) as EntityMeta[];
}

async function saveEntityIndex(idx: EntityMeta[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_ENTITY_INDEX, idx.filter(Boolean));
}

// ── Migration ─────────────────────────────────────────────────────────────────
// migrateEntity runs every time an EntityRecord is loaded from storage.
// Handles all legacy field shapes from prior engine versions.

function migrateEntity(raw: any): EntityRecord {
    const ent = raw as any;
    if (!ent.id) ent.id = generateId();
    if (!ent.name) ent.name = 'Unnamed Entity';

    // Force legacy spatial sub-types into the current functional type system
    if (!ent.type || ['interior', 'exterior', 'transit', 'abstract'].includes(ent.type)) {
        ent.type = 'location';
    }
    // Migrate legacy shop type → narrative
    if (ent.type === 'shop') ent.type = 'narrative';

    if (ent.narrativeParentId === undefined) ent.narrativeParentId = null;
    if (ent.parentId === undefined) ent.parentId = null;
    if (!ent.storyState) ent.storyState = 'locked';

    // [v0.9.25 E4] Encounter migration removed; delete stale field from old saves
    delete (ent as any).encounters;

    // v0.9.3 field guards
    if (!ent.rules) ent.rules = [];
    if (!ent.skillBonuses) ent.skillBonuses = [];
    if (ent.isVehicle === undefined) ent.isVehicle = false;

    // Migrate flat EntityAction fields → ActionRule objects on each action
    if (ent.actions && Array.isArray(ent.actions)) {
        ent.actions = ent.actions.map(function(a: any) {
            return migrateEntityAction(a);
        });
    }

    if (!ent.description) ent.description = '';
    if (!ent.atmosphere) ent.atmosphere = '';
    if (!ent.state) ent.state = 'default';
    if (!ent.stateDescriptions) ent.stateDescriptions = {};

    // Migrate old connection array key to current key
    ent.connectedEntityIds = ent.connectedEntityIds || ent.connectedLocationIds || [];
    delete ent.connectedLocationIds;

    if (!ent.presentCharacterIds) ent.presentCharacterIds = [];
    if (!ent.awareCharacterIds) ent.awareCharacterIds = [];
    if (!ent.actions) ent.actions = [];

    // Remove legacy commerce fields
    delete ent.price;
    if (!ent.inventoryIds) ent.inventoryIds = [];

    if (ent.showActionWidget === undefined) ent.showActionWidget = true;
    if (!ent.notes) ent.notes = '';
    if (!ent.lorebookTags) ent.lorebookTags = [];
    if (ent.lorebookText === undefined) ent.lorebookText = '';
    if (ent.locationVisuals === undefined) ent.locationVisuals = '';
    if (ent.gated === undefined) ent.gated = false;
    if (!ent.tagSubscriptions) ent.tagSubscriptions = [];
    if (!ent.createdAt) ent.createdAt = Date.now();
    if (!ent.updatedAt) ent.updatedAt = Date.now();

    // Filter null entries in all arrays for safety
    ent.connectedEntityIds  = ent.connectedEntityIds.filter(Boolean);
    ent.presentCharacterIds = ent.presentCharacterIds.filter(Boolean);
    ent.awareCharacterIds   = ent.awareCharacterIds.filter(Boolean);
    ent.actions             = ent.actions.filter(Boolean);

    return ent as EntityRecord;
}

function migrateEntityAction(a: any): EntityAction {
    // Migrates a flat action shape (pre-rule-system) to the current ActionRule-based format.
    // Each migration is additive — if a matching rule already exists it is not duplicated.
    if (!a.rules) a.rules = [];

    // Flat skill gate → skill-gate rule
    if (a.skillCheckTag && !a.rules.some(function(r: any) { return r.type === 'skill-gate'; })) {
        a.rules.push({ id: generateId(), type: 'skill-gate', skillTag: a.skillCheckTag, successThreshold: a.successThreshold || 3, failureNote: a.failureNote || '' });
    }
    // Flat resource cost → resource-cost rule
    if (a.requiresResourceTag && !a.rules.some(function(r: any) { return r.type === 'resource-cost'; })) {
        a.rules.push({ id: generateId(), type: 'resource-cost', resourceTag: a.requiresResourceTag, amount: a.resourceCost || 1 });
    }
    // Flat resource gain → resource-gain rule
    if (a.providesResourceTag && !a.rules.some(function(r: any) { return r.type === 'resource-gain'; })) {
        a.rules.push({ id: generateId(), type: 'resource-gain', resourceTag: a.providesResourceTag, amount: a.providesAmount || 1 });
    }
    // Flat targetState → set-field rule on entity.state
    if (a.targetState && !a.rules.some(function(r: any) { return r.type === 'set-field' && r.fieldKey === 'state'; })) {
        a.rules.push({ id: generateId(), type: 'set-field', targetType: 'entity', targetId: '__self__', fieldKey: 'state', fieldValue: a.targetState });
    }
    // Flat moveEntityId + moveToParentId → set-field rule on entity.parentId
    if (a.moveEntityId && a.moveToParentId && !a.rules.some(function(r: any) { return r.type === 'set-field' && r.fieldKey === 'parentId'; })) {
        a.rules.push({ id: generateId(), type: 'set-field', targetType: 'entity', targetId: a.moveEntityId, fieldKey: 'parentId', fieldValue: a.moveToParentId });
    }
    // Flat targetEntityId + targetStoryState → set-field rule on storyState
    if (a.targetEntityId && a.targetStoryState && !a.rules.some(function(r: any) { return r.type === 'set-field' && r.fieldKey === 'storyState'; })) {
        a.rules.push({ id: generateId(), type: 'set-field', targetType: 'entity', targetId: a.targetEntityId, fieldKey: 'storyState', fieldValue: a.targetStoryState });
    }

    // Strip all migrated flat fields
    delete a.targetEntityId; delete a.targetStoryState;
    delete a.skillCheckTag; delete a.successThreshold;
    delete a.requiresResourceTag; delete a.resourceCost;
    delete a.providesResourceTag; delete a.providesAmount;
    delete a.targetState;
    delete a.moveEntityId; delete a.moveToParentId;

    return a as EntityAction;
}

// ── Load ──────────────────────────────────────────────────────────────────────

async function loadEntity(id: string): Promise<EntityRecord | null> {
    const raw = await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_PFX + id, null);
    return raw ? migrateEntity(raw) : null;
}

// ── Save ──────────────────────────────────────────────────────────────────────

async function saveEntity(ent: EntityRecord): Promise<void> {
    ent.updatedAt = Date.now();
    // [v0.9.24 E3] Auto-clear tracking when a narrative is completed.
    if (ent.type === 'narrative' && ent.storyState === 'completed') {
        try {
            let _trackedId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
            if (_trackedId === ent.id) {
                await api.v1.storyStorage.set(STORAGE_TRACKED_NARRATIVE, '');
                api.v1.ui.toast('📍 Tracking cleared — narrative completed.', { type: 'info', autoClose: 2000 });
            }
        } catch (_e3) { /* non-fatal */ }
    }
    await api.v1.storyStorage.set(STORAGE_ENTITY_PFX + ent.id, ent);

    const idx = await loadEntityIndex();
    const meta: EntityMeta = {
        id: ent.id,
        name: ent.name,
        type: ent.type,
        parentId: ent.parentId,
        narrativeParentId: ent.narrativeParentId,
        storyState: ent.storyState,
        childCount: idx.filter(function(m) { return m.parentId === ent.id; }).length,
        presentCharacterCount: ent.presentCharacterIds.filter(Boolean).length,
        state: ent.state,
        icon: ent.icon || undefined,
        gated:     !!(ent as any).gated     || false,
        isVehicle: !!(ent as any).isVehicle || false,
        hasGlobalAutoTrigger: (((ent as any).actionInstances || []) as any[]).some(function(i) { return !!(i as any).globalAutoTrigger; }) || false
    };

    const i = idx.findIndex(function(m) { return m.id === ent.id; });
    if (i >= 0) { idx[i] = meta; } else { idx.push(meta); }
    await saveEntityIndex(idx);

    // [CHANGE] Queue a debounced scene state broadcast. Any entity change — location
    // state, available actions, connection changes — may affect the HUD. Debouncing
    // at 200ms coalesces the storm of saves during bulk operations like imports.
    // Defined in Section 18. No-ops if bridge is not yet connected.
    queueSceneStateBroadcast();
}

// [UNIFY] One-time migration: canonicalise faction-standing args (name → index) on
// entity-ATTACHED action instances. migrateConfig (above) already converts every
// action TEMPLATE in the Library on every load, because cfg is cheap to touch on
// every load. Entity instances live one-per-entity in storyStorage, so scanning all
// of them is comparatively expensive — not something to repeat on every session
// load. Instead this runs exactly once per story, gated by a storyStorage flag, and
// is safe to skip even if it never runs: aeResolveResourceCompareValue (used by every
// faction condition/effect at evaluation time) still accepts a saved NAME as a
// fallback, so un-migrated instances keep working correctly either way — this pass
// only tidies the underlying data to indices so a later faction rename can't strip
// old actions. Called once from onScriptsLoaded, after config is available.
async function migrateFactionArgsOnEntities(cfg: GlobalConfig): Promise<void> {
    try {
        const already = await api.v1.storyStorage.getOrDefault(STORAGE_FAC_ENTITY_MIGRATED, false) as boolean;
        if (already) return;

        let facById: Record<string, FactionDef> = {};
        (cfg.factions || []).forEach(function(f) { facById[f.id] = f; });

        const idx = await loadEntityIndex();
        let touched = 0;
        for (const meta of idx.filter(Boolean)) {
            let ent = await loadEntity(meta.id).catch(function() { return null; });
            if (!ent) continue;
            let insts = ((ent as any).actionInstances || []) as ActionInstance[];
            if (!insts.length) continue;
            let before = JSON.stringify(insts);
            insts.forEach(function(inst) { aeWalkActionForFactionArgs(inst, facById); });
            if (JSON.stringify(insts) !== before) {
                await saveEntity(ent);
                touched++;
            }
        }

        await api.v1.storyStorage.set(STORAGE_FAC_ENTITY_MIGRATED, true);
        if (touched > 0) api.v1.log('[AE:migrate] Faction-standing args canonicalised on ' + touched + ' entit' + (touched === 1 ? 'y' : 'ies') + '.');
    } catch (eFacEnt) {
        // Non-fatal: leave the flag unset so a future load can retry, and the
        // runtime name-fallback keeps everything working in the meantime.
        api.v1.error('[AE:migrate] migrateFactionArgsOnEntities error:', eFacEnt);
    }
}

// ── Delete ────────────────────────────────────────────────────────────────────

async function deleteEntity(id: string): Promise<void> {
    await api.v1.storyStorage.remove(STORAGE_ENTITY_PFX + id);
    const idx = await loadEntityIndex();

    // Collect orphaned children BEFORE removing the entry from the index,
    // since we need their parentId reference while it still points to the deleted entity.
    const orphaned = idx.filter(function(m) { return m.parentId === id; });

    await saveEntityIndex(idx.filter(function(m) { return m.id !== id; }));

    // Re-parent any child entities to the world root (null parent).
    // [CHANGE] Fixes a pre-existing dead-code bug: the original code checked
    // CharacterRecord.currentLocationId which is never stored on that type
    // (it is derived and only stored in CharacterMeta). Now correctly iterates
    // child entities via their parentId relationship in the entity index.
    for (const m of orphaned) {
        try {
            const child = await loadEntity(m.id);
            if (child) { child.parentId = null; await saveEntity(child); }
        } catch (ignoredErr) { /* non-fatal */ }
    }
}

// ── Copy ──────────────────────────────────────────────────────────────────────

async function copyEntity(id: string, deep: boolean = false): Promise<void> {
    try {
        const src = await loadEntity(id);
        if (!src) return;

        const newId = generateId();
        const copy: EntityRecord = JSON.parse(JSON.stringify(src));

        copy.id = newId;
        copy.name = 'Copy of ' + src.name;
        copy.createdAt = Date.now();
        copy.updatedAt = Date.now();

        // Clear runtime state — copy starts fresh, not carrying over scene presence
        copy.connectedEntityIds = [];
        copy.presentCharacterIds = [];
        copy.awareCharacterIds = [];

        // Regenerate action IDs to avoid collisions with source entity
        copy.actions = (copy.actions || []).map(function(a) {
            return Object.assign({}, a, { id: generateId() });
        });

        // [v0.9.25 E4] Encounter range copy removed
        if (false && (copy as any).encounters) {
            (copy as any).encounters.ranges = ((copy as any).encounters.ranges || []).map(function(r) {
                return Object.assign({}, r, { id: generateId(), triggered: false });
            });
        }

        await saveEntity(copy);

        if (deep) {
            const allMeta = await loadEntityIndex();
            const children = allMeta.filter(function(m) { return m.parentId === src.id; });

            for (const childMeta of children) {
                const childSrc = await loadEntity(childMeta.id);
                if (!childSrc) continue;

                const childCopy: EntityRecord = JSON.parse(JSON.stringify(childSrc));
                childCopy.id = generateId();
                childCopy.name = childSrc.name;
                childCopy.parentId = newId;
                childCopy.createdAt = Date.now();
                childCopy.updatedAt = Date.now();
                childCopy.connectedEntityIds = [];
                childCopy.presentCharacterIds = [];
                childCopy.awareCharacterIds = [];
                childCopy.actions = (childCopy.actions || []).map(function(a) {
                    return Object.assign({}, a, { id: generateId() });
                });
                if (false && (childCopy as any).encounters) {
                    (childCopy as any).encounters.ranges = ((childCopy as any).encounters.ranges || []).map(function(r) {
                        return Object.assign({}, r, { id: generateId(), triggered: false });
                    });
                }
                await saveEntity(childCopy);
            }

            api.v1.ui.toast('Copied "' + src.name + '" with ' + children.length + ' child(ren).', { type: 'success' });
        } else {
            api.v1.ui.toast('Copied "' + src.name + '".', { type: 'success' });
        }

        await refreshSidebar();
        await openEntityEditModal(newId);
    } catch (e) {
        api.v1.error('[AE] copyEntity:', e);
        api.v1.ui.toast('Copy failed.', { type: 'error' });
    }
}

// ── History (recent location breadcrumb) ─────────────────────────────────────

async function loadEntityHistory(): Promise<string[]> {
    return await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_HISTORY, []) as string[];
}

async function saveEntityHistory(ids: string[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_ENTITY_HISTORY, ids.slice(0, 10));
}


// ============================================================================
// SECTION 7 — STORAGE: GLOBAL CONFIG
// Single GlobalConfig record per story. Governs engine intervals, field labels,
// resources, factions, skill modifiers, and generation style.
// ============================================================================

// [v0.9.9.2] Default time bands. Night wraps midnight (start 22 > end 6).
const DEFAULT_TIME_BANDS: TimeBandDef[] = [
    { label: 'Morning',   startHour: 6,  endHour: 12 },
    { label: 'Afternoon', startHour: 12, endHour: 18 },
    { label: 'Evening',   startHour: 18, endHour: 22 },
    { label: 'Night',     startHour: 22, endHour: 6  }
];

function makeDefaultConfig(): GlobalConfig {
    return {
        contextTemplates: JSON.parse(JSON.stringify(DEFAULT_TEMPLATES)),
        interfaceMode: 'native',   // [v0.9.9.6] default to the native HUD; bridge is opt-in
        thoughtIntervalGens: 2,    // [v0.9.24 E1] ephemeral every 2 generations
        dynamicIntervalGens: 4,    // mid-range every 4 generations
        arcIntervalGens: 10,       // arc/relationship every 10 generations
        hookIntervalGens: 6,       // hooks every 6 generations
        totalGenerations: 0,
        ephemeralCap: 3,
        maxDynamicCharacters: 0,   // [vNEXT] 0 = no cap (all present dynamic chars process)
        sheetCategories: JSON.parse(JSON.stringify(DEFAULT_SHEET_CATEGORIES)),
        autoUpdateDefault: true,
        autoThoughtsDefault: true,
        showFieldHeaders: true,
        generalStyle: DEFAULT_GENERAL_STYLE,
        fieldLabels: {},
        fieldInstructions: {},
        fieldBudgets: {},
        customStaticFields: [],
        relationshipArchetypes: [...DEFAULT_REL_ARCHETYPES],
        resources: JSON.parse(JSON.stringify(DEFAULT_RESOURCES)),
        species: [],
        factions: [],
        projectName: '',
        projectGenre: '',
        projectConcept: '',
        wizardSections: JSON.parse(JSON.stringify(DEFAULT_WIZARD_SECTIONS)),
        defaultBackgroundUrl: '',
        timeAutoAdvanceEnabled: false,
        timeAdvanceHours: 1,
        timeAdvanceEveryGens: 3,
        timeStartHours: 8,
        timeShowInAN: true,
        timeBands: JSON.parse(JSON.stringify(DEFAULT_TIME_BANDS)),
        timeDayNames: [],
        timeWeekNames: []
    };
}

// [UNIFY] Shared faction-standing-arg normaliser — converts a saved NAME on any
// faction condition/effect rule to its index, in place, on a single action's full
// rule tree (conditions, all three effect buckets, resolution bands, branches).
// Idempotent: a value that already parses as a number, or doesn't match any
// standing, is left untouched (the runtime resolver still handles bare names as
// a fallback either way). Used by migrateConfig (action templates) and by
// migrateFactionArgsOnEntities (entity-attached action instances) so both surfaces
// share one conversion path instead of two copies that could drift apart.
const AE_FAC_STANDING_RULE_TYPES: Record<string, number> = { char_faction: 1, player_faction: 1, set_char_faction: 1, set_player_faction: 1 };
function aeConvertFactionStandingArgs(rule: any, facById: Record<string, FactionDef>): void {
    if (!rule || !rule.args || !AE_FAC_STANDING_RULE_TYPES[rule.type]) return;
    let raw = rule.args.state;
    if (raw === undefined || raw === null || raw === '__ask__') return;
    if (!isNaN(Number(String(raw).trim())) && String(raw).trim() !== '') return; // already an index
    let fdef = facById[String(rule.args.factionId || '')];
    if (!fdef || !fdef.relationshipStates) return;
    let idx = fdef.relationshipStates.findIndex(function(s) { return String(s).toLowerCase() === String(raw).toLowerCase(); });
    if (idx >= 0) rule.args.state = String(idx);
}
// [PATCH v0998] Generic rule-arg repair — driven off UIRuleManifest so it covers
// every current 'string'/'number' arg automatically, not just the two known
// culprits. Two things it fixes, both idempotent:
//   1) manifest says 'string' but the stored value is a number/boolean -> stringify.
//   2) manifest says 'number' but the stored value is a string -> resolve to a real
//      number. For char_resource.amount / char_skill.amount this means running the
//      SAME name-or-index lookup the runtime already uses (aeResolveResourceCompareValue),
//      so a legacy "dead" keeps matching the "dead" state's current index rather than
//      being silently discarded. Anything that can't be resolved is left untouched and
//      logged to AE_ARG_REPAIR_LOG for the Scan & Repair report instead of guessed at.
// NOTE: aeResolveResourceCompareValue is defined later in the file; safe because
// function declarations are hoisted and this only ever runs after script load.
let AE_ARG_REPAIR_LOG: string[] = [];
function aeCoerceRuleArgTypes(rule: any, cfg: GlobalConfig, ctx: string): void {
    if (!rule || !rule.type || !rule.args) return;
    const manifest = (typeof UIRuleManifest !== 'undefined') ? UIRuleManifest[rule.type] : undefined;
    if (!manifest || !manifest.args) return;

    manifest.args.forEach(function(argDef: any) {
        const key = argDef.key;
        const v = rule.args[key];
        if (v === undefined || v === null) return;

        if ((argDef.type === 'string' || argDef.type === 'longtext') && typeof v !== 'string') {
            if (typeof v === 'number' || typeof v === 'boolean') {
                AE_ARG_REPAIR_LOG.push(`${ctx}: ${rule.type}.${key} ${JSON.stringify(v)} -> "${String(v)}"`);
                rule.args[key] = String(v);
            } else {
                AE_ARG_REPAIR_LOG.push(`\u26a0 ${ctx}: ${rule.type}.${key} = ${JSON.stringify(v)} \u2014 could not auto-repair (unexpected type), please check manually`);
            }
            return;
        }

        if (argDef.type === 'number' && typeof v !== 'number') {
            let resolved: number = NaN;
            if (rule.type === 'char_resource' && key === 'amount') {
                const rdef = (cfg.characterResourceDefs || []).find(function(r: any) { return r.tag === rule.args.tag; });
                resolved = aeResolveResourceCompareValue(v, rdef ? rdef.states : undefined);
            } else if (rule.type === 'char_skill' && key === 'amount') {
                const parts = String(rule.args.fieldRef || '').split('.');
                const cat = (cfg.sheetCategories || []).find(function(c: any) { return c.id === parts[0]; });
                resolved = aeResolveResourceCompareValue(v, (cat && cat.fieldType === 'enum') ? cat.enumValues : undefined);
            } else {
                resolved = Number(v);
            }
            if (!isNaN(resolved)) {
                AE_ARG_REPAIR_LOG.push(`${ctx}: ${rule.type}.${key} ${JSON.stringify(v)} -> ${resolved}`);
                rule.args[key] = resolved;
            } else {
                AE_ARG_REPAIR_LOG.push(`\u26a0 ${ctx}: ${rule.type}.${key} = ${JSON.stringify(v)} \u2014 could not resolve to an index/number, please check manually`);
            }
        }
    });
}
function aeWalkActionForArgTypeRepair(act: any, cfg: GlobalConfig, ctx: string): void {
    if (!act) return;
    (act.conditions      || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    (act.successEffects  || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    (act.failureEffects  || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    (act.alwaysEffects   || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx); });
    if (act.resolution && Array.isArray(act.resolution.bands)) {
        act.resolution.bands.forEach(function(b: any) { (b.effects || []).forEach(function(r: any) { aeCoerceRuleArgTypes(r, cfg, ctx + ' [band]'); }); });
    }
    (act.branches || []).forEach(function(b: any) { aeWalkActionForArgTypeRepair(b, cfg, ctx + ' [branch:' + (b.name || '?') + ']'); });
}

function aeWalkActionForFactionArgs(act: any, facById: Record<string, FactionDef>): void {
    if (!act) return;
    (act.conditions || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    (act.successEffects || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    (act.failureEffects || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    (act.alwaysEffects  || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); });
    if (act.resolution && Array.isArray(act.resolution.bands)) {
        act.resolution.bands.forEach(function(b: any) { (b.effects || []).forEach(function(r: any) { aeConvertFactionStandingArgs(r, facById); }); });
    }
    (act.branches || []).forEach(function(b: any) { aeWalkActionForFactionArgs(b, facById); });
}

function migrateConfig(raw: any): GlobalConfig {
    // Merges raw saved data over defaults so new fields always have values.
    // Strips deprecated keys so old saves don't carry stale data.
    const d = makeDefaultConfig();
    const c = { ...d, ...raw };

    // Deprecated field removal
    delete c.storyRolePresets;
    delete c.conditionPresets;
    delete (c as any).defaultBudgetCap;
    delete (c as any).globalRules;
    delete (c as any).arcTypePresets; // Purge old config properties

    // Structural guards
    if (!c.relationshipArchetypes) c.relationshipArchetypes = JSON.parse(JSON.stringify(DEFAULT_REL_ARCHETYPES));
    // Migrate legacy string[] archetypes → RelationshipArchetypeDef[]
    if (Array.isArray(c.relationshipArchetypes) && c.relationshipArchetypes.length > 0 && typeof c.relationshipArchetypes[0] === 'string') {
        c.relationshipArchetypes = (c.relationshipArchetypes as any[]).map(function(s: any) {
            return { id: 'arch_' + String(s).toLowerCase().replace(/[^a-z0-9]+/g, '_').slice(0, 24) + '_' + Math.random().toString(36).slice(2, 6), name: String(s), stages: [] };
        });
    }
    if (!c.customStaticFields)     c.customStaticFields = [];
    if (!c.fieldLabels)            c.fieldLabels = {};
    if (!c.fieldInstructions)      c.fieldInstructions = {};
    if (!c.fieldBudgets)           c.fieldBudgets = {};
    if (!c.sheetCategories)        c.sheetCategories = [];
    if (c.ephemeralCap === undefined) c.ephemeralCap = 3;
    if (!c.resources) c.resources = JSON.parse(JSON.stringify(DEFAULT_RESOURCES));

    // Migrate resources: strip old rules array (superseded), ensure hasBounds exists
    c.resources = c.resources.map(function(r: any) {
        delete r.rules;
        if (r.hasBounds === undefined) r.hasBounds = true;
        return r;
    });

    // v0.9.3 fields
    if (!c.species)  c.species  = [];
    if (!c.factions) c.factions = [];

    // [UNIFY] Normalise faction-standing args from saved NAMES to indices on every
    // action TEMPLATE (entity-attached action INSTANCES are handled separately by
    // migrateFactionArgsOnEntities, run once at startup — see Section 27). Delegates
    // to the shared walker/converter above so both surfaces use one conversion path.
    try {
        let facById: Record<string, FactionDef> = {};
        (c.factions || []).forEach(function(f: FactionDef) { facById[f.id] = f; });
        (c.actionTemplates || []).forEach(function(t: any) { aeWalkActionForFactionArgs(t, facById); });
    } catch (eFacCfg) { /* non-fatal: leave args as-is, runtime resolver still handles names */ }

    // [PATCH v0998] Repair legacy rule-arg values against the current UIRuleManifest
    // arg types (e.g. numeric char_resource.amount that must be a string vs. a saved
    // state-NAME amount that must now be a number). Runs every load; idempotent.
    try {
        AE_ARG_REPAIR_LOG = [];
        (c.actionTemplates || []).forEach(function(t: any) { aeWalkActionForArgTypeRepair(t, c, t.name || t.id || '?'); });
        if (AE_ARG_REPAIR_LOG.length) {
            api.v1.log('[AE:migrate] Repaired ' + AE_ARG_REPAIR_LOG.length + ' legacy action arg field(s) — see Worldbuilding \u2192 \ud83e\ude7a Scan & Repair Actions for details.\n' + AE_ARG_REPAIR_LOG.join('\n'));
        }
    } catch (eArgRepair) { api.v1.error('[AE:migrate] arg-type repair error:', eArgRepair); }

    // [v0.9.24 E1] Remove deprecated token-interval fields from old saves
    delete (c as any).thoughtIntervalTokens;
    delete (c as any).dynamicIntervalTokens;
    delete (c as any).arcIntervalTokens;
    delete (c as any).hookIntervalTokens;
    // Ensure gen-interval fields exist (new saves via makeDefaultConfig will have them)
    if (!c.thoughtIntervalGens) c.thoughtIntervalGens = 2;
    if (!c.dynamicIntervalGens) c.dynamicIntervalGens = 4;
    if (!c.arcIntervalGens)     c.arcIntervalGens     = 10;
    if (!c.hookIntervalGens)    c.hookIntervalGens    = 6;
    if (c.maxDynamicCharacters === undefined) c.maxDynamicCharacters = 0;  // [vNEXT] no cap by default
    if (c.totalGenerations === undefined) c.totalGenerations = 0;
    if (c.defaultBackgroundUrl === undefined) c.defaultBackgroundUrl = ''; // [v0.9.40]
    if (!c.contextTemplates) c.contextTemplates = JSON.parse(JSON.stringify(DEFAULT_TEMPLATES));
    if (typeof (c as any).interfaceMode !== 'string') (c as any).interfaceMode = 'native';  // [v0.9.9.6]
    // [v0.9.8.4] Upgrade context templates left at the previous default to the new
    // narrative-block standard. User-customised templates are left untouched.
    if (c.contextTemplates) {
        let ctUpgradeKeys = ['location', 'trackedNarrative', 'player', 'npc'];
        for (let ctK of ctUpgradeKeys) {
            if ((c.contextTemplates as any)[ctK] === OLD_DEFAULT_TEMPLATES_V0982[ctK]) {
                (c.contextTemplates as any)[ctK] = (DEFAULT_TEMPLATES as any)[ctK];
            }
        }
    }

    // Setup global system templates
    if (!c.actionTemplates) c.actionTemplates = [];
    if (!(c as any).npcArchetypes) (c as any).npcArchetypes = [];   // [vNEXT] Bestiary
    if (!c.actionTemplates.some(function(t) { return t.id === 'sys_default_travel'; })) {
        c.actionTemplates.unshift(JSON.parse(JSON.stringify(SYS_DEFAULT_TRAVEL)));
    }
    // [v0.9.21 E4] Seed return travel template alongside default travel.
    if (!c.actionTemplates.some(function(t) { return t.id === 'sys_return_travel'; })) {
        c.actionTemplates.unshift(JSON.parse(JSON.stringify(SYS_RETURN_TRAVEL)));
    }
    // [v0.9.82] Seed tier travel templates (tier1 / tier2). Deeper uses sys_default_travel.
    if (!c.actionTemplates.some(function(t) { return t.id === 'sys_travel_tier1'; })) {
        c.actionTemplates.push(JSON.parse(JSON.stringify(SYS_TRAVEL_TIER1)));
    }
    if (!c.actionTemplates.some(function(t) { return t.id === 'sys_travel_tier2'; })) {
        c.actionTemplates.push(JSON.parse(JSON.stringify(SYS_TRAVEL_TIER2)));
    }
    // [v0.9.67] Seed the default resolution (Stakes) template — visible & editable.
    if (!c.actionTemplates.some(function(t) { return t.id === 'sys_default_resolution'; })) {
        c.actionTemplates.push(JSON.parse(JSON.stringify(SYS_DEFAULT_RESOLUTION)));
    }
    // [v0.9.69] Seed the configurable character-resource template (gold/luck/health). Inert
    // until a character is created or the new Worldbuilding section's Sync button is used.
    if (!c.characterResourceDefs) {
        c.characterResourceDefs = JSON.parse(JSON.stringify(DEFAULT_CHAR_RESOURCES));
    }
    // [v0.9.89] Migrate #gold → #currency in characterResourceDefs and stakeDefs.
    // Also add #attitude and #currency to characterResourceDefs if absent (new installs
    // already get them via DEFAULT_CHAR_RESOURCES; this covers existing saves).
    if (Array.isArray(c.characterResourceDefs)) {
        c.characterResourceDefs = c.characterResourceDefs.map(function(r: any) {
            if (r.tag === '#gold') { return { ...r, id: 'cres_currency', name: r.name === 'Wealth' ? 'Currency' : r.name, tag: '#currency' }; }
            return r;
        });
        if (!c.characterResourceDefs.some(function(r: any) { return r.tag === '#currency'; })) {
            c.characterResourceDefs.push({ id: 'cres_currency', name: 'Currency', tag: '#currency', type: 'pool', hasBounds: true, min: 0, max: 9999 });
        }
        if (!c.characterResourceDefs.some(function(r: any) { return r.tag === '#attitude'; })) {
            c.characterResourceDefs.push({ id: 'cres_attitude', name: 'Attitude', tag: '#attitude', type: 'track', hasBounds: true, states: ['Hostile', 'Unfriendly', 'Neutral', 'Friendly', 'Devoted'] });
        }
    }
    if (Array.isArray(c.stakeDefs)) {
        c.stakeDefs = c.stakeDefs.map(function(s: any) {
            function _migTag(t: string) { return t === '#gold' ? '#currency' : t; }
            return { ...s,
                id: s.id === 'stake_gold' ? 'stake_currency' : s.id,
                name: s.name === 'Gold' ? 'Currency' : s.name,
                strong:  s.strong  ? { ...s.strong,  player: { ...s.strong.player,  tag: _migTag(s.strong.player.tag)  }, target: { ...s.strong.target,  tag: _migTag(s.strong.target.tag)  } } : s.strong,
                partial: s.partial ? { ...s.partial, player: { ...s.partial.player, tag: _migTag(s.partial.player.tag) }, target: { ...s.partial.target, tag: _migTag(s.partial.target.tag) } } : s.partial,
                miss:    s.miss    ? { ...s.miss,    player: { ...s.miss.player,    tag: _migTag(s.miss.player.tag)    }, target: { ...s.miss.target,    tag: _migTag(s.miss.target.tag)    } } : s.miss
            };
        });
    }

    // [v0.9.89] Seed default library action templates — common patterns that demonstrate
    // the action system. Idempotent: guarded by stable id, never re-added after first seed.
    var _defLibActions: ActionInstance[] = [
        // ── Pick Up ──────────────────────────────────────────────────────────────
        // Player picks up a loose item in the current room (not owned by another character).
        {
            id: 'lib_pick_up', name: 'Pick Up', tags: ['player'], silent: true,
            appliesTo: [],
            targetMode: 'player_pick', targetFilter: ['item'],
            conditions: [
                { id: 'lib_pu_c1', type: 'entity_parent', args: { scope: '__target__', parentId: '__current_room__' } }
            ],
            resolution: undefined,
            successEffects: [
                { id: 'lib_pu_e1', type: 'set_entity_parent', args: { scope: '__target__', parentId: '__player__' } }
            ],
            failureEffects: [], alwaysEffects: []
        } as ActionInstance,
        // ── Give ─────────────────────────────────────────────────────────────────
        // Player gives one of their own items to any target (character, room, etc).
        {
            id: 'lib_give', name: 'Give', tags: ['player'], silent: true,
            appliesTo: [],
            targetMode: 'player_pick', targetFilter: ['item'],
            conditions: [
                { id: 'lib_gv_c1', type: 'entity_parent', args: { scope: '__target__', parentId: '__player__' } }
            ],
            resolution: undefined,
            successEffects: [
                { id: 'lib_gv_e1', type: 'set_entity_parent', args: { scope: '__target__', parentId: '__ask__' } }
            ],
            failureEffects: [], alwaysEffects: []
        } as ActionInstance,
        // ── Drop ─────────────────────────────────────────────────────────────────
        // Player drops one of their own items to the current room. No runtime prompt.
        {
            id: 'lib_drop', name: 'Drop', tags: ['player'], silent: true,
            appliesTo: [],
            targetMode: 'player_pick', targetFilter: ['item'],
            conditions: [
                { id: 'lib_dr_c1', type: 'entity_parent', args: { scope: '__target__', parentId: '__player__' } }
            ],
            resolution: undefined,
            successEffects: [
                { id: 'lib_dr_e1', type: 'set_entity_parent', args: { scope: '__target__', parentId: '__current_room__' } }
            ],
            failureEffects: [], alwaysEffects: []
        } as ActionInstance,
        // ── Purchase ─────────────────────────────────────────────────────────────
        // Player buys an item from a vendor. Requires ≥1 #currency; costs 1 on success.
        // Attach to the vendor entity. Item must be a direct child of that vendor entity.
        {
            id: 'lib_purchase', name: 'Purchase', tags: ['vendor'], silent: true,
            appliesTo: [],
            targetMode: 'player_pick', targetFilter: ['item'],
            conditions: [
                { id: 'lib_pu2_c1', type: 'char_resource', args: { scope: '__player__', tag: '#currency', op: '>=', amount: 1 } }
            ],
            resolution: undefined,
            successEffects: [
                { id: 'lib_pu2_e1', type: 'set_entity_parent',      args: { scope: '__target__',   parentId: '__player__' } },
                { id: 'lib_pu2_e2', type: 'modify_char_resource',   args: { scope: '__player__',   tag: '#currency', op: 'subtract', amount: 1 } }
            ],
            failureEffects: [], alwaysEffects: []
        } as ActionInstance,
        // ── Sleep ─────────────────────────────────────────────────────────────────
        // Resets health and luck to full; resets Time of Day to Morning.
        // Uses op:'set' with amount:999 for pools (clamped to max) and
        // amount:999 for tracks (clamped to highest state index = best state).
        // Attach to player or a bed/rest-point entity.
        {
            id: 'lib_sleep', name: 'Sleep', tags: ['player', 'rest'], silent: false,
            appliesTo: [],
            targetMode: 'none',
            conditions: [],
            resolution: undefined,
            successEffects: [
                { id: 'lib_sl_e1', type: 'modify_char_resource', args: { scope: '__player__', tag: '#health',   op: 'set', amount: 999 } },
                { id: 'lib_sl_e2', type: 'modify_char_resource', args: { scope: '__player__', tag: '#luck',     op: 'set', amount: 999 } },
                { id: 'lib_sl_e3', type: 'modify_resource',      args: { tag: '#time', op: 'set', amount: 0 } }
            ],
            failureEffects: [], alwaysEffects: []
        } as ActionInstance
    ];
    for (var _dli = 0; _dli < _defLibActions.length; _dli++) {
        var _dla = _defLibActions[_dli];
        if (!c.actionTemplates.some(function(t: any) { return t.id === _dla.id; })) {
            c.actionTemplates.push(JSON.parse(JSON.stringify(_dla)));
        }
    }
    // [v0.9.82] Seed per-tier travel defaults (top-level / sub-location / deeper).
    if (!c.tierTravelDefaults) {
        c.tierTravelDefaults = JSON.parse(JSON.stringify(DEFAULT_TIER_TRAVEL));
    }
    // [vNEXT] Seed the default Stakes library.
    if (!c.stakeDefs) {
        c.stakeDefs = JSON.parse(JSON.stringify(DEFAULT_STAKE_DEFS));
    }
    // [vNEXT] Seed the World-Build Wizard's Memory section list and concept fields.
    if (!c.wizardSections) {
        c.wizardSections = JSON.parse(JSON.stringify(DEFAULT_WIZARD_SECTIONS));
    }
    if (c.projectName === undefined) c.projectName = '';
    if (c.projectGenre === undefined) c.projectGenre = '';
    if (c.projectConcept === undefined) c.projectConcept = '';

    // [v0.9.9.2] Time & Calendar backfill.
    if (c.timeAutoAdvanceEnabled === undefined) c.timeAutoAdvanceEnabled = false;
    if (c.timeAdvanceHours === undefined || !(Number(c.timeAdvanceHours) > 0)) c.timeAdvanceHours = 1;
    if (c.timeAdvanceEveryGens === undefined || !(Number(c.timeAdvanceEveryGens) > 0)) c.timeAdvanceEveryGens = 3;
    if (c.timeStartHours === undefined) c.timeStartHours = 8;
    if (c.timeShowInAN === undefined) c.timeShowInAN = true;
    if (!Array.isArray(c.timeBands) || c.timeBands.length === 0) c.timeBands = JSON.parse(JSON.stringify(DEFAULT_TIME_BANDS));
    if (!Array.isArray(c.timeDayNames)) c.timeDayNames = [];
    if (!Array.isArray(c.timeWeekNames)) c.timeWeekNames = [];

    return c as GlobalConfig;
}

async function loadConfig(): Promise<GlobalConfig> {
    const raw = await api.v1.storyStorage.getOrDefault(STORAGE_CONFIG, null);
    // [v0.9.37 SEED1] Run migrateConfig on the DEFAULT too, so a brand-new story is
    // seeded with sys_default_travel / sys_return_travel. Previously makeDefaultConfig
    // bypassed migrateConfig, leaving fresh stories with no travel templates until the
    // action editor happened to save a config -> travel silently did nothing.
    return migrateConfig(raw ? raw : makeDefaultConfig());
}

async function saveConfig(cfg: GlobalConfig): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_CONFIG, cfg);
}

// ── Relationship archetype helpers ──────────────────────────────────────────
function findArchetypeDef(cfg: GlobalConfig, rel: PrimaryRelationship | undefined): RelationshipArchetypeDef | null {
    if (!rel) return null;
    let defs = (cfg.relationshipArchetypes || []) as RelationshipArchetypeDef[];
    // Prefer explicit ID; fall back to name match (lazy migration for old saves).
    if (rel.archetypeId) {
        let byId = defs.find(function(d) { return d.id === rel.archetypeId; });
        if (byId) return byId;
    }
    if (rel.archetype) {
        let byName = defs.find(function(d) { return d.name.toLowerCase() === String(rel.archetype).toLowerCase(); });
        if (byName) return byName;
    }
    return null;
}

// Returns the current stage label for a relationship, or '' if no stages defined.
function resolveArchetypeStage(cfg: GlobalConfig, rel: PrimaryRelationship | undefined): string {
    let def = findArchetypeDef(cfg, rel);
    if (!def || !def.stages || !def.stages.length) return '';
    let idx = (rel && typeof rel.stageIndex === 'number') ? rel.stageIndex : 0;
    idx = Math.max(0, Math.min(def.stages.length - 1, idx));
    return def.stages[idx] || '';
}

// ── Unified search picker ───────────────────────────────────────────────────
// Any picker with potentially >5 options should use this. Renders a live search
// box that re-filters as the user types. items: { id, label }[]. onSelect gets the
// chosen id. Auto-omits the search box when there are 5 or fewer items.
interface PickItem { id: string; label: string; selected?: boolean; }
async function openSearchPicker(title: string, items: PickItem[], onSelect: (id: string) => Promise<void>, extraTop?: UIPart[]): Promise<void> {
    let searchKey = 'temp:ce_uipick_' + title.toLowerCase().replace(/[^a-z0-9]+/g, '_').slice(0, 24);
    await api.v1.tempStorage.set(searchKey, '');
    let showSearch = items.length > 5;
    let pmP: any = null;
    async function draw() {
        let term = ((await api.v1.tempStorage.getOrDefault(searchKey, '')) as string).toLowerCase();
        let filtered = (showSearch && term) ? items.filter(function(it) { return it.label.toLowerCase().includes(term); }) : items;
        let content: UIPart[] = [];
        if (extraTop && extraTop.length) { for (const e of extraTop) content.push(e); }
        if (showSearch) {
            content.push({ type: 'textInput', placeholder: '\ud83d\udd0d Search\u2026', initialValue: term, onChange: async function(v: string) { await api.v1.tempStorage.set(searchKey, v); await draw(); } } as UIPart);
        }
        for (const it of filtered) {
            content.push({ type: 'button', text: it.label, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: it.selected ? 'rgba(126,200,160,0.2)' : 'rgba(255,255,255,0.02)', color: it.selected ? '#7ec8a0' : undefined }, callback: async function() { if (pmP) pmP.close(); await onSelect(it.id); } } as UIPart);
        }
        if (!filtered.length) content.push({ type: 'text', text: 'No matches.', style: { fontSize: '11px', opacity: '0.5' } } as UIPart);
        if (pmP && !pmP.isClosed()) { await pmP.update({ content: content }); }
        else { pmP = await openEngineModal({ id: 'ce-search-picker', title: title, size: 'small', content: content }); }
    }
    await draw();
}


// ============================================================================
// SECTION 8 — STORAGE: PARTY STATE, NPC WEB, QUICK ACTION PRESETS
// Three independent storyStorage records that don't fit in the character or
// entity systems but are story-persistent.
// ============================================================================

// ── Party State ───────────────────────────────────────────────────────────────
// Global resource values (wealth, health track, time of day, etc.) and faction
// relationship standings. Player-level, not character-level.

async function loadPartyState(): Promise<PartyState> {
    const raw = await api.v1.storyStorage.getOrDefault(STORAGE_PARTY, null) as any;
    if (!raw) return { resourceValues: {}, factionRelationships: {} };
    if (!raw.factionRelationships) raw.factionRelationships = {};
    return raw as PartyState;
}

async function savePartyState(state: PartyState): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_PARTY, state);
}

// ── Time & Calendar ──────────────────────────────────────────────────────
// [v0.9.9.2] The world clock. clockHours is absolute whole hours since campaign
// start; the 28-day calendar (4 weeks x 7 days) is a looped VIEW derived from it,
// while the underlying counter climbs forever (so countdowns are just T - now).
// ClockState lives in HISTORY storage, so an undo rewinds BOTH the hour count and
// the gensSinceTick cadence counter to the ancestor node's values - replaying
// forward reproduces the identical clock. Reading never writes; the first advance
// persists the state. No behavioural wiring lives here (conditions, effects, AN,
// auto-advance, and UI consume these helpers elsewhere).

function clockStartHours(cfg: GlobalConfig): number {
    let s = (cfg && cfg.timeStartHours !== undefined) ? Number(cfg.timeStartHours) : 8;
    if (isNaN(s)) s = 8;
    return Math.max(0, Math.min(23, Math.floor(s)));
}

async function loadClock(cfg?: GlobalConfig): Promise<ClockState> {
    let raw = await api.v1.historyStorage.getOrDefault(STORAGE_CLOCK, null) as any;
    if (raw && typeof raw.hours === 'number') {
        return { hours: Number(raw.hours) || 0, gensSinceTick: Number(raw.gensSinceTick) || 0 };
    }
    let seedCfg = cfg ? cfg : await loadConfig();
    return { hours: clockStartHours(seedCfg), gensSinceTick: 0 };
}

async function saveClock(state: ClockState): Promise<void> {
    let safe: ClockState = { hours: Math.max(0, Math.floor(Number(state.hours) || 0)), gensSinceTick: Math.max(0, Math.floor(Number(state.gensSinceTick) || 0)) };
    await api.v1.historyStorage.set(STORAGE_CLOCK, safe);
}

// [v0.9.9.2] Shared clock-mutation path used by the bridge time messages AND the
// native calendar modal. Sets the absolute hour, then re-resolves schedules and
// fires time-gated auto-triggers so a manual change behaves like a turn passing.
// Returns the formatted stamp, or null if the engine was busy / input invalid.
async function applyClockChange(absHours: number): Promise<string | null> {
    if (ae_lock) { try { api.v1.ui.toast('Engine processing - try again in a moment.', { type: 'info', autoClose: 2500 }); } catch (e0) {} return null; }
    if (isNaN(absHours)) return null;
    try {
        let accCfg = await loadConfig();
        let accClk = await loadClock(accCfg);
        accClk.hours = Math.max(0, Math.floor(absHours));
        await saveClock(accClk);
        await resolveSchedules();
        await runAutoTriggers();
        await recalculateScenePresence();
        await refreshSidebar();
        await broadcastSceneState();
        let stamp = clockFormatStamp(accClk.hours, accCfg);
        try { api.v1.ui.toast(stamp, { type: 'info', autoClose: 2000 }); } catch (eT) {}
        return stamp;
    } catch (e) { api.v1.error('[AE] applyClockChange error:', e); return null; }
}

// Pure derivations from the absolute hour counter.
function clockHourOfDay(hours: number): number { return ((Math.floor(hours) % 24) + 24) % 24; }
function clockAbsoluteDay(hours: number): number { return Math.floor(Math.floor(hours) / 24); }
function clockDayOfCycle(hours: number): number { return ((clockAbsoluteDay(hours) % 28) + 28) % 28 + 1; }   // 1-28
function clockWeek(hours: number): number { return Math.floor((clockDayOfCycle(hours) - 1) / 7) + 1; }        // 1-4
function clockDayOfWeek(hours: number): number { return ((clockDayOfCycle(hours) - 1) % 7) + 1; }             // 1-7

// Which named band contains an hour-of-day. A band with startHour > endHour wraps
// past midnight; endHour is exclusive. Returns '' if no band matches.
function clockBandFor(hour: number, bands: TimeBandDef[]): string {
    let h = ((Math.floor(hour) % 24) + 24) % 24;
    for (let i = 0; i < (bands || []).length; i++) {
        let b = bands[i];
        if (!b) continue;
        let s = Math.floor(b.startHour);
        let e = Math.floor(b.endHour);
        let inBand = (s <= e) ? (h >= s && h < e) : (h >= s || h < e);
        if (inBand) return b.label || '';
    }
    return '';
}

// '07:00' - always on the hour (whole-hour clock).
function clockFormatHour(hour: number): string {
    let h = ((Math.floor(hour) % 24) + 24) % 24;
    return (h < 10 ? '0' + h : '' + h) + ':00';
}

// Human label for the current day, honouring optional custom weekday names.
function clockDayLabel(hours: number, cfg: GlobalConfig): string {
    let dow = clockDayOfWeek(hours);
    let names = (cfg && Array.isArray(cfg.timeDayNames)) ? cfg.timeDayNames : [];
    let custom = names[dow - 1];
    return (custom && String(custom).trim()) ? String(custom).trim() : ('Day ' + clockDayOfCycle(hours));
}

// Human label for the current week, honouring optional custom week names.
function clockWeekLabel(hours: number, cfg: GlobalConfig): string {
    let wk = clockWeek(hours);
    let names = (cfg && Array.isArray(cfg.timeWeekNames)) ? cfg.timeWeekNames : [];
    let custom = names[wk - 1];
    return (custom && String(custom).trim()) ? String(custom).trim() : ('Week ' + wk);
}

// Full one-line stamp, e.g. 'Week 2, Day 12 - 07:00 (Morning)'.
function clockFormatStamp(hours: number, cfg: GlobalConfig): string {
    let band = clockBandFor(clockHourOfDay(hours), (cfg && cfg.timeBands) ? cfg.timeBands : []);
    let core = clockWeekLabel(hours, cfg) + ', ' + clockDayLabel(hours, cfg) + ' - ' + clockFormatHour(clockHourOfDay(hours));
    return band ? (core + ' (' + band + ')') : core;
}

// ── NPC Web ───────────────────────────────────────────────────────────────────
// The bilateral dynamic relationship graph between NPCs (WebLink[]).
// Stored as a JSON string because it can grow large and benefits from direct
// string serialization rather than NAI's object storage path.

async function loadNpcWeb(): Promise<WebLink[]> {
    const raw = await api.v1.storyStorage.get(STORAGE_NPC_WEB) as string;
    try { return raw ? JSON.parse(raw) : []; } catch { return []; }
}

async function saveNpcWeb(web: WebLink[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_NPC_WEB, JSON.stringify(web));
}

// ── Quick Instance Presets ──────────────────────────────────────────────────────

// [WP-5] New-system Quick Actions: simplified, player-authored from the HUD.
// Default dice only, optional in-scene target, a prompt inserted with the action.
interface QuickInstance { id: string; name: string; prompt: string; targetId?: string | null; }
async function loadQuickInstances(): Promise<QuickInstance[]> {
    return await api.v1.storyStorage.getOrDefault('ae_quick_instances', []) as QuickInstance[];
}
async function saveQuickInstances(list: QuickInstance[]): Promise<void> {
    await api.v1.storyStorage.set('ae_quick_instances', list);
}

// [v0.9.8.6] Single source of truth for the Story/Silent action mode. Silent =
// actions run without injecting story text. Stored in tempStorage (session-scoped).
async function getSilentMode(): Promise<boolean> {
    return await api.v1.tempStorage.getOrDefault('ae_silent_mode', false) as boolean;
}
async function setSilentMode(value: boolean): Promise<void> {
    await api.v1.tempStorage.set('ae_silent_mode', !!value).catch(function() {});
}


// ============================================================================
// SECTION 9 — STORAGE: IMAGE SETTINGS
// Image generation presets and global image settings.
// Stored in api.v1.storage (global, not story-bound) so they persist across
// stories without being part of the adventure module export.
// ============================================================================

// NOTE FOR ASSEMBLY: EVT_PRESET_SYNC = 'PRESET_SYNC' was missed from Section 2
// and should be added to the Bridge Event Name Constants block there.
// Used by saveImageSettings() below.

function generateDefaultPresets(): ImagePreset[] {
    // Creates a fresh set of 5 presets. Index 0 is pre-filled with sensible defaults;
    // slots 1–4 start blank for user customisation.
    return Array.from({ length: 5 }, function(_, i): ImagePreset {
        return {
            width: 832, height: 1216,
            steps: 28, scale: 5.0,
            qualityTags:  i === 0 ? 'masterpiece, best quality, detailed' : '',
            negativeTags: i === 0 ? 'lowres, bad anatomy, worst quality, text, watermark, signature' : ''
        };
    });
}

async function loadImageSettings(): Promise<void> {
    // [CHANGE] Renamed from loadSettings() to clarify scope.
    // [CHANGE] Removed tempStorage mirroring (the 20 img_p*_steps/scale/etc. writes).
    //   Those keys only fed the now-removed AI engine NAI modal. Settings live
    //   in-memory (profiles[], activeIndex, globalSettings) for the engine and
    //   are broadcast to the bridge via saveImageSettings() → PRESET_SYNC.
    // [CHANGE] Removed cachedCharConfigs load from old STORAGE_KEY_CHAR_CONFIGS key.
    //   Character visual data is now seeded by buildCharacterDataPayload() in
    //   onScriptsLoaded (Section 27) and kept current by saveCharacter() calls.

    const sp = await api.v1.storage.get(STORAGE_KEY_PROFILES);
    profiles = Array.isArray(sp) ? sp : generateDefaultPresets();
    // Ensure exactly 5 preset slots exist (pad if old save had fewer)
    while (profiles.length < 5) profiles.push(generateDefaultPresets()[0]);
    profiles.length = 5;

    activeIndex = ((await api.v1.storage.get(STORAGE_KEY_ACTIVE)) as number); if (activeIndex === null || activeIndex === undefined) activeIndex = 0;
    if (activeIndex < 0 || activeIndex > 4) activeIndex = 0;

    const sg = await api.v1.storage.get(STORAGE_KEY_GLOBAL);
    if (sg) globalSettings = Object.assign({}, globalSettings, sg);

    // Guard every globalSettings field so partial saves from older versions work
    if (globalSettings.contextSize        === undefined) globalSettings.contextSize        = DEFAULT_CTX;
    if (!globalSettings.architectPrompt)                  globalSettings.architectPrompt   = DEFAULT_ARCH;
    if (globalSettings.architectAutoSnap   === undefined) globalSettings.architectAutoSnap   = true;
    if (globalSettings.autoDownload        === undefined) globalSettings.autoDownload        = false;
}

async function saveImageSettings(): Promise<void> {
    // [CHANGE] Renamed from saveSettings() to clarify scope.
    await api.v1.storage.set(STORAGE_KEY_PROFILES, profiles);
    await api.v1.storage.set(STORAGE_KEY_ACTIVE,   activeIndex);
    await api.v1.storage.set(STORAGE_KEY_GLOBAL,   globalSettings);

    // Keep bridge in sync with the active preset so avatar/image generation
    // picks up quality tag and dimension changes immediately.
    if (isBridgeReady) {
        try {
            await broadcastToTM('PRESET_SYNC', { preset: getActivePresetData() });
        } catch (e) { api.v1.error('[AE] saveImageSettings: PRESET_SYNC failed:', e); }
    }
}

function getActivePresetData(): Partial<ImagePreset> {
    // Returns the fields used by bridge image generation (quality/negative tags,
    // steps, scale). Width/height come from the full preset accessed by index.
    const p = profiles[activeIndex] || {} as any;
    return {
        qualityTags:  p.qualityTags  || '',
        negativeTags: p.negativeTags || '',
        steps:        p.steps        || 28,
        scale:        p.scale        || 5.0
    };
}

async function restoreImageDefaults(): Promise<void> {
    // [CHANGE] Renamed from restoreDefaults() to clarify scope.
    // [CHANGE] Simplified: removed modal.close() and renderModal() calls since
    //   the Director's Cut NAI modal no longer exists. Settings live in the
    //   AE config modal (Section 22) which uses its own refresh pattern.
    globalSettings.contextSize     = DEFAULT_CTX;
    globalSettings.architectPrompt = DEFAULT_ARCH;
    await saveImageSettings();
    api.v1.ui.toast('🔄 Image defaults restored.');
}
// ============================================================================
// SECTION 10 — LOREBOOK HELPERS
// Functions that build, create, and sync NAI lorebook entries for characters,
// factions, and species. Lorebook entries are how static character profiles
// get injected into context via NAI's native keyword-matching system.
//
// PATTERN NOTE: All three record types (character, faction, species) share an
// identical four-function family: getKeys / buildContent / createLinked / sync.
// This is a future candidate for a generalized syncLorebookRecord<T>(spec) helper
// once the refactor stabilizes. Not changing now — the calls are simple enough
// that the abstraction would add indirection without immediate benefit.
// ============================================================================

// ── Character Lorebook ────────────────────────────────────────────────────────

function getLorebookKeys(char: CharacterRecord): string[] {
    // Returns the name + all nicknames as lorebook trigger keys.
    return [char.name, ...char.nicknames.filter(Boolean)].filter(Boolean);
}

async function buildLorebookContent(char: CharacterRecord): Promise<string> {
    // Assembles the lorebook entry text from a character's static fields.
    // showFieldHeaders controls whether field labels are prepended.
    // This is the single authoritative builder — used by both create and sync.
    const cfg = await loadConfig();
    const showHeaders = cfg.showFieldHeaders;
    const lines: string[] = [];

    function addField(label: string, value: string | undefined | null) {
        if (!value || value.trim() === '') return;
        lines.push(showHeaders ? `${label}: ${value.trim()}` : value.trim());
    }

    // [v0.9.8.5] Identity line — collapsed from five separate Name/Age/Species/
    // Gender/Role fields into a single dossier header, e.g. "Gareth — human male,
    // 34, blacksmith". Header-agnostic by design (it reads as a header itself).
    let idLeader = [char.species, char.gender].map(function(s) { return (s || '').trim(); }).filter(Boolean).join(' ');
    let idMid = [idLeader, (char.age || '').trim(), (char.occupationRole || '').trim()].filter(Boolean).join(', ');
    let identityLine = (char.name || '').trim();
    if (identityLine && idMid) identityLine += ' \u2014 ' + idMid;
    else if (!identityLine && idMid) identityLine = idMid;
    if (identityLine) lines.push(identityLine);

    // Core static fields — label keys are customisable via cfg.fieldLabels
    addField(cfg.fieldLabels['physicalDescription'] || 'Physical Description', char.physicalDescription);
    addField(cfg.fieldLabels['personalityCore']     || 'Personality Core',     char.personalityCore);
    addField(cfg.fieldLabels['voiceAndMannerisms']  || 'Voice & Mannerisms',   char.voiceAndMannerisms);
    addField(cfg.fieldLabels['background']          || 'Background',           char.background);

    // Core values
    if (char.coreValues && char.coreValues.length > 0) {
        addField('Core Values', char.coreValues.filter(Boolean).join(', '));
    }

    // Author-defined custom static fields
    if (cfg.customStaticFields && char.customFieldValues) {
        for (const cf of cfg.customStaticFields) {
            addField(cf.label, char.customFieldValues[cf.id]);
        }
    }

    // [v0.9.8.5] Equipment no longer rides the permanent lorebook entry. It is
    // emitted per-generation as an ephemeral temporaryLorebookEntry by
    // buildSceneLorebookActivation(), so the static entry stays content-stable
    // (cache-friendly) and equip/unequip no longer triggers a lorebook re-sync.
    return lines.join('\n');
}

async function createLinkedLorebookEntry(charId: string, silent?: boolean): Promise<void> {
    const char = await loadCharacter(charId);
    if (!char) return;
    try {
        const content  = await buildLorebookContent(char);
        const keys     = getLorebookKeys(char);
        const entryId  = await api.v1.lorebook.createEntry({ displayName: char.name, text: content, keys, enabled: true });
        char.lorebookEntryId = entryId;
        await saveCharacter(char);
        if (!silent) api.v1.ui.toast(`Lorebook entry created for ${char.name}.`, { type: 'success' });
    } catch (e) {
        if (!silent) api.v1.ui.toast('Failed to create lorebook entry.', { type: 'error' });
        if (silent) throw e;
    }
}

async function syncLorebookEntry(charId: string, silent?: boolean): Promise<void> {
    const char = await loadCharacter(charId);
    if (!char?.lorebookEntryId) return;
    try {
        const content = await buildLorebookContent(char);
        await api.v1.lorebook.updateEntry(char.lorebookEntryId, {
            text: content,
            keys: getLorebookKeys(char),
            displayName: char.name
        });
        if (!silent) api.v1.ui.toast('Lorebook entry synced.', { type: 'success' });
    } catch (e) {
        api.v1.error('[AE] syncLorebookEntry:', e);
        if (!silent) api.v1.ui.toast('Failed to sync lorebook entry.', { type: 'error' });
    }
}

// [v0.9.8.5] Builds the per-generation lorebook activation package for the current
// scene. For every active, scene-present character (and the protagonist):
//   - permanent entry present  -> force-activate it ([id, {active:true}])
//   - permanent entry absent    -> emit its static identity as an ephemeral temp
//                                  entry (no permanent lorebook needed, no regression)
//   - equipped items present    -> emit a separate ephemeral equipment temp entry
// Returned from onBeforeContextBuild so static identity lives in the lorebook block
// while the Author's Note carries only the dynamic layer.
async function buildSceneLorebookActivation(): Promise<{ lorebookEntries: any[]; temporaryLorebookEntries: any[] }> {
    const lorebookEntries: any[] = [];
    const temporaryLorebookEntries: any[] = [];
    try {
        const slaIdx = await loadIndex();
        for (const meta of slaIdx.filter(Boolean)) {
            if (!meta.active) continue;
            if (!meta.scenePresent && !meta.isProtagonist) continue;
            if ((meta as any).npcClass === 'minor') continue;   // [vNEXT] minors ride the combined entry below
            const slaChar = await loadCharacter(meta.id);
            if (!slaChar) continue;

            // Static identity: force-activate the permanent entry, or fall back to
            // an ephemeral temp entry so un-linked characters keep their context.
            if (slaChar.lorebookEntryId) {
                lorebookEntries.push([slaChar.lorebookEntryId, { active: true }]);
            } else {
                let slaStatic = await buildLorebookContent(slaChar);
                if (slaStatic.trim()) {
                    temporaryLorebookEntries.push({
                        id: 'ae_static_' + slaChar.id,
                        name: slaChar.name || 'Character',
                        content: slaStatic,
                        active: true,
                        appearWithPermanent: true
                    });
                }
            }

            // Equipment: ephemeral temp entry, rebuilt fresh each generation.
            if (slaChar.equippedItemIds && slaChar.equippedItemIds.length > 0) {
                const slaWorn: string[] = [];
                for (const slaItemId of slaChar.equippedItemIds) {
                    try {
                        let slaItem = await loadEntity(slaItemId);
                        if (!slaItem) continue;
                        let slaDetail = (slaItem.description || '').trim() || (slaItem.atmosphere || '').trim();
                        slaWorn.push(slaDetail ? (slaItem.name + ' (' + slaDetail + ')') : slaItem.name);
                    } catch (eSlaItem) { /* non-fatal: skip unreadable item */ }
                }
                if (slaWorn.length > 0) {
                    temporaryLorebookEntries.push({
                        id: 'ae_equip_' + slaChar.id,
                        name: (slaChar.name || 'Character') + ' Equipment',
                        content: (slaChar.name || 'They') + ' is wearing/carrying: ' + slaWorn.join(', ') + '.',
                        active: true,
                        appearWithPermanent: true
                    });
                }
            }
        }

        // [v1.6.3 LOC-LORE] Force-activate the player's CURRENT room's own dossier entry
        // the same way a scene-present character's entry is activated above. If the player
        // is in the Haunted House, the Haunted House's own lorebook entry activates. This
        // is immediate/single-location only — no ancestor walking up the location tree.
        try {
            const slaRoomId = await aeGetPlayerRoomId();
            if (slaRoomId) {
                const slaRoom = await loadEntity(slaRoomId);
                if (slaRoom && (slaRoom as any).lorebookEntryId) {
                    lorebookEntries.push([(slaRoom as any).lorebookEntryId, { active: true }]);
                }
            }
        } catch (eSlaLoc) { api.v1.error('[AE:context] current-location activation:', eSlaLoc); }

        // [vNEXT] Minor NPCs present in scene -> one combined ephemeral entry so the
        // model knows who else is here, without a permanent lorebook or dossier fields.
        const mnLines: string[] = [];
        for (const mnMeta of slaIdx.filter(Boolean)) {
            if ((mnMeta as any).npcClass !== 'minor') continue;
            if (!mnMeta.active || !mnMeta.scenePresent) continue;
            const mnChar = await loadCharacter(mnMeta.id);
            if (!mnChar) continue;
            const mnBrief = (mnChar.briefDescription || '').trim();
            if (!mnBrief) continue;   // engine tracks them; LLM only sees those with a brief
            let mnStatus: string[] = [];
            for (const mnDef of (mnChar.charResourceDefs || [])) {
                if (mnDef.type !== 'track' || !mnDef.states || mnDef.states.length === 0) continue;
                let mnCv = (mnChar.charResourceValues && typeof mnChar.charResourceValues[mnDef.id] === 'number') ? mnChar.charResourceValues[mnDef.id] : (mnDef.states.length - 1);
                if (mnCv < 0) mnCv = 0;
                if (mnCv > mnDef.states.length - 1) mnCv = mnDef.states.length - 1;
                if (mnCv < mnDef.states.length - 1) mnStatus.push(mnDef.states[mnCv]);   // surface only when not at best/top state
            }
            let mnSuffix = mnStatus.length > 0 ? ' (' + mnStatus.join(', ') + ')' : '';
            mnLines.push((mnChar.name || 'Someone') + ' \u2014 ' + mnBrief + mnSuffix);
        }
        if (mnLines.length > 0) {
            temporaryLorebookEntries.push({
                id: 'ae_minor_npcs',
                name: 'Others Present',
                content: 'Also present in the scene:\n' + mnLines.join('\n'),
                active: true,
                appearWithPermanent: true
            });
        }
    } catch (eSla) { api.v1.error('[AE:context] buildSceneLorebookActivation:', eSla); }
    return { lorebookEntries: lorebookEntries, temporaryLorebookEntries: temporaryLorebookEntries };
}

// ── Faction Lorebook ──────────────────────────────────────────────────────────

function getFactionLorebookKeys(faction: FactionDef): string[] {
    return [faction.name].concat(faction.lorebookTags || []).filter(Boolean);
}

function buildFactionLorebookContent(faction: FactionDef): string {
    const lines: string[] = [];
    if (faction.name) lines.push(faction.name);
    if (faction.description?.trim()) lines.push(faction.description.trim());
    if (faction.relationshipStates && faction.relationshipStates.length > 0) {
        lines.push(`Relationship standings: ${faction.relationshipStates.join(' → ')}`);
    }
    return lines.join('\n');
}

async function createLinkedFactionLorebookEntry(factionId: string, silent?: boolean): Promise<void> {
    const cfg  = await loadConfig();
    const fIdx = (cfg.factions || []).findIndex(function(f) { return f.id === factionId; });
    if (fIdx < 0) return;
    const faction = cfg.factions[fIdx];
    try {
        let catId = await ensureLorebookCategory('AE Factions');
        let entry: any = {
            displayName: faction.name,
            text: buildFactionLorebookContent(faction),
            keys: getFactionLorebookKeys(faction),
            enabled: true
        };
        if (catId) entry.category = catId;
        const entryId = await api.v1.lorebook.createEntry(entry);
        cfg.factions[fIdx].lorebookEntryId = entryId;
        await saveConfig(cfg);
        if (!silent) api.v1.ui.toast(`Lorebook entry created for ${faction.name}.`, { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to create faction lorebook entry.', { type: 'error' }); if (silent) throw e; }
}

async function syncFactionLorebookEntry(factionId: string, silent?: boolean): Promise<void> {
    const cfg     = await loadConfig();
    const faction = (cfg.factions || []).find(function(f) { return f.id === factionId; });
    if (!faction?.lorebookEntryId) return;
    try {
        await api.v1.lorebook.updateEntry(faction.lorebookEntryId, {
            text: buildFactionLorebookContent(faction),
            keys: getFactionLorebookKeys(faction),
            displayName: faction.name
        });
        if (!silent) api.v1.ui.toast('Faction lorebook synced.', { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to sync faction lorebook.', { type: 'error' }); if (silent) throw e; }
}

async function unlinkFactionLorebookEntry(factionId: string): Promise<void> {
    const cfg = await loadConfig();
    const fIdx = (cfg.factions || []).findIndex(function(f) { return f.id === factionId; });
    if (fIdx < 0) return;
    if (cfg.factions[fIdx].lorebookEntryId) {
        try { await api.v1.lorebook.removeEntry(cfg.factions[fIdx].lorebookEntryId!); } catch(e) {}
        cfg.factions[fIdx].lorebookEntryId = undefined;
        await saveConfig(cfg);
        api.v1.ui.toast('Faction lorebook unlinked.', { type: 'info' });
    }
}

// ── Species Lorebook ──────────────────────────────────────────────────────────

function getSpeciesLorebookKeys(sp: SpeciesDef): string[] {
    return [sp.name].concat(sp.lorebookTags || []).filter(Boolean);
}

function buildSpeciesLorebookContent(sp: SpeciesDef): string {
    const lines: string[] = [];
    if (sp.name) lines.push(sp.name);
    if (sp.description?.trim()) lines.push(sp.description.trim());
    return lines.join('\n');
}

async function createLinkedSpeciesLorebookEntry(speciesId: string, silent?: boolean): Promise<void> {
    const cfg  = await loadConfig();
    const sIdx = (cfg.species || []).findIndex(function(s) { return s.id === speciesId; });
    if (sIdx < 0) return;
    const sp = cfg.species[sIdx];
    try {
        let catId = await ensureLorebookCategory('AE Species');
        let entry: any = {
            displayName: sp.name,
            text: buildSpeciesLorebookContent(sp),
            keys: getSpeciesLorebookKeys(sp),
            enabled: true
        };
        if (catId) entry.category = catId;
        const entryId = await api.v1.lorebook.createEntry(entry);
        cfg.species[sIdx].lorebookEntryId = entryId;
        await saveConfig(cfg);
        if (!silent) api.v1.ui.toast(`Lorebook entry created for ${sp.name}.`, { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to create species lorebook entry.', { type: 'error' }); if (silent) throw e; }
}

async function syncSpeciesLorebookEntry(speciesId: string, silent?: boolean): Promise<void> {
    const cfg = await loadConfig();
    const sp  = (cfg.species || []).find(function(s) { return s.id === speciesId; });
    if (!sp?.lorebookEntryId) return;
    try {
        await api.v1.lorebook.updateEntry(sp.lorebookEntryId, {
            text: buildSpeciesLorebookContent(sp),
            keys: getSpeciesLorebookKeys(sp),
            displayName: sp.name
        });
        if (!silent) api.v1.ui.toast('Species lorebook synced.', { type: 'success' });
    } catch (e) { if (!silent) api.v1.ui.toast('Failed to sync species lorebook.', { type: 'error' }); if (silent) throw e; }
}

async function unlinkSpeciesLorebookEntry(speciesId: string): Promise<void> {
    const cfg = await loadConfig();
    const sIdx = (cfg.species || []).findIndex(function(s) { return s.id === speciesId; });
    if (sIdx < 0) return;
    if (cfg.species[sIdx].lorebookEntryId) {
        try { await api.v1.lorebook.removeEntry(cfg.species[sIdx].lorebookEntryId!); } catch(e) {}
        cfg.species[sIdx].lorebookEntryId = undefined;
        await saveConfig(cfg);
        api.v1.ui.toast('Species lorebook unlinked.', { type: 'info' });
    }
}
// ── Entity Lorebook (locations / items / narratives) ────────────────────────
// New in [WP-1]. Same getKeys/buildContent/create/sync family as the character
// lorebook above, but for world entities, filed under an "AE <Type>s" category.
// ensureLorebookCategory() is the shared find-or-create helper (reusable by the
// character/faction/species families on a later unification pass).

async function ensureLorebookCategory(name: string): Promise<string> {
    // Returns the id of the named lorebook category, creating it if absent.
    // Returns '' on failure — callers then create the entry uncategorised.
    try {
        let cats = await api.v1.lorebook.categories();
        let found = (cats || []).find(function(c) { return c.name === name; });
        if (found) return found.id;
        let newId = await api.v1.lorebook.createCategory({ id: api.v1.uuid(), name: name, enabled: true });
        return newId || '';
    } catch (e) { api.v1.error('[AE:lore] ensureLorebookCategory:', e); return ''; }
}

function entityLorebookCategoryName(ent: EntityRecord): string {
    if (ent.type === 'item')      return 'AE Items';
    if (ent.type === 'narrative') return 'AE Narratives';
    if (ent.type === 'character') return 'AE Characters';
    return 'AE Locations';
}

function getEntityLorebookKeys(ent: EntityRecord): string[] {
    // Entity name is always a key; lorebookTags add extra trigger words.
    return [ent.name].concat(ent.lorebookTags || []).filter(Boolean);
}

function buildEntityLorebookContent(ent: EntityRecord): string {
    // [WP-1] The dedicated extended-lore body, injected when a key (the entity
    // name or an added key) appears in the story. Deliberately NOT the
    // description/state — those already inject via the world-state block while
    // the player is present, so echoing them here would double them in context.
    return (ent.lorebookText || '').trim();
}

async function createLinkedEntityLorebookEntry(entId: string, silent?: boolean): Promise<void> {
    let ent = await loadEntity(entId);
    if (!ent) return;
    if (!(ent.lorebookText || '').trim()) { if (!silent) api.v1.ui.toast('Add Lorebook Entry text first, then create the entry.', { type: 'info' }); return; }
    try {
        let catId = await ensureLorebookCategory(entityLorebookCategoryName(ent));
        let entry: any = { id: api.v1.uuid(), displayName: ent.name, text: buildEntityLorebookContent(ent), keys: getEntityLorebookKeys(ent), enabled: true };
        if (catId) entry.category = catId;
        let newId = await api.v1.lorebook.createEntry(entry);
        ent.lorebookEntryId = newId;
        await saveEntity(ent);
        if (!silent) api.v1.ui.toast('Lorebook entry created for ' + ent.name + '.', { type: 'success' });
    } catch (e) {
        api.v1.error('[AE:lore] createLinkedEntityLorebookEntry:', e);
        if (!silent) api.v1.ui.toast('Failed to create lorebook entry.', { type: 'error' });
        if (silent) throw e;
    }
}

async function syncEntityLorebookEntry(entId: string, silent?: boolean): Promise<void> {
    let ent = await loadEntity(entId);
    if (!ent || !ent.lorebookEntryId) return;
    try {
        await api.v1.lorebook.updateEntry(ent.lorebookEntryId, { text: buildEntityLorebookContent(ent), keys: getEntityLorebookKeys(ent), displayName: ent.name });
        if (!silent) api.v1.ui.toast('Lorebook entry synced.', { type: 'success' });
    } catch (e) {
        api.v1.error('[AE:lore] syncEntityLorebookEntry:', e);
        if (!silent) api.v1.ui.toast('Failed to sync lorebook entry.', { type: 'error' });
    }
}

async function unlinkEntityLorebookEntry(entId: string): Promise<void> {
    let ent = await loadEntity(entId);
    if (!ent || !ent.lorebookEntryId) return;
    try { await api.v1.lorebook.removeEntry(ent.lorebookEntryId); }
    catch (e) { api.v1.error('[AE:lore] unlinkEntityLorebookEntry:', e); }
    ent.lorebookEntryId = undefined;
    await saveEntity(ent);
    api.v1.ui.toast('Lorebook entry unlinked.', { type: 'info' });
}

// ── Sync-All Lorebooks ──────────────────────────────────────────────────────
// [vNEXT] The individual sync helpers all early-return when a record has no
// lorebookEntryId, and none of them notice when a stored id points at an entry the
// user has since deleted in NAI. syncAllLorebooks fixes both: it never assumes an
// entry exists. It pulls the full live entry-id set ONCE (single API call), then per
// record decides create-vs-sync from that set in memory — so a run over the whole
// world costs one entries() call plus one update/create per record, no per-record
// existence probing. A record is (re)created when it has no id OR its id is stale
// (missing from the live set); otherwise it is synced. Returns per-type tallies.
//
// liveIds: pass the prebuilt Set so a single sync-all shares one snapshot across all
// four families. _ensure* helpers below are also individually callable.
async function _liveLorebookIdSet(): Promise<Set<string>> {
    let set = new Set<string>();
    try {
        let all = await api.v1.lorebook.entries();
        (all || []).forEach(function(e: any) { if (e && e.id) set.add(e.id); });
    } catch (e) { api.v1.error('[AE:lore] _liveLorebookIdSet:', e); }
    return set;
}

async function ensureCharacterLorebook(charId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let char = await loadCharacter(charId);
    if (!char) return 'skipped';
    let hasLive = !!(char.lorebookEntryId && liveIds.has(char.lorebookEntryId));
    if (hasLive) { await syncLorebookEntry(charId, true).catch(function() {}); return 'synced'; }
    // No id, or a stale id whose entry was deleted in NAI: clear + recreate.
    if (char.lorebookEntryId && !hasLive) { char.lorebookEntryId = undefined; await saveCharacter(char).catch(function() {}); }
    await createLinkedLorebookEntry(charId, true).catch(function() {});
    return 'created';
}

async function ensureFactionLorebook(factionId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let cfg = await loadConfig();
    let f = (cfg.factions || []).find(function(x) { return x.id === factionId; });
    if (!f) return 'skipped';
    let hasLive = !!(f.lorebookEntryId && liveIds.has(f.lorebookEntryId));
    if (hasLive) { await syncFactionLorebookEntry(factionId, true).catch(function() {}); return 'synced'; }
    if (f.lorebookEntryId && !hasLive) {
        // Clear the stale id before recreate so create doesn't leave a dangling ref.
        let cfg2 = await loadConfig();
        let f2i = (cfg2.factions || []).findIndex(function(x) { return x.id === factionId; });
        if (f2i >= 0) { cfg2.factions[f2i].lorebookEntryId = undefined; await saveConfig(cfg2).catch(function() {}); }
    }
    await createLinkedFactionLorebookEntry(factionId, true).catch(function() {});
    return 'created';
}

async function ensureSpeciesLorebook(speciesId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let cfg = await loadConfig();
    let s = (cfg.species || []).find(function(x) { return x.id === speciesId; });
    if (!s) return 'skipped';
    let hasLive = !!(s.lorebookEntryId && liveIds.has(s.lorebookEntryId));
    if (hasLive) { await syncSpeciesLorebookEntry(speciesId, true).catch(function() {}); return 'synced'; }
    if (s.lorebookEntryId && !hasLive) {
        let cfg2 = await loadConfig();
        let s2i = (cfg2.species || []).findIndex(function(x) { return x.id === speciesId; });
        if (s2i >= 0) { cfg2.species[s2i].lorebookEntryId = undefined; await saveConfig(cfg2).catch(function() {}); }
    }
    await createLinkedSpeciesLorebookEntry(speciesId, true).catch(function() {});
    return 'created';
}

async function ensureEntityLorebook(entId: string, liveIds: Set<string>): Promise<'created' | 'synced' | 'skipped'> {
    let ent = await loadEntity(entId);
    if (!ent) return 'skipped';
    // Entity entries only carry the dedicated extended-lore body; with none there is
    // nothing to store, so skip (matches createLinkedEntityLorebookEntry's own guard).
    if (!((ent as any).lorebookText || '').trim()) return 'skipped';
    let hasLive = !!(ent.lorebookEntryId && liveIds.has(ent.lorebookEntryId));
    if (hasLive) { await syncEntityLorebookEntry(entId, true).catch(function() {}); return 'synced'; }
    if (ent.lorebookEntryId && !hasLive) { ent.lorebookEntryId = undefined; await saveEntity(ent).catch(function() {}); }
    await createLinkedEntityLorebookEntry(entId, true).catch(function() {});
    return 'created';
}

interface SyncAllTally { created: number; synced: number; skipped: number; }
async function syncAllLorebooks(): Promise<{ characters: SyncAllTally; locations: SyncAllTally; species: SyncAllTally; factions: SyncAllTally }> {
    let mk = function(): SyncAllTally { return { created: 0, synced: 0, skipped: 0 }; };
    let out = { characters: mk(), locations: mk(), species: mk(), factions: mk() };
    let bump = function(t: SyncAllTally, r: 'created' | 'synced' | 'skipped') { if (r === 'created') t.created++; else if (r === 'synced') t.synced++; else t.skipped++; };

    // One live snapshot shared by every family — the only lorebook read of the run.
    let liveIds = await _liveLorebookIdSet();

    try {
        // Characters (from the lightweight index; skip minor NPCs — they ride the
        // combined scene entry, not individual permanent entries).
        let cIdx = await loadIndex();
        for (let m of cIdx.filter(Boolean)) {
            if ((m as any).npcClass === 'minor') { out.characters.skipped++; continue; }
            bump(out.characters, await ensureCharacterLorebook(m.id, liveIds));
        }
    } catch (e) { api.v1.error('[AE:lore] syncAll characters:', e); }

    try {
        // Locations (location-type entities).
        let eIdx = await loadEntityIndex();
        for (let em of eIdx.filter(function(x) { return x && x.type === 'location'; })) {
            bump(out.locations, await ensureEntityLorebook(em.id, liveIds));
        }
    } catch (e) { api.v1.error('[AE:lore] syncAll locations:', e); }

    try {
        let cfg = await loadConfig();
        for (let sp of (cfg.species || [])) { bump(out.species, await ensureSpeciesLorebook(sp.id, liveIds)); }
        for (let fa of (cfg.factions || [])) { bump(out.factions, await ensureFactionLorebook(fa.id, liveIds)); }
    } catch (e) { api.v1.error('[AE:lore] syncAll species/factions:', e); }

    return out;
}



// ============================================================================
// SECTION 10b — PLAYER JOURNAL  [v1.7.0 JOURNAL]
// A player-authored running record ("The story so far") that survives context
// pressure by living in the lorebook. Bubbles are the source of truth in
// storyStorage; two lorebook entries are a *projection* of them:
//   - Active  entry: Always-On, keyless — non-archived bubbles, injected every turn.
//   - Archive entry: keyless + disabled — archived bubbles, retained but NEVER
//                    injected; unarchiving moves a bubble back to the active set.
// Renderer (native HUD) lives in Section 27; this section is pure state + lore +
// generation so the bridge can later drive the same verbs over a message pair.
// ============================================================================

async function loadJournal(): Promise<JournalState> {
    try {
        const raw = await api.v1.storyStorage.getOrDefault(STORAGE_JOURNAL, null);
        if (raw && typeof raw === 'object' && Array.isArray((raw as any).bubbles)) {
            const s = raw as JournalState;
            s.bubbles = (s.bubbles || []).filter(Boolean);
            return s;
        }
    } catch (e) { api.v1.error('[AE:journal] loadJournal:', e); }
    return { bubbles: [] };
}

async function saveJournal(state: JournalState): Promise<void> {
    try {
        await api.v1.storyStorage.set(STORAGE_JOURNAL, {
            bubbles: (state.bubbles || []).filter(Boolean),
            activeLoreId: state.activeLoreId,
            archiveLoreId: state.archiveLoreId
        });
    } catch (e) { api.v1.error('[AE:journal] saveJournal:', e); }
}

// [v1.7.0 JOURNAL] Stamp reflects the STORY's in-world calendar at the moment the
// entry was written (captured as storyHours at creation), not wall-clock time.
// Formatted via the same clockFormatStamp the calendar/Author's-Note use.
function journalStampFromHours(hours: number | undefined, cfg: GlobalConfig): string {
    if (typeof hours !== 'number') return '';
    try { return '[' + clockFormatStamp(hours, cfg) + ']'; } catch (e) { return ''; }
}

// Ordered prose body from a bubble list. Stamped bubbles carry their in-story stamp
// inline (the only place a stamp reaches context), so a merge preserves them.
function buildJournalBody(bubbles: JournalBubble[], cfg: GlobalConfig): string {
    return (bubbles || []).map(function(b) {
        const t = (b.text || '').trim();
        if (!t) return '';
        const stamp = (b.stamped && typeof b.storyHours === 'number') ? journalStampFromHours(b.storyHours, cfg) : '';
        return stamp ? (stamp + '\n' + t) : t;
    }).filter(Boolean).join('\n\n');
}

function buildActiveJournalText(bubbles: JournalBubble[], cfg: GlobalConfig): string {
    const body = buildJournalBody(bubbles, cfg);
    return body ? ('The story so far:\n\n' + body) : '';
}

function buildArchiveJournalText(bubbles: JournalBubble[], cfg: GlobalConfig): string {
    const body = buildJournalBody(bubbles, cfg);
    return body ? ('The story so far (archived):\n\n' + body) : '';
}

// Update an existing lore entry, or (re)create it if the id is missing/stale
// (e.g. the user deleted it in NAI's lorebook UI). Returns the live entry id.
async function ensureJournalEntry(existingId: string | undefined, spec: Partial<LorebookEntry>): Promise<string> {
    if (existingId) {
        try {
            const cur = await api.v1.lorebook.entry(existingId);
            if (cur) { await api.v1.lorebook.updateEntry(existingId, spec); return existingId; }
        } catch (e) { /* fall through and recreate */ }
    }
    return await api.v1.lorebook.createEntry(spec);
}

// Re-project bubbles onto the two lorebook entries. Best-effort: never throws,
// mutates state.activeLoreId / state.archiveLoreId in place. Does NOT save —
// persistJournal() owns the single authoritative save after ids settle.
async function syncJournalLore(state: JournalState): Promise<void> {
    try {
        const cfg = await loadConfig();
        const active   = (state.bubbles || []).filter(function(b) { return !b.archived; });
        const archived = (state.bubbles || []).filter(function(b) { return b.archived; });

        const activeText = buildActiveJournalText(active, cfg);
        const hasActive  = activeText.trim().length > 0;

        // The Always-On entry only force-activates when it has content; empty, it
        // is disabled so a lone "The story so far:" header never enters context.
        state.activeLoreId = await ensureJournalEntry(state.activeLoreId, {
            displayName: 'The story so far',
            keys: [],
            text: activeText,
            forceActivation: hasActive,
            enabled: hasActive
        });

        // Archive entry is created lazily — only once something is archived (or it
        // already exists) — so untouched stories don't accrue an empty keyless entry.
        if (archived.length > 0 || state.archiveLoreId) {
            state.archiveLoreId = await ensureJournalEntry(state.archiveLoreId, {
                displayName: 'Journal — Archived (unarchive to restore)',
                keys: [],
                text: buildArchiveJournalText(archived, cfg),
                forceActivation: false,
                enabled: false
            });
        }
    } catch (e) {
        api.v1.error('[AE:journal] syncJournalLore:', e);
    }
}

// Single persistence path for every mutator: project to lore, then one save.
async function persistJournal(state: JournalState): Promise<JournalState> {
    await syncJournalLore(state);
    await saveJournal(state);
    // Keep an open bridge HUD in sync when native mutates the journal (both-mode).
    if (isBridgeReady) { broadcastJournal().catch(function() {}); }
    return state;
}

// Bridge-facing projection: the bridge has no clock/cfg access, so the engine
// precomputes each bubble's in-story stampLabel here. stampLabel is always sent
// (even when not currently stamped) so the HUD can preview it on the stamp toggle.
async function journalPayloadForBridge(): Promise<Record<string, any>> {
    const state = await loadJournal();
    const cfg = await loadConfig();
    const bubbles = (state.bubbles || []).filter(Boolean).map(function(b) {
        return {
            id: b.id,
            text: b.text || '',
            stamped: !!b.stamped,
            archived: !!b.archived,
            createdAt: b.createdAt || 0,
            storyHours: (typeof b.storyHours === 'number') ? b.storyHours : null,
            stampLabel: (typeof b.storyHours === 'number') ? clockFormatStamp(b.storyHours, cfg) : ''
        };
    });
    return { bubbles: bubbles };
}

async function broadcastJournal(): Promise<void> {
    try { await broadcastToTM('AE_JOURNAL_STATE', await journalPayloadForBridge()); }
    catch (e) { api.v1.error('[AE:journal] broadcast:', e); }
}

async function journalAddBubble(text: string, stamped: boolean): Promise<JournalState> {
    const state = await loadJournal();
    const t = (text || '').trim();
    if (!t) return state;
    let storyHours = 0;
    try { const cfg = await loadConfig(); const clk = await loadClock(cfg); storyHours = clk.hours; } catch (e) { storyHours = 0; }
    state.bubbles.push({ id: api.v1.uuid(), text: t, createdAt: Date.now(), storyHours: storyHours, stamped: !!stamped, archived: false });
    return await persistJournal(state);
}

async function journalUpdateBubble(id: string, text: string): Promise<JournalState> {
    const state = await loadJournal();
    const b = state.bubbles.find(function(x) { return x.id === id; });
    if (b) b.text = (text || '').trim();
    return await persistJournal(state);
}

async function journalDeleteBubble(id: string): Promise<JournalState> {
    const state = await loadJournal();
    state.bubbles = state.bubbles.filter(function(x) { return x.id !== id; });
    return await persistJournal(state);
}

async function journalToggleStamp(id: string): Promise<JournalState> {
    const state = await loadJournal();
    const b = state.bubbles.find(function(x) { return x.id === id; });
    if (b) b.stamped = !b.stamped;
    return await persistJournal(state);
}

async function journalSetArchived(id: string, archived: boolean): Promise<JournalState> {
    const state = await loadJournal();
    const b = state.bubbles.find(function(x) { return x.id === id; });
    if (b) b.archived = !!archived;
    return await persistJournal(state);
}

// Merge-down: append all non-archived bubbles (in order) into a single bubble.
// Archived bubbles are untouched. Inline stamps survive via buildJournalBody.
async function journalMergeDown(): Promise<JournalState> {
    const state = await loadJournal();
    const active = state.bubbles.filter(function(b) { return !b.archived; });
    if (active.length <= 1) return state;
    const mergedText = buildJournalBody(active, await loadConfig());
    const earliest = active.reduce(function(m, b) { return b.createdAt < m ? b.createdAt : m; }, active[0].createdAt);
    const earliestHours = active.reduce(function(m, b) {
        return (typeof b.storyHours === 'number' && b.storyHours < m) ? b.storyHours : m;
    }, (typeof active[0].storyHours === 'number' ? active[0].storyHours : 0));
    const merged: JournalBubble = { id: api.v1.uuid(), text: mergedText, createdAt: earliest, storyHours: earliestHours, stamped: false, archived: false };
    const archived = state.bubbles.filter(function(b) { return b.archived; });
    state.bubbles = [merged].concat(archived);
    return await persistJournal(state);
}

// ── Generation verbs (story-aware, so voice matches the current model/style) ──
// Both run in 'background' mode and suppress this script's own context hooks so
// the journal doesn't re-inject itself while being rewritten.

async function journalGenerateRewrite(text: string): Promise<string | null> {
    const src = (text || '').trim();
    if (!src) return null;
    try {
        const cfg = await loadConfig();
        const sys = [
            (cfg.generalStyle || '').trim(),
            '',
            'Rewrite the player\'s journal note below in the narrative voice of this story.',
            'Absolute priority: preserve every fact, name, event, number, and decision exactly as written \u2014 invent nothing, omit nothing.',
            'Be token-efficient: tighten wording and cut filler while keeping all content.',
            'Past tense, third-person recap voice. Output ONLY the rewritten note \u2014 no preamble, no quotes, no commentary.'
        ].filter(Boolean).join('\n');
        const maxTok = Math.max(120, Math.min(700, Math.ceil(src.length / 3) + 80));
        const resp = await api.v1.generateWithStory(
            [ { role: 'system', content: sys }, { role: 'user', content: src } ],
            { model: 'glm-4-6', max_tokens: maxTok, temperature: 0.7 },
            { suppressScriptHooks: 'self', contextLimitReduction: 600 },
            undefined,
            'background'
        );
        if (resp && resp.choices && resp.choices.length > 0) return (resp.choices[0].text || '').trim() || null;
        return null;
    } catch (e) { api.v1.error('[AE:journal] rewrite:', e); return null; }
}

async function journalGenerateCompress(text: string): Promise<string | null> {
    const src = (text || '').trim();
    if (!src) return null;
    try {
        const cfg = await loadConfig();
        const sys = [
            (cfg.generalStyle || '').trim(),
            '',
            'Compress the player\'s journal note below into a shorter recap for long-term memory.',
            'Keep the load-bearing details: names, places, relationships, commitments, and outcomes. Drop atmosphere and repetition.',
            'Aim for roughly half the length or less. Past tense, plain and dense.',
            'Output ONLY the compressed recap \u2014 no preamble, no quotes, no commentary.'
        ].filter(Boolean).join('\n');
        const maxTok = Math.max(60, Math.min(400, Math.ceil(src.length / 6) + 40));
        const resp = await api.v1.generateWithStory(
            [ { role: 'system', content: sys }, { role: 'user', content: src } ],
            { model: 'glm-4-6', max_tokens: maxTok, temperature: 0.5 },
            { suppressScriptHooks: 'self', contextLimitReduction: 600 },
            undefined,
            'background'
        );
        if (resp && resp.choices && resp.choices.length > 0) return (resp.choices[0].text || '').trim() || null;
        return null;
    } catch (e) { api.v1.error('[AE:journal] compress:', e); return null; }
}



// ============================================================================
// SECTION 11 — RESOURCE MANAGER
// Reading and mutating global party resources and per-character resources.
// Party resources (wealth, health track, etc.) live in PartyState.
// Character resources are per-CharacterRecord fields.
//
// DEAD CODE NOTE: adjustResource() returns a boolean wasRelocated that is
// hardcoded false and was never implemented. The return value is read by
// executeTravelTo() in Section 19. The return type and that call site will be
// cleaned up together when Section 19 is written — changing it here in
// isolation would produce a compile error at the call site.
// ============================================================================

// [v0.9.63] Resolve the protagonist's character id — owner of personal resources.
async function getProtagonistId(): Promise<string | null> {
    try {
        const gpIdx = await loadIndex();
        const gpMeta = gpIdx.find(function(m) { return !!m.isProtagonist; });
        return gpMeta ? gpMeta.id : null;
    } catch (_e) { return null; }
}

async function checkResource(tag: string, amount: number = 1): Promise<boolean> {
    // Returns true if the party can afford `amount` of the resource tagged `tag`.
    // For track resources, "can afford" means there are enough steps remaining
    // to advance by `amount` (val + amount must not exceed maxIdx).
    // [FIX] Previously checked only val < maxIdx, ignoring the amount parameter.
    if (!tag) return true;
    const cfg   = await loadConfig();
    const party = await loadPartyState();

    const resDef = (cfg.resources || []).find(function(r) { return r.tag === tag; });
    if (!resDef) {
        // [v0.9.63] Not a global — check the protagonist's personal resource instead.
        // Personal resources are spent (subtracted toward 0), so affordability is
        // val >= amount for pool and track alike.
        const cpId = await getProtagonistId();
        if (!cpId) return false;
        const cpCh = await loadCharacter(cpId);
        if (!cpCh) return false;
        const cpDef = (cpCh.charResourceDefs || []).find(function(r) { return r.tag === tag; });
        if (!cpDef) return false;
        const cpVal = (cpCh.charResourceValues && cpCh.charResourceValues[cpDef.id]) || 0;
        return cpVal >= amount;
    }

    const val = party.resourceValues[resDef.id] || 0;
    if (resDef.type === 'track') {
        const maxIdx = (resDef.states || []).length > 0 ? resDef.states.length - 1 : 0;
        return val + amount <= maxIdx;
    } else {
        return val >= amount;
    }
}

async function adjustResource(tag: string, amount: number): Promise<boolean> {
    // Applies a delta to a party resource, respects bounds, fires a toast,
    // and broadcasts the updated scene state to the HUD.
    // Returns false always (wasRelocated — never implemented; see dead code note above).
    const cfg      = await loadConfig();
    const party    = await loadPartyState();
    const cleanTag = tag.trim();
    const resDef   = (cfg.resources || []).find(function(r: any) { return r.tag === cleanTag; });
    if (!resDef) {
        // [v0.9.63] Not a global — delegate to the protagonist's personal resource.
        // adjustCharResource applies the signed delta, clamps, toasts, saves, broadcasts.
        const apId = await getProtagonistId();
        if (apId) await adjustCharResource(apId, cleanTag, amount);
        return false;
    }

    if (!party.resourceValues) party.resourceValues = {};
    let currentVal = party.resourceValues[resDef.id] || 0;

    currentVal += amount;

    if (resDef.type === 'pool' && resDef.hasBounds) {
        currentVal = Math.max(resDef.min || 0, Math.min(resDef.max || 100, currentVal));
    } else if (resDef.type === 'track' || resDef.type === 'discrete') {
        const maxIdx = (resDef.states || []).length > 0 ? resDef.states.length - 1 : 0;
        currentVal = Math.max(0, Math.min(maxIdx, currentVal));
    }

    party.resourceValues[resDef.id] = currentVal;
    await savePartyState(party);

    api.v1.ui.toast(`${amount > 0 ? '+' : ''}${amount} ${resDef.name} [Total: ${currentVal}]`, { type: 'info', autoClose: 2500 });

    // [CHANGE] Queue scene state broadcast so the HUD resource bar updates immediately.
    queueSceneStateBroadcast();

    return false; // wasRelocated — always false, see dead code note above
}

async function adjustCharResource(charId: string, tag: string, amount: number): Promise<void> {
    // Applies a delta to a character-level resource (not party-level).
    // saveCharacter() at the end triggers queueCharacterDataBroadcast() automatically.
    try {
        const char = await loadCharacter(charId);
        if (!char) return;

        const resDef = (char.charResourceDefs || []).find(function(r) { return r.tag === tag; });
        if (!resDef) return;

        if (!char.charResourceValues) char.charResourceValues = {};
        const current = char.charResourceValues[resDef.id] || 0;
        let newVal = current;

        if (resDef.type === 'pool') {
            newVal = current + amount;
            if (resDef.hasBounds) {
                if (resDef.min !== undefined) newVal = Math.max(resDef.min, newVal);
                if (resDef.max !== undefined) newVal = Math.min(resDef.max, newVal);
            }
        } else {
            // track and discrete both use state-index bounds
            const states = resDef.states || [];
            newVal = Math.max(0, Math.min(states.length - 1, current + amount));
        }

        char.charResourceValues[resDef.id] = newVal;
        await saveCharacter(char); // triggers queueCharacterDataBroadcast() internally
    } catch (e) { api.v1.error('[AE] adjustCharResource:', e); }
}


// ============================================================================
// SECTION 12 — ENTITY KNOWLEDGE & CHARACTER SNAPSHOT GENERATION
//
// This section covers two distinct but related capabilities:
//
// 1. ENTITY KNOWLEDGE (deterministic — no AI generation)
//    buildEntityKnowledgeString: describes what a character "knows" about an
//    entity in the world — its type, location, occupants, connections.
//    syncEntityKnowledgeToAwareChars: propagates a knowledge string to all
//    characters listed in an entity's awareCharacterIds.
//
// 2. CHARACTER SNAPSHOT (GLM-backed — AI generation)
//    generateCharacterSnapshot: writes a present-tense appearance description
//    of a character as the protagonist encounters them. Used as scene flavor
//    text for the entity system's character-type nodes.
//
// NOTE — CONTEXT BUILDER SEPARATION:
// The injection sub-builders that feed into the Author's Note (buildCharInjection,
// buildMidRangeInjection, buildEphemeralInjection, charIsRelevant,
// buildEntityContextBlock, buildProtagonistInjection, buildDramatisPersonae)
// are NOT in this section. They live in Section 13 (Context Injection Builders)
// because they are pipeline components — the output of this section feeds them
// but they are architecturally distinct.
// ============================================================================

// ── Entity Knowledge (deterministic) ─────────────────────────────────────────

async function buildEntityKnowledgeString(entityId: string): Promise<string> {
    // Builds a short factual description of what a character could know about
    // this entity based on objective world state. No AI generation — reads the
    // entity tree only. Used to populate KnownEntityEntry.snapshot.
    try {
        const ent    = await loadEntity(entityId);
        if (!ent) return '';
        const entIdx = await loadEntityIndex();

        function parentName(parentId: string | null): string {
            if (!parentId) return 'the world (ungrouped)';
            const p = entIdx.find(function(m) { return m.id === parentId; });
            return p ? p.name : 'Unknown';
        }

        if (ent.type === 'character') {
            const chars   = await loadAllCharacters();
            const charRec = chars.find(function(c) { return c.entityId === ent.id; });
            const roleStr = [charRec?.occupationRole, charRec?.species, charRec?.age].filter(Boolean).join(', ');
            const locStr  = parentName(ent.parentId);
            return `${ent.name}${roleStr ? ' (' + roleStr + ')' : ''} — currently in ${locStr}.`;

        } else if (ent.type === 'item') {
            // Check if carried by a character entity
            const carrier = entIdx.find(function(m) { return m.id === ent.parentId && m.type === 'character'; });
            if (carrier) {
                const carrierEnt    = await loadEntity(carrier.id);
                const carrierLocStr = carrierEnt ? parentName(carrierEnt.parentId) : 'unknown location';
                return `${ent.name} — ${ent.description ? ent.description.trim() + ' — ' : ''}carried by ${carrier.name}, who is in ${carrierLocStr}.`;
            }
            return `${ent.name} — ${ent.description ? ent.description.trim() + ' — ' : ''}located in ${parentName(ent.parentId)}.`;

        } else if (ent.type === 'location') {
            // Parent context + present characters + explicit connections
            // (description omitted — lorebook entry covers it)
            const childChars  = entIdx.filter(function(m) { return m.parentId === ent.id && m.type === 'character'; });
            const connections = (ent.connectedEntityIds || []).map(function(c) {
                const t = entIdx.find(function(m) { return m.id === c.targetId; });
                return t ? t.name : null;
            }).filter(Boolean);
            const parts: string[] = [`${ent.name} is a location within ${parentName(ent.parentId)}.`];
            if (childChars.length > 0)   parts.push(`Present: ${childChars.map(function(m) { return m.name; }).join(', ')}.`);
            if (connections.length > 0)  parts.push(`Connects to: ${connections.join(', ')}.`);
            return parts.join(' ');

        } else if (ent.type === 'narrative') {
            const stateStr = ent.storyState ? ' (' + ent.storyState + ')' : '';
            return `${ent.name}${stateStr} — a story thread${ent.parentId ? ' located at ' + parentName(ent.parentId) : ''}.${ent.description ? ' ' + ent.description.trim() : ''}`;
        }

        return `${ent.name} — located in ${parentName(ent.parentId)}.`;
    } catch (e) {
        api.v1.error('[AE:knowledge] buildEntityKnowledgeString:', e);
        return '';
    }
}

async function syncEntityKnowledgeToAwareChars(ent: EntityRecord): Promise<void> {
    // Propagates an entity's knowledgeString to all characters in its awareCharacterIds list.
    // Called from the entity editor when the knowledge string is updated or an entity is saved.
    // Each character's KnownEntityEntry is updated in-place or created if absent.
    try {
        for (const charId of (ent.awareCharacterIds || [])) {
            const char = await loadCharacter(charId);
            if (!char) continue;
            if (!char.knownEntities) char.knownEntities = [];
            const existing = char.knownEntities.find(function(e) { return e.entityId === ent.id; });
            if (existing) {
                existing.snapshot    = ent.knowledgeString || '';
                existing.entityName  = ent.name;
            } else {
                char.knownEntities.push({
                    id: generateId(),
                    entityId:   ent.id,
                    entityName: ent.name,
                    snapshot:   ent.knowledgeString || '',
                    addedAt:    Date.now()
                });
            }
            await saveCharacter(char);
        }
    } catch (e) { api.v1.error('[AE:knowledge] syncEntityKnowledgeToAwareChars:', e); }
}

// ── Character Snapshot (AI generation) ───────────────────────────────────────

async function generateCharacterSnapshot(charRec: CharacterRecord, ent: EntityRecord, cfg: GlobalConfig): Promise<string | null> {
    // Generates a brief present-tense appearance description for a character
    // as encountered in their current location. Used by the entity system
    // for character-type nodes when a snapshot hasn't been generated yet.
    //
    // Uses api.v1.generateWithStory in 'background' mode so it runs without
    // surfacing a visible generation progress indicator.
    try {
        // Resolve location name for scene grounding
        let locationName = 'Unknown';
        let locationDesc = '';
        if (ent.parentId) {
            const locEnt = await loadEntity(ent.parentId);
            if (locEnt) { locationName = locEnt.name; locationDesc = locEnt.description || ''; }
        }

        // Resolve equipped item names for appearance context
        const equippedItems: string[] = [];
        for (const itemId of (charRec.equippedItemIds || [])) {
            try {
                const itemEnt = await loadEntity(itemId);
                if (itemEnt) equippedItems.push(itemEnt.name);
            } catch (ignoredErr) { /* non-fatal */ }
        }

        const idParts  = [charRec.gender, charRec.species, charRec.age, charRec.occupationRole].filter(Boolean);
        const idLine   = idParts.length > 0 ? ' (' + idParts.join(', ') + ')' : '';

        const sysPrompt = [
            cfg.generalStyle || '',
            '',
            `Write a brief present-tense description of ${charRec.name} as the protagonist notices them.`,
            '1 short paragraph. No internal thoughts, no dialogue, no summary statements.',
            '',
            'Capture:',
            '- Physical appearance including anything worn or carried',
            `- What they appear to be doing in ${locationName} (work here? live here? passing through? with the protagonist?)`,
            '- One behavioral or expressive detail reflecting their current state',
            '',
            'Concrete and specific. Show rather than tell.'
        ].join('\n');

        const userPrompt = [
            charRec.name + idLine,
            charRec.briefDescription         ? 'Brief: '     + charRec.briefDescription : '',
            charRec.physicalDescription      ? 'Appearance: ' + charRec.physicalDescription : '',
            charRec.background               ? 'Background: ' + charRec.background.slice(0, 100) : '',
            equippedItems.length > 0         ? 'Wearing/Carrying: ' + equippedItems.join(', ') : '',
            'Location: ' + locationName,
            locationDesc                     ? 'Setting: '    + locationDesc.slice(0, 80) : '',
            ent.atmosphere                   ? 'Thoughts: '   + ent.atmosphere : '',
            charRec.midRange?.currentDesire  ? 'Drive: '      + charRec.midRange.currentDesire : '',
            charRec.ephemeral?.compressedLine ? 'State: '     + charRec.ephemeral.compressedLine : ''
        ].filter(Boolean).join('\n');

        const response = await api.v1.generateWithStory(
            [
                { role: 'system', content: sysPrompt },
                { role: 'user',   content: userPrompt }
            ],
            { model: 'glm-4-6', max_tokens: 200 },
            { suppressScriptHooks: 'self', contextLimitReduction: 450 },
            undefined,
            'background'
        );

        if (response && response.choices && response.choices.length > 0) {
            return response.choices[0].text || null;
        }
        return null;
    } catch (e) {
        api.v1.error('[AE:knowledge] generateCharacterSnapshot:', e);
        return null;
    }
}

// ============================================================================
// SECTION 13 — CONTEXT INJECTION BUILDERS
//
// All functions that construct content injected into the AI's context window.
//
// ── FULL INJECTION PIPELINE MAP ──────────────────────────────────────────────
//
// onBeforeContextBuild  →  Author's Note (AN) slot
//   └── buildWorldStateBlock(protag)
//         ├── Location: entity name, state-resolved description, atmosphere
//         ├── Protagonist: identity line, brief description, equipped items
//         └── Scene-present NPCs: identity + relationship + mid-range +
//                                  equipment + non-critical hook + ephemeral
//   └── Quest line (if STORAGE_TRACKED_NARRATIVE is set)
//
// onContextBuilt  →  Spliced before player input (highest recency weight)
//   └── Imperative block  [Section 26 — inline in hook]
//         ├── Pending encounter (STORAGE_PENDING_ENCOUNTER, fires once)
//         ├── Pending knowledge query (STORAGE_PENDING_KNOWLEDGE, fires once)
//         ├── Critical character hooks (pressureLevel ≥ 85%)
//         └── Critical NPC web links (priority ≥ 70, both parties present)
//
// onContextBuilt  →  
//   └── buildDramaContextBlock()
//         ├── Urgent hooks (60–84%) — scene-present characters
//         ├── Background NPC web (priority < 70, both parties present)
//         └── Active narrative nodes (storyState === 'active', has description)
//
// onContextBuilt  →  Replaces player input (tag-based dice roll)
//   └── ⚠️ note: replaced probability system 
//         └── #tagname in player input → 1d6 + skill modifier → outcome line
//
// ── FUTURE: UNIFIED CONTEXT PIPELINE ─────────────────────────────────────────
// The three AN/splice/drama operations above are currently assembled inline
// inside two hook handlers. A future `buildFullContextPackage(params)` function
// could return all pieces at once and make the hook handlers 10-line delegation
// calls. The individual sub-builders here are already the right decomposition;
// only the assembly site needs to change.
//
// ── SUB-BUILDER STATUS ────────────────────────────────────────────────────────
// buildWorldStateBlock and buildDramaContextBlock: called from hooks (live).
// charIsRelevant: called from runDynamicEngine (live).
// buildProtagonistInjection, buildDramatisPersonae, buildEntityContextBlock,
// buildCharInjection, buildMidRangeInjection, buildEphemeralInjection:
//   defined but NOT currently called from the generation pipeline — buildWorldStateBlock
//   inlines all character-level assembly. Preserved as utilities for future use
//   and for any UI section that invokes them for preview or diagnostics.
// ============================================================================

// Builds macro-accessible fields for a character: relArchetype, relStage, and one
// entry per character resource keyed res_<tag> (tag '#' stripped). Discrete/track
// resources resolve to their current state label; pools to their numeric value.
// Blank/index-0 discrete values resolve to '' so the [ ... ] block self-suppresses.
function buildCharMacroExtras(char: CharacterRecord, cfg: GlobalConfig): Record<string, any> {
    let extras: Record<string, any> = {};
    // Relationship archetype + stage
    if (char.primaryRelationship) {
        extras.relArchetype = char.primaryRelationship.archetype || '';
        extras.relStage = resolveArchetypeStage(cfg, char.primaryRelationship);
        // [v0.9.17] Resolve the relationship target-name macro: __player__ -> protagonist name.
        let _relTgt = char.primaryRelationship.targetName;
        if (_relTgt === '__player__') _relTgt = (cfg as any).protagonistName || 'the player';
        extras.primaryRelationship = Object.assign({}, char.primaryRelationship, { targetName: _relTgt });
    } else {
        extras.relArchetype = '';
        extras.relStage = '';
    }
    // Character resources → res_<tag>
    let resMap: Record<string, any> = {};
    for (const rdef of (char.charResourceDefs || [])) {
        let key = String(rdef.tag || '').replace('#', '').trim();
        if (!key) continue;
        let val = (char.charResourceValues && char.charResourceValues[rdef.id] !== undefined) ? char.charResourceValues[rdef.id] : 0;
        if (rdef.type === 'pool') {
            resMap[key] = String(val);
        } else {
            // track / discrete → state label; index 0 of a discrete is the clear/none slot → blank
            let states = rdef.states || [];
            let label = states[val] || '';
            if (rdef.type === 'discrete' && val === 0) label = '';
            resMap[key] = label;
        }
    }
    extras.res = resMap;

    // [v0.9.8.4] conditionStates: a convenience join of every active condition-type
    // resource (discrete/track with a non-blank current label), e.g. "drunk, poisoned".
    // Per-tag |res.<tag>| macros still work for precise references.
    let condParts: string[] = [];
    for (const cdef of (char.charResourceDefs || [])) {
        if (!cdef || cdef.type === 'pool') continue;
        let condVal = (char.charResourceValues && char.charResourceValues[cdef.id] !== undefined) ? char.charResourceValues[cdef.id] : 0;
        let condStates = cdef.states || [];
        let condLabel = condStates[condVal] || '';
        if (cdef.type === 'discrete' && condVal === 0) condLabel = '';
        if (condLabel) condParts.push(condLabel);
    }
    extras.conditionStates = condParts.join(', ');

    return extras;
}

function parseMacroTemplate(template: string, data: any): string {
    if (!template) return '';
    return template.replace(/\[([^\[\]]+)\]/g, function(match, inner) {
        let isValid = true;
        
        // Globally find and evaluate all |macro.path| tokens inside this specific bracket block
        const evaluatedInner = inner.replace(/\|([^\|]+)\|/g, function(macroMatch, path) {
            let val: any = data;
            const keys = path.trim().split('.');
            for (const k of keys) {
                if (val === undefined || val === null) break;
                val = val[k];
            }
            
            // If any token evaluates to empty/null, flag the entire bracket block for deletion
            if (val === undefined || val === null || String(val).trim() === '') {
                isValid = false;
                return '';
            }
            
            return String(val);
        });
        
        if (!isValid) return '';
        
        // Finalize block formatting
        return evaluatedInner.replace(/\\n/g, '\n');
    });
}


// NOTE FOR ASSEMBLY: STORAGE_RETRY_CHARS = 'ae_retry_chars' (used in Section 15's
// runDynamicEngine) was declared mid-file at line 8039 in the original alongside
// STORAGE_ENGINE_SKIP. Both belong in Section 2 constants. Add:
//   var STORAGE_RETRY_CHARS = 'ae_retry_chars';

// ── Per-character sub-builders ────────────────────────────────────────────────
// These build individual string fragments for one character at a time.
// buildWorldStateBlock calls equivalent inline logic rather than these helpers,
// but they are available for future pipeline refactoring and UI previews.

function buildProtagonistInjection(protag: CharacterRecord): string {
    // Builds the [ Player: ... ] header line for the protagonist in the AN.
    const idParts = [protag.gender, protag.species, protag.age, protag.occupationRole].filter(Boolean);
    const header  = idParts.length > 0 ? `${protag.name} (${idParts.join(', ')})` : protag.name;
    const lines: string[] = [`[ Player: ${header} ]`];
    if (protag.briefDescription?.trim()) lines.push(protag.briefDescription.trim());
    return lines.join('\n');
}

function buildDramatisPersonae(index: CharacterMeta[]): string {
    // Builds the [ Dramatis Personae ] cast list from the character index.
    // Marks offstage characters explicitly so the AI knows who is not present.
    const active = index.filter(function(m) { return m.active; });
    if (active.length === 0) return '';
    const lines = ['[ Dramatis Personae ]'];
    for (const m of active) {
        const idParts = [m.species?.trim(), m.age?.trim(), m.occupationRole?.trim()].filter(Boolean);
        const header  = idParts.length > 0 ? `${m.name} (${idParts.join(', ')})` : m.name;
        const brief   = m.briefDescription?.trim() ? ` — ${m.briefDescription.trim()}` : '';
        lines.push(`${header}${(m.scenePresent || m.isProtagonist) ? '' : ' [offstage]'}${brief}`);
    }
    return lines.join('\n');
}

function buildCharInjection(
    char: CharacterRecord,
    cfg: GlobalConfig,              // [CHANGE] was a free variable bug — now explicit param
    equippedItemNames?: string[]    // [CHANGE] removed three unused _-prefixed params
): string {
    // Builds a compact [ CharName ] block with arc, relationship, and equipment.
    // Currently not called from buildWorldStateBlock (which inlines all assembly),
    // but preserved as a utility for future pipeline use.
    if (!char.active || !char.scenePresent) return '';
    const contentLines: string[] = [];

    function tryQueue(line: string): void {
        if (!line?.trim()) return;
        contentLines.push(line);
    }

    if (char.primaryRelationship?.targetName && char.primaryRelationship.enabled && char.charContextEnabled !== false) {
        let relTarget = char.primaryRelationship.targetName;
        if (relTarget === '__player__') {
            relTarget = (cfg as any).protagonistName || 'the player';
        }
        let stageName = resolveArchetypeStage(cfg, char.primaryRelationship);
        let archName  = char.primaryRelationship.archetype || '';
        let relPrefix = '';
        if (archName && stageName) relPrefix = archName + ' \u2014 ' + stageName + ': ';
        else if (archName) relPrefix = archName + ': ';
        tryQueue(`Relationship (${relTarget}): ${relPrefix}${char.primaryRelationship.currentStatus}`);
    }

    if (equippedItemNames && equippedItemNames.length > 0) {
        tryQueue(`Equipped: ${equippedItemNames.join(', ')}`);
    }

    if (contentLines.length === 0) return '';
    return `[ ${char.name} ]\n${contentLines.join('\n')}`;
}

function buildMidRangeInjection(char: CharacterRecord): string {
    // Builds a single attributed line from the character's mid-range state
    // (goal / mask / view). Three distinct beats in one line.
    if (char.charContextEnabled === false) return '';
    const mid = char.midRange;
    if (!mid) return '';
    const parts = [mid.currentDesire, mid.socialMask, mid.shiftedView].filter(Boolean);
    return parts.length > 0 ? `${char.name} — ${parts.join('. ')}` : '';
}

function buildEphemeralInjection(char: CharacterRecord): string {
    // Builds an attributed ephemeral injection from the character's immediate state.
    // Prefers the three structured sub-fields; falls back to compressedLine.
    if (char.charContextEnabled === false) return '';
    if (!char.ephemeral) return '';
    const eph = char.ephemeral;
    const parts = [eph.eventAnchor, eph.emotionalResponse, eph.immediateDesire].filter(Boolean);
    if (parts.length >= 2) return `${char.name} — ${parts.join(' — ')}`;
    if (eph.compressedLine) return `${char.name} — ${eph.compressedLine}`;
    return '';
}

function charIsRelevant(c: CharacterRecord, activeEntryIds: Set<string>): boolean {
    // Returns true if a character should receive dynamic engine updates this turn.
    // A character is relevant if they are scene-present OR their lorebook entry fired.
    return c.active && c.scenePresent; // [v0.9.24 E2] removed lorebook-entry clause
}

// [vNEXT] Dynamic-priority cap. Given the already-loaded character index and the
// configured cap, returns the Set of character ids permitted to run as dynamic this
// turn. Pure in-memory over the index metas — NO storage reads, so it costs nothing
// on the generation path beyond a sort of the present-dynamic subset.
//
// Eligible pool = active, scene-present, non-protagonist, non-minor, non-static
// (static chars are already excluded from dynamics by their own gate; excluding them
// here too means they never occupy a cap slot). Ordering: ranked characters first by
// ascending rank (1 = highest priority), then unranked characters by name. Unranked
// present-dynamic characters DO consume slots, after all ranked ones. cap <= 0 means
// no cap — every eligible id is returned.
function computeDynamicAllowedSet(index: CharacterMeta[], cap: number): Set<string> {
    const eligible = (index || []).filter(function(m) {
        return m && m.active && m.scenePresent && !m.isProtagonist
            && (m as any).npcClass !== 'minor' && !(m as any).isStatic;
    });
    if (!(cap > 0) || eligible.length <= cap) {
        // No cap, or everyone fits — allow all eligible.
        return new Set(eligible.map(function(m) { return m.id; }));
    }
    eligible.sort(function(a, b) {
        const ar = (typeof (a as any).dynamicPriorityRank === 'number' && (a as any).dynamicPriorityRank > 0) ? (a as any).dynamicPriorityRank : Infinity;
        const br = (typeof (b as any).dynamicPriorityRank === 'number' && (b as any).dynamicPriorityRank > 0) ? (b as any).dynamicPriorityRank : Infinity;
        if (ar !== br) return ar - br;                       // ranked ascending; unranked (Infinity) last
        return String(a.name || '').localeCompare(String(b.name || '')); // stable tiebreak
    });
    return new Set(eligible.slice(0, cap).map(function(m) { return m.id; }));
}

// [vNEXT] Assign (or clear) a character's dynamic-priority rank, enforcing "one
// character per rank" by swapping. If another character already holds newRank, they
// inherit the assignee's OLD rank (which may be undefined -> they become unranked).
// Pass newRank <= 0 or undefined to simply clear the assignee's rank (no swap).
// Writes only the (at most) two affected records. Returns nothing; callers refresh UI.
async function assignDynamicPriorityRank(charId: string, newRank: number | undefined): Promise<void> {
    try {
        const target = await loadCharacter(charId);
        if (!target) return;
        const oldRank = (typeof (target as any).dynamicPriorityRank === 'number' && (target as any).dynamicPriorityRank > 0) ? (target as any).dynamicPriorityRank : undefined;
        const wantRank = (typeof newRank === 'number' && newRank > 0) ? Math.floor(newRank) : undefined;

        if (wantRank === oldRank) return; // no change

        // Clear case: just drop the rank.
        if (wantRank === undefined) {
            (target as any).dynamicPriorityRank = undefined;
            await saveCharacter(target);
            return;
        }

        // Find whoever currently holds wantRank (excluding the target) via the index
        // (cheap — no full character loads for the scan).
        const idx = await loadIndex();
        const holderMeta = idx.find(function(m) { return m && m.id !== charId && (m as any).dynamicPriorityRank === wantRank; });

        if (holderMeta) {
            const holder = await loadCharacter(holderMeta.id);
            if (holder) {
                // Swap: holder takes the target's old rank (may be undefined -> unranked).
                (holder as any).dynamicPriorityRank = oldRank;
                await saveCharacter(holder);
            }
        }
        (target as any).dynamicPriorityRank = wantRank;
        await saveCharacter(target);
    } catch (e) {
        api.v1.error('[AE:dynrank] assignDynamicPriorityRank:', e);
    }
}

// [vNEXT] Shared rank-picker modal for a character. Offers "Unranked" plus ranks
// 1..maxRank, where maxRank is the configured dynamic cap (or, if no cap is set, the
// count of eligible present characters, floored at a small minimum so the control is
// always usable). Shows which character currently holds each rank. onDone (optional)
// is invoked after assignment so the caller can refresh its own view.
async function openDynamicRankPicker(charId: string, onDone?: () => (void | Promise<void>)): Promise<void> {
    try {
        const cfg = await loadConfig();
        const idx = await loadIndex();
        const self = idx.find(function(m) { return m.id === charId; });
        const selfName = self ? (self.name || 'Character') : 'Character';
        const curRank = (self && typeof (self as any).dynamicPriorityRank === 'number' && (self as any).dynamicPriorityRank > 0) ? (self as any).dynamicPriorityRank : undefined;

        const cap = Number((cfg as any).maxDynamicCharacters) || 0;
        // How many rank slots to offer. With a cap, offer exactly the cap. Without a
        // cap, offer as many as there are eligible present characters (min 4 so the
        // control is meaningful even in a small scene).
        let eligibleCount = idx.filter(function(m) {
            return m && m.active && !m.isProtagonist && (m as any).npcClass !== 'minor';
        }).length;
        const maxRank = cap > 0 ? cap : Math.max(4, eligibleCount);

        // Rank -> holder name lookup (from the index; no character loads).
        const holderByRank: Record<number, string> = {};
        idx.forEach(function(m) {
            const r = (m as any).dynamicPriorityRank;
            if (typeof r === 'number' && r > 0) holderByRank[r] = m.name || 'Character';
        });

        const items: { id: string; label: string; selected?: boolean }[] = [];
        items.push({ id: '__unranked__', label: 'Unranked' + (curRank === undefined ? '  (current)' : ''), selected: curRank === undefined });
        for (let r = 1; r <= maxRank; r++) {
            let holder = holderByRank[r];
            let suffix = '';
            if (r === curRank) suffix = '  (current)';
            else if (holder && holder !== selfName) suffix = '  — held by ' + holder;
            items.push({ id: String(r), label: 'Rank ' + r + suffix, selected: r === curRank });
        }

        await openPickerModal({
            title: 'Dynamic Priority — ' + selfName,
            items: items,
            getId: function(item: any) { return item.id; },
            getLabel: function(item: any) { return item.label; },
            searchable: false,
            selectedId: curRank === undefined ? '__unranked__' : String(curRank),
            emptyText: 'No ranks available.',
            onSelect: async function(item: any) {
                const pick = item && item.id;
                if (pick === '__unranked__') await assignDynamicPriorityRank(charId, undefined);
                else await assignDynamicPriorityRank(charId, parseInt(pick, 10));
                if (onDone) await onDone();
            }
        });
    } catch (e) {
        api.v1.error('[AE:dynrank] openDynamicRankPicker:', e);
    }
}

async function buildEntityContextBlock(ent: EntityRecord): Promise<string> {
    // Builds a [ Type: Name ] header with state-resolved description and atmosphere.
    // Used when injecting a specific entity into context (e.g. from a HUD action).
    const resolved = (ent.state !== 'default' && ent.stateDescriptions[ent.state])
        ? ent.stateDescriptions[ent.state]
        : ent.description;
    const lines: string[] = [`[ ${ent.type.charAt(0).toUpperCase() + ent.type.slice(1)}: ${ent.name} ]`];
    if (resolved?.trim()) lines.push(resolved.trim());
    if (ent.atmosphere?.trim()) lines.push(ent.atmosphere.trim());
    return lines.join('\n');
}

// ── Primary builders ──────────────────────────────────────────────────────────

async function buildWorldStateBlock(protagChar: CharacterRecord | null): Promise<string> {
    // [v0.9.8.4] Slimmed to the dynamic layer only. Static identity now rides each
    // character's force-activated lorebook entry; the Author's Note carries the live
    // scene: location, the present-roster line, and one compact dynamics line per NPC.
    const parts: string[] = [];
    const cfg = await loadConfig();

    const playerName = (protagChar && protagChar.name) ? protagChar.name : 'You';

    // [v0.9.9.2] Lead the AN with the world clock when enabled. This is the always-on
    // date/time stamp; the per-narrative day countdown rides the tracked-narrative
    // block instead, so only one countdown ever appears.
    try {
        if (cfg.timeShowInAN) {
            let _clk = await loadClock(cfg);
            parts.push('[ ' + clockFormatStamp(_clk.hours, cfg) + ' ]');
        }
    } catch (e) { api.v1.error('[AE:context] buildWorldStateBlock time:', e); }

    // Resolve scene-present NPCs once — both the roster line and the per-character
    // detail loop draw from the same set.
    const charIndex = await loadIndex();
    const presentMetas = charIndex.filter(function(m) { return m && m.active && m.scenePresent && !m.isProtagonist && (m as any).npcClass !== 'minor'; });
    const presentNames = presentMetas.map(function(m) { return m.name; }).filter(Boolean).join(', ');
    // [vNEXT] The roster line above lists EVERYONE present (they're physically in the
    // scene regardless of the dynamic cap). The per-character dynamics loop below,
    // however, only emits detail for characters within the cap, so injected dynamics
    // match what the engine actually keeps updated. Same in-memory helper, reusing
    // the index already loaded here — no extra storage reads.
    const _wsDynCap = Number((cfg as any).maxDynamicCharacters) || 0;
    const _wsDynAllowed = computeDynamicAllowedSet(charIndex as any, _wsDynCap);

    // ── LOCATION + SCENE ──────────────────────────────────────────────────────
    try {
        const locId = await loadPlayerLocation();
        if (locId) {
            const locEnt = await loadEntity(locId);
            if (locEnt) {
                const resolvedDesc = (locEnt.state !== 'default' && locEnt.stateDescriptions?.[locEnt.state])
                    ? locEnt.stateDescriptions[locEnt.state]
                    : locEnt.description;
                const locData = { name: locEnt.name, description: resolvedDesc, atmosphere: locEnt.atmosphere, state: locEnt.state, playerName: playerName };
                const locBlock = parseMacroTemplate(cfg.contextTemplates.location, locData).trim();
                if (locBlock) parts.push(locBlock);
            }
        }
    } catch (e) { api.v1.error('[AE:context] buildWorldStateBlock loc:', e); }

    // ── SCENE ROSTER (player slot) ────────────────────────────────────────────
    // The 'player' template is now the present-with line. The protagonist's full
    // record + extras are still spread in so a custom roster template may reference
    // any player field; the default uses only |playerName| and |presentNames|.
    try {
        const rosterExtras = protagChar ? buildCharMacroExtras(protagChar, cfg) : {};
        const rosterData = Object.assign({}, protagChar || {}, rosterExtras, { playerName: playerName, presentNames: presentNames });
        const rosterBlock = parseMacroTemplate(cfg.contextTemplates.player, rosterData).trim();
        if (rosterBlock) parts.push(rosterBlock);
    } catch (e) { api.v1.error('[AE:context] buildWorldStateBlock roster:', e); }

    // ── PER-CHARACTER DYNAMICS ────────────────────────────────────────────────
    try {
        const presentChars: string[] = [];

        for (const meta of presentMetas) {
            // [vNEXT] Under a dynamic cap, only inject per-character dynamics for chars
            // within the cap. Others still appear in the roster line, just without a
            // (possibly stale) dynamics detail line.
            if (_wsDynCap > 0 && !_wsDynAllowed.has(meta.id)) continue;
            const char = await loadCharacter(meta.id);
            if (!char) continue;

            // [v0.9.30 HOOK-TIER] Ambient hooks (<60) remain available via the
            // |hookDescription| macro but are omitted from the default template;
            // 60-84 promote to the Scene Drama block and 85+ to the Imperative block.
            let hookDesc = '';
            if (char.hooks && char.hooks.length > 0 && !char.hooks[0].resolved && char.hooks[0].pressureLevel < 60) {
                hookDesc = char.hooks[0].description;
            }

            const npcData = Object.assign({}, char, buildCharMacroExtras(char, cfg), { hookDescription: hookDesc });
            const block = parseMacroTemplate(cfg.contextTemplates.npc, npcData).trim();
            // Drop a character whose line rendered to nothing but their bare name —
            // they have no dynamics worth a detail line and the roster already lists them.
            if (!block || block === (char.name || '').trim()) continue;
            presentChars.push(block);
        }

        if (presentChars.length > 0) {
            parts.push(presentChars.join('\n'));
        }
    } catch (e) { api.v1.error('[AE:context] buildWorldStateBlock scene chars:', e); }

    return parts.join('\n\n');
}

async function buildTrackedNarrativeBlock(narrId: string, cfg: GlobalConfig): Promise<string> {
    try {
        const narr = await loadEntity(narrId);
        if (!narr) return '';
        let pathNamesStr = '';
        if (narr.questTarget) {
            const entIdx = await loadEntityIndex();
            const qtTgt = entIdx.find(m => m.id === narr.questTarget);
            if (qtTgt) {
                const curLoc = await loadPlayerLocation();
                const navId = qtTgt.type === 'location' ? qtTgt.id : (qtTgt.parentId || '');
                if (curLoc && navId) {
                    const path = await findTravelPath(curLoc, navId);
                    if (path && path.length > 0) {
                        pathNamesStr = path.map(id => {
                            const m = entIdx.find(n => n.id === id);
                            return m ? m.name : id;
                        }).join(' → ');
                        if (qtTgt.type !== 'location') pathNamesStr += ' → ' + qtTgt.name;
                    }
                }
            }
        }
        let _countdown = '';
        if (typeof narr.eventDayTarget === 'number') {
            let _clkTN = await loadClock(cfg);
            let _due = Math.floor(narr.eventDayTarget) - clockAbsoluteDay(_clkTN.hours);
            if (_due > 1) _countdown = '(' + _due + ' days remaining)';
            else if (_due === 1) _countdown = '(1 day remaining)';
            else if (_due === 0) _countdown = '(due today)';
            else _countdown = '(overdue by ' + (-_due) + (_due === -1 ? ' day' : ' days') + ')';
        }
        const data = {
            name: narr.name,
            description: narr.description,
            storyState: narr.storyState,
            pathNames: pathNamesStr,
            countdown: _countdown
        };
        let _tnBlock = parseMacroTemplate(cfg.contextTemplates.trackedNarrative, data).trim();
        if (_countdown && _tnBlock.indexOf(_countdown) < 0) _tnBlock = (_tnBlock ? _tnBlock + ' ' : '') + _countdown;
        return _tnBlock;
    } catch (e) {
        api.v1.error('[AE:context] buildTrackedNarrativeBlock:', e);
        return '';
    }
}

async function buildDramaContextBlock(): Promise<string> {
    const cfg = await loadConfig();
    const index = await loadIndex();
    const presentChars: CharacterRecord[] = [];

    for (const meta of index) {
        if (!meta.active || !meta.scenePresent) continue;
        if ((meta as any).npcClass === 'minor') continue;
        const c = await loadCharacter(meta.id);
        if (c) presentChars.push(c);
    }

    const lines: string[] = [];

    // Urgent hooks (60–84%) — scene-present characters
    for (const c of presentChars) {
        if (!c.hooks || c.hooks.length === 0) continue;
        const h = c.hooks[0];
        if (!h.resolved && h.pressureLevel >= 60 && h.pressureLevel < 85) {
            lines.push(`${c.name} — ${h.description}`);
        }
    }

    // Background NPC web (priority < 70, both parties present)
    const web = await loadNpcWeb();
    const backgroundLinks = web
        .filter(function(link) {
            const aPresent = presentChars.some(function(c) { return c.id === link.charA_id; });
            const bPresent = presentChars.some(function(c) { return c.id === link.charB_id; });
            return aPresent && bPresent && link.priority < 70 && link.dynamic.trim() !== '';
        })
        .sort(function(a, b) { return b.priority - a.priority; });

    for (const link of backgroundLinks) {
        const cA = presentChars.find(function(c) { return c.id === link.charA_id; });
        const cB = presentChars.find(function(c) { return c.id === link.charB_id; });
        if (cA && cB) {
            const webData = { charA_name: cA.name, charB_name: cB.name, dynamic: link.dynamic };
            const webBlock = parseMacroTemplate(cfg.contextTemplates.npcWeb, webData).trim();
            if (webBlock) lines.push(webBlock);
        }
    }

    // Active narrative nodes (story threads in play).
    // [v0.9.28 INJ1] Skip the tracked narrative here — it is injected separately via
    // the trackedNarrative template in onBeforeContextBuild, so including it in this
    // active loop would double-inject it.
    // [v0.9.30 INJ2] Active-narrative loop removed - only the tracked narrative injects
    // (above, via the trackedNarrative template). Listing every active narrative here
    // leaked multiple objectives into context, including a just-untracked one after the
    // player switched which quest was tracked.

    if (lines.length === 0) return '';
    return `[ Scene ]\n${lines.join('\n')}`;
}



// ============================================================================
// SECTION 14 — [RETIRED] legacy freeform #tag 1d6 skill-check system.
// Removed [vNEXT]: typing #force etc. directly in the story box no longer rolls.
// All skill checks now run through the Quick Action composer (2d6 fail-forward +
// the Stakes library below). UNIVERSAL_OUTCOMES / DEFAULT_OUTCOME_BANDS / rollD6 /
// getUniversalOutcome / getConsumedRoll / markRollConsumed removed with it.
// ============================================================================

// ============================================================================
// SECTION 15 — DYNAMIC ENGINE
//
// All AI generation that runs AFTER a story generation completes. This is the
// "background engine" — it updates character states (ephemeral thoughts,
// mid-range dynamics, arcs, hooks) based on the new story content.
//
// Execution order in runDynamicEngine (per character, per turn):
//   1. Retry queue — flushes characters deferred from previous budget-limited turn
//   2. Per character (active, non-protagonist, non-static):
//      a. Ephemeral thoughts (interval: thoughtIntervalTokens, ~600)
//      b. Mid-range dynamics (interval: dynamicIntervalTokens, ~1200)
//      c. Arc + Relationship update (interval: arcIntervalTokens, ~3000)
//      d. Hook update or spawn (interval: hookIntervalTokens, ~1800)
//
// Budget gates: checks api.v1.script.getAllowedOutput() before dispatching.
// If budget < threshold, the character is queued in STORAGE_RETRY_CHARS for
// the next generation rather than blocking this one.
//
// HELPERS IN THIS SECTION:
//   extractJSON, extractJSONArray     — GLM output parsers
//   getRecentStoryText                — story context reader
//   generateFieldContent              — character field AI generator
//   buildCharacterStateContext        — assembles character state for generator prompts
//   generateArcMilestones             — milestone generator (called from UI)
// ============================================================================

// ── GLM Output Parsers ────────────────────────────────────────────────────────

function extractJSON(text: string): any {
    // Attempts multiple strategies to parse a JSON object from model output.
    // GLM sometimes omits the outer braces or wraps output in markdown fences.
    if (!text) return null;
    let clean = text.trim();

    // Fallback: model responded with key-value pairs missing the opening brace
    if (clean.startsWith('"') && !clean.includes('{')) {
        clean = '{' + clean;
        if (!clean.endsWith('}')) clean += '}';
    }

    try { return JSON.parse(clean); } catch {}
    try { const stripped = clean.replace(/```json\s*/gi, '').replace(/```\s*/gi, '').trim(); return JSON.parse(stripped); } catch {}
    try {
        const s = clean.indexOf('{'); const e = clean.lastIndexOf('}');
        if (s !== -1 && e !== -1 && e > s) return JSON.parse(clean.substring(s, e + 1));
    } catch (e) {}

    api.v1.log('[AE:engine] extractJSON failed on:', text.slice(0, 80));
    return null;
}

function extractJSONArray(text: string): any[] | null {
    // Attempts multiple strategies to parse a JSON array from model output.
    if (!text) return null;
    let clean = text.trim();

    // Fallback: model output a single object instead of an array
    if (clean.startsWith('{') && !clean.startsWith('[')) clean = '[' + clean + ']';

    try { return JSON.parse(clean); } catch {}
    try { const stripped = clean.replace(/```json\s*/gi, '').replace(/```\s*/gi, '').trim(); return JSON.parse(stripped); } catch {}
    try {
        const s = clean.indexOf('['); const e = clean.lastIndexOf(']');
        if (s !== -1 && e !== -1 && e > s) return JSON.parse(clean.substring(s, e + 1));
    } catch (e) {}

    api.v1.log('[AE:engine] extractJSONArray failed on:', text.slice(0, 80));
    return null;
}

// ── Story Context Reader ──────────────────────────────────────────────────────

// [v0.9.7.0 CYOA] Intent-based CYOA option generation. The bridge's left tray picks a
// mode (action/dialog/mix); the engine builds the matching system prompt from the
// protagonist profile + recent story, runs one yoink generation, and parses exactly four
// second-person archetypal options. The chosen option is then run as a transient Quick
// Action by the bridge (RUN_QUICK_INSTANCE), so no new execution path is needed.
const CYOA_MODE_SPECS: Record<string, { engineName: string; label: string; focus: string; diversity: string }> = {
    action: {
        engineName: 'Action CYOA Engine',
        label: 'physical, action-oriented',
        focus: 'Physical movement, combat, stealth, or object manipulation. NO spoken dialogue or social gestures.',
        diversity:
            '- Option 1 [aggressive]: Direct force, attacking, or confronting a physical threat.\n' +
            '- Option 2 [evasive]: Defense, dodging, taking cover, stealth, or escape.\n' +
            '- Option 3 [environmental]: Interact with an object or use the physical layout of the scene.\n' +
            '- Option 4 [wildcard]: A state-driven, impulsive physical move dictated by how this character would emotionally react to this exact context.'
    },
    dialog: {
        engineName: 'Social CYOA Engine',
        label: 'social or interpersonal',
        focus: 'Speaking, tone of voice, persuasion, body language, or social gestures. NO combat or purely physical travel.',
        diversity:
            '- Option 1 [diplomatic]: Speak calmly, negotiate, show empathy, or de-escalate.\n' +
            '- Option 2 [manipulative]: Lie, bluff, threaten, or socially coerce.\n' +
            '- Option 3 [inquisitive]: Ask a pointed question or demand information.\n' +
            '- Option 4 [wildcard]: An expressive social gesture (a glare, a laugh, a dismissive wave) or an emotionally charged outburst driven by this character\u2019s current state.'
    },
    mix: {
        engineName: 'General CYOA Engine',
        label: 'balanced',
        focus: 'A balanced mix of action, dialogue, and interaction types.',
        diversity:
            '- Option 1 [direct]: The most straightforward or direct way to advance the scene.\n' +
            '- Option 2 [tactical]: A cautious, stealthy, defensive, or diplomatic approach.\n' +
            '- Option 3 [clever]: Trickery, environmental elements, or items.\n' +
            '- Option 4 [wildcard]: An option heavily driven by this character\u2019s internal state, personality, or implied emotional reaction.'
    }
};

// Compact protagonist profile for CYOA prompts: stable identity + live emotional state.
function buildCyoaCharacterProfile(char: CharacterRecord): string {
    let lines: string[] = [];
    if (char.name) lines.push('Name: ' + char.name);
    let occ = (char as any).occupationRole || '';
    if (occ) lines.push('Role: ' + occ);
    let brief = (char as any).briefDescription || '';
    if (brief) lines.push('Description: ' + brief);
    let pers = (char as any).personalityCore || '';
    if (pers) lines.push('Personality: ' + pers);
    let voice = (char as any).voiceAndMannerisms || '';
    if (voice) lines.push('Voice & mannerisms: ' + voice);
    let state = buildCharacterStateContext(char);
    if (state.trim()) lines.push('Current state:\n' + state.trim());
    return lines.join('\n');
}

// Parse model output into up to four {id,type,text} options. Strict JSON first, then a
// fallback that scrapes quoted "text" values, then second-person lines.
function parseCyoaOptions(raw: string): { id: number; type: string; text: string }[] {
    let out: { id: number; type: string; text: string }[] = [];
    let str = (raw || '').trim();
    if (!str) return out;
    str = str.replace(/```json/gi, '').replace(/```/g, '').trim();
    let lb = str.indexOf('[');
    let rb = str.lastIndexOf(']');
    if (lb >= 0 && rb > lb) {
        let slice = str.slice(lb, rb + 1);
        try {
            let arr = JSON.parse(slice);
            if (Array.isArray(arr)) {
                for (let i = 0; i < arr.length; i++) {
                    let it = arr[i] || {};
                    let txt = String(it.text || '').trim();
                    if (txt) out.push({ id: out.length + 1, type: (String(it.type || '').trim() || 'option'), text: txt });
                }
            }
        } catch (eCyJson) { out = []; }
    }
    if (!out.length) {
        let m: RegExpExecArray | null;
        let re = /"text"\s*:\s*"([^"]+)"/g;
        while ((m = re.exec(str)) !== null) {
            let t = (m[1] || '').trim();
            if (t) out.push({ id: out.length + 1, type: 'option', text: t });
        }
    }
    if (!out.length) {
        let lines = str.split('\n');
        for (let i = 0; i < lines.length; i++) {
            let t = lines[i].replace(/^[^A-Za-z]+/, '').trim();
            if (/^you\b/i.test(t)) out.push({ id: out.length + 1, type: 'option', text: t });
        }
    }
    return out.slice(0, 4);
}

async function generateCyoaOptions(mode: string, profile: string, story: string): Promise<{ id: number; type: string; text: string }[]> {
    let spec = CYOA_MODE_SPECS[mode] || CYOA_MODE_SPECS.mix;
    let sys = [
        'You are the ' + spec.engineName + ' for a text-based RPG. Analyze the recent narrative and the character profile, then generate exactly 4 distinct ' + spec.label + ' choices.',
        'RULES:\n1. Style: Second-person ("You..."). Max 15 words each. Describe the attempt, not the outcome.\n2. Focus: ' + spec.focus + '\n3. Output: Respond ONLY with a valid JSON array of 4 objects, each {"id":<n>,"type":"<archetype>","text":"You..."}. No prose, no markdown, no code fences.',
        'REQUIRED DIVERSITY:\n' + spec.diversity
    ].join('\n\n');
    let usr = [
        '<Character_Profile>\n' + (profile || '(none available)') + '\n</Character_Profile>',
        '<Context>\n' + (story || '(the story has not started yet)') + '\n</Context>',
        'Output the JSON array of 4 options now.'
    ].join('\n\n');
    let raw = '';
    // [v0.9.7.3 CYOA-FIX] Retry up to 3 times with 600ms gap if the editor is busy
    // (ae_genInFlight||ae_lock from the dynamic engine running after a story gen).
    // executeYoinkGeneration rejects immediately when busy rather than queuing, so
    // we poll rather than deadlock.
    let cyAttempt = 0;
    while (cyAttempt < 3) {
        cyAttempt++;
        try {
            raw = await executeYoinkGeneration([{ role: 'system', content: sys }, { role: 'user', content: usr }]);
            break; // success
        } catch (eCyGen) {
            let cyMsg = String((eCyGen as any).message || eCyGen);
            if (cyAttempt < 3 && (cyMsg.includes('busy') || cyMsg.includes('progress'))) {
                api.v1.log('[AE:cyoa] editor busy, retrying (' + cyAttempt + '/3)…');
                await api.v1.timers.sleep(600);
            } else {
                api.v1.error('[AE:cyoa] generation failed after ' + cyAttempt + ' attempt(s):', eCyGen);
                return [];
            }
        }
    }
    return parseCyoaOptions(raw);
}

async function getRecentStoryText(maxTokens: number): Promise<string> {
    // Returns the most recent story text fitting within maxTokens.
    // Reads backward from the end so the freshest content is always included.
    try {
        const ids = await api.v1.document.sectionIds();
        if (ids.length === 0) return '';
        const si       = Math.max(0, ids.length - Math.ceil(maxTokens / 10) - 20);
        const sections = await api.v1.document.scan(undefined, { from: ids[si] });
        let text = ''; let used = 0;
        for (let i = sections.length - 1; i >= 0; i--) {
            const t = sections[i].section?.text || '';
            if (!t.trim()) continue;
            const enc = await api.v1.tokenizer.encode(t, 'glm-4-6');
            if (used + enc.length > maxTokens) break;
            text = t + '\n\n' + text;
            used += enc.length;
        }
        return text.trim();
    } catch { return ''; }
}

// [v0.9.8.6] Orchestration wrapper for CYOA generation, shared by the bridge
// AE_CYOA_GENERATE handler and the native CYOA modal. Normalizes the mode
// (action | dialog | mix), assembles protagonist profile + recent story, and
// returns the generated options WITHOUT broadcasting — the caller decides how to
// surface them. generateCyoaOptions() itself is unchanged.
async function prepareCyoaOptions(mode: string): Promise<{ mode: string; options: { id: number; type: string; text: string }[] }> {
    let cyMode = (mode === 'action' || mode === 'dialog' || mode === 'mix') ? mode : 'mix';
    let cyIdx = await loadIndex();
    let cyProtagMeta = cyIdx.find(function(m) { return !!(m as any).isProtagonist; });
    let cyProtag = cyProtagMeta ? await loadCharacter(cyProtagMeta.id) : null;
    let cyProfile = cyProtag ? buildCyoaCharacterProfile(cyProtag) : '';
    let cyStory = await getRecentStoryText(1500);
    let cyOptions = await generateCyoaOptions(cyMode, cyProfile, cyStory);
    return { mode: cyMode, options: cyOptions };
}

// ── Character Field Generator ─────────────────────────────────────────────────

async function generateFieldContent(
    char: CharacterRecord,
    fieldLabel: string,
    instructions: string,
    generalStyle: string,
    hint: string,
    maxTokens: number
): Promise<string | null> {
    // Generates content for a single character field using GLM.
    // Used by the character editor's auto-generate buttons.
    // NOTE: waitForAllowedOutput is intentionally absent — this runs from modal
    // button callbacks where the signal never fires (deadlock risk).
    const recentText  = await getRecentStoryText(2000);
    const targetWords = Math.max(20, Math.floor(maxTokens * 0.75));

    const sys = [
        generalStyle,
        `You are writing the "${fieldLabel}" field for a character. This field has specific scope — stay inside it.`,
        instructions,
        `CONSTRAINT: Strictly under ~${targetWords} words. Finish your thought completely. ` +
        `Your output must be the content itself — do not begin with a label, header, or category name. ` +
        `Outputs that begin with words like "Voice:", "Appearance:", "Core Drive:", or any descriptor of what follows are invalid. ` +
        `Your first word must be content.`
    ].filter(Boolean).join('\n\n');

    const usrParts: string[] = [
        `Character: ${char.name}`,
        char.briefDescription ? `Anchor (do not contradict): ${char.briefDescription}` : '',
        char.conceptDump?.trim()
            ? `Reference notes (extract only what is directly relevant to the ${fieldLabel} field — ignore the rest):\n${char.conceptDump.trim()}`
            : '',
        hint?.trim() ? `Focus constraint: ${hint.trim()}` : '',
        recentText   ? `Recent story context:\n${recentText}` : '',
        `\nNow write the ${fieldLabel} field for ${char.name}.`
    ];

    try {
        const resp = await api.v1.generate(
            [{ role: 'system', content: sys }, { role: 'user', content: usrParts.filter(Boolean).join('\n\n') }],
            { model: 'glm-4-6', max_tokens: maxTokens + 30, temperature: 0.8 }
        );
        return (resp.choices[0]?.text || '').trim() || null;
    } catch (e) {
        api.v1.error('[AE:engine] generateFieldContent:', e);
        return null;
    }
}

// ── Character State Context Builder ──────────────────────────────────────────

function buildCharacterStateContext(char: CharacterRecord): string {
    // Assembles a compact multi-line summary of a character's current dynamic state.
    // Passed as context to all generator prompts so GLM can update fields correctly.
    const lines: string[] = [];

    if (char.ephemeral && char.ephemeral.compressedLine) {
        lines.push(`Current moment (${char.name}): "${char.ephemeral.compressedLine}"`);
        if (char.ephemeral.eventAnchor)     lines.push(`  → Triggered by: ${char.ephemeral.eventAnchor}`);
        if (char.ephemeral.immediateDesire) lines.push(`  → Driving them to: ${char.ephemeral.immediateDesire}`);
    }
    if (char.midRange) {
        if (char.midRange.currentDesire) lines.push(`Current Desire: ${char.midRange.currentDesire}`);
        if (char.midRange.socialMask)    lines.push(`Social Mask: ${char.midRange.socialMask}`);
        if (char.midRange.shiftedView)   lines.push(`Shifted View: ${char.midRange.shiftedView}`);
    }
    return lines.join('\n');
}

// ── Generators ────────────────────────────────────────────────────────────────

async function generateEphemeral(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number = 0 // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    try {
        const recentText = await getRecentStoryText(1500);
        const sys = [
            cfg.generalStyle,
            `Generate a three-part internal snapshot for ${char.name} based on the current moment.`,
            // [v0.9.33 AIR1] Explicit isolation: when multiple characters are present,
            // each generation call must produce only this character's perspective.
            `Focus exclusively on ${char.name}. Do not generate, reference, or echo the internal states, reactions, or thoughts of any other character present in the scene.`,
            `Return ONLY valid JSON with these exact keys:`,
            `  "eventAnchor": The specific concrete thing they are reacting to right now. Capitalized. Ends with a period. No abstractions.`,
            `    Bad: "the tension in the room.". Good: "The way he looked away when I asked.".`,
            `  "emotionalResponse": How it landed, in ${char.name}'s own voice. Capitalized. Ends with a period. Specific, no emotion-label words like 'felt' or 'angry'. Do not use their name.`,
            `    Bad: "She felt betrayed.". Good: "Second time this week he's done this.".`,
            `  "immediateDesire": A verb phrase stating what ${char.name} intends right now. Capitalized. Ends with a period. Under 10 words. No name prefix.`,
            `    Bad: "Wants closure.". Good: "Find the source and burn it out.".`,
            `No markdown fences. No extra keys. Return nothing but the JSON object.`
        ].join('\n');

        const ephHistLines = (char.ephemeralHistory || []).slice(0, 2)
            .map(function(h: any) { return h.compressedLine || ''; }).filter(Boolean);

        const usr = [
            `Character: ${char.name}`,
            char.personalityCore       ? `Personality: ${char.personalityCore}` : '',
            char.voiceAndMannerisms    ? `Voice/manner: ${char.voiceAndMannerisms}` : '',
            char.midRange?.currentDesire ? `Current goal: ${char.midRange.currentDesire}` : '',
            char.midRange?.socialMask  ? `Performing: ${char.midRange.socialMask}` : '',
            char.primaryRelationship?.enabled && char.primaryRelationship?.targetName
                ? `Primary relationship (${char.primaryRelationship.targetName}): ${char.primaryRelationship.currentStatus || 'unresolved'}` : '',
            ephHistLines.length > 0    ? `Previous thoughts (do not repeat): ${ephHistLines.join(' / ')}` : '',
            recentText                 ? `\nRecent Story:\n${recentText}` : '',
            '\n```json\n'
        ].filter(Boolean).join('\n');

        const resp   = await api.v1.generate(
            [{ role: 'system', content: sys }, { role: 'user', content: usr }],
            { model: 'glm-4-6', max_tokens: 220, temperature: 0.85 }
        );
        const parsed = extractJSON(resp.choices[0]?.text || '');
        if (!parsed || (!parsed.eventAnchor && !parsed.emotionalResponse && !parsed.immediateDesire)) return false;

        const fresh = await loadCharacter(char.id);
        if (!fresh) return false;

        const _ea = String(parsed.eventAnchor       || '').trim();
        const _er = String(parsed.emotionalResponse || '').trim();
        const _id = String(parsed.immediateDesire   || '').trim();
        const _composed: string = (_ea || _er || _id)
            ? [_ea, _er, _id].filter(Boolean).join(' — ')
            : String(parsed.compressedLine || '').trim();

        const snapshot: EphemeralSnapshot = {
            eventAnchor: _ea, emotionalResponse: _er, immediateDesire: _id,
            compressedLine: _composed, generatedAtGen: genCount // [v0.9.24 E1]
        };

        fresh.ephemeral        = snapshot;
        fresh.ephemeralHistory = [snapshot, ...(fresh.ephemeralHistory || [])].slice(0, Number(cfg.ephemeralCap) || 3);
        fresh.lastEphemeralGen = genCount; // [v0.9.24 E1]
        await saveCharacter(fresh);
        await refreshSidebar();
        return true;
    } catch (e) {
        api.v1.error('[AE:engine] generateEphemeral:', e);
        return false;
    }
}

async function generateMidRange(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number = 0 // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    try {
        const recentText  = await getRecentStoryText(3000);
        const charState   = char.ephemeral ? `Recent moment: "${char.ephemeral.compressedLine}"` : '';

        const sys = [
            cfg.generalStyle,
            `Update the dynamic profile layer for ${char.name}. These three fields must be genuinely different from each other — they answer different questions.`,
            ``,
            `"currentDesire": ${char.name}'s current overarching goal — a sustained objective shaping decisions across scenes or days, not a momentary urge or reaction. Something they are actively working toward or protecting.`,
            `  Wrong: "survive this meeting" (too immediate)`,
            `  Wrong: "wants to feel safe" (too abstract)`,
            `  Right: "keep the garrison loyal to her until the Duke's arrival"`,
            ``,
            `"socialMask": What are they performing or projecting to other people right now, and what is actually happening underneath that performance? Name both sides.`,
            `  Wrong: "acting calm"`,
            `  Right: "playing cooperative while counting every exit"`,
            ``,
            `"shiftedView": What does ${char.name} now believe or understand that they did not before? Something the recent story has changed in how they read this situation, a person, or themselves. Must name something specific.`,
            `  Wrong: "more wary of everyone"`,
            `  Right: "the steward knew about the missing shipment — which means someone told him"`,
            ``,
            `Return ONLY valid JSON with exactly these three keys. One sentence each. No abstractions. No emotion-label words.`,
            `Each field: capitalize the first word, end with a period. Do not use the word 'currently'.`,
            `No markdown fences.`
        ].join('\n');

        const midEphContext: string[] = [];
        if (char.ephemeral?.eventAnchor)       midEphContext.push(`Reacting to: ${char.ephemeral.eventAnchor}`);
        if (char.ephemeral?.emotionalResponse)  midEphContext.push(`Felt: ${char.ephemeral.emotionalResponse}`);
        if (char.ephemeral?.immediateDesire)    midEphContext.push(`Immediate drive: ${char.ephemeral.immediateDesire}`);

        const usr = [
            `Character: ${char.name}`,
            char.personalityCore ? `Core personality: ${char.personalityCore}` : '',
            char.primaryRelationship?.enabled && char.primaryRelationship?.archetype
                ? `Primary relationship archetype (${char.primaryRelationship.targetName}): ${char.primaryRelationship.archetype}` : '',
            midEphContext.length > 0 ? `Immediate state:\n${midEphContext.join('\n')}` : charState,
            char.midRange?.currentDesire ? `Previous goal: ${char.midRange.currentDesire}` : '',
            char.midRange?.socialMask    ? `Previous mask: ${char.midRange.socialMask}` : '',
            char.midRange?.shiftedView   ? `Previous shifted view: ${char.midRange.shiftedView}` : '',
            recentText ? `\nRecent Story:\n${recentText}` : '',
            '\n```json\n'
        ].filter(Boolean).join('\n');

        const resp   = await api.v1.generate(
            [{ role: 'system', content: sys }, { role: 'user', content: usr }],
            { model: 'glm-4-6', max_tokens: 220, temperature: 0.8 }
        );
        const result = extractJSON(resp.choices[0]?.text || '');
        if (!result) return false;

        const fresh = await loadCharacter(char.id);
        if (!fresh) return false;

        fresh.midRange = {
            currentDesire:   String(result.currentDesire  || fresh.midRange?.currentDesire  || '').trim(),
            socialMask:      String(result.socialMask     || fresh.midRange?.socialMask     || '').trim(),
            shiftedView:     String(result.shiftedView    || fresh.midRange?.shiftedView    || '').trim(),
            updatedAtGen: genCount // [v0.9.24 E1]
        };
        fresh.lastMidrangeGen = genCount; // [v0.9.24 E1]
        await saveCharacter(fresh);
        await refreshSidebar();
        return true;
    } catch (e) {
        api.v1.error('[AE:engine] generateMidRange:', e);
        return false;
    }
}

async function generateRelationshipUpdate(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    if (!char.primaryRelationship.targetName) {
        api.v1.ui.toast('Requires a Target Name first.', { type: 'warning' });
        return false;
    }
    const rel        = char.primaryRelationship;
    const recentText = await getRecentStoryText(5000);
    const charState  = buildCharacterStateContext(char);

    const sys = [
        cfg.generalStyle,
        `Update the relationship between ${char.name} and ${rel.targetName}. These three fields answer different questions — do not let them overlap.`,
        ``,
        `"currentStatus": What does their interaction LOOK LIKE right now? Describe only observable surface behavior — how they speak to each other, how they occupy space together, what they do when they're in the same room. No inner states. No 'feels'.`,
        `  Wrong: "tension and unspoken resentment"`,
        `  Right: "formal in public, doesn't finish sentences when they're alone"`,
        ``,
        `"trajectory": What specific FORCE or recent event is pushing this relationship somewhere? Name the thing that changed — an action, a revelation, a silence. Not where it's going — what is pushing it.`,
        `  Wrong: "moving toward inevitable confrontation"`,
        `  Right: "the lie about the letter is still sitting between them, unaddressed"`,
        ``,
        `"summary": The CORE INCOMPATIBILITY. What does ${char.name} need from ${rel.targetName} that ${rel.targetName} cannot or will not give? Or vice versa. The structural knot that makes this relationship charged.`,
        `  Wrong: "complicated feelings"`,
        `  Right: "she needs him to choose her over the mission; he can't make that promise"`,
        ``,
        `One sentence each. No markdown fences. Return ONLY valid JSON with exactly these three keys.`
    ].join('\n');

    const relStageName = resolveArchetypeStage(cfg, rel);
    const usr = [
        rel.archetype     ? `Archetype: ${rel.archetype}${relStageName ? ' (current stage: ' + relStageName + ')' : ''}` : '',
        rel.howItStarted  ? `Origin: ${rel.howItStarted}` : '',
        rel.threads.filter(Boolean).length > 0 ? `Active threads: ${rel.threads.filter(Boolean).join('; ')}` : '',
        rel.currentStatus ? `Previous status: ${rel.currentStatus}` : '',
        charState         ? `${char.name}'s current state:\n${charState}` : '',
        recentText        ? `\nRecent Story:\n${recentText}` : '',
        '\n```json\n'
    ].filter(Boolean).join('\n');

    try {
        const resp   = await api.v1.generate(
            [{ role: 'system', content: sys }, { role: 'user', content: usr }],
            { model: 'glm-4-6', max_tokens: 200, temperature: 0.75 }
        );
        const parsed = extractJSON(resp.choices[0]?.text || '');
        if (!parsed) return false;

        const ch = await loadCharacter(char.id);
        if (!ch) return false;

        ch.primaryRelationship.currentStatus = String(parsed.currentStatus || rel.currentStatus || '').substring(0, 400);
        ch.primaryRelationship.trajectory    = String(parsed.trajectory    || rel.trajectory    || '').substring(0, 400);
        ch.primaryRelationship.summary       = String(parsed.summary       || rel.summary       || '').substring(0, 600);
        ch.lastArcGen = genCount; // [v0.9.24 E1]
        await saveCharacter(ch);
        return true;
    } catch (e) {
        api.v1.log('[AE:engine] generateRelationshipUpdate:', e);
        return false;
    }
}

async function generateEventSummary(char: CharacterRecord, cfg: GlobalConfig): Promise<string | null> {
    const recentText = await getRecentStoryText(3000);
    const sys = `${cfg.generalStyle}\n\nWrite a single-sentence summary of the most significant recent event affecting ${char.name}. Past tense. Concrete and specific. Under 25 words.`;
    const usr = recentText ? `Recent story:\n${recentText}` : 'No story text available.';
    try {
        const resp = await api.v1.generate(
            [{ role: 'system', content: sys }, { role: 'user', content: usr }],
            { model: 'glm-4-6', max_tokens: 60, temperature: 0.7 }
        );
        return (resp.choices[0]?.text || '').trim() || null;
    } catch (e) { api.v1.error('[AE:engine] generateEventSummary:', e); return null; }
}

async function generateHookUpdates(
    char: CharacterRecord,
    cfg: GlobalConfig,
    genCount: number // [v0.9.24 E1] was tokenCount
): Promise<boolean> {
    const recentText = await getRecentStoryText(4000);
    if (!recentText) return false;
    const charState = buildCharacterStateContext(char);

    // SCENARIO 1: Update existing hook (the escalator)
    if (char.hooks && char.hooks.length > 0) {
        const hook = char.hooks[0];
        const sys = [
            `Evaluate ${char.name}'s active tension regarding ${hook.targetName}.`,
            `Current hook: "${hook.description}" (Pressure: ${hook.pressureLevel}%)`,
            ``,
            `1. PRESSURE: Adjust "pressureLevel" (0-100) based on what actually happened. Did something force it closer to confrontation, or did it cool? Be specific.`,
            ``,
            `2. REWRITE: Rewrite "description" as a single sentence that reflects the current state. The tone MUST match the pressure tier:`,
            `   0-59 (Latent): Observational. Something noticed, not yet acted on. ("Still hasn't asked why she lied about the docks.")`,
            `   60-84 (Urgent): Active. Demands action, can't be ignored. ("Has to confront him before he tells the captain what he saw.")`,
            `   85-100 (Critical): Explosive. Desperate, do-or-die imperative. ("End this before he destroys everything — one way or another.")`,
            ``,
            `Return ONLY valid JSON: {"pressureLevel": 50, "description": "..."}. No isResolved field needed.`,
            `No markdown fences.`
        ].join('\n');

        const usr = [
            charState ? `${char.name}'s current state:\n${charState}` : '',
            `Story:\n${recentText}`,
            '\n```json\n'
        ].filter(Boolean).join('\n\n');

        try {
            const resp   = await api.v1.generate(
                [{ role: 'system', content: sys }, { role: 'user', content: usr }],
                { model: 'glm-4-6', max_tokens: 200, temperature: 0.6 }
            );
            const update = extractJSON(resp.choices[0]?.text || '');
            if (!update) return false;

            const f = await loadCharacter(char.id);
            if (!f) return false;

            const targetHook = f.hooks[0];

            // Surface detection (≥85% only) — two consecutive YES clears the hook
            if (targetHook.pressureLevel >= 85 && recentText) {
                const hookWords = [targetHook.targetName, ...targetHook.description.split(' ')]
                    .filter(function(w) { return w && w.length > 3; })
                    .map(function(w) { return w.toLowerCase().replace(/[^a-z]/g, ''); })
                    .filter(Boolean);
                const recentLower = recentText.toLowerCase();
                const matchCount  = hookWords.filter(function(w) { return recentLower.includes(w); }).length;
                const surfaced    = matchCount >= Math.max(2, Math.floor(hookWords.length * 0.3));
                if (surfaced) {
                    const prevCount = targetHook.surfacedCount || 0;
                    if (prevCount >= 1) {
                        // Second YES — hook surfaced and lingered. Clear it, queue a new spawn.
                        f.hooks = [];
                        f.lastHookGen = genCount; // [v0.9.24 E1]
                        await saveCharacter(f);
                        api.v1.ui.toast('🔥 ' + char.name + ': hook surfaced — ' + hook.description.substring(0, 50), { type: 'success', autoClose: 4000 });
                        const _hr = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
                        const _hi: string[] = JSON.parse(_hr);
                        if (!_hi.includes(char.id + ':hook')) { _hi.push(char.id + ':hook'); await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, JSON.stringify(_hi)); }
                        return true;
                    } else {
                        targetHook.surfacedCount = 1;
                        api.v1.log('[AE:engine] Hook surfaced (1/2) for ' + char.name + ': ' + hook.description.substring(0, 40));
                    }
                } else {
                    targetHook.surfacedCount = 0;
                }
            }

            targetHook.pressureLevel = Math.min(100, Math.max(0, Number(update.pressureLevel) || targetHook.pressureLevel));
            if (update.description && update.description.trim() !== '') {
                targetHook.description = update.description.substring(0, 300);
            }
            f.lastHookGen = genCount; // [v0.9.24 E1]
            await saveCharacter(f);
            return true;
        } catch (e) {
            api.v1.log('[AE:engine] generateHookUpdates escalator error:', e);
            return false;
        }

    // SCENARIO 2: Spawn a new hook
    } else {
        const sys = [
            `Analyze the recent story for a specific, unresolved tension involving ${char.name}.`,
            ``,
            `You are looking for: a direct conflict with another person, a threat that demands response, or an urgent unfulfilled need that recent events created. Passive feelings and general mood do NOT qualify.`,
            ``,
            `If a clear tension exists, set "targetName" to the other person's name and write "description" as a single, punchy sentence naming the core conflict. Use concrete language — what happened, what is owed, what is at stake.`,
            `  Wrong: "feels betrayed by the situation"`,
            `  Right: "Cassius read the letter — he knows, and hasn't said anything yet"`,
            ``,
            `If no qualifying tension exists, set "targetName" to "None".`,
            `Set "pressureLevel" between 20-50 for a new hook (it hasn't had time to escalate).`,
            ``,
            `Return ONLY valid JSON: {"targetName": "Name or None", "description": "...", "pressureLevel": 30}`,
            `No markdown fences.`
        ].join('\n');

        const usr = [
            charState ? `${char.name}'s current state:\n${charState}` : '',
            `Story:\n${recentText}`,
            '\n```json\n'
        ].filter(Boolean).join('\n\n');

        try {
            const resp  = await api.v1.generate(
                [{ role: 'system', content: sys }, { role: 'user', content: usr }],
                { model: 'glm-4-6', max_tokens: 200, temperature: 0.65 }
            );
            const spawn = extractJSON(resp.choices[0]?.text || '');
            if (!spawn || !spawn.targetName || spawn.targetName.toLowerCase() === 'none') return false;

            const f = await loadCharacter(char.id);
            if (!f) return false;

            f.hooks = [{
                id:           api.v1.uuid(),
                targetName:   spawn.targetName.substring(0, 50),
                description:  String(spawn.description || '').substring(0, 300),
                pressureLevel: Math.min(100, Math.max(0, Number(spawn.pressureLevel) || 30)),
                developmentNotes: [],
                resolved: false
            }];
            f.lastHookGen = genCount; // [v0.9.24 E1]
            await saveCharacter(f);
            return true;
        } catch (e) {
            api.v1.log('[AE:engine] generateHookUpdates spawn error:', e);
            return false;
        }
    }
}

// ── Engine Orchestrator ───────────────────────────────────────────────────────

// ── AUTO-TRIGGERS ───────────────────────────────────────────────────────────
// Scans scene-present entities for ActionInstances flagged autoTrigger, evaluates
// their conditions, and fires the ones that pass. Runs post-generation (onGenerationEnd)
// so it never recurses into the active generation. Auto-triggered actions always run
// silently (no nested api.v1.editor.generate) to avoid generation-in-generation.
// ── Tag-Subscription Action Resolver ─────────────────────────────────────────
// [v0.9.86] Returns the merged action list for an entity: its manually-added
// actionInstances PLUS every library template whose tags intersect the entity's
// tagSubscriptions. Templates are returned by reference (not copied) so all
// conditions, effects, branches, and resolution data are fully intact at call time.
// Deduplication is by template id — if a user already imported a template manually
// (templateId back-ref), the live copy from cfg takes precedence over the snapshot.
function getTagSubscribedActions(ent: EntityRecord, cfg: GlobalConfig): ActionInstance[] {
    const subs: string[] = (ent as any).tagSubscriptions || [];
    if (!subs.length) return (ent as any).actionInstances || [];

    const templates: ActionInstance[] = (cfg.actionTemplates || []) as ActionInstance[];
    const manual: ActionInstance[]    = (ent as any).actionInstances || [];

    // Collect live templates whose tags overlap the subscription list.
    // Filter by appliesTo if present (same rule as the [+Action Library] picker).
    const subscribed: ActionInstance[] = [];
    const seenIds = new Set<string>();

    for (const tpl of templates) {
        const tplTags: string[] = (tpl as any).tags || [];
        if (!tplTags.some(function(t) { return subs.indexOf(t) >= 0; })) continue;
        if (tpl.appliesTo && tpl.appliesTo.length && tpl.appliesTo.indexOf(ent.type) < 0) continue;
        seenIds.add(tpl.id);
        subscribed.push(tpl);
    }

    // Merge: manual instances first (so user overrides stay on top).
    // Skip any manual instance whose templateId is already covered by a subscribed template
    // (avoids double-listing when a user imported before subscribing to the tag).
    const merged: ActionInstance[] = manual.filter(function(m) {
        return !(m.templateId && seenIds.has(m.templateId));
    });
    for (const s of subscribed) merged.push(s);

    return merged;
}

async function runAutoTriggers(): Promise<void> {
    try {
        let cfgAT = await loadConfig();
        let locId = await loadPlayerLocation();
        if (!locId) return;

        // Build the candidate entity set: current location + direct children + connections.
        let allMeta = await loadEntityIndex();
        let scanIds = new Set<string>([locId]);
        for (const m of allMeta) { if (m.parentId === locId) scanIds.add(m.id); }
        let locEnt0 = await loadEntity(locId);
        if (locEnt0 && locEnt0.connectedEntityIds) { for (const cn of locEnt0.connectedEntityIds) scanIds.add(cn.targetId); }

        // [v0.9.16] Global auto-trigger entities: fire every turn regardless of player location.
        for (const gm of allMeta) { if ((gm as any).hasGlobalAutoTrigger) scanIds.add(gm.id); }

        let firedCount = 0;
        for (const eid of Array.from(scanIds)) {
            let ent = await loadEntity(eid);
            if (!ent) continue;
            let insts = getTagSubscribedActions(ent, cfgAT).filter(function(i) { return !!(i as any).autoTrigger; });
            if (!insts.length) continue;
            // Resolve protagonist context once per entity.
            let idxAT = await loadIndex();
            let pMetaAT = idxAT.find(function(m) { return !!(m as any).isProtagonist; });
            let protagAT = pMetaAT ? await loadCharacter(pMetaAT.id) : null;
            let protagEntAT = (protagAT && (protagAT as any).entityId) ? await loadEntity((protagAT as any).entityId) : null;
            let parentAT = ent.parentId ? await loadEntity(ent.parentId) : null;
            for (const inst of insts) {
                let scopeAT: AEScope = { sourceEnt: ent, protag: protagAT, protagEnt: protagEntAT, target: null, parentEnt: parentAT, __silent: true };
                let passAT = await aeCheckConditions(inst.conditions || [], scopeAT);
                if (!passAT) continue;
                // One-shot guard so a passing auto-trigger doesn't fire every turn forever.
                if (inst.oneShot) {
                    let osKeyAT = 'ae_inst_1shot_' + ent.id + '_' + inst.id;
                    let usedAT = await api.v1.historyStorage.getOrDefault(osKeyAT, false) as boolean;
                    if (usedAT) continue;
                }
                // Resolve + effects, but never generate (silent). Mirrors runActionInstance core.
                let outcomeAT = await aeRollResolution(inst.resolution, cfgAT, protagAT);
                await preloadSpecificEnts(inst, scopeAT);
                if (outcomeAT.band && outcomeAT.band.effects) await aeApplyEffects(outcomeAT.band.effects, scopeAT, cfgAT);
                else if (outcomeAT.success) await aeApplyEffects(inst.successEffects || [], scopeAT, cfgAT);
                else await aeApplyEffects(inst.failureEffects || [], scopeAT, cfgAT);
                await aeApplyEffects((inst as any).alwaysEffects || [], scopeAT, cfgAT);
                if (inst.oneShot) await api.v1.historyStorage.set('ae_inst_1shot_' + ent.id + '_' + inst.id, true);
                // Optional GM message injection without forcing a generation.
                if (inst.outcomeNote && inst.outcomeNote.trim()) {
                    let noteAT = aeSubstituteTokens(inst.outcomeNote, scopeAT);
                    if (noteAT.trim()) await api.v1.tempStorage.set(STORAGE_PENDING_INJECT, noteAT.trim()).catch(function(_e: any) {});
                }
                firedCount++;
            }
        }
        if (firedCount > 0) {
            api.v1.log('[AE:auto] ' + firedCount + ' auto-trigger(s) fired');
            queueSceneStateBroadcast();
        }
    } catch (e) { api.v1.error('[AE:auto] runAutoTriggers error:', e); }
}

async function runDynamicEngine(): Promise<void> {
    // [v0.9.24 E1] Generation-based intervals replace token-based.
    // genCount is the story-persistent generation counter incremented in onGenerationEnd.
    let genCount = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
    genCount = Number(genCount) || 0;
    if (genCount < 1) {
        api.v1.log('[AE:engine] genCount=0, skipping dynamic engine');
        return;
    }

    ae_lock = true; // [v0.9.34 LOCK1] block travel generates while background gen runs
    api.v1.log('[AE:TRACE] dynamic engine ACQUIRED ae_lock');
    const index = await loadIndex();
    const cfg   = await loadConfig();
    const raw   = await api.v1.tempStorage.get(STORAGE_LORE_IDS) as string | undefined;
    const activeEntryIds = new Set<string>(raw ? JSON.parse(raw) : []);

    // ── Retry queue ───────────────────────────────────────────────────────────
    const _retryRaw = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
    const _retryQ: string[] = JSON.parse(_retryRaw);
    if (_retryQ.length > 0) {
        await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, '[]');
        for (const entry of _retryQ) {
            if (api.v1.script.getAllowedOutput() < 220) break;
            const [_rcId, _rcType] = entry.split(':');
            const _rc = await loadCharacter(_rcId);
            if (!_rc || _rc.isProtagonist) continue;
            if (_rcType === 'eph' && _rc.autoThoughtsEnabled) {
                const _ok = await generateEphemeral(_rc, cfg, genCount).catch(function() { return false; });
                if (_ok) api.v1.ui.toast('💭 ' + _rc.name + ': thoughts updated', { type: 'info', autoClose: 2000 });
            } else if (_rcType === 'mid' && _rc.autoUpdateEnabled) {
                const _ok2 = await generateMidRange(_rc, cfg, genCount).catch(function() { return false; });
                if (_ok2) api.v1.ui.toast('🌀 ' + _rc.name + ': dynamics updated', { type: 'info', autoClose: 2000 });
            }
        }
        api.v1.log('[AE:engine] Retry queue processed.');
    }

    api.v1.log('[AE:engine] genCount=' + genCount + ', active chars=' + index.filter(function(m: any) { return m.active; }).length);

    // [vNEXT] Dynamic-priority cap. Compute the permitted id set ONCE from the index
    // (no storage reads). When a cap is set, characters outside the top-N by rank are
    // skipped this turn without touching their records — the user's manual Static
    // toggle is untouched; they simply aren't processed while over the cap.
    const _dynCap = Number((cfg as any).maxDynamicCharacters) || 0;
    const _dynAllowed = computeDynamicAllowedSet(index as any, _dynCap);
    if (_dynCap > 0) api.v1.log('[AE:engine] dynamic cap=' + _dynCap + ', allowed=' + _dynAllowed.size);

    // ── Per-character dispatch ────────────────────────────────────────────────
    for (const meta of index.filter(Boolean)) {
        if (!meta.active) continue;
        if (meta.isProtagonist) continue;
        // [v0.9.34 PERF1] Skip storage read for chars flagged static in the index
        // (propagated there by saveCharacter since v0.9.31). Avoids a DB load per
        // static character per generation end.
        if ((meta as any).isStatic) { api.v1.log('[AE:engine] Static (index), skipping: ' + meta.name); continue; }
        // [vNEXT] Enforce the dynamic cap from the index before any storage read, so
        // a capped-out character costs nothing this turn.
        if (_dynCap > 0 && !_dynAllowed.has(meta.id)) { api.v1.log('[AE:engine] Over dynamic cap, skipping: ' + meta.name); continue; }
        const char = await loadCharacter(meta.id);
        if (!char) continue;
        if ((char as any).isStatic) { api.v1.log('[AE:engine] Static, skipping: ' + char.name); continue; }

        const relevant = charIsRelevant(char, activeEntryIds);

        // NaN-safe — old saves without gen stamps default to 0 (triggers update immediately)
        const lastEph  = Number(char.lastEphemeralGen) || 0;
        const lastMid  = Number(char.lastMidrangeGen)  || 0;
        const lastArc  = Number(char.lastArcGen)       || 0;
        const lastHook = Number(char.lastHookGen)      || 0;
        const intEph   = Number(cfg.thoughtIntervalGens)  || 2;
        const intMid   = Number(cfg.dynamicIntervalGens)  || 4;
        const intArc   = Number(cfg.arcIntervalGens)      || 10;
        const intHook  = Number(cfg.hookIntervalGens)     || 6;

        api.v1.log('[AE:engine] ' + char.name
            + ' rel=' + relevant
            + ' eph=' + char.autoThoughtsEnabled + '(' + (genCount - lastEph) + '/' + intEph + 'gen)'
            + ' mid=' + char.autoUpdateEnabled + '(' + (genCount - lastMid) + '/' + intMid + 'gen)'
            + ' budget=' + api.v1.script.getAllowedOutput());

        if (char.autoThoughtsEnabled && relevant && (genCount - lastEph) >= intEph) {
            if (api.v1.script.getAllowedOutput() >= 220) {
                const ephOk = await generateEphemeral(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Eph err:', e); return false; });
                if (ephOk) api.v1.ui.toast('💭 ' + char.name + ': thoughts updated', { type: 'info', autoClose: 2000 });
            } else {
                const _rr = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
                const _ri: string[] = JSON.parse(_rr);
                if (!_ri.includes(char.id + ':eph')) { _ri.push(char.id + ':eph'); await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, JSON.stringify(_ri)); }
            }
        }
        if (char.autoUpdateEnabled && relevant && (genCount - lastMid) >= intMid) {
            if (api.v1.script.getAllowedOutput() >= 220) {
                const midOk = await generateMidRange(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Mid err:', e); return false; });
                if (midOk) api.v1.ui.toast('🌀 ' + char.name + ': dynamics updated', { type: 'info', autoClose: 2000 });
            } else {
                const _rr2 = await api.v1.tempStorage.getOrDefault(STORAGE_RETRY_CHARS, '[]') as string;
                const _ri2: string[] = JSON.parse(_rr2);
                if (!_ri2.includes(char.id + ':mid')) { _ri2.push(char.id + ':mid'); await api.v1.tempStorage.set(STORAGE_RETRY_CHARS, JSON.stringify(_ri2)); }
            }
        }
        if (char.autoUpdateEnabled && relevant && char.primaryRelationship?.targetName && char.primaryRelationship?.enabled && (genCount - lastArc) >= intArc) {
            if (api.v1.script.getAllowedOutput() >= 200) {
                const relOk = await generateRelationshipUpdate(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Rel err:', e); return false; });
                if (relOk) api.v1.ui.toast('💞 ' + char.name + ': relationship updated', { type: 'info', autoClose: 2000 });
            }
        }
        if (char.autoUpdateEnabled && relevant && (genCount - lastHook) >= intHook) {
            if (api.v1.script.getAllowedOutput() >= 200) {
                const hookOk = await generateHookUpdates(char, cfg, genCount).catch(function(e) { api.v1.log('[AE:engine] Hook err:', e); return false; });
                if (hookOk) api.v1.ui.toast('🎯 ' + char.name + ': hook updated', { type: 'info', autoClose: 2000 });
            }
        }
    }

    await recalculateScenePresence();
    queueSceneStateBroadcast();
    api.v1.log('[AE:TRACE] dynamic engine RELEASING ae_lock');
    ae_lock = false; // [v0.9.34 LOCK1] release after all background generates complete
}

// ============================================================================
// SECTION 16 — IMAGE PROMPT GENERATION
// Assembles image prompts for auto-snap and Director's Cut, and dispatches
// generation requests to the bridge via EVT_GENERATE_IMAGE.
//
// [CHANGE] Widget system fully removed. All functions that formerly wrote to
// KEY_PENDING and called rebuildWidgets() now call broadcastToTM(EVT_GENERATE_IMAGE, payload)
// directly. No story document writes for image generation.
//
// [CHANGE] getCharacterData() now reads from cachedCharVisuals (CharacterVisualRecord[])
// instead of cachedCharConfigs. Field names updated: c.visuals (was c.characterVisuals),
// c.sceneVisuals, c.uc (was c.characterUC). baseSceneVisuals/baseSceneUC are not tracked
// in CharacterVisualRecord — extractBaseAdditions() returns empty strings naturally.
// Nickname matching added (CharacterVisualRecord includes nicknames[]).
//
// [CHANGE] loadSettings() renamed to loadImageSettings() throughout.
//
// [CHANGE] enhanceDirectorPrompt() and submitDirectorPhoto() extracted as standalone
// pure functions with explicit parameters — no modal state or module-level director vars.
// Called from handleBridgeMessage() (Section 18) when EVT_DIRECTOR_SUBMIT arrives.
//
// NOTE FOR ASSEMBLY: Add to Section 2 Bridge Event constants:
//   const EVT_DIRECTOR_ENHANCE_RESULT = 'DIRECTOR_ENHANCE_RESULT'; // engine→bridge
// ============================================================================

// ── Character Data Lookup ─────────────────────────────────────────────────────

// [v0.9.7.6] Whole-word presence test. Substring matching caused short names
// (e.g. "Nev") to fire inside longer words ("never"). Boundary = anything that
// is not an ASCII letter/digit/underscore, or string start/end. Multi-word names
// match on their outer boundaries; internal spaces are unaffected.
function _nameAppearsAsWord(hayLower: string, needleLower: string): boolean {
    if (!needleLower) return false;
    let esc = needleLower.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    let re = new RegExp('(?:^|[^a-z0-9_])' + esc + '(?:[^a-z0-9_]|$)');
    return re.test(hayLower);
}

function getCharacterData(promptText: string): { name: string; visuals: string; uc: string; baseSceneVisuals: string; baseSceneUC: string; }[] {
    // Returns an array of matched character visual records for characters mentioned in promptText.
    // [CHANGE] Reads from cachedCharVisuals (CharacterVisualRecord[]) instead of old cachedCharConfigs.
    // [CHANGE] Added nickname matching — CharacterVisualRecord includes nicknames[].
    // [CHANGE] baseSceneVisuals and baseSceneUC always return '' — not tracked in CharacterVisualRecord.
    //          extractBaseAdditions() will return empty strings for these, which is correct behaviour:
    //          the bridge receives an empty extraBaseVisuals/extraBaseUC and generates normally.
    if (!promptText || !cachedCharVisuals.length) return [];
    const lower = promptText.toLowerCase();
    return cachedCharVisuals
        .filter(function(c) {
            if (!c.name || !c.name.trim()) return false;
            if (_nameAppearsAsWord(lower, c.name.trim().toLowerCase())) return true;
            return (c.nicknames || []).some(function(nick) {
                return nick && nick.trim() && _nameAppearsAsWord(lower, nick.trim().toLowerCase());
            });
        })
        .map(function(c) {
            return {
                name:             c.name,
                // Combine core visuals + scene-specific additions for character captions
                visuals:          [c.visuals, c.sceneVisuals].filter(Boolean).join(', '),
                uc:               c.uc || '',
                baseSceneVisuals: '', // not stored in CharacterVisualRecord
                baseSceneUC:      ''  // not stored in CharacterVisualRecord
            };
        });
}

function extractBaseAdditions(matchedChars: { baseSceneVisuals: string; baseSceneUC: string }[]): { extraBaseVisuals: string; extraBaseUC: string } {
    // Extracts base-level prompt additions (added to main fp/fu, not char captions).
    // Preserved verbatim — in the merged system these fields are always '' (see getCharacterData note),
    // so this function will always return { extraBaseVisuals: '', extraBaseUC: '' }.
    return {
        extraBaseVisuals: matchedChars.map(function(c) { return c.baseSceneVisuals; }).filter(Boolean).join(', '),
        extraBaseUC:      matchedChars.map(function(c) { return c.baseSceneUC;      }).filter(Boolean).join(', ')
    };
}

// ── Auto-Snap ─────────────────────────────────────────────────────────────────

async function getCurrentLocationPromptLine(): Promise<string> {
    // [WP-img] Returns "Location: <name> — <resolved description>" for the
    // protagonist's current location, or '' if none. Feeds the image architect so
    // generated scenes reflect where the player is. Uses the (state-resolved)
    // description, NOT locationVisuals — locationVisuals is reserved for renders
    // that are specifically about a location.
    try {
        let locId = await loadPlayerLocation();
        if (!locId) return '';
        let loc = await loadEntity(locId);
        if (!loc) return '';
        let desc = (loc.state && loc.state !== 'default' && loc.stateDescriptions && loc.stateDescriptions[loc.state])
            ? loc.stateDescriptions[loc.state]
            : (loc.description || '');
        desc = (desc || '').trim();
        if (!loc.name && !desc) return '';
        return 'Location: ' + (loc.name || '') + (desc ? ' — ' + desc : '');
    } catch (e) { api.v1.error('[AE:img] getCurrentLocationPromptLine:', e); return ''; }
}

// [v0.9.8.0] Reusable architect pass over the recent story. Reads the last
// `paragraphs` sections, detects characters (whole-word), runs the GLM architect,
// and returns the raw prompt plus the resolved character records. Shared by
// executeAutoSnap (generate now) and the AUTO_SNAP_PROMPT path (fill the Image
// Studio composer for the user to review/edit before generating).
async function buildArchitectPromptFromStory(paragraphs?: number): Promise<{ prompt: string; matchedChars: { name: string; visuals: string; uc: string; baseSceneVisuals: string; baseSceneUC: string; }[]; } | null> {
    await loadImageSettings();
    const nodeId = await api.v1.document.history.currentNodeId();
    const node   = await api.v1.document.history.nodeState(nodeId);
    if (!node || !node.sections) { api.v1.ui.toast('Error: Could not read document.'); return null; }

    const ctxSize = (typeof paragraphs === 'number' && paragraphs > 0) ? paragraphs : (globalSettings.contextSize || DEFAULT_CTX);
    let asContextText = '';
    const asStartIndex = Math.max(0, node.sections.length - ctxSize);
    for (let i = asStartIndex; i < node.sections.length; i++) {
        if (node.sections[i].section && node.sections[i].section.text) asContextText += node.sections[i].section.text + '\n';
    }

    const asMatched   = getCharacterData(asContextText);
    const asNames     = asMatched.map(function(c) { return c.name; }).join(', ');
    const asLocLine   = await getCurrentLocationPromptLine();
    const asCharCtx   = asNames ? '\n\nCharacters identified in scene: ' + asNames + '. Apply their specific visual tags.' : '';

    try {
        const asResp = await api.v1.generate(
            [
                { role: 'system', content: globalSettings.architectPrompt || DEFAULT_ARCH },
                { role: 'user',   content: 'Current Scene:\n' + asContextText.trim() + asCharCtx + (asLocLine ? '\n\n' + asLocLine : '') + '\n\nGenerate the image prompt:' }
            ],
            { model: 'glm-4-6', max_tokens: 300 }
        );
        const asPrompt = ((asResp.choices && asResp.choices[0] &&
            (asResp.choices[0].message && asResp.choices[0].message.content || asResp.choices[0].text)) || asResp.text || '').trim();
        if (!asPrompt) return null;
        return { prompt: asPrompt, matchedChars: asMatched };
    } catch (asErr) {
        api.v1.log('[AE:img] buildArchitectPromptFromStory failed:', asErr);
        return null;
    }
}

async function executeAutoSnap(): Promise<void> {
    // [CHANGE] Widget system removed. Previously wrote to KEY_PENDING + rebuildWidgets().
    //          Now broadcasts EVT_GENERATE_IMAGE directly to bridge.
    // [CHANGE] loadSettings() → loadImageSettings().
    // [CHANGE] Bridge guard added — auto-snap requires the bridge to be connected.
    api.v1.ui.toast('📸 Architect Pass: Analysing scene…');
    await loadImageSettings();

    if (!isBridgeReady) {
        api.v1.ui.toast('⚠️ Bridge not connected — auto-snap requires bridge.', { type: 'warning', autoClose: 3000 });
        return;
    }

    const nodeId = await api.v1.document.history.currentNodeId();
    const node   = await api.v1.document.history.nodeState(nodeId);
    if (!node || !node.sections) { api.v1.ui.toast('Error: Could not read document.'); return; }

    const ctxSize = globalSettings.contextSize || DEFAULT_CTX;
    let contextText = '';
    const startIndex = Math.max(0, node.sections.length - ctxSize);
    for (let i = startIndex; i < node.sections.length; i++) {
        if (node.sections[i].section && node.sections[i].section.text) contextText += node.sections[i].section.text + '\n';
    }

    const matchedChars = getCharacterData(contextText);
    const { extraBaseVisuals, extraBaseUC } = extractBaseAdditions(matchedChars);
    const charNames   = matchedChars.map(function(c) { return c.name; }).join(', ');
    const locLine     = await getCurrentLocationPromptLine();
    const charContext = charNames ? '\n\nCharacters identified in scene: ' + charNames + '. Apply their specific visual tags.' : '';

    try {
        const response = await api.v1.generate(
            [
                { role: 'system', content: globalSettings.architectPrompt || DEFAULT_ARCH },
                { role: 'user',   content: 'Current Scene:\n' + contextText.trim() + charContext + (locLine ? '\n\n' + locLine : '') + '\n\nGenerate the image prompt:' }
            ],
            { model: 'glm-4-6', max_tokens: 300 }
        );
        const rawPrompt = ((response.choices && response.choices[0] &&
            (response.choices[0].message && response.choices[0].message.content || response.choices[0].text)) || response.text || '').trim();
        if (!rawPrompt) throw new Error('GLM returned an empty prompt.');

        const preset = profiles[activeIndex];
        await broadcastToTM(EVT_GENERATE_IMAGE, {
            uuid:             api.v1.uuid(),
            prompt:           rawPrompt,
            characters:       matchedChars.map(function(c) { return { name: c.name, visuals: c.visuals, uc: c.uc }; }),
            extraBaseVisuals: extraBaseVisuals,
            extraBaseUC:      extraBaseUC,
            settings: {
                width:    preset.width,
                height:   preset.height,
                steps:    Math.min(preset.steps, 28),
                scale:    preset.scale,
                quality:  preset.qualityTags,
                negative: preset.negativeTags
            },
            autoDownload: globalSettings.autoDownload
        });
        api.v1.ui.toast('📸 Auto-Snap complete! Image generating in bridge…');
    } catch (err) {
        api.v1.ui.toast('Architect Error: ' + ((err as any).message || String(err)));
    }
}

// ── Director's Cut — Enhance & Submit ─────────────────────────────────────────

async function enhanceDirectorPrompt(
    prompt: string,
    chars: { name: string; visuals: string }[]
): Promise<{ enhancedPrompt: string; charVisuals: { name: string; visuals: string }[] } | null> {
    // [CHANGE] Extracted as pure function with explicit parameters.
    //          Old version mutated module-level state (currentDirectorPrompt, char1Vis_in, etc.)
    //          and called renderModal(). New version returns the enhanced data as a value
    //          so the caller (handleBridgeMessage / EVT_DIRECTOR_SUBMIT) can broadcast it back.
    if (!prompt.trim()) return null;

    let char1Name = chars.length > 0 ? chars[0].name : '';
    let char2Name = chars.length > 1 ? chars[1].name : '';
    const locLine = await getCurrentLocationPromptLine();

    let char1Context = '';
    let char2Context = '';
    if (char1Name.trim()) {
        const found = getCharacterData(char1Name.trim());
        char1Context = found.length > 0
            ? '\nCharacter 1 (' + char1Name + '): Known visuals are "' + found[0].visuals + '". Enhance and adapt for the scene.'
            : '\nCharacter 1 (' + char1Name + '): No known visuals. Generate appropriate tags.';
    }
    if (char2Name.trim()) {
        const found = getCharacterData(char2Name.trim());
        char2Context = found.length > 0
            ? '\nCharacter 2 (' + char2Name + '): Known visuals are "' + found[0].visuals + '". Enhance and adapt for the scene.'
            : '\nCharacter 2 (' + char2Name + '): No known visuals. Generate appropriate tags.';
    }

    const sysPrompt = 'You are an uncompromising art director. Output ONLY a valid JSON object, no markdown:\n{\n  "enhanced_prompt": "5-10 core tags + 1-2 sentences of observational prose. No quality tags or negative weights.",\n  "char1_visuals": "Tags for Character 1 if present.",\n  "char2_visuals": "Tags for Character 2 if present."\n}';

    try {
        const response = await api.v1.generate(
            [
                { role: 'system', content: sysPrompt },
                { role: 'user',   content: 'Rough Concept: ' + prompt + char1Context + char2Context + (locLine ? '\n' + locLine : '') + '\n\nOutput the JSON:' }
            ],
            { model: 'glm-4-6', max_tokens: 350, temperature: 0.7 }
        );
        let rawOutput = ((response.choices && response.choices[0] &&
            (response.choices[0].message && response.choices[0].message.content || response.choices[0].text)) || response.text || '').trim();
        const jsonMatch = rawOutput.match(/\{[\s\S]*\}/);
        if (!jsonMatch) throw new Error('No JSON block found in architect response.');
        const parsed = JSON.parse(jsonMatch[0]);

        const enhancedChars = chars.map(function(c, i) {
            return {
                name:    c.name,
                visuals: (i === 0 && parsed.char1_visuals && char1Name.trim())
                    ? parsed.char1_visuals
                    : (i === 1 && parsed.char2_visuals && char2Name.trim())
                        ? parsed.char2_visuals
                        : c.visuals
            };
        });

        return {
            enhancedPrompt: parsed.enhanced_prompt || prompt,
            charVisuals:    enhancedChars
        };
    } catch (err) {
        api.v1.log('[AE:img] enhanceDirectorPrompt failed:', err);
        return null;
    }
}

async function submitDirectorPhoto(
    prompt: string,
    uc: string,
    chars: { name: string; visuals: string }[]
): Promise<void> {
    // [CHANGE] Extracted as pure function with explicit parameters.
    //          Old version read module-level state (currentDirectorPrompt, char1Name_in, etc.)
    //          and wrote to KEY_PENDING + rebuildWidgets().
    //          New version takes all data from parameters and broadcasts EVT_GENERATE_IMAGE.
    // [CHANGE] Bridge guard added.
    const rawPrompt = prompt.trim();
    if (!rawPrompt) return;

    if (!isBridgeReady) {
        api.v1.ui.toast('⚠️ Bridge not connected — Director\'s Cut requires bridge.', { type: 'warning', autoClose: 3000 });
        return;
    }

    const preset = profiles[activeIndex];
    const finalUC = uc || preset.negativeTags;

    // Resolve character visuals: enrich with cached engine data where available
    const resolvedChars: { name: string; visuals: string; uc: string }[] = chars.map(function(c) {
        if (!c.name.trim()) return { name: c.name, visuals: c.visuals, uc: '' };
        const found = getCharacterData(c.name.trim());
        if (found.length) {
            // Merge: overlay any passed visuals on top of cached visuals
            return {
                name:    c.name,
                visuals: [found[0].visuals, c.visuals].filter(Boolean).join(', '),
                uc:      found[0].uc
            };
        }
        return { name: c.name, visuals: c.visuals, uc: '' };
    }).filter(function(c) { return c.name.trim(); });

    // Deduplicate by name
    const seen = new Set<string>();
    const uniqueChars = resolvedChars.filter(function(c) {
        if (seen.has(c.name)) return false;
        seen.add(c.name);
        return true;
    });

    await broadcastToTM(EVT_GENERATE_IMAGE, {
        uuid:             api.v1.uuid(),
        prompt:           rawPrompt,
        characters:       uniqueChars,
        extraBaseVisuals: '',
        extraBaseUC:      '',
        settings: {
            width:    preset.width,
            height:   preset.height,
            steps:    Math.min(preset.steps, 28),
            scale:    preset.scale,
            quality:  preset.qualityTags,
            negative: finalUC
        },
        autoDownload: globalSettings.autoDownload
    });
    api.v1.ui.toast('📸 Manual Snap dispatched!');
}


// ---- Snapshot Image (callable: button or future actions) -------------------
// Reads the stored GLM appearance snapshot for charId, resolves the character's
// cached visuals and any location visuals, and broadcasts a tagged
// EVT_GENERATE_IMAGE { entityId, kind:'snapshot' } so the bridge can land the
// result in the snapshot gallery section and the entity's top pane.
async function assembleSnapshotImage(charId: string): Promise<void> {
    try {
        if (!isBridgeReady) {
            api.v1.ui.toast('Bridge not connected - image generation requires bridge.', { type: 'warning', autoClose: 3000 });
            return;
        }
        let aChar = await loadCharacter(charId);
        if (!aChar) { api.v1.log('[AE:img] assembleSnapshotImage: char not found'); return; }
        let aEntId = (aChar as any).entityId || null;
        let aEnt = aEntId ? await loadEntity(aEntId) : null;
        let snapText = await api.v1.storyStorage.getOrDefault(STORAGE_CHAR_SNAP_PFX + charId, '') as string;
        if (!snapText) {
            api.v1.ui.toast('Generate a text snapshot first.', { type: 'warning', autoClose: 3000 });
            return;
        }
        let locVisuals = '';
        if (aEnt && aEnt.parentId) {
            let aLoc = await loadEntity(aEnt.parentId);
            if (aLoc && (aLoc as any).visuals) locVisuals = String((aLoc as any).visuals);
        }
        let basePrompt = [snapText, locVisuals].filter(Boolean).join(', ');
        let found = getCharacterData(aChar.name);
        let charVisuals = found.length ? found[0].visuals : '';
        let charUC = found.length ? found[0].uc : '';
        let preset = profiles[activeIndex];
        await broadcastToTM(EVT_GENERATE_IMAGE, {
            uuid:             api.v1.uuid(),
            prompt:           basePrompt,
            characters:       charVisuals ? [{ name: aChar.name, visuals: charVisuals, uc: charUC }] : [],
            extraBaseVisuals: '',
            extraBaseUC:      '',
            charId:           aChar.id,
            entityId:         aEntId,
            kind:             'snapshot',
            settings: {
                width:    preset.width,
                height:   preset.height,
                steps:    Math.min(preset.steps, 28),
                scale:    preset.scale,
                quality:  preset.qualityTags,
                negative: preset.negativeTags
            },
            autoDownload: globalSettings.autoDownload
        });
        api.v1.ui.toast('Generating snapshot image for ' + aChar.name + '...', { type: 'info', autoClose: 2500 });
    } catch (snapImgGenErr) {
        api.v1.error('[AE:img] assembleSnapshotImage:', snapImgGenErr);
    }
}

// ---- Action-driven Image Generation ---------------------------------------
// [vNEXT] Wires the action-effect pipeline into the existing EVT_GENERATE_IMAGE
// broadcast used by Auto-Snap and Snapshot. An action outcome can now fire an
// image the same way the snapshot button does: character-name fields are matched
// against cachedCharVisuals (via getCharacterData) so a targeted character's
// stored visual tags populate automatically, and {Actor}/{Target}/__self__/
// __target__ macros resolve in every text field. The bridge lands the result in
// a phantom widget captioned with the header/body and saves it to the gallery.
//
// args (all optional; needs at least a prompt OR one matched character to fire):
//   prompt        — extra prose/tags appended after the scene tags; macros ok
//   char1, char2  — character-name fields; macros ok. Each resolved name is
//                   matched against cachedCharVisuals to pull its visual tags + uc
//   header        — phantom-widget title / gallery caption header; macros ok
//   body          — phantom-widget caption body / gallery note; macros ok
//   includeScene  — 'true' (default) prepends the current room's visual tags
async function aeGenerateActionImage(rawArgs: Record<string, any>, scope: AEScope): Promise<void> {
    try {
        if (!isBridgeReady) {
            if (!isSilentScope(scope)) api.v1.ui.toast('Bridge not connected \u2014 image generation requires bridge.', { type: 'warning', autoClose: 3000 });
            return;
        }

        // 1) Resolve every text field through the standard macro substituter.
        const extraPrompt = aeSubstituteTokens(String(rawArgs.prompt || ''), scope).trim();
        const headerText  = aeSubstituteTokens(String(rawArgs.header || ''), scope).trim();
        const bodyText    = aeSubstituteTokens(String(rawArgs.body || ''), scope).trim();

        // 2) Resolve the two character-name fields (macros first), collect names.
        const requestedNames: string[] = [];
        [rawArgs.char1, rawArgs.char2].forEach(function(raw) {
            const resolved = aeSubstituteTokens(String(raw || ''), scope);
            resolved.split(',').map(function(s) { return s.trim(); }).filter(Boolean).forEach(function(nm) {
                requestedNames.push(nm);
            });
        });

        // 3) Match each requested name against cached visuals. getCharacterData
        //    does word-boundary + nickname matching; feed names one at a time and
        //    dedupe the hits by canonical name.
        const seen: Record<string, boolean> = {};
        const resolvedChars: { name: string; visuals: string; uc: string }[] = [];
        requestedNames.forEach(function(nm) {
            const hits = getCharacterData(nm);
            hits.forEach(function(h) {
                const key = h.name.toLowerCase();
                if (seen[key]) return;
                seen[key] = true;
                resolvedChars.push({ name: h.name, visuals: h.visuals, uc: h.uc });
            });
        });

        // 4) Optionally prepend the current room's visual tags as base setting.
        const includeScene = String(rawArgs.includeScene === undefined ? 'true' : rawArgs.includeScene) === 'true';
        let sceneVisuals = '';
        if (includeScene) {
            const locId = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
            if (locId) {
                const locEnt = await loadEntity(locId).catch(function() { return null; });
                if (locEnt && (locEnt as any).visuals) sceneVisuals = String((locEnt as any).visuals);
            }
        }

        // 5) Assemble the base prompt: scene tags (setting) then extra prose/tags.
        const basePrompt = [sceneVisuals, extraPrompt].filter(Boolean).join(', ').trim();

        if (!basePrompt && resolvedChars.length === 0) {
            if (!isSilentScope(scope)) api.v1.ui.toast('Generate Image effect had no prompt and no matched characters.', { type: 'warning', autoClose: 3000 });
            return;
        }

        const preset = profiles[activeIndex] || ({} as ImagePreset);

        await broadcastToTM(EVT_GENERATE_IMAGE, {
            uuid:             api.v1.uuid(),
            prompt:           basePrompt,
            characters:       resolvedChars,
            extraBaseVisuals: '',
            extraBaseUC:      '',
            kind:             'action',
            header:           headerText,
            body:             bodyText,
            settings: {
                width:    preset.width,
                height:   preset.height,
                steps:    Math.min(preset.steps || 28, 28),
                scale:    preset.scale,
                quality:  preset.qualityTags,
                negative: preset.negativeTags
            },
            autoDownload: globalSettings.autoDownload
        });

        if (!isSilentScope(scope)) {
            const who = resolvedChars.length ? (' (' + resolvedChars.map(function(c) { return c.name; }).join(', ') + ')') : '';
            api.v1.ui.toast('\ud83d\udcf8 Generating image' + who + '\u2026', { type: 'info', autoClose: 2500 });
        }
    } catch (genImgErr) {
        api.v1.error('[AE:img] aeGenerateActionImage:', genImgErr);
        if (!isSilentScope(scope)) api.v1.ui.toast('Image generation effect failed.', { type: 'error', autoClose: 3000 });
    }
}

// ============================================================================
// SECTION 18 — BRIDGE MESSAGING LAYER
// All communication between the engine (Web Worker) and bridge (Tampermonkey
// page-context script). Engine→Bridge via api.v1.messaging.broadcast().
// Bridge→Engine via the onMessage listener registered in initMessaging().
//
// Broadcast functions queue and debounce to avoid redundant round-trips when
// multiple storage writes fire in rapid succession (e.g., during runDynamicEngine).
//
// buildSceneStatePayload() is the most complex new function. It loads the
// protagonist's location + one-hop entity graph and packages the data the bridge
// needs to render the Scene HUD. Capped to one-hop range for performance (<200ms).
//
// handleBridgeMessage() is the inbound message router. New event handlers:
//   EVT_DIRECTOR_SUBMIT — bridge submitted Director's Cut (enhance or generate)
//   EVT_REQ_SCENE_STATE — bridge requests immediate SCENE_STATE_UPDATE push
//   EVT_REQ_CHAR_DATA   — bridge requests immediate CHARACTER_DATA_SYNC push
// On EVT_HANDSHAKE_ACK: immediately push char data then scene state, then PRESET_SYNC.
// ============================================================================

// ── Broadcast Primitives ──────────────────────────────────────────────────────

// openEngineModal — wraps api.v1.ui.modal.open to signal the bridge.
// Bridge adds ae-behind-modal class (display:none) on OPENED and removes on CLOSED.
// Use this instead of api.v1.ui.modal.open directly throughout the engine.
async function openEngineModal(opts: any): Promise<any> {
    // [FIX] Was calling openEngineModal(opts) recursively — infinite recursion.
    // Corrected to call api.v1.ui.modal.open(opts) which is the actual NAI API.
    broadcastToTM('AE_MODAL_OPENED', {}).catch(function() {});
    let handle: any;
    try {
        handle = await api.v1.ui.modal.open(opts);
    } catch (modalErr) {
        broadcastToTM('AE_MODAL_CLOSED', {}).catch(function() {});
        throw modalErr;
    }
    if (handle && handle.closed) {
        handle.closed.then(function() {
            broadcastToTM('AE_MODAL_CLOSED', {}).catch(function() {});
        });
    }
    return handle;
}

// ============================================================================
// UNIFIED PICKER  —  openPickerModal<T>()
//
// One modal for every "pick one item from a list" selection. Replaces the
// scattered bespoke pickers (parent, entity, resource, skill, lorebook tag, ...)
// so that search, item rendering, and selected-highlighting are consistent and
// changing them all is a one-place edit. Migrate inline pickers onto this as
// they are touched (look for leftover drawSearchablePicker / openEngineModal
// list pickers).
//
// Items render as full-width buttons: "<icon> <label>  ·  <sublabel>".
// A search box appears automatically for lists > 8 (force with searchable:true).
// The picker closes itself first, THEN runs onSelect — matching the prior
// close-then-act pattern so a reopened parent modal never stacks under it.
//
//   await openPickerModal({
//       title:       'Nest Under Entity',
//       items:       allNodes,
//       getId:       function(m) { return m.id; },
//       getLabel:    function(m) { return m.name; },
//       getIcon:     function(m) { return m.icon || '\ud83d\udccd'; },  // optional
//       getSublabel: function(m) { return m.type; },                       // optional
//       selectedId:  ent.parentId || undefined,                            // optional highlight
//       searchable:  true,                                                 // optional
//       pinnedOptions: [{ id: '__none__', label: 'None', icon: '\u2715',
//                         onSelect: function() { ... } }],                 // optional, unfiltered, on top
//       onSelect:    function(item) { ... }                               // required
//   });
// ============================================================================
interface PickerPinnedOption { id: string; label: string; icon?: string; sublabel?: string; onSelect: () => void | Promise<void>; }
interface PickerConfig {
    title: string;
    items: any[];
    getId: (item: any) => string;
    getLabel: (item: any) => string;
    getIcon?: (item: any) => string | undefined;
    getSublabel?: (item: any) => string | undefined;
    selectedId?: string;
    searchable?: boolean;
    pinnedOptions?: PickerPinnedOption[];
    onSelect: (item: any) => void | Promise<void>;
    size?: string;
    emptyText?: string;
}

async function openPickerModal(cfg: PickerConfig): Promise<void> {
    let handle: any = null;
    let term = '';
    const forceSearch = cfg.searchable === true;
    const allowSearch = cfg.searchable !== false && (forceSearch || cfg.items.length > 8);
    const pickerSize  = cfg.size || 'medium';

    // Close the picker first, then run the caller's handler. This mirrors the
    // prior bespoke order (pm.close() then reopen parent modal) so a modal a
    // handler opens never ends up stacked beneath the (still-open) picker.
    function closingCallback(fn: () => void | Promise<void>) {
        return async function() {
            try { if (handle && !handle.isClosed()) await handle.close(); } catch (e0) {}
            try { await fn(); } catch (e) { api.v1.error('[AE:picker] select handler:', e); }
        };
    }

    function itemButton(label: string, selected: boolean, fn: () => void | Promise<void>): UIPart {
        return {
            type: 'button',
            text: label,
            style: {
                width: '100%', marginBottom: '2px', textAlign: 'left', fontSize: '12px',
                backgroundColor: selected ? 'rgba(126,200,160,0.2)' : 'rgba(255,255,255,0.04)',
                border: selected ? '1px solid rgba(126,200,160,0.4)' : '1px solid rgba(255,255,255,0.08)'
            },
            callback: closingCallback(fn)
        };
    }

    function buildContent(): UIPart[] {
        const parts: UIPart[] = [];
        if (allowSearch) {
            parts.push({ type: 'textInput', placeholder: '\ud83d\udd0d Search\u2026', initialValue: term, onChange: async function(v: string) { term = v; await render(); } });
        }
        if (cfg.pinnedOptions && cfg.pinnedOptions.length > 0) {
            for (const po of cfg.pinnedOptions) {
                parts.push(itemButton(aeIconPfx(po.icon) + po.label + (po.sublabel ? '  \u00b7  ' + po.sublabel : ''), false, po.onSelect));
            }
        }
        const needle = term.trim().toLowerCase();
        const filtered = (!allowSearch || needle === '') ? cfg.items : cfg.items.filter(function(it) {
            const lbl = cfg.getLabel(it).toLowerCase();
            const sub = cfg.getSublabel ? (cfg.getSublabel(it) || '').toLowerCase() : '';
            return lbl.indexOf(needle) >= 0 || sub.indexOf(needle) >= 0;
        });
        if ((cfg.pinnedOptions && cfg.pinnedOptions.length > 0) && filtered.length > 0) {
            parts.push({ type: 'text', text: '\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500', style: { opacity: '0.2', fontSize: '10px', textAlign: 'center', marginTop: '4px', marginBottom: '4px' } });
        }
        for (const it of filtered) {
            const itemId = cfg.getId(it);
            const icon = cfg.getIcon ? cfg.getIcon(it) : undefined;
            const sub  = cfg.getSublabel ? cfg.getSublabel(it) : undefined;
            const label = aeIconPfx(icon) + cfg.getLabel(it) + (sub ? '  \u00b7  ' + sub : '');
            const isSel = cfg.selectedId !== undefined && itemId === cfg.selectedId;
            parts.push(itemButton(label, isSel, (function(captured) { return function() { return cfg.onSelect(captured); }; })(it)));
        }
        if (filtered.length === 0) {
            parts.push({ type: 'text', text: cfg.emptyText || 'No matches.', style: { opacity: '0.5', fontSize: '11px', padding: '8px', textAlign: 'center' } });
        }
        return parts;
    }

    async function render() {
        const content = buildContent();
        try {
            if (handle && !handle.isClosed()) { await handle.update({ content: content }); return; }
        } catch (e) { /* handle stale — fall through and (re)open */ }
        handle = await openEngineModal({ id: 'ae-unified-picker', title: cfg.title, size: pickerSize, content: content });
    }

    await render();
}

async function broadcastToTM(event: string, data?: Record<string, any>): Promise<void> {
    // Preserved verbatim from AI engine.
    data = data || {};
    try {
        await api.v1.messaging.broadcast(
            { type: 'MESSAGE', sid: api.v1.script.id, payload: Object.assign({ event: event }, data) },
            'hypebot'
        );
    } catch (e) {
        api.v1.log('[AE:bridge] broadcastToTM failed:', e);
    }
}

// ── Character Data Broadcast ──────────────────────────────────────────────────

async function buildCharacterDataPayload(): Promise<CharacterVisualRecord[]> {
    // Reads all active characters and packages their visual + persona fields into
    // CharacterVisualRecord[]. Also updates cachedCharVisuals in-memory so
    // getCharacterData() stays current without a round-trip on the next call.
    try {
        const chars = await loadAllCharacters();
        const result: CharacterVisualRecord[] = chars
            .filter(function(c) { return c.active !== false; })
            .map(function(c): CharacterVisualRecord {
                return {
                    id:                  c.id,
                    name:                c.name,
                    nicknames:           c.nicknames           || [],
                    visuals:             c.visuals             || '',
                    uc:                  c.uc                  || '',
                    sceneVisuals:        c.sceneVisuals        || '',
                    avatarVisuals:       c.avatarVisuals       || '',
                    avatarWidth:         c.avatarWidth         || 832,
                    avatarHeight:        c.avatarHeight        || 1216,
                    avatarSeed:          c.avatarSeed          || 0,
                    species:             c.species             || '',
                    age:                 c.age                 || '',
                    gender:              c.gender              || '',
                    briefDescription:    c.briefDescription    || '',
                    physicalDescription: c.physicalDescription || '',
                    personalityCore:     c.personalityCore     || '',
                    voiceAndMannerisms:  c.voiceAndMannerisms  || '',
                    background:          c.background          || ''
                };
            });
        cachedCharVisuals = result; // keep in-memory cache current
        return result;
    } catch (e) {
        api.v1.log('[AE:bridge] buildCharacterDataPayload error:', e);
        return [];
    }
}

// [v0.9.36] Single choke-point for ALL editor generations. The trace showed a
// second editor.generate() (from an auto-trigger / chain effect) racing the one in
// commitTravel, which NAI rejects with 'editor is currently blocked'. This guard
// allows exactly one in-flight generation; concurrent or lock-held requests are
// suppressed (the loser of the old race produced no output anyway), and a blocked
// error is swallowed rather than surfaced. ae_genInFlight is cleared in onGenerationEnd.
async function aeEditorGenerate(tag: string): Promise<void> {
    if (ae_genInFlight || ae_lock) {
        api.v1.log('[AE:gen] suppressed generate (' + tag + ') inFlight=' + ae_genInFlight + ' lock=' + ae_lock);
        return;
    }
    ae_genInFlight = true;
    try {
        await api.v1.editor.generate();
    } catch (gErr) {
        let gMsg = (gErr && (gErr as any).message) ? String((gErr as any).message) : '';
        if (gMsg.indexOf('blocked') >= 0) { api.v1.log('[AE:gen] editor blocked, suppressed (' + tag + ')'); }
        else { api.v1.log('[AE:gen] generate error (' + tag + '):', gErr); }
        ae_genInFlight = false;   // kickoff failed — release so we never deadlock
    }
}

async function broadcastCharacterData(): Promise<void> {
    if (!isBridgeReady) return;
    try {
        const payload = await buildCharacterDataPayload();
        await broadcastToTM(EVT_CHAR_DATA_SYNC, { characters: payload });
        api.v1.log('[AE:bridge] Character data synced:', payload.length, 'characters.');
    } catch (e) {
        api.v1.log('[AE:bridge] broadcastCharacterData error:', e);
    }
}

function queueCharacterDataBroadcast(): void {
    // [v0.9.36] Serialize + coalesce (same rationale as queueSceneStateBroadcast).
    // commitTravel's scene-presence loop saves several characters in a row, each of
    // which queued a broadcast; this collapses them into one.
    if (!isBridgeReady) return;
    if (ae_cdbInFlight) { ae_cdbPending = true; return; }
    ae_cdbInFlight = true;
    broadcastCharacterData()
        .catch(function(e) { api.v1.log('[AE:bridge] charData broadcast err:', e); })
        .then(function() {
            ae_cdbInFlight = false;
            if (ae_cdbPending) { ae_cdbPending = false; queueCharacterDataBroadcast(); }
        });
}

// ── Scene State Broadcast ─────────────────────────────────────────────────────

// [v0.9.9.2] Summarise one time condition for a calendar marker. Returns null for
// non-time conditions. Equality placement hints only fire for the '==' operator.
function aeTimeCondSummary(rule: any): { summary: string; dayOfWeek?: number; dayOfCycle?: number; absoluteDay?: number; band?: string } | null {
    let a = (rule && rule.args) ? rule.args : {};
    let t = rule ? rule.type : '';
    if (t === 'time_between') return { summary: 'between ' + (Number(a.startHour) || 0) + ':00 and ' + (Number(a.endHour) || 0) + ':00' };
    if (t === 'time_band_is') return { summary: 'during ' + (a.band || '?'), band: a.band ? String(a.band) : undefined };
    if (t === 'day_of_cycle_is') return { summary: 'cycle day ' + String(a.op || '==') + ' ' + (Number(a.day) || 0), dayOfCycle: (String(a.op || '==') === '==' ? (Number(a.day) || 0) : undefined) };
    if (t === 'day_of_week_is') return { summary: 'on weekday ' + (Number(a.dayOfWeek) || 0), dayOfWeek: (Number(a.dayOfWeek) || 0) };
    if (t === 'date_is') return { summary: 'absolute day ' + String(a.op || '==') + ' ' + (Number(a.day) || 0), absoluteDay: (String(a.op || '==') === '==' ? (Number(a.day) || 0) : undefined) };
    return null;
}

// [v0.9.9.2] Scan library templates (cheap, in-memory) for time conditions so the
// calendar can mark actions tied to times. One entry per template; the first time
// condition found provides the placement hint, the summary lists them all.
function collectTimedActions(cfg: GlobalConfig): SceneTimedActionInfo[] {
    let out: SceneTimedActionInfo[] = [];
    let tmpls = ((cfg.actionTemplates || []) as any[]);
    for (let i = 0; i < tmpls.length; i++) {
        let tmpl = tmpls[i];
        if (!tmpl) continue;
        let condSets: any[] = [];
        condSets.push(tmpl.conditions || []);
        let branches = tmpl.branches || [];
        for (let bi = 0; bi < branches.length; bi++) condSets.push(branches[bi].conditions || []);
        let summaries: string[] = [];
        let firstHint: any = null;
        for (let ci = 0; ci < condSets.length; ci++) {
            let conds = condSets[ci];
            for (let ki = 0; ki < conds.length; ki++) {
                let s = aeTimeCondSummary(conds[ki]);
                if (s) { summaries.push(s.summary); if (!firstHint) firstHint = s; }
            }
        }
        if (summaries.length === 0) continue;
        let info: SceneTimedActionInfo = { name: tmpl.name || 'Action', entityName: 'Library', summary: summaries.join('; '), auto: !!(tmpl.autoTrigger || tmpl.globalAutoTrigger) };
        if (firstHint) {
            if (firstHint.dayOfWeek !== undefined) info.dayOfWeek = firstHint.dayOfWeek;
            if (firstHint.dayOfCycle !== undefined) info.dayOfCycle = firstHint.dayOfCycle;
            if (firstHint.absoluteDay !== undefined) info.absoluteDay = firstHint.absoluteDay;
            if (firstHint.band !== undefined) info.band = firstHint.band;
        }
        out.push(info);
    }
    return out;
}

async function buildSceneStatePayload(): Promise<SceneStatePayload | null> {
    // Assembles the full HUD payload. Reads protagonist location, present characters,
    // party resources, and one-hop entity actions. Capped to one hop for performance.
    // Calls evaluateFieldCondition (Section 19) — forward reference, safe at runtime.
    try {
        // 1. Protagonist
        const charIdx    = await loadIndex();
        const protagMeta = charIdx.find(function(m) { return !!m.isProtagonist; });
        if (!protagMeta) return null;
        const protag = await loadCharacter(protagMeta.id);
        if (!protag) return null;

        // 2. Current location entity
        const locId  = await loadPlayerLocation();
        if (!locId) return null;
        const locEnt = await loadEntity(locId);
        if (!locEnt) return null;
        api.v1.log('[AE:TRACE] buildSceneState playerLoc=' + locEnt.name + '(' + locId + ')');

        // 3. Resolve state-dependent description
        const locDesc = (locEnt.stateDescriptions && locEnt.stateDescriptions[locEnt.state])
            || locEnt.description || '';

        // 4. Present characters → SceneCharacterInfo[]
        const allChars = await loadAllCharacters();
        const presentCharacters: SceneCharacterInfo[] = allChars
            .filter(function(c) { return (c.scenePresent || c.isProtagonist) && (c as any).npcClass !== 'minor'; })
            .map(function(c): SceneCharacterInfo {
                return {
                    id:              c.id,
                    name:            c.name,
                    entityId:        c.entityId || '',
                    briefDescription: c.briefDescription || '',
                    socialMask:      (c.midRange && c.midRange.socialMask) || '',
                    compressedLine:  (c.ephemeral && c.ephemeral.compressedLine) || '',
                    isProtagonist:   !!c.isProtagonist
                };
            });

        // 5. Party resources → SceneResourceInfo[]
        const cfg   = await loadConfig();
        const party = await loadPartyState();
        const partyResources: SceneResourceInfo[] = (cfg.resources || []).map(function(resDef): SceneResourceInfo {
            const val = (party.resourceValues && party.resourceValues[resDef.id]) || 0;
            const res: SceneResourceInfo = {
                id:    resDef.id,
                name:  resDef.name,
                type:  resDef.type,
                value: val,
                tag:   resDef.tag,
                icon:  resDef.icon
            };
            if (resDef.type === 'pool' && resDef.hasBounds) {
                res.min = resDef.min;
                res.max = resDef.max;
            } else if (resDef.type === 'track' || resDef.type === 'discrete') {
                res.states = resDef.states || [];
            }
            return res;
        });

        // 6. [v0.9.42] Action scope: current location + its direct CHARACTER/ITEM/NARRATIVE
        // children only. Sub-locations (e.g. a bedroom under a house) and connectedEntityIds
        // targets (e.g. Violencia's Room linked from the Motel) are deliberately excluded —
        // those are separate places the player hasn't entered yet, not part of "here". Travel
        // into them is unaffected: locationGraph resolves connection/child travel actions
        // directly from cfg.actionTemplates by id, independent of this set.
        const allEntityMeta = await loadEntityIndex();
        const oneHopIds = new Set<string>([locId]);
        for (const m of allEntityMeta) {
            if (m.parentId === locId && m.type !== 'location') oneHopIds.add(m.id);
        }

        // 7. Filter to showActionWidget entities, evaluate visibility gates, build SceneActionInfo[]
        const availableActions: SceneActionInfo[] = [];
        for (const entId of Array.from(oneHopIds)) {
            const ent = await loadEntity(entId);
            if (!ent || !ent.showActionWidget) continue;
            for (const act of (ent.actions || [])) {
                if (act.hidden) continue;
                // Evaluate visibility gates — evaluateFieldCondition defined in Section 19
                let visible = true;
                for (const rule of (act.rules || [])) {
                    if (rule.type === 'visibility-gate') {
                        try {
                            visible = await evaluateFieldCondition(rule, protag, ent, cfg);
                        } catch (_) { visible = true; /* non-fatal — show the action */ }
                        if (!visible) break;
                    }
                }
                if (!visible) continue;

                const costRule  = (act.rules || []).find(function(r) { return r.type === 'resource-cost'; });
                const skillRule = (act.rules || []).find(function(r) { return r.type === 'skill-gate'; });
                availableActions.push({
                    id:           act.id,
                    entityId:     ent.id,
                    entityName:   ent.name,
                    label:        act.label,
                    hidden:       !!act.hidden,
                    outcomeNote:  act.outcomeNote || '',
                    hasSkillGate: !!skillRule,
                    hasCost:      !!costRule,
                    costTag:      costRule ? costRule.resourceTag : undefined,
                    costAmount:   costRule ? costRule.amount      : undefined,
                    silent:       !!act.silent,
                    icon:         ent.icon || undefined,
                    type:         ent.type
                });
            }
        }

        // 7b. [WP-5] Aggregate new-system ActionInstances visible to the player:
        //     player entity, current location, equipped items, present-character
        //     entities, and one-hop entities. Non-hidden instances only.
        const availableInstances: SceneInstanceInfo[] = [];
        const instIds = new Set<string>(oneHopIds);
        const protagForInst = allChars.find(function(c) { return !!c.isProtagonist; });
        if (protagForInst && protagForInst.entityId) {
            instIds.add(protagForInst.entityId);
            // [v0.9.30 FILT2] Whole player subtree, not just equipped items: carried gear,
            // party members parented under the player body, and anything those companions
            // in turn carry. Bounded breadth-first walk over the entity index so actions on
            // owned entities surface in the HUD regardless of equip state.
            let pHierFrontier: string[] = [protagForInst.entityId];
            let pHierGuard = 0;
            while (pHierFrontier.length && pHierGuard < 10000) {
                let pHierNext: string[] = [];
                for (const pHid of pHierFrontier) {
                    for (const pHm of allEntityMeta) {
                        if (pHm.parentId === pHid && !instIds.has(pHm.id)) { instIds.add(pHm.id); pHierNext.push(pHm.id); }
                    }
                    pHierGuard++;
                }
                pHierFrontier = pHierNext;
            }
        }
        // [v0.9.31 FOLLOW1] Annotate scene chars with follow state; re-computed from entity index
        // on every broadcast so it self-corrects if an external action moves the character.
        const _protagBodyId = protagForInst ? (protagForInst.entityId || '') : '';
        if (_protagBodyId) {
            presentCharacters.forEach(function(pc) {
                if (!pc.isProtagonist && pc.entityId) {
                    const pcEntMeta = allEntityMeta.find(function(m) { return m.id === pc.entityId; });
                    (pc as any).isFollowing = !!(pcEntMeta && pcEntMeta.parentId === _protagBodyId);
                }
            });
        }
        for (const pcInst of presentCharacters) { if (pcInst.entityId) instIds.add(pcInst.entityId); }
        for (const iid of Array.from(instIds)) {
            const ieEnt = await loadEntity(iid);
            if (!ieEnt) continue;
            // [v0.9.28 FILT1] Build a scope once per entity for condition evaluation.
            const filtProtagEnt = (protagForInst && (protagForInst as any).entityId) ? await loadEntity((protagForInst as any).entityId) : null;
            const filtParentEnt = ieEnt.parentId ? await loadEntity(ieEnt.parentId) : null;
            for (const inst of getTagSubscribedActions(ieEnt, cfg)) {
                if (inst.hidden) continue;
                if (inst.oneShot) {
                    let osUsed = await api.v1.historyStorage.getOrDefault('ae_inst_1shot_' + ieEnt.id + '_' + inst.id, false) as boolean;
                    if (osUsed) continue;
                }
                // [v0.9.28 FILT1] Hide instances whose conditions don't currently pass.
                // Target-picker actions are exempt (target unknown until picked).
                if (inst.targetMode !== 'player_pick' && (inst.conditions && inst.conditions.length)) {
                    let filtScope: AEScope = { sourceEnt: ieEnt, protag: protagForInst || null, protagEnt: filtProtagEnt, target: null, parentEnt: filtParentEnt, __silent: true };
                    let filtPass = await aeCheckConditions(inst.conditions, filtScope);
                    if (!filtPass) continue;
                }
                const instAllEff = [...(inst.successEffects || []), ...((inst as any).alwaysEffects || [])];
                const instCostEff = instAllEff.find(function(e: any) {
                    return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0;
                });
                let iTag = undefined; let iAmt = undefined; let iIcon = undefined;
                if (instCostEff) {
                    iTag = instCostEff.args.tag; iAmt = instCostEff.args.amount;
                    const rDef = (cfg.resources || []).find(r => r.tag === iTag);
                    if (rDef && rDef.icon) iIcon = rDef.icon;
                }
                availableInstances.push({
                    id:             inst.id,
                    entityId:       ieEnt.id,
                    entityName:     ieEnt.name,
                    name:           inst.name || 'Action',
                    hasResolution:  !!(inst.resolution && ((inst.resolution as any).type || (inst.resolution as any).dice)),
                    requiresTarget: inst.targetMode === 'player_pick',
                    outcomeNote:    inst.outcomeNote || '',
                    silent:         !!inst.silent,
                    icon:           ieEnt.icon || undefined,
                    type:           ieEnt.type,
                    hasCost:        !!instCostEff,
                    costTag:        iTag,
                    costAmount:     iAmt,
                    costIcon:       iIcon
                });
            }
        }

        // 8. Location graph — parent (up), children (down), explicit connections (side)
        // [FIX Bug3] Added currentIcon + parentIcon so bridge can render entity icons on map nodes.
        // [FIX v0.9.13] Children now include gated + isVehicle from index (no extra loads).
        //               Connections now include full traversal metadata for map line styling.
        const locationGraph = {
            currentName:    locEnt.name,
            currentType:    'location',
            currentIcon:    (locEnt as any).icon || undefined,
            currentGated:   !!(locEnt as any).gated,
            currentIsVehicle: !!(locEnt as any).isVehicle,
            currentResourceTag: undefined as string | undefined,
            currentResourceCost: undefined as number | undefined,
            currentResourceIcon: undefined as string | undefined,
            parentId:    locEnt.parentId || null,
            parentName:  '',
            parentType:  '',
            parentIcon:  undefined as string | undefined,
            children:    [] as { id: string; name: string; type: string; hasChildren: boolean; icon?: string; gated: boolean; isVehicle: boolean; resourceTag?: string; resourceCost?: number; resourceIcon?: string; timeCost?: number; }[],
            connections: [] as { id: string; name: string; label: string; oneWay: boolean; icon?: string; gated: boolean; requiresVehicle: boolean; resourceTag?: string; resourceCost?: number; resourceIcon?: string; isSilent: boolean; timeCost?: number; }[],
            siblings:    [] as { id: string; name: string; type: string; icon?: string; gated: boolean; resourceTag?: string; resourceCost?: number; resourceIcon?: string; timeCost?: number; }[]
        };
        
        let curActionIdToCheck = (locEnt as any).entryActionId ? (locEnt as any).entryActionId : 'sys_default_travel';
        const curAct = (cfg.actionTemplates || []).find(function(t: any) { return t.id === curActionIdToCheck; });
        if (curAct) {
            const cEffs = [...(curAct.successEffects || []), ...((curAct as any).alwaysEffects || [])];
            const cCostEff = cEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
            if (cCostEff) { 
                locationGraph.currentResourceTag = cCostEff.args.tag; 
                locationGraph.currentResourceCost = cCostEff.args.amount; 
                const rDef = (cfg.resources || []).find(r => r.tag === locationGraph.currentResourceTag);
                if (rDef && rDef.icon) locationGraph.currentResourceIcon = rDef.icon;
            }
        }
        if (locEnt.parentId) {
            const parentMeta = allEntityMeta.find(function(m) { return m.id === locEnt.parentId; });
            if (parentMeta) { locationGraph.parentName = parentMeta.name; locationGraph.parentType = parentMeta.type; locationGraph.parentIcon = (parentMeta as any).icon || undefined; }
        }
        for (const childMeta of allEntityMeta) {
            if (childMeta.parentId === locId && childMeta.type === 'location') {
                const lgHasGrandchildren = allEntityMeta.some(function(m) { return m.parentId === childMeta.id && m.type === 'location'; });
                const cEnt = await loadEntity(childMeta.id);
                let cTag = undefined; let cAmt = undefined; let cIcon = undefined; let cTime = undefined;
                let actionIdToCheck = (cEnt && (cEnt as any).entryActionId) ? (cEnt as any).entryActionId : 'sys_default_travel';
                let cAct = (cfg.actionTemplates || []).find(function(t: any) { return t.id === actionIdToCheck; });
                if (!cAct && actionIdToCheck !== 'sys_default_travel') cAct = (cfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                if (cAct) {
                    const cEffs = [...(cAct.successEffects || []), ...((cAct as any).alwaysEffects || [])];
                    const cCostEff = cEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
                    if (cCostEff) { 
                        cTag = cCostEff.args.tag; cAmt = cCostEff.args.amount; 
                        const rDef = (cfg.resources || []).find(r => r.tag === cTag);
                        if (rDef && rDef.icon) cIcon = rDef.icon;
                    }
                    const cTimeEff = cEffs.find(function(e: any) { return e.type === 'advance_time' && e.args && (e.args.hours || 0) > 0; });
                    if (cTimeEff) cTime = cTimeEff.args.hours;
                }
                locationGraph.children.push({
                    id: childMeta.id, name: childMeta.name, type: childMeta.type,
                    hasChildren: lgHasGrandchildren, icon: childMeta.icon || undefined,
                    gated:     !!childMeta.gated,
                    isVehicle: !!childMeta.isVehicle,
                    resourceTag: cTag,
                    resourceCost: cAmt,
                    resourceIcon: cIcon,
                    timeCost: cTime
                });
            }
        }
        for (const lgConn of (locEnt.connectedEntityIds || [])) {
            const lgConnMeta = allEntityMeta.find(function(m) { return m.id === lgConn.targetId; });
            if (lgConnMeta) {
                let cTag = undefined; let cAmt = undefined; let cIcon = undefined;
                let actionIdToCheck = (lgConn as any).travelActionId ? (lgConn as any).travelActionId : 'sys_default_travel';
                let cTime = undefined;
                let cAct = (cfg.actionTemplates || []).find(function(t: any) { return t.id === actionIdToCheck; });
                if (!cAct && actionIdToCheck !== 'sys_default_travel') cAct = (cfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                if (cAct) {
                    const cEffs = [...(cAct.successEffects || []), ...((cAct as any).alwaysEffects || [])];
                    const cCostEff = cEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
                    if (cCostEff) { 
                        cTag = cCostEff.args.tag; cAmt = cCostEff.args.amount; 
                        const rDef = (cfg.resources || []).find(r => r.tag === cTag);
                        if (rDef && rDef.icon) cIcon = rDef.icon;
                    }
                    const cTimeEff = cEffs.find(function(e: any) { return e.type === 'advance_time' && e.args && (e.args.hours || 0) > 0; });
                    if (cTimeEff) cTime = cTimeEff.args.hours;
                }
                locationGraph.connections.push({
                    id: lgConn.targetId, name: lgConnMeta.name,
                    label: (lgConn as any).label || '', oneWay: (lgConn as any).oneWay || false,
                    icon: lgConnMeta.icon || undefined,
                    gated:          !!lgConnMeta.gated,
                    requiresVehicle: !!(lgConn as any).requiresVehicle,
                    resourceTag:    cTag,
                    resourceCost:   cAmt,
                    resourceIcon:   cIcon,
                    timeCost:       cTime,
                    isSilent:       !!(lgConn as any).isSilent
                });
            }
        }

        // [v0.9.81] Lateral siblings: location-type entities sharing this location's parentId
        // (null parentId = shared world root, so top-level locations are mutually reachable).
        // Cost mirrors entry/default-travel resolution. Vehicles excluded (boarded, not entered).
        for (const sibMeta of allEntityMeta) {
            if (sibMeta.type !== 'location' || sibMeta.id === locId) continue;
            if (sibMeta.parentId !== locEnt.parentId) continue;
            if ((sibMeta as any).isVehicle) continue;
            let sibEnt = await loadEntity(sibMeta.id);
            let sTag = undefined; let sAmt = undefined; let sIcon = undefined; let sTime = undefined;
            let sActionId = (sibEnt && (sibEnt as any).entryActionId) ? (sibEnt as any).entryActionId : 'sys_default_travel';
            let sAct = (cfg.actionTemplates || []).find(function(t: any) { return t.id === sActionId; });
            if (!sAct && sActionId !== 'sys_default_travel') sAct = (cfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
            if (sAct) {
                let sEffs = [...(sAct.successEffects || []), ...((sAct as any).alwaysEffects || [])];
                let sCostEff = sEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
                if (sCostEff) {
                    sTag = sCostEff.args.tag; sAmt = sCostEff.args.amount;
                    let sResDef = (cfg.resources || []).find(function(r) { return r.tag === sTag; });
                    if (sResDef && sResDef.icon) sIcon = sResDef.icon;
                }
                let sTimeEff = sEffs.find(function(e: any) { return e.type === 'advance_time' && e.args && (e.args.hours || 0) > 0; });
                if (sTimeEff) sTime = sTimeEff.args.hours;
            }
            locationGraph.siblings.push({
                id: sibMeta.id, name: sibMeta.name, type: sibMeta.type,
                icon: sibMeta.icon || undefined, gated: !!sibMeta.gated,
                resourceTag: sTag, resourceCost: sAmt, resourceIcon: sIcon, timeCost: sTime
            });
        }

        // 8b. Present items — item-type entities whose parent is the current location
        const presentItems = allEntityMeta
            .filter(function(m) { return m.type === 'item' && m.parentId === locId; })
            .map(function(m) { return { id: m.id, name: m.name, icon: (m as any).icon || undefined }; });

        // [vNEXT] Minor NPCs present at this location, surfaced like present items so
        // the HUDs list them without the heavy character avatar/inspect path.
        const presentMinorNpcs = allChars
            .filter(function(c) { return (c as any).npcClass === 'minor' && c.scenePresent && c.active; })
            .map(function(c) { return { id: c.entityId || '', charId: c.id, name: c.name, brief: c.briefDescription || '' }; })
            .filter(function(n) { return !!n.id; });

        // 9. Active narratives (all non-completed narrative entities)
        // [v0.9.25 B8-fix] inPlayerHierarchy = direct child of the protagonist's entity body only.
        // A quest appears in the HUD Quests tab exclusively when an action moves it under
        // protag.entityId — e.g. "Accept Quest" sets parentId = protag.entityId.
        const _protagEntityId = protag && (protag as any).entityId;
        // [v0.9.30 NARR-HUD] Include ALL narratives (completed included) so the HUD Quests
        // tab can list the full set under the player hierarchy and sort them
        // tracked -> active -> locked -> completed. isTracked flags the pinned objective.
        const _trackedNarrId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
        const activeNarratives = allEntityMeta
            .filter(function(m) { return m.type === 'narrative'; })
            .map(function(m) { return { id: m.id, name: m.name, storyState: m.storyState || 'locked', parentId: m.parentId, icon: (m as any).icon || undefined, inPlayerHierarchy: !!(_protagEntityId && m.parentId === _protagEntityId), isTracked: m.id === _trackedNarrId }; });

        // 9b. Player Equipment
        const playerEquipment: any[] = [];
        if (protag && protag.entityId) {
            const myItems = allEntityMeta.filter(m => m.type === 'item' && m.parentId === protag.entityId);
            for (const m of myItems) {
                const isEq = (protag.equippedItemIds || []).includes(m.id);
                playerEquipment.push({ id: m.id, name: m.name, icon: (m as any).icon || undefined, isEquipped: isEq });
            }
        }

        // 10. Party faction relationships
        const factionRelationships = (cfg.factions || []).map(function(fDef: FactionDef) {
            const stateIdx = (party.factionRelationships && party.factionRelationships[fDef.id]) || 0;
            return {
                id:         fDef.id,
                name:       fDef.name,
                states:     fDef.relationshipStates || [],
                stateIdx:   stateIdx,
                stateLabel: (fDef.relationshipStates || [])[stateIdx] || '',
                isParty:    true
            };
        });

        // 11. Protagonist skills from sheet categories
        const protagSkills: { name: string; sheetMod: number }[] = [];
        for (const cat of (cfg.sheetCategories || [])) {
            for (const field of (cat.fields || [])) {
                const combinedId = cat.id + '.' + field.id;                          // [FIX] canonical dot key (matches CharacterEditModal + #skill)
                const legacyUnderscoreId = cat.id + '_' + field.id;                  // legacy fallback
                const rawVal = protag.sheetValues[combinedId] !== undefined
                    ? protag.sheetValues[combinedId]
                    : (protag.sheetValues[legacyUnderscoreId] !== undefined
                        ? protag.sheetValues[legacyUnderscoreId]
                        : (protag.sheetValues[field.id] !== undefined ? protag.sheetValues[field.id] : ''));
                let numMod = parseInt(String(rawVal), 10);
                if (isNaN(numMod)) numMod = 0;
                protagSkills.push({ name: field.name, sheetMod: numMod,
                    displayValue: String(rawVal !== undefined && rawVal !== null ? rawVal : ''),
                    fieldType: cat.fieldType || 'text',
                    enumValues: cat.enumValues || [],
                    categoryId: cat.id,
                    fieldId: field.id
                });
            }
        }

        // 11b. [v0.9.68] Protagonist personal resources — drives the Stakes picker and
        // a future HUD personal bar. Same SceneResourceInfo shape as partyResources.
        const protagResources: SceneResourceInfo[] = (((protag as any).charResourceDefs) || []).map(function(rd: any): SceneResourceInfo {
            const cVal = (((protag as any).charResourceValues) && (protag as any).charResourceValues[rd.id] !== undefined) ? (protag as any).charResourceValues[rd.id] : 0;
            const pr: SceneResourceInfo = { id: rd.id, name: rd.name, type: rd.type, value: cVal, tag: rd.tag, icon: rd.icon || '' };
            if (rd.type === 'pool' && rd.hasBounds) { pr.min = rd.min; pr.max = rd.max; }
            else if (rd.type === 'track' || rd.type === 'discrete') { pr.states = rd.states || []; }
            return pr;
        });

        // 11c. [vNEXT] Stake definitions — drives the Stakes picker in the bridge composer
        // (replaces the old raw-resource picker; selecting a stake binds its own band x side
        // effect table rather than a generic single-resource substitution).
        const sceneStakeDefs: { id: string; name: string; defaultForAttrs: string[]; }[] = (cfg.stakeDefs || []).map(function(sd: any) {
            return { id: sd.id, name: sd.name, defaultForAttrs: sd.defaultForAttrs || [] };
        });

        let _scClk = await loadClock(cfg);
        let _scClock: SceneClockInfo = {
            enabled: !!cfg.timeShowInAN,
            hours: _scClk.hours,
            hourOfDay: clockHourOfDay(_scClk.hours),
            dayOfCycle: clockDayOfCycle(_scClk.hours),
            week: clockWeek(_scClk.hours),
            dayOfWeek: clockDayOfWeek(_scClk.hours),
            absoluteDay: clockAbsoluteDay(_scClk.hours),
            band: clockBandFor(clockHourOfDay(_scClk.hours), cfg.timeBands || []),
            stamp: clockFormatStamp(_scClk.hours, cfg),
            dayLabel: clockDayLabel(_scClk.hours, cfg),
            weekLabel: clockWeekLabel(_scClk.hours, cfg),
            bands: (cfg.timeBands || []),
            dayNames: (cfg.timeDayNames || []),
            weekNames: (cfg.timeWeekNames || []),
            autoAdvanceEnabled: !!cfg.timeAutoAdvanceEnabled,
            advanceHours: (Number(cfg.timeAdvanceHours) > 0 ? Math.floor(Number(cfg.timeAdvanceHours)) : 1),
            advanceEveryGens: (Number(cfg.timeAdvanceEveryGens) > 0 ? Math.floor(Number(cfg.timeAdvanceEveryGens)) : 3),
            timedActions: collectTimedActions(cfg)
        };

        return {
            locationId:           locId,
            locationName:         locEnt.name,
            locationDescription:  locDesc,
            locationAtmosphere:   locEnt.atmosphere || '',
            locationState:        locEnt.state || 'default',
            presentCharacters:    presentCharacters,
            partyResources:       partyResources,
            availableActions:     [],   // [cutover] OLD ent.actions retired; HUD now uses availableInstances
            availableInstances:   availableInstances,
            lastRoll:             await api.v1.tempStorage.getOrDefault('ae_last_roll', null),
            quickInstances:       await loadQuickInstances(),
            locationGraph:        locationGraph,
            inVehicleId:          !!(locEnt as any).isVehicle ? locId : null,
            vehicleWorldLocationId: !!(locEnt as any).isVehicle ? (locEnt.parentId || null) : null,
            activeNarratives:     activeNarratives,
            factionRelationships: factionRelationships,
            protagSkills:         protagSkills,
            protagResources:      protagResources,
            stakeDefs:            sceneStakeDefs,
            presentItems:         presentItems,
            presentMinorNpcs:     presentMinorNpcs,
            playerEquipment:      playerEquipment,
            defaultBgUrl:         (cfg as any).defaultBackgroundUrl || '',
            clock:                _scClock
        };
    } catch (e) {
        api.v1.log('[AE:bridge] buildSceneStatePayload error:', e);
        return null;
    }
}

// [v0.9.8.6] Stable entry point for renderers (native HUD modals) to read scene
// state, decoupling them from buildSceneStatePayload's name. Pass-through for now;
// a cache with verb-driven invalidation can be layered here once modals consume it.
async function getSceneState(): Promise<SceneStatePayload | null> {
    return await buildSceneStatePayload();
}

async function broadcastSceneState(): Promise<void> {
    if (!isBridgeReady) return;
    try {
        const payload = await buildSceneStatePayload();
        if (payload) await broadcastToTM(EVT_SCENE_STATE, payload);
    } catch (e) {
        api.v1.log('[AE:bridge] broadcastSceneState error:', e);
    }
}

function queueSceneStateBroadcast(): void {
    // [v0.9.36] Serialize + coalesce. The previous fire-and-forget spawned a fresh
    // broadcastSceneState() on every call; during commitTravel that meant ~5 CONCURRENT
    // payload builds, each calling loadPlayerLocation() at a different instant, so a
    // stale 'old room' payload could land after the fresh one -> visible flicker/flap.
    // Now at most one runs at a time; requests during a run collapse into a single
    // follow-up that reflects the final settled state.
    if (!isBridgeReady) return;
    if (ae_sbcInFlight) { ae_sbcPending = true; return; }
    ae_sbcInFlight = true;
    broadcastSceneState()
        .catch(function(e) { api.v1.log('[AE:bridge] sceneState broadcast err:', e); })
        .then(function() {
            ae_sbcInFlight = false;
            if (ae_sbcPending) { ae_sbcPending = false; queueSceneStateBroadcast(); }
        });
}

// ── Messaging Init ────────────────────────────────────────────────────────────

async function initMessaging(): Promise<void> {
    // [v0.9.29 HSK1] onMessage registration is awaited so the handler is in place
    // before onScriptsLoaded continues (fast ACKs won't be missed).
    // The handshake itself is then retried in a detached loop so story init is not
    // blocked if the bridge proxy installed after our worker was constructed.
    try {
        await api.v1.messaging.onMessage(handleBridgeMessage);
    } catch (e) {
        api.v1.log('[AE:bridge] initMessaging onMessage error:', e);
        return;
    }

    // Fire-and-forget retry loop. Sends the full handshake sequence (IN + OUT + REQ)
    // every 1.5 s until the bridge ACKs (isBridgeReady) or 20 attempts are exhausted.
    // Using an anonymous IIFE avoids the named-async-in-sync-body NAI sandbox constraint.
    (async function() {
        let _hsAttempts = 0;
        while (!isBridgeReady && _hsAttempts < 20) {
            try {
                await api.v1.messaging.broadcast(
                    { type: 'HANDSHAKE', sid: api.v1.script.id, payload: { handshake: 'NAI_SCRIPT:IN' } }
                );
                await api.v1.messaging.broadcast(
                    { type: 'HANDSHAKE', sid: api.v1.script.id, payload: { handshake: 'NAI_SCRIPT:OUT' } }
                );
                await broadcastToTM(EVT_HANDSHAKE_REQ, { scriptId: api.v1.script.id });
            } catch (e2) {
                api.v1.log('[AE:bridge] handshake attempt', _hsAttempts, 'error:', e2);
            }
            _hsAttempts++;
            if (isBridgeReady) break;
            api.v1.log('[AE:bridge] Handshake attempt', _hsAttempts, '— waiting for ACK…');
            await api.v1.timers.sleep(1500);
        }
        if (isBridgeReady) {
            api.v1.log('[AE:bridge] Bridge connected after', _hsAttempts, 'attempt(s).');
        } else {
            api.v1.log('[AE:bridge] Bridge did not ACK after', _hsAttempts, 'attempts. Running engine-only.');
        }
    })().catch(function(e3) { api.v1.log('[AE:bridge] initMessaging loop error:', e3); });
}

async function buildEntityDetailPayload(fId: string, char: any, ent: any): Promise<any> {
    const detailPayload: any = {
        id: fId,
        name: char ? char.name : (ent ? ent.name : 'Unknown'),
        type: char ? 'character' : (ent ? ent.type : 'location'),
        compiledThought: char && char.ephemeral ? char.ephemeral.compressedLine : '',
        hooks: char ? (char.hooks || []).filter((h: any) => !h.resolved) : [],
        isEquipped: ent ? !!ent.isEquipped : false,
        equippedToCharId: ent ? ent.equippedToCharId : undefined,
        isProtagonist: !!(char && char.isProtagonist)
    };

    // [v0.9.88] For item entities, resolve the character record ID whose entity body
    // is the item's parent. AE_EQUIP_ITEM requires a character record ID (not an entity ID),
    // so we expose it as ownerCharId. equippedToCharId covers the "currently equipped to"
    // case; ownerCharId covers "which character owns / carries this item" (same as unequip).
    if (ent && ent.type === 'item' && ent.parentId) {
        const _itemAllChars = await loadAllCharacters();
        const _itemOwner = _itemAllChars.find(function(c: any) { return c.entityId === ent.parentId; });
        detailPayload.ownerCharId = _itemOwner ? _itemOwner.id : undefined;
        detailPayload.parentId = ent.parentId; // expose raw entity parentId too for reference
    }

    const targetParentId = char ? char.entityId : (ent ? ent.id : null);
    const entIdx = await loadEntityIndex();
    // [v0.9.32 FOLLOW3] Compute isFollowing: char entity parented under protagonist body.
    if (char && char.entityId && ent) {
        const _fdAllChars = await loadAllCharacters();
        const _fdProtag = _fdAllChars.find(function(c) { return !!c.isProtagonist; });
        detailPayload.isFollowing = !!(ent && _fdProtag && _fdProtag.entityId && ent.parentId === _fdProtag.entityId);
    }
    const children = [];
    if (targetParentId) {
        // [v0.9.9.7] Narrative children carry storyState/isTracked/questTargetName/
        // eventDayTarget so any list that renders a character's or location's
        // narrative children (inventory, quests) can show real state instead of
        // always-locked/never-tracked placeholders. Fetched once, not per-child.
        const _cdTrackedId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
        const childMetas = entIdx.filter(m => m.parentId === targetParentId);
        for (const cm of childMetas) {
            const cEnt = await loadEntity(cm.id);
            if (cEnt) {
                const childOut: any = {
                    id: cEnt.id,
                    name: cEnt.name,
                    type: cEnt.type,
                    icon: cEnt.icon || undefined,
                    description: cEnt.description || '',
                    state: cEnt.state || 'default',
                    isEquipped: !!cEnt.isEquipped,
                    equippedToCharId: (cEnt as any).equippedToCharId,
                    actions: (cEnt.actions || []).map((a: any) => ({ id: a.id, label: a.label })),
                    actionInstances: ((cEnt as any).actionInstances || []).map((inst: any) => ({ id: inst.id, name: inst.name, silent: !!inst.silent }))
                };
                if (cEnt.type === 'narrative') {
                    childOut.storyState = (cEnt as any).storyState || 'locked';
                    childOut.isTracked = (_cdTrackedId === cEnt.id);
                    childOut.questTarget = (cEnt as any).questTarget || '';
                    childOut.eventDayTarget = (cEnt as any).eventDayTarget;
                    if ((cEnt as any).questTarget) {
                        const _cdQt = entIdx.find(m => m.id === (cEnt as any).questTarget);
                        childOut.questTargetName = _cdQt ? _cdQt.name : '';
                    }
                }
                children.push(childOut);
            }
        }
    }
    detailPayload.children = children;

    // [v0.9.20] Per-character resources (charResourceDefs + charResourceValues)
    if (char) {
        const crdefs: any[] = char.charResourceDefs || [];
        if (crdefs.length > 0) {
            detailPayload.charResources = crdefs.map(function(def: any) {
                const val = (char.charResourceValues || {})[def.id] || 0;
                return { id: def.id, tag: def.tag, name: def.name, type: def.type, value: val,
                    hasBounds: !!def.hasBounds, min: def.min, max: def.max, states: def.states || [] };
            });
        }
    }

    if (ent) {
        detailPayload.actions = (ent.actions || []).map((a: any) => ({ id: a.id, label: a.label }));
        detailPayload.actionInstances = ((ent as any).actionInstances || []).map((inst: any) => ({
            id: inst.id,
            name: inst.name,
            hasResolution: !!(inst.resolution && (inst.resolution.type || inst.resolution.dice)),
            requiresTarget: inst.targetMode === 'player_pick',
            outcomeNote: inst.outcomeNote || '',
            silent: !!inst.silent
        }));
    }

    if (ent && ent.type === 'narrative') {
        const isTracked = (await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string) === ent.id;
        let questTargetName = '';
        let pathNames: string[] = [];
        if (ent.questTarget) {
            const qtTgt = entIdx.find(m => m.id === ent.questTarget);
            if (qtTgt) {
                questTargetName = qtTgt.name;
                const curLoc = await loadPlayerLocation();
                const isLocTgt = qtTgt.type === 'location';
                const navId = isLocTgt ? qtTgt.id : (qtTgt.parentId || '');
                if (curLoc && navId) {
                    const path = await findTravelPath(curLoc, navId);
                    if (path && path.length > 0) {
                        pathNames = path.map(id => {
                            const m = entIdx.find(n => n.id === id);
                            return m ? m.name : id;
                        });
                        if (!isLocTgt) pathNames.push(qtTgt.name);
                    }
                }
            }
        }
        detailPayload.narrative = {
            isTracked,
            questTarget: ent.questTarget || '',
            questTargetName,
            pathNames,
            storyState: ent.storyState || 'locked',
            description: ent.description || ''
        };
    }

    return detailPayload;
}

// [v0.9.9.5] Shared travel entry point. Extracted from the AE_TRAVEL_REQUEST
// handler so the native map HUD routes travel through the SAME action-template
// pipeline (connection travelActionId -> destination entryActionId -> synthesized
// sys_default_travel), including condition checks, resource costs, narrative
// injection and the single deferred generation. Callers: message router + native map.
async function performTravelRequest(targetId: string, seq?: any): Promise<void> {
                // [v0.9.15] Travel actions fully replace all old gate/narrative/cost logic.
                // Every travel goes through an ActionInstance — either a stored one from
                // travelActionId / entryActionId, or a synthesized default.
                //
                // Scope convention: sourceEnt = DESTINATION (so __self__ = dest name in narratives)
                //                   target    = current location
                //
                // Upward travel (retreat to parent) is always fast and silent — no action.
                // [v0.9.34 LOCK1] Guard: if ae_lock is held (dynamic engine making background
                // api.v1.generate() calls), calling api.v1.editor.generate() inside commitTravel
                // would fail with 'editor is currently blocked'. Bail with a friendly message.
                if (ae_lock) {
                    api.v1.ui.toast('⌛ Engine processing — please try again in a moment.', { type: 'info', autoClose: 2500 });
                    return;
                }
                try {
                    const tgtId = targetId;
                    if (!tgtId) { api.v1.ui.toast('Travel failed: no target ID.', { type: 'error', autoClose: 2500 }); return; }
                    const tgtEnt = await loadEntity(tgtId);
                    if (!tgtEnt) {
                        api.v1.ui.toast('Travel failed: destination not found.', { type: 'error', autoClose: 4000 });
                        api.v1.log('[AE:travel] loadEntity returned null for targetId:', tgtId);
                        return;
                    }
                    const locId  = await loadPlayerLocation();
                    const locEnt = locId ? await loadEntity(locId) : null;

                    if (!locEnt) {
                        // Fallback: player location unknown — anchor directly, no narrative.
                        const trFbIdx  = await loadIndex();
                        const trFbMeta = trFbIdx.find(function(m) { return !!m.isProtagonist; });
                        if (trFbMeta) {
                            const trFbProtag = await loadCharacter(trFbMeta.id);
                            if (trFbProtag && trFbProtag.entityId) {
                                const trFbBody = await loadEntity(trFbProtag.entityId);
                                if (trFbBody) { trFbBody.parentId = tgtId; await saveEntity(trFbBody); }
                            }
                            if (trFbProtag) { trFbProtag.currentLocationId = tgtId; await saveCharacter(trFbProtag); }
                            await recalculateScenePresence();
                            api.v1.ui.toast('📍 Anchored to ' + tgtEnt.name, { type: 'info', autoClose: 2000 });
                            await broadcastSceneState();
                        }
                        return;
                    }

                    // ── Adjacency ──────────────────────────────────────────────────
                    const trIsUpward   = (locEnt.parentId === tgtId);
                    const trIsDownward = (tgtEnt.parentId === locId);
                    const trConn       = (locEnt.connectedEntityIds || []).find(function(c) { return c.targetId === tgtId; });
                    const trIsExplicit = !!trConn;
                    // [v0.9.81] Lateral sibling travel: same parentId (null = shared world root),
                    // not self, not a vehicle. Flows through the downward path below (lateral
                    // parentId set, identical to entering a child).
                    const trIsSibling  = (tgtEnt.parentId === locEnt.parentId && tgtId !== locId && !(tgtEnt as any).isVehicle);
                    api.v1.log('[AE:TRACE] TRAVEL_REQUEST seq=' + (seq || '?') + ' from=' + locEnt.name + '(' + locId + ') to=' + tgtEnt.name + '(' + tgtId + ') upward=' + trIsUpward + ' downward=' + trIsDownward + ' explicit=' + trIsExplicit + ' connSilent=' + (trConn ? !!(trConn as any).isSilent : 'n/a'));
                    if (!trIsUpward && !trIsDownward && !trIsExplicit && !trIsSibling) {
                        api.v1.ui.toast('Cannot travel: ' + tgtEnt.name + ' is not adjacent.', { type: 'error', autoClose: 3000 });
                        return;
                    }

                    // ── Upward (return to parent): routed through SYS_RETURN_TRAVEL ──
                    // [v0.9.21 E4] Scope convention: sourceEnt = destination (parent),
                    // so __self__ resolves to the parent name in narrative text.
                    // Variable suffix 'U' avoids const-name collisions with the
                    // downward-path 'R'-suffix variables that follow.
                    if (trIsUpward) {
                        const trCharIdxU = await loadIndex();
                        const trProtagMU = trCharIdxU.find(function(m) { return !!m.isProtagonist; });
                        const trProtagU  = trProtagMU ? await loadCharacter(trProtagMU.id) : null;
                        const trProtagEntU = (trProtagU && trProtagU.entityId) ? await loadEntity(trProtagU.entityId) : null;
                        const trCfgU = await loadConfig();
                        let trActionU: any = null;
                        const trSysRet = ((trCfgU as any).actionTemplates || []).find(function(t: any) { return t.id === 'sys_return_travel'; });
                        if (trSysRet) {
                            trActionU = JSON.parse(JSON.stringify(trSysRet));
                        } else {
                            // Failsafe: no stored template found (pre-migration save).
                            trActionU = { conditions: [{ id: '_ru_g', type: 'entity_locked', args: { scope: '__self__', value: 'false' } }], failureNote: '🔒 ' + tgtEnt.name + ' is locked.', alwaysEffects: [], successEffects: [{ id: '_ru_n', type: 'inject_narrative', args: { text: 'You return to __self__.' } }, { id: '_ru_m', type: 'move_player_to_self', args: {} }], silent: false };
                        }
                        const trScopeU: AEScope = { sourceEnt: tgtEnt, target: locEnt, protag: trProtagU, protagEnt: trProtagEntU, parentEnt: null, __silent: !!(trActionU as any).silent };
                        const trPassU = await aeCheckConditions((trActionU as any).conditions || [], trScopeU);
                        if (!trPassU) {
                            const trFailU = (trActionU as any).failureNote || ('Cannot return to ' + tgtEnt.name + '.');
                            api.v1.ui.toast(trFailU, { type: 'error', autoClose: 3000 });
                            return;
                        }
                        api.v1.log('[AE:TRACE] UPWARD via ' + ((trActionU as any).id || 'failsafe') + ' silent=' + !!(trActionU as any).silent + ' always=' + (((trActionU as any).alwaysEffects||[]).length) + ' success=' + (((trActionU as any).successEffects||[]).length));
                        await aeApplyEffects((trActionU as any).alwaysEffects || [], trScopeU, trCfgU);
                        await aeApplyEffects((trActionU as any).successEffects || [], trScopeU, trCfgU);
                        // [v0.9.37 DEFER1] Single deferred generation after all effects.
                        if (ae_pendingGenerate) { ae_pendingGenerate = false; await aeEditorGenerate('travelUpward'); }
                        return;
                    }

                    // ── Build scope: sourceEnt = destination (for __self__ token) ──
                    const trCharIdxR  = await loadIndex();
                    const trProtagMR  = trCharIdxR.find(function(m) { return !!m.isProtagonist; });
                    const trProtagR   = trProtagMR ? await loadCharacter(trProtagMR.id) : null;
                    const trProtagEntR = (trProtagR && trProtagR.entityId) ? await loadEntity(trProtagR.entityId) : null;

                    // ── Resolve travel action (stored or synthesized default) ───────
                    let trActionR: any = null;
                    const trCfgR = await loadConfig();

                    // Priority: connection-level action > destination entry action
                    if (trConn && (trConn as any).travelActionId) {
                        trActionR = ((trCfgR as any).actionTemplates || []).find(function(t: any) { return t.id === (trConn as any).travelActionId; }) || null;
                    }
                    if (!trActionR && (tgtEnt as any).entryActionId) {
                        trActionR = ((trCfgR as any).actionTemplates || []).find(function(t: any) { return t.id === (tgtEnt as any).entryActionId; }) || null;
                    }

                    // Synthesize default when no stored action configured
                    if (!trActionR) {
                        const sysDef = ((trCfgR as any).actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                        if (sysDef) {
                            trActionR = JSON.parse(JSON.stringify(sysDef));
                            if (trConn && trConn.label && trConn.label.trim()) {
                                const nEff = (trActionR.successEffects || []).find(function(e: any) { return e.type === 'inject_narrative'; });
                                if (nEff && nEff.args) nEff.args.text = trConn.label.trim();
                            }
                        } else {
                            // Failsafe fallback
                            const trDefNarr = (trConn && trConn.label && trConn.label.trim()) ? trConn.label.trim() : 'You leave for __self__.';
                            trActionR = { conditions: [{ id: '_tr_g', type: 'entity_locked', args: { scope: '__self__', value: 'false' } }], failureNote: '', alwaysEffects: [], successEffects: [{ id: '_tr_n', type: 'inject_narrative', args: { text: trDefNarr } }, { id: '_tr_m', type: 'move_player_to_self', args: {} }], silent: false };
                        }

                        if (trConn && !!(trConn as any).requiresVehicle) {
                            if (!trActionR.conditions) trActionR.conditions = [];
                            trActionR.conditions.push({ id: '_tr_v', type: 'in_vehicle', args: {} });
                        }
                        const trIsSilentR = trConn ? !!(trConn as any).isSilent : false;
                        trActionR.silent = trIsSilentR || trActionR.silent;
                        
                        const trFailNote = (trConn && !!(trConn as any).requiresVehicle)
                            ? '🚢 A vehicle is required to reach ' + tgtEnt.name + '.'
                            : '🔒 ' + tgtEnt.name + ' is locked.';
                        if (!trActionR.failureNote) trActionR.failureNote = trFailNote;
                    }

                    const trScopeR: AEScope = { sourceEnt: tgtEnt, target: locEnt, protag: trProtagR, protagEnt: trProtagEntR, parentEnt: null, __silent: !!(trActionR as any).silent };
                    api.v1.log('[AE:TRACE] DOWNWARD/EXPLICIT via ' + ((trActionR as any).id || 'synth') + ' silent=' + !!(trActionR as any).silent + ' always=' + (((trActionR as any).alwaysEffects||[]).length) + ' success=' + (((trActionR as any).successEffects||[]).length) + ' narrativeEffects=' + (((trActionR as any).successEffects||[]).filter(function(e:any){return e.type==='inject_narrative';}).length));

                    // ── Spend flat resource cost (synthesized path only) ────────────
                    // Stored actions handle costs via their own effects; synthesized ones
                    // use the legacy flat-field approach here to avoid double-spend.
                    if (!(trConn && (trConn as any).travelActionId) && !(tgtEnt as any).entryActionId) {
                        const trResTag  = trConn ? trConn.requiresResourceTag : (tgtEnt as any).entryCostTag;
                        const trResCost = trConn ? (trConn.resourceCost || 0)  : ((tgtEnt as any).entryCostAmount || 0);
                        if (trResTag && trResCost > 0) {
                            const trResOk = await checkResource(trResTag, trResCost);
                            if (!trResOk) {
                                api.v1.ui.toast('Insufficient ' + trResTag + ' to travel.', { type: 'error', autoClose: 3000 });
                                return;
                            }
                            const trResDef  = (trCfgR.resources || []).find(function(r) { return r.tag === trResTag; });
                            const trIsTrack = trResDef && trResDef.type === 'track';
                            await adjustResource(trResTag, trIsTrack ? trResCost : -trResCost);
                        }
                    }

                    // ── Run action conditions ──────────────────────────────────────
                    const trPassR = await aeCheckConditions((trActionR as any).conditions || [], trScopeR);
                    if (!trPassR) {
                        const trFailR = (trActionR as any).failureNote || ('Cannot travel to ' + tgtEnt.name + '.');
                        api.v1.ui.toast(trFailR, { type: 'error', autoClose: 3000 });
                        return;
                    }

                    // ── Run action effects (alwaysEffects, then successEffects) ─────
                    // inject_narrative fires first, then move_player_to_self which calls
                    // commitTravel → generate(). Execution ends when generate() returns.
                    api.v1.log('[AE:TRACE] running downward effects now (seq=' + (seq || '?') + ')');
                    await aeApplyEffects((trActionR as any).alwaysEffects || [], trScopeR, trCfgR);
                    await aeApplyEffects((trActionR as any).successEffects || [], trScopeR, trCfgR);
                    api.v1.log('[AE:TRACE] downward effects complete (seq=' + (seq || '?') + ')');
                    // [v0.9.37 DEFER1] Every effect (incl. inject_narrative) ran on an
                    // unblocked editor. Now perform the single deferred generation.
                    if (ae_pendingGenerate) {
                        ae_pendingGenerate = false;
                        api.v1.log('[AE:TRACE] travel finalize generate (seq=' + (seq || '?') + ')');
                        await aeEditorGenerate('travelDownward');
                    }

                } catch (e) { api.v1.log('[AE:bridge] AE_TRAVEL_REQUEST error:', e); }
}

// [v0.9.9.7] Shared follow/stay toggle. Extracted from AE_TOGGLE_FOLLOW so the
// native character inspection view can call the SAME logic in-worker.
async function toggleCharFollow(tfCharId: string): Promise<void> {
    try {
        const tfAllChars = await loadAllCharacters();
        const tfProtag = tfAllChars.find(function(c) { return !!c.isProtagonist; });
        const tfChar = tfAllChars.find(function(c) { return c.id === tfCharId; });
        if (!tfProtag || !tfChar || !tfChar.entityId || !tfProtag.entityId) return;
        const tfEntMeta = await loadEntityIndex();
        const tfCharEntMeta = tfEntMeta.find(function(m) { return m.id === tfChar.entityId; });
        const tfProtagRoom = getEffectiveRoomId(tfProtag.entityId, tfEntMeta);
        const tfIsFollowing = !!(tfCharEntMeta && tfCharEntMeta.parentId === tfProtag.entityId);
        const tfNewParent = tfIsFollowing ? (tfProtagRoom || null) : tfProtag.entityId;
        const tfEnt = await loadEntity(tfChar.entityId);
        if (tfEnt) {
            tfEnt.parentId = tfNewParent;
            await saveEntity(tfEnt);
            await recalculateScenePresence();
            const tfName = tfChar.name || 'Character';
            api.v1.ui.toast(tfIsFollowing ? ('\u{1F464} ' + tfName + ' stays here') : ('\u{1F465} ' + tfName + ' follows you'), { type: 'info', autoClose: 2000 });
            await broadcastSceneState();
        }
    } catch (e) { api.v1.log('[AE:bridge] toggleCharFollow error:', e); }
}

// [v0.9.9.7] Shared hook resolution. Extracted from AE_RESOLVE_HOOK so the native
// character inspection view can resolve a hook without a message round-trip.
async function resolveCharHook(charId: string, hookId?: string, hookIndex?: number): Promise<void> {
    try {
        if (!charId) return;
        const fresh = await loadCharacter(charId);
        if (!fresh) return;
        if (!fresh.hooks) fresh.hooks = [];

        let idx = -1;
        if (hookId) {
            idx = fresh.hooks.findIndex((h: any) => h.id === hookId);
        } else if (typeof hookIndex === 'number') {
            idx = hookIndex;
        }

        if (idx >= 0 && idx < fresh.hooks.length) {
            const hkFresh = fresh;
            const hkDesc = hkFresh.hooks[idx].description.substring(0, 50);
            hkFresh.hooks.splice(idx, 1);
            await saveCharacter(hkFresh);
            api.v1.ui.toast('✓ Resolved: ' + hkDesc, { type: 'success', autoClose: 3000 });
            await broadcastCharacterData();
            await broadcastSceneState();

            let ent = null;
            if (hkFresh.entityId) ent = await loadEntity(hkFresh.entityId);
            const detailPayload = await buildEntityDetailPayload(charId, hkFresh, ent);
            await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', detailPayload);
        }
    } catch (e) { api.v1.log('[AE:bridge] resolveCharHook error:', e); }
}

// [v0.9.9.7] Shared quest-tracking toggle. Extracted from AE_TRACK_NARRATIVE so
// native narrative rows (Inspect / character inventory / Player Quests tab) can
// toggle tracking without a message round-trip.
async function toggleNarrativeTracking(narrativeId: string): Promise<void> {
    try {
        if (!narrativeId) return;
        const currentTracked = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
        if (currentTracked === narrativeId) {
            await api.v1.storyStorage.set(STORAGE_TRACKED_NARRATIVE, '');
            api.v1.ui.toast('Quest tracking stopped.', { type: 'info', autoClose: 1500 });
        } else {
            await api.v1.storyStorage.set(STORAGE_TRACKED_NARRATIVE, narrativeId);
            const narr = await loadEntity(narrativeId);
            api.v1.ui.toast('📍 Tracking: ' + (narr ? narr.name : narrativeId), { type: 'success', autoClose: 2000 });
        }
        await broadcastSceneState();
    } catch (e) { api.v1.log('[AE:bridge] toggleNarrativeTracking error:', e); }
}

// [v0.9.9.7] Shared equip/unequip. Extracted from AE_EQUIP_ITEM / AE_UNEQUIP_ITEM
// (merged via the equip flag) so native item rows can toggle equip state without a
// message round-trip. Rule preserved exactly: the toggle only ever targets the
// item's own owner/parent character id passed in as charId -- callers resolve which
// character that is (owner for equip, equippedToCharId for unequip); there is no
// character picker.
async function setItemEquip(charId: string, itemId: string, equip: boolean): Promise<void> {
    try {
        if (!charId || !itemId) return;
        const char = await loadCharacter(charId);
        const item = await loadEntity(itemId);
        if (!char || !item) return;
        await aeSetEquip(item, char, equip);
        api.v1.ui.toast(equip ? ('🎒 Equipped: ' + item.name) : ('🎒 Unequipped: ' + item.name), { type: equip ? 'success' : 'info', autoClose: 2000 });
        await broadcastCharacterData();
        await broadcastSceneState();

        let ent = null;
        if (char.entityId) ent = await loadEntity(char.entityId);
        const detailPayload = await buildEntityDetailPayload(charId, char, ent);
        await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', detailPayload);
    } catch (e) { api.v1.log('[AE:bridge] setItemEquip error:', e); }
}

// ── Inbound Message Router ────────────────────────────────────────────────────

// [v0.9.101 ENTITIES] Normalize a kind's entities (memory sections / species / factions)
// into a uniform shape for the HUD. Reads the SAME cfg stores the engine wizard writes.
async function buildWizardEntitiesPayload(kind: string): Promise<any> {
    let ecfg = await loadConfig();
    let items: any[] = [];
    if (kind === 'memory') {
        items = (ecfg.wizardSections || []).map(function(sx: WizardMemorySection) {
            return { id: sx.id, name: sx.label, content: sx.content || '', enabled: sx.enabled !== false, target: sx.target || 'memory', instructions: sx.instructions || '' };
        });
    } else if (kind === 'species') {
        items = (ecfg.species || []).map(function(x: any) { return { id: x.id, name: x.name, content: x.description || '' }; });
    } else if (kind === 'factions') {
        items = (ecfg.factions || []).map(function(x: any) { return { id: x.id, name: x.name, content: x.description || '', relationshipStates: x.relationshipStates || [] }; });
    }
    return { kind: kind, items: items };
}

// [v0.9.97 WIZHUD] Build the wizard snapshot for the HUD: topic registry, chat list
// (lightweight), and the active chat in full (messages + context selection).
async function buildWizardStatePayload(): Promise<any> {
    let wcfg = await loadConfig();
    let topicsSrc = ((wcfg as any).wizardTopics && (wcfg as any).wizardTopics.length) ? (wcfg as any).wizardTopics : DEFAULT_WIZARD_TOPICS;
    let topics = topicsSrc.map(function(t: WizardTopic) { return { id: t.id, label: t.label, commitKind: t.commitKind }; });
    let chats = await loadWizardChats();
    let list = chats.map(function(c: WizardChat) {
        return { id: c.id, topicId: c.topicId, title: c.title, updatedAt: c.updatedAt, msgCount: (c.messages || []).length };
    }).sort(function(a: any, b: any) { return b.updatedAt - a.updatedAt; });
    let activeId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_ACTIVE_CHAT, '') as string;
    let active = null;
    if (activeId) {
        let ac = await loadWizardChat(activeId);
        if (ac) {
            active = {
                id: ac.id, topicId: ac.topicId, title: ac.title,
                messages: ac.messages || [],
                contextChatIds: ac.contextChatIds || [],
                lorebookEntryIds: ac.lorebookEntryIds || [],
                includeStory: !!ac.includeStory
            };
        } else { activeId = ''; }
    }
    return { topics: topics, chats: list, activeChatId: activeId, activeChat: active, project: { name: wcfg.projectName || '', genre: wcfg.projectGenre || '', concept: wcfg.projectConcept || '' } };
}

// [v0.9.97 WIZHUD] List selectable context sources for a chat: other wizard chats,
// lorebook entries, and characters (each flagged whether it already has a lore entry,
// so the picker can show 'will create on add'). Mirrors buildWizardContext's sources.
async function buildWizardSourcesPayload(chatId: string): Promise<any> {
    let chats = await loadWizardChats();
    let otherChats = chats.filter(function(c: WizardChat) { return c.id !== chatId; })
        .map(function(c: WizardChat) { return { id: c.id, title: c.title, topicId: c.topicId }; });
    let lbEntries: any[] = [];
    try {
        let entries = await api.v1.lorebook.entries();
        lbEntries = (entries || []).map(function(e: any) {
            let label = e.displayName || (e.keys && e.keys.length ? e.keys[0] : 'Untitled');
            let preview = (e.text || '').slice(0, 80);
            return { id: e.id, label: label, preview: preview };
        });
    } catch (eWlb) { lbEntries = []; }
    let chars = await loadAllCharacters();
    let charSources = chars.map(function(ch: CharacterRecord) {
        return { id: ch.id, name: ch.name, hasLoreEntry: !!ch.lorebookEntryId, lorebookEntryId: ch.lorebookEntryId || '' };
    });
    let active = chatId ? await loadWizardChat(chatId) : null;
    return {
        chatId: chatId,
        chats: otherChats,
        lorebookEntries: lbEntries,
        characters: charSources,
        selected: active ? {
            contextChatIds: active.contextChatIds || [],
            lorebookEntryIds: active.lorebookEntryIds || [],
            characterIds: active.characterIds || [],
            includeStory: !!active.includeStory
        } : { contextChatIds: [], lorebookEntryIds: [], characterIds: [], includeStory: false }
    };
}

// [v0.9.93 PROFILE] Narrative fields regenerable per-field from the concept dump alone
// (seed-and-go). These map 1:1 to generateCharacterFields' labelled output, so a per-field
// regen runs that generator and applies only the requested key.
var REGENERABLE_CHAR_FIELDS: string[] = [
    'species', 'age', 'gender', 'occupationRole', 'briefDescription',
    'physicalDescription', 'personalityCore', 'voiceAndMannerisms', 'background', 'coreValues'
];

// [v0.9.93 PROFILE] Build the full editable character profile for the HUD. Reads the SAME
// CharacterRecord the native editor reads — single source of truth, no divergence.
async function buildCharProfilePayload(char: CharacterRecord, cfg: GlobalConfig): Promise<any> {
    // Sheet categories (the Four Fs live in cat_attr). sheetValues are dot-keyed
    // (cat.id + '.' + field.id) with legacy underscore / bare-id fallbacks.
    let sheetOut: any[] = [];
    for (let pCat of (cfg.sheetCategories || [])) {
        let pFields: any[] = [];
        for (let pF of (pCat.fields || [])) {
            let pDot = pCat.id + '.' + pF.id;
            let pUnd = pCat.id + '_' + pF.id;
            let pVal = char.sheetValues ? char.sheetValues[pDot] : undefined;
            if (pVal === undefined && char.sheetValues) pVal = char.sheetValues[pUnd];
            if (pVal === undefined && char.sheetValues) pVal = char.sheetValues[pF.id];
            if (pVal === undefined) pVal = '';
            pFields.push({ id: pF.id, key: 'sheet.' + pDot, name: pF.name, value: pVal });
        }
        sheetOut.push({ id: pCat.id, name: pCat.name, fieldType: pCat.fieldType, enumValues: pCat.enumValues || [], fields: pFields });
    }

    // Custom static fields: pair each def with its current value.
    let pCustom: any[] = [];
    for (let pCf of (cfg.customStaticFields || [])) {
        pCustom.push({ id: pCf.id, key: 'custom.' + pCf.id, label: pCf.label, instructions: pCf.instructions || '', value: (char.customFieldValues || {})[pCf.id] || '' });
    }

    // Faction relationships paired with display names.
    let pFactionRels: any[] = [];
    let pCfr = char.charFactionRelationships || {};
    for (let pFid of Object.keys(pCfr)) {
        let pFdef = (cfg.factions || []).find(function(x: any) { return x.id === pFid; });
        pFactionRels.push({ id: pFid, name: pFdef ? pFdef.name : pFid, value: pCfr[pFid] });
    }

    let pPr = char.primaryRelationship || ({} as PrimaryRelationship);

    return {
        id: char.id,
        name: char.name,
        isProtagonist: !!char.isProtagonist,
        hasLoreEntry: !!char.lorebookEntryId,
        conceptDump: char.conceptDump || '',
        nicknames: char.nicknames || [],
        species: char.species || '',
        age: char.age || '',
        gender: char.gender || '',
        occupationRole: char.occupationRole || '',
        briefDescription: char.briefDescription || '',
        physicalDescription: char.physicalDescription || '',
        personalityCore: char.personalityCore || '',
        voiceAndMannerisms: char.voiceAndMannerisms || '',
        background: char.background || '',
        coreValues: char.coreValues || [],
        customFields: pCustom,
        sheet: sheetOut,
        primaryRelationship: {
            enabled: pPr.enabled !== false,
            targetName: pPr.targetName || '',
            archetype: pPr.archetype || '',
            stageIndex: pPr.stageIndex || 0,
            howItStarted: pPr.howItStarted || '',
            currentStatus: pPr.currentStatus || '',
            trajectory: pPr.trajectory || '',
            summary: pPr.summary || '',
            threads: pPr.threads || []
        },
        factionRelationships: pFactionRels,
        hooks: (char.hooks || []).filter(function(h: any) { return !h.resolved; }),
        charResources: (char.charResourceDefs || []).map(function(def: any) {
            return { id: def.id, tag: def.tag, name: def.name, type: def.type,
                value: (char.charResourceValues || {})[def.id] || 0,
                hasBounds: !!def.hasBounds, min: def.min, max: def.max, states: def.states || [] };
        }),
        flags: {
            charContextEnabled: !!char.charContextEnabled,
            autoUpdateEnabled: !!char.autoUpdateEnabled,
            autoThoughtsEnabled: !!char.autoThoughtsEnabled,
            hooksEnabled: !!char.hooksEnabled
        },
        regenerableFields: REGENERABLE_CHAR_FIELDS
    };
}

async function handleBridgeMessage(msg: any): Promise<void> {
    try {
        const payload: any = (msg.data && msg.data.payload) ? msg.data.payload : (msg.data || {});
        const event: string = payload.event;

        switch (event) {

            case EVT_HANDSHAKE_ACK:
                // [CHANGE] On ACK: push char data first (bridge needs it for image gen lookups),
                //          then scene state (needs char data for compressedLine/socialMask),
                //          then PRESET_SYNC (bridge needs preset for avatar generation quality).
                isBridgeReady = true;
                api.v1.log('[AE:bridge] Bridge handshake confirmed.');
                api.v1.ui.toast('🔗 Bridge connected!', { type: 'success', autoClose: 2000 });
                await broadcastCharacterData();
                await broadcastSceneState();
                try { await broadcastToTM('PRESET_SYNC', { preset: getActivePresetData() }); } catch (_) {}
                // Send all preset slots to bridge so Presets panel has full data on connect.
                try { await broadcastToTM('AE_ALL_PRESETS_SYNC', { presets: profiles.slice(), activeIndex: activeIndex }); } catch (_) {}
                try { await broadcastJournal(); } catch (_) {}   // [v1.7.0 JOURNAL] populate HUD journal on connect
                break;

            case EVT_PING:
                await broadcastToTM(EVT_PONG, {});
                api.v1.log('[AE:bridge] Bridge PING → PONG.');
                break;

            case EVT_CHAR_SYNC_PUSH:
                // Legacy path: bridge pushes character configs (e.g., on reconnect from old bridge version).
                // In the merged system the engine is source of truth, but we accept the push to update
                // the cache in case bridge has newer emotion-portrait data we don't have.
                if (Array.isArray(payload.configs)) {
                    // Merge bridge configs into cachedCharVisuals without overwriting engine fields.
                    // Only update fields that the bridge is authoritative for: none in the merged system.
                    // This case is essentially a no-op for new bridges; kept for backward compatibility.
                    api.v1.log('[AE:bridge] EVT_CHAR_SYNC_PUSH received (', payload.configs.length, 'entries) — legacy path, no-op in merged system.');
                }
                // Still reply with story ID so bridge can key chat history correctly.
                try {
                    const syncStoryId = await api.v1.story.id();
                    await broadcastToTM(EVT_STORY_ID_SYNC, { storyId: syncStoryId });
                } catch (_) {}
                break;

            case EVT_RUN_ACTION_INSTANCE: {
                // [WP-5] payload: { entityId, instanceId, targetId? }
                // [v0.9.87] Also searches cfg.actionTemplates so tag-subscribed actions
                // (which are live template references, not entity.actionInstances copies)
                // execute correctly when triggered from the HUD.
                try {
                    let riEnt = await loadEntity(payload.entityId);
                    if (!riEnt) { api.v1.log('[AE:bridge] RUN_ACTION_INSTANCE: entity not found'); break; }
                    let riCfg = await loadConfig();
                    // Primary search: entity's own actionInstances (manual copies).
                    let riInst: ActionInstance | undefined = (((riEnt as any).actionInstances || []) as ActionInstance[]).find(function(x) { return x.id === payload.instanceId; });
                    // Fallback: library template (tag-subscribed actions live here by reference).
                    if (!riInst) {
                        riInst = ((riCfg.actionTemplates || []) as ActionInstance[]).find(function(x) { return x.id === payload.instanceId; });
                    }
                    if (!riInst) { api.v1.log('[AE:bridge] RUN_ACTION_INSTANCE: instance not found in entity or library', payload.instanceId); break; }
                    let riTarget = payload.targetId ? (await loadEntity(payload.targetId) || null) : null;
                    await runActionInstance(riInst, riEnt, riCfg, { target: riTarget });
                } catch (e) { api.v1.log('[AE:bridge] RUN_ACTION_INSTANCE error:', e); }
                break;
            }

            case 'RUN_QUICK_INSTANCE': {
                // Resolve the instance (live object or saved preset id) then delegate to the
                // shared runQuickInstance() — same path the native Action modal uses.
                try {
                    let qi = payload.instance;
                    if (!qi && payload.instanceId) {
                        let qiList = await loadQuickInstances();
                        qi = qiList.find(function(x) { return x.id === payload.instanceId; });
                    }
                    if (!qi) { api.v1.log('[AE:bridge] RUN_QUICK_INSTANCE: not found'); break; }
                    await runQuickInstance(qi);
                } catch (e) { api.v1.log('[AE:bridge] RUN_QUICK_INSTANCE error:', e); }
                break;
            }

            case 'AE_CYOA_GENERATE': {
                // [v0.9.7.0 CYOA] Generate 4 intent-based options for the chosen mode and
                // return them to the HUD, which renders them as runnable Quick Actions.
                try {
                    api.v1.ui.toast('Generating choices\u2026', { type: 'info', autoClose: 1500 });
                    let cyResult = await prepareCyoaOptions(payload.mode);
                    await broadcastToTM(EVT_CYOA_OPTIONS, { mode: cyResult.mode, options: cyResult.options, ok: cyResult.options.length > 0 });
                } catch (e) {
                    api.v1.log('[AE:bridge] AE_CYOA_GENERATE error:', e);
                    try { await broadcastToTM(EVT_CYOA_OPTIONS, { mode: payload.mode || 'mix', options: [], ok: false }); } catch (eCy2) {}
                }
                break;
            }

            case 'AE_SAVE_QUICK_INSTANCE': {
                // Saves a quick action preset configuration to storyStorage.
                try {
                    if (payload && payload.instance && payload.instance.id) {
                        let sList = await loadQuickInstances();
                        let sPos = sList.findIndex(function(x) { return x.id === payload.instance.id; });
                        let sRec: QuickInstance = {
                            id: String(payload.instance.id),
                            name: String(payload.instance.name || 'Quick Action'),
                            prompt: String(payload.instance.prompt || ''),
                            targetId: payload.instance.targetId || null,
                            targetType: payload.instance.targetType || 'none',
                            skillTag: payload.instance.skillTag || null,
                            modifierType: payload.instance.modifierType || 'none',
                            modifierTag: payload.instance.modifierTag || null,
                            modifierAmount: typeof payload.instance.modifierAmount === 'number' ? payload.instance.modifierAmount : 0
                        };
                        if (sPos >= 0) sList[sPos] = sRec; else sList.push(sRec);
                        await saveQuickInstances(sList);
                        queueSceneStateBroadcast();
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_QUICK_INSTANCE error:', e); }
                break;
            }

            case 'AE_DELETE_QUICK_INSTANCE': {
                // [WP-5] payload: { instanceId }
                try {
                    let dList = await loadQuickInstances();
                    dList = dList.filter(function(x) { return x.id !== payload.instanceId; });
                    await saveQuickInstances(dList);
                    queueSceneStateBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_DELETE_QUICK_INSTANCE error:', e); }
                break;
            }

            case 'AE_SET_SILENT': {
                // [v0.9.8.6] Persist the Story/Silent toggle. Previously unhandled — the
                // bridge sent this but nothing wrote ae_silent_mode, so the toggle was a no-op.
                try { await setSilentMode(!!(payload && payload.value)); }
                catch (e) { api.v1.log('[AE:bridge] AE_SET_SILENT error:', e); }
                break;
            }
            case EVT_AUTOSNAP: {
                // [WP-img] Bridge ⚙️ "Auto-Snap" button → story-driven scene image.
                try { await executeAutoSnap(); } catch (e) { api.v1.log('[AE:bridge] EVT_AUTOSNAP error:', e); }
                break;
            }
            case EVT_AUTOSNAP_PROMPT: {
                // [v0.9.8.0] Image Studio auto-snap: architect pass over the recent story,
                // result returned to the bridge to fill the composer. payload: { paragraphs }
                try {
                    let asPara = (payload && typeof payload.paragraphs === 'number' && payload.paragraphs > 0) ? Math.floor(payload.paragraphs) : (globalSettings.contextSize || DEFAULT_CTX);
                    if (asPara !== globalSettings.contextSize) { globalSettings.contextSize = asPara; await saveImageSettings(); }
                    let asBuilt = await buildArchitectPromptFromStory(asPara);
                    if (asBuilt) {
                        await broadcastToTM('AUTO_SNAP_PROMPT_RESULT', { prompt: asBuilt.prompt, charNames: asBuilt.matchedChars.map(function(c) { return c.name; }) });
                    } else {
                        await broadcastToTM('AUTO_SNAP_PROMPT_RESULT', { error: 'Could not build a prompt from the recent story.' });
                    }
                } catch (e) { api.v1.log('[AE:bridge] EVT_AUTOSNAP_PROMPT error:', e); await broadcastToTM('AUTO_SNAP_PROMPT_RESULT', { error: 'Auto-snap failed.' }); }
                break;
            }
            case EVT_DIRECTOR_SUBMIT: {
                // [NEW] Bridge submitted a Director's Cut image.
                // payload: { prompt, uc, chars: [{ name, visuals }], enhance?: boolean }
                // If payload.enhance === true: run architect pass and respond with EVT_DIRECTOR_ENHANCE_RESULT.
                // Otherwise: generate and broadcast EVT_GENERATE_IMAGE via submitDirectorPhoto.
                try {
                    if (payload.enhance) {
                        const enhanced = await enhanceDirectorPrompt(payload.prompt || '', payload.chars || []);
                        if (enhanced) {
                            await broadcastToTM('DIRECTOR_ENHANCE_RESULT', {
                                enhancedPrompt: enhanced.enhancedPrompt,
                                charVisuals:    enhanced.charVisuals
                            });
                        } else {
                            await broadcastToTM('DIRECTOR_ENHANCE_RESULT', { error: 'Enhancement failed.' });
                        }
                    } else {
                        await submitDirectorPhoto(payload.prompt || '', payload.uc || '', payload.chars || []);
                    }
                } catch (e) { api.v1.log('[AE:bridge] EVT_DIRECTOR_SUBMIT error:', e); }
                break;
            }

            case EVT_REQ_SCENE_STATE:
                // [NEW] Bridge requests an immediate scene state push (e.g., on reconnect or HUD open).
                await broadcastSceneState();
                break;

            case EVT_REQ_CHAR_DATA:
                // [NEW] Bridge requests an immediate character data push (e.g., on reconnect).
                await broadcastCharacterData();
                break;

            case 'AE_GEN_SNAPSHOT_TEXT': {
                // [v027] Generate the GLM appearance snapshot for a character and
                // store it under STORAGE_CHAR_SNAP_PFX. Result broadcast to bridge.
                try {
                    let stCharId = payload.charId;
                    let stChar = stCharId ? await loadCharacter(stCharId) : null;
                    if (!stChar) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_TEXT: char not found'); break; }
                    let stEntId = (stChar as any).entityId || null;
                    let stEnt = stEntId ? await loadEntity(stEntId) : null;
                    if (!stEnt) { api.v1.ui.toast('No scene context for snapshot.', { type: 'warning' }); break; }
                    let stCfg = await loadConfig();
                    let stText = await generateCharacterSnapshot(stChar, stEnt, stCfg);
                    if (stText) {
                        await api.v1.storyStorage.set(STORAGE_CHAR_SNAP_PFX + stCharId, stText);
                        await broadcastToTM('SNAPSHOT_TEXT_RESULT', { charId: stCharId, text: stText });
                    } else {
                        await broadcastToTM('SNAPSHOT_TEXT_RESULT', { charId: stCharId, error: 'Snapshot generation failed.' });
                    }
                } catch (snapTxtErr) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_TEXT error:', snapTxtErr); }
                break;
            }

            case 'AE_GEN_SNAPSHOT_IMAGE': {
                // [v027] Build an image from the stored snapshot text + character
                // visuals (+ optional location visuals) and broadcast EVT_GENERATE_IMAGE.
                try {
                    let siCharId = payload.charId;
                    if (!siCharId) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_IMAGE: no charId'); break; }
                    await assembleSnapshotImage(siCharId);
                } catch (snapImgErr) { api.v1.log('[AE:bridge] AE_GEN_SNAPSHOT_IMAGE error:', snapImgErr); }
                break;
            }

            case 'AE_OPEN_CHAR_EDIT': {
                // [NEW] Bridge requests Smart Modal for character edit.
                // Phase 2: will use openSmartModal(). For now opens NAI sidebar char edit.
                try {
                    const ceCharId = payload.charId;
                    if (ceCharId) {
                        const ceChar = await loadCharacter(ceCharId);
                        if (ceChar) await openCharEditModal(ceCharId);
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_OPEN_CHAR_EDIT error:', e); }
                break;
            }

            case 'AE_OPEN_ENTITY_EDIT': {
                try {
                    const oeId = payload.entityId;
                    if (oeId) await openEntityEditModal(oeId);
                } catch (e) { api.v1.log('[AE:bridge] AE_OPEN_ENTITY_EDIT error:', e); }
                break;
            }

            case 'AE_OPEN_CALENDAR': {
                // [v0.9.9.2] Bridge calendar button opens the native clock/narrative-calendar modal.
                try { await openCalendarModal(); } catch (e) { api.v1.error('[AE:bridge] AE_OPEN_CALENDAR error:', e); }
                break;
            }

            case 'AE_ADJUST_CHAR_RESOURCE': {
                // Bridge steppers in character focus view adjust a per-character resource.
                try {
                    const acCharId = payload.charId;
                    const acTag    = payload.tag;
                    const acDelta  = payload.delta;
                    if (acCharId && acTag && typeof acDelta === 'number') {
                        await adjustCharResource(acCharId, acTag, acDelta);
                        const acFresh = await loadCharacter(acCharId);
                        let acEnt = null;
                        if (acFresh && acFresh.entityId) acEnt = await loadEntity(acFresh.entityId);
                        const acDp = await buildEntityDetailPayload(acCharId, acFresh, acEnt);
                        await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', acDp);
                        await broadcastSceneState();
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_ADJUST_CHAR_RESOURCE error:', e); }
                break;
            }

            case 'AE_FETCH_ENTITY_DETAIL': {
                try {
                    const fId = payload.entityId || payload.charId;
                    if (fId) {
                        let char = await loadCharacter(fId);
                        let ent = null;
                        if (char) {
                            if (char.entityId) ent = await loadEntity(char.entityId);
                        } else {
                            ent = await loadEntity(fId);
                            if (ent && ent.type === 'character') {
                                const idx = await loadIndex();
                                const match = idx.find(m => m.entityId === ent.id);
                                if (match) char = await loadCharacter(match.id);
                            }
                        }

                        if (char || ent) {
                            const detailPayload = await buildEntityDetailPayload(fId, char, ent);
                            await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', detailPayload);
                        } else {
                            await broadcastToTM('AE_ENTITY_DETAIL_RESPONSE', { id: fId, error: 'Not found' });
                        }
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_FETCH_ENTITY_DETAIL error:', e); }
                break;
            }

            case 'AE_RESOLVE_HOOK': {
                // [v0.9.9.7] Delegated to resolveCharHook() (shared with native char inspect).
                await resolveCharHook(payload.charId, payload.hookId, payload.hookIndex);
                break;
            }

            case 'AE_EQUIP_ITEM': {
                // [v0.9.9.7] Delegated to setItemEquip() (shared with native item rows).
                await setItemEquip(payload.charId, payload.itemId, true);
                break;
            }

            case 'AE_UNEQUIP_ITEM': {
                // [v0.9.9.7] Delegated to setItemEquip() (shared with native item rows).
                await setItemEquip(payload.charId, payload.itemId, false);
                break;
            }

            case 'AE_PROMOTE_MINOR_NPC': {
                try { if (payload && payload.entityId) await promoteMinorNpc(payload.entityId); }
                catch (ePm) { api.v1.log('[AE:bridge] AE_PROMOTE_MINOR_NPC error:', ePm); }
                break;
            }

            case 'AE_SET_CHAR_PRESENT': {
                try { if (payload && payload.charId) await aeSetCharScenePresent(payload.charId, !!payload.present); }
                catch (eEx) { api.v1.log('[AE:bridge] AE_SET_CHAR_PRESENT error:', eEx); }
                break;
            }

            case 'AE_MOVE_CHAR_TO_SCENE': {
                try { if (payload && payload.charId) await aeMoveCharToScene(payload.charId); }
                catch (eMv) { api.v1.log('[AE:bridge] AE_MOVE_CHAR_TO_SCENE error:', eMv); }
                break;
            }

            case 'AE_REFRESH_PRESENCE': {
                try { await aeRefreshPresence(); }
                catch (eRf) { api.v1.log('[AE:bridge] AE_REFRESH_PRESENCE error:', eRf); }
                break;
            }

            case 'AE_TRACK_NARRATIVE': {
                // [v0.9.9.7] Delegated to toggleNarrativeTracking() (shared with native views).
                await toggleNarrativeTracking(payload.narrativeId);
                break;
            }

            case 'AE_SET_DEFAULT_BG_URL': {
                // [v0.9.40] Bridge Theme Forge sets module-level scene default background.
                // Saves to GlobalConfig so it persists with the story and flows back
                // through the next buildSceneStatePayload broadcast to all open bridges.
                try {
                    let bgCfg = await loadConfig();
                    (bgCfg as any).defaultBackgroundUrl = (payload.url || '').trim();
                    await saveConfig(bgCfg);
                    await broadcastSceneState();
                    api.v1.ui.toast(
                        (bgCfg as any).defaultBackgroundUrl
                            ? '✓ Scene background URL saved.'
                            : '✓ Scene background cleared.',
                        { type: 'success', autoClose: 2000 }
                    );
                } catch (e) { api.v1.error('[AE] AE_SET_DEFAULT_BG_URL error:', e); }
                break;
            }

            case EVT_IMPORT_WORLD: {
                // [v0.9.39] Bridge-delivered adventure module (Try-the-Demo button).
                // Same importPayload() funnel as file import, then seed/refresh exactly
                // like the new-story prompt callbacks.
                try {
                    let iwModule = payload.module || payload.data || null;
                    if (!iwModule) { api.v1.ui.toast('Demo payload was empty.', { type: 'warning', autoClose: 2500 }); break; }
                    let iwResult = await importPayload(iwModule);
                    let iwParts: string[] = [];
                    if (iwResult.charCount > 0)   iwParts.push(iwResult.charCount + ' character' + (iwResult.charCount !== 1 ? 's' : ''));
                    if (iwResult.entityCount > 0) iwParts.push(iwResult.entityCount + ' node' + (iwResult.entityCount !== 1 ? 's' : ''));
                    await ensureProtagonistExists();
                    await refreshSidebar();
                    queueSceneStateBroadcast();
                    api.v1.ui.toast('Demo loaded: ' + (iwParts.length ? iwParts.join(', ') : 'world') + '.', { type: 'success', autoClose: 3000 });
                } catch (e) {
                    api.v1.error('[AE:bridge] AE_IMPORT_WORLD error:', e);
                    api.v1.ui.toast('Demo import failed.', { type: 'error', autoClose: 2500 });
                }
                break;
            }

            case EVT_DEMO_FAILED: {
                // Bridge could not fetch the module (offline / URL down). Seed a fresh
                // story so the player is never stranded on an empty fresh story.
                try {
                    await ensureProtagonistExists();
                    await refreshSidebar();
                    queueSceneStateBroadcast();
                } catch (e) { api.v1.error('[AE:bridge] AE_DEMO_FAILED fallback error:', e); }
                api.v1.ui.toast('Demo unavailable — started a fresh story instead.', { type: 'warning', autoClose: 3500 });
                break;
            }

            case 'AE_TOGGLE_FOLLOW': {
                // [v0.9.9.7] Delegated to toggleCharFollow() (shared with native char inspect).
                await toggleCharFollow(payload.charId);
                break;
            }

            case 'AE_TRAVEL_REQUEST': {
                // [v0.9.9.5] Delegated to performTravelRequest() (shared with native map).
                await performTravelRequest(payload.targetId, payload.seq);
                break;
            }

            case 'AE_VEHICLE_TRAVEL_REQUEST': {
                // Bridge operate-mode travel: moves the vehicle entity (not the player body)
                // to a destination. The player stays inside the vehicle; the vehicle moves.
                // Validates that the target is adjacent to the vehicle's world location.
                try {
                    const vtVehicleId = payload.vehicleId;
                    const vtTargetId  = payload.targetId;
                    if (!vtVehicleId || !vtTargetId) { api.v1.ui.toast('Vehicle travel failed - missing IDs.', { type: 'error' }); break; }
                    const vtVehicle = await loadEntity(vtVehicleId);
                    if (!vtVehicle || !(vtVehicle as any).isVehicle) { api.v1.ui.toast('Vehicle not found or not a vehicle.', { type: 'error' }); break; }
                    // Check adjacency from vehicle's world location (parentId)
                    const vtWorldLocId = vtVehicle.parentId;
                    if (vtWorldLocId) {
                        const vtWorldLoc = await loadEntity(vtWorldLocId);
                        if (vtWorldLoc) {
                            const vtIsAdj = (vtWorldLoc.parentId === vtTargetId)
                                || ((await loadEntityIndex()).some(function(m) { return m.parentId === vtWorldLocId && m.id === vtTargetId; }))
                                || (vtWorldLoc.connectedEntityIds || []).some(function(c) { return c.targetId === vtTargetId; });
                            if (!vtIsAdj) { api.v1.ui.toast('Cannot travel: destination not reachable from vehicle location.', { type: 'error', autoClose: 3000 }); break; }
                        }
                    }
                    await executeVehicleTravel(vtVehicle, vtTargetId, undefined, 0);
                } catch (e) { api.v1.log('[AE:bridge] AE_VEHICLE_TRAVEL_REQUEST error:', e); }
                break;
            }

            case 'REQUEST_NODE_GRAPH': {
                // Bridge map Inspect button — returns the adjacency graph of any entity.
                // [FIX v0.9.13] Children now include gated + isVehicle + hasChildren.
                //               Connections now include full traversal metadata for map line styling.
                try {
                    const ngId  = payload.entityId;
                    if (!ngId) break;
                    const ngEnt = await loadEntity(ngId);
                    if (!ngEnt) break;
                    const ngAll = await loadEntityIndex();

                    // Children — gated + isVehicle read from the index (no extra entity loads)
                    const ngCfg = await loadConfig();
                    const ngChildren: any[] = [];
                    for (const ngCM of ngAll.filter(function(m) { return m.parentId === ngId && m.type === 'location'; })) {
                        const ngHasGC = ngAll.some(function(m) { return m.parentId === ngCM.id && m.type === 'location'; });
                        const cEnt = await loadEntity(ngCM.id);
                        let cTag = undefined; let cAmt = undefined; let cIcon = undefined;
                        let actionIdToCheck = (cEnt && (cEnt as any).entryActionId) ? (cEnt as any).entryActionId : 'sys_default_travel';
                        let cAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === actionIdToCheck; });
                        if (!cAct && actionIdToCheck !== 'sys_default_travel') cAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                        if (cAct) {
                            const cEffs = [...(cAct.successEffects || []), ...((cAct as any).alwaysEffects || [])];
                            const cCostEff = cEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
                            if (cCostEff) { 
                                cTag = cCostEff.args.tag; cAmt = cCostEff.args.amount; 
                                const rDef = (ngCfg.resources || []).find(r => r.tag === cTag);
                                if (rDef && rDef.icon) cIcon = rDef.icon;
                            }
                        }
                        ngChildren.push({
                            id: ngCM.id, name: ngCM.name, type: ngCM.type, icon: ngCM.icon || undefined,
                            hasChildren:  ngHasGC,
                            gated:        !!ngCM.gated,
                            isVehicle:    !!ngCM.isVehicle,
                            resourceTag:  cTag,
                            resourceCost: cAmt,
                            resourceIcon: cIcon
                        });
                    }

                    // Connections — full traversal metadata; target gated from index
                    const ngConns: any[] = [];
                    for (const ngC of (ngEnt.connectedEntityIds || [])) {
                        const ngCM2 = ngAll.find(function(m) { return m.id === ngC.targetId; });
                        let cTag = undefined; let cAmt = undefined; let cIcon = undefined;
                        let actionIdToCheck = (ngC as any).travelActionId ? (ngC as any).travelActionId : 'sys_default_travel';
                        let cAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === actionIdToCheck; });
                        if (!cAct && actionIdToCheck !== 'sys_default_travel') cAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                        if (cAct) {
                            const cEffs = [...(cAct.successEffects || []), ...((cAct as any).alwaysEffects || [])];
                            const cCostEff = cEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
                            if (cCostEff) { 
                                cTag = cCostEff.args.tag; cAmt = cCostEff.args.amount; 
                                const rDef = (ngCfg.resources || []).find(r => r.tag === cTag);
                                if (rDef && rDef.icon) cIcon = rDef.icon;
                            }
                        }
                        ngConns.push({
                            id: ngC.targetId,
                            name:   ngCM2 ? ngCM2.name : ngC.targetId,
                            label:  (ngC as any).label   || '',
                            oneWay: (ngC as any).oneWay  || false,
                            icon:   ngCM2 ? ngCM2.icon || undefined : undefined,
                            gated:           !!( ngCM2 && ngCM2.gated),
                            requiresVehicle: !!(ngC as any).requiresVehicle,
                            resourceTag:     cTag,
                            resourceCost:    cAmt,
                            resourceIcon:    cIcon,
                            isSilent:        !!(ngC as any).isSilent
                        });
                    }

                    let curNodeTag = undefined; let curNodeAmt = undefined; let curNodeIcon = undefined;
                    let curActionIdToCheck = (ngEnt as any).entryActionId ? (ngEnt as any).entryActionId : 'sys_default_travel';
                    let curAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === curActionIdToCheck; });
                    if (!curAct && curActionIdToCheck !== 'sys_default_travel') curAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                    if (curAct) {
                        const cEffs = [...(curAct.successEffects || []), ...((curAct as any).alwaysEffects || [])];
                        const cCostEff = cEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
                        if (cCostEff) { 
                            curNodeTag = cCostEff.args.tag; curNodeAmt = cCostEff.args.amount; 
                            const rDef = (ngCfg.resources || []).find(r => r.tag === curNodeTag);
                            if (rDef && rDef.icon) curNodeIcon = rDef.icon;
                        }
                    }

                    // [v0.9.89] Lateral siblings for Orbital HUD
                    const ngSiblings: any[] = [];
                    for (const sibMeta of ngAll) {
                        if (sibMeta.type !== 'location' || sibMeta.id === ngId) continue;
                        if (sibMeta.parentId !== ngEnt.parentId) continue;
                        if ((sibMeta as any).isVehicle) continue;
                        const sibEnt = await loadEntity(sibMeta.id);
                        let sTag = undefined; let sAmt = undefined; let sIcon = undefined;
                        let sActionId = (sibEnt && (sibEnt as any).entryActionId) ? (sibEnt as any).entryActionId : 'sys_default_travel';
                        let sAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === sActionId; });
                        if (!sAct && sActionId !== 'sys_default_travel') sAct = (ngCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                        if (sAct) {
                            const sEffs = [...(sAct.successEffects || []), ...((sAct as any).alwaysEffects || [])];
                            const sCostEff = sEffs.find(function(e: any) { return e.type === 'modify_resource' && e.args && e.args.tag && (e.args.amount || 0) > 0; });
                            if (sCostEff) {
                                sTag = sCostEff.args.tag; sAmt = sCostEff.args.amount;
                                const sResDef = (ngCfg.resources || []).find(function(r) { return r.tag === sTag; });
                                if (sResDef && sResDef.icon) sIcon = sResDef.icon;
                            }
                        }
                        ngSiblings.push({
                            id: sibMeta.id, name: sibMeta.name, type: sibMeta.type,
                            icon: sibMeta.icon || undefined, gated: !!sibMeta.gated,
                            resourceTag: sTag, resourceCost: sAmt, resourceIcon: sIcon
                        });
                    }

                    // [FIX Bug3] Added currentIcon + parentIcon to node graph response.
                    const ngGraph: any = {
                        currentName:      ngEnt.name,
                        currentType:      ngEnt.type,
                        currentIcon:      (ngEnt as any).icon      || undefined,
                        currentGated:     !!(ngEnt as any).gated,
                        currentIsVehicle: !!(ngEnt as any).isVehicle,
                        currentResourceTag: curNodeTag,
                        currentResourceCost: curNodeAmt,
                        currentResourceIcon: curNodeIcon,
                        parentId: ngEnt.parentId || null, parentName: '', parentType: '', parentIcon: undefined,
                        children: ngChildren, connections: ngConns, siblings: ngSiblings
                    };
                    if (ngEnt.parentId) {
                        const ngPm = ngAll.find(function(m) { return m.id === ngEnt.parentId; });
                        if (ngPm) { ngGraph.parentName = ngPm.name; ngGraph.parentType = ngPm.type; ngGraph.parentIcon = ngPm.icon || undefined; }
                    }
                    await broadcastToTM('AE_NODE_GRAPH_RESPONSE', { entityId: ngId, graph: ngGraph });
                } catch (e) { api.v1.log('[AE:bridge] REQUEST_NODE_GRAPH error:', e); }
                break;
            }

            case 'AE_SILENT_TELEPORT': {
                // Bridge 📍 Teleport button — moves protagonist silently with no story text.
                try {
                    const tpTargetId = payload.targetId;
                    if (!tpTargetId) break;
                    const tpTgtEnt = await loadEntity(tpTargetId);
                    if (!tpTgtEnt) break;
                    const tpCharIdx = await loadIndex();
                    const tpProtagMeta = tpCharIdx.find(function(m) { return !!m.isProtagonist; });
                    if (!tpProtagMeta) break;
                    const tpProtag = await loadCharacter(tpProtagMeta.id);
                    if (!tpProtag) break;
                    // Move the protagonist's entity body to the target
                    if (tpProtag.entityId) {
                        const tpBody = await loadEntity(tpProtag.entityId);
                        if (tpBody) { tpBody.parentId = tpTargetId; await saveEntity(tpBody); }
                    }
                    // Update camera / currentLocationId
                    const tpFreshProtag = await loadCharacter(tpProtagMeta.id);
                    if (tpFreshProtag) {
                        tpFreshProtag.currentLocationId = tpTargetId;
                        await saveCharacter(tpFreshProtag);
                    }
                    api.v1.ui.toast('📍 Teleported to ' + tpTgtEnt.name, { type: 'info', autoClose: 2000 });
                    await recalculateScenePresence(); // [CHANGE] update scene presence after teleport
                    await broadcastSceneState();
                } catch (e) { api.v1.log('[AE:bridge] AE_SILENT_TELEPORT error:', e); }
                break;
            }

            case 'AE_ADJUST_RESOURCE': {
                // Bridge resource stepper − / + buttons — adjusts party resource by delta.
                try {
                    const arCfg   = await loadConfig();
                    const arParty = await loadPartyState();
                    const arDef   = (arCfg.resources || []).find(function(r: any) { return r.tag === payload.tag; });
                    if (!arDef) break;
                    const arCur = (arParty.resourceValues && arParty.resourceValues[arDef.id]) || 0;
                    let arNew = arCur + ((payload.delta as number) || 0);
                    if (arDef.type === 'pool' && arDef.hasBounds) {
                        arNew = Math.max(arDef.min || 0, Math.min(arDef.max || 9999, arNew));
                    } else if (arDef.type === 'track') {
                        arNew = Math.max(0, Math.min((arDef.states || []).length - 1, arNew));
                    }
                    if (!arParty.resourceValues) arParty.resourceValues = {};
                    arParty.resourceValues[arDef.id] = arNew;
                    await savePartyState(arParty);
                    queueSceneStateBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_ADJUST_RESOURCE error:', e); }
                break;
            }

            case 'AE_SET_RESOURCE': {
                // Bridge resource inline input — sets party resource to exact value.
                try {
                    const srCfg   = await loadConfig();
                    const srParty = await loadPartyState();
                    const srDef   = (srCfg.resources || []).find(function(r: any) { return r.tag === payload.tag; });
                    if (!srDef) break;
                    let srNew = typeof payload.value === 'number' ? payload.value : parseInt(String(payload.value), 10);
                    if (isNaN(srNew)) break;
                    if (srDef.type === 'pool' && srDef.hasBounds) {
                        srNew = Math.max(srDef.min || 0, Math.min(srDef.max || 9999, srNew));
                    } else if (srDef.type === 'track') {
                        srNew = Math.max(0, Math.min((srDef.states || []).length - 1, srNew));
                    }
                    if (!srParty.resourceValues) srParty.resourceValues = {};
                    srParty.resourceValues[srDef.id] = srNew;
                    await savePartyState(srParty);
                    queueSceneStateBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_RESOURCE error:', e); }
                break;
            }

            case 'AE_SET_FACTION': {
                // Bridge faction picker — sets party faction relationship to state index.
                try {
                    const sfCfg   = await loadConfig();
                    const sfParty = await loadPartyState();
                    const sfDef   = (sfCfg.factions || []).find(function(f: any) { return f.id === payload.factionId; });
                    if (!sfDef) break;
                    const sfClamped = Math.max(0, Math.min((sfDef.relationshipStates || []).length - 1,
                        typeof payload.stateIdx === 'number' ? payload.stateIdx : 0));
                    if (!sfParty.factionRelationships) sfParty.factionRelationships = {};
                    sfParty.factionRelationships[payload.factionId] = sfClamped;
                    await savePartyState(sfParty);
                    queueSceneStateBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_FACTION error:', e); }
                break;
            }

            case 'AE_SET_SKILL': {
                // Bridge skill editor — updates protagonist sheetValues.
                try {
                    const ssIdx = await loadIndex();
                    const ssProtagMeta = ssIdx.find(function(m) { return !!m.isProtagonist; });
                    if (!ssProtagMeta) break;
                    const ssProtag = await loadCharacter(ssProtagMeta.id);
                    if (!ssProtag) break;
                    if (!ssProtag.sheetValues) ssProtag.sheetValues = {};
                    const ssDotId = payload.categoryId + '.' + payload.fieldId;        // [FIX] canonical key (matches CharacterEditModal + #skill)
                    const ssUnderscoreId = payload.categoryId + '_' + payload.fieldId;  // legacy key — written for back-compat with old reads
                    const ssVal = String(payload.value !== undefined ? payload.value : '');
                    ssProtag.sheetValues[ssDotId] = ssVal;
                    ssProtag.sheetValues[ssUnderscoreId] = ssVal;
                    ssProtag.sheetValues[payload.fieldId] = ssVal;
                    await saveCharacter(ssProtag);
                    queueSceneStateBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_SKILL error:', e); }
                break;
            }

            case 'AE_DELETE_CHAR': {
                // Bridge orphan removal — deletes a character from index and storage.
                try {
                    const dcId = payload.charId;
                    if (!dcId) break;
                    const dcIdx = await loadIndex();
                    await saveIndex(dcIdx.filter(function(m) { return m.id !== dcId; }));
                    await api.v1.storyStorage.remove(STORAGE_CHAR_PFX + dcId);
                    api.v1.ui.toast('Character removed from index.', { type: 'info', autoClose: 2000 });
                    await broadcastCharacterData();
                    await broadcastSceneState();
                } catch (e) { api.v1.log('[AE:bridge] AE_DELETE_CHAR error:', e); }
                break;
            }

            case 'AE_SAVE_CHAR_VISUALS': {
                // Bridge gallery saved visual overrides for a character. Merges into CharacterRecord.
                try {
                    const scvId = payload.charId; if (!scvId) break;
                    const scvChar = await loadCharacter(scvId); if (!scvChar) break;
                    if (payload.visuals       !== undefined) scvChar.visuals       = payload.visuals;
                    if (payload.uc            !== undefined) scvChar.uc            = payload.uc;
                    if (payload.avatarVisuals !== undefined) scvChar.avatarVisuals = payload.avatarVisuals;
                    if (payload.avatarWidth   !== undefined) scvChar.avatarWidth   = payload.avatarWidth;
                    if (payload.avatarHeight  !== undefined) scvChar.avatarHeight  = payload.avatarHeight;
                    if (payload.avatarSeed    !== undefined) scvChar.avatarSeed    = payload.avatarSeed;
                    await saveCharacter(scvChar);
                    api.v1.ui.toast('\u2713 Visuals saved \u2014 ' + scvChar.name, { type: 'success', autoClose: 1500 });
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_CHAR_VISUALS error:', e); }
                break;
            }

            case 'AE_FETCH_CHAR_PROFILE': {
                // Bridge opened a character's combined HUD profile. Build and push the
                // full editable record (same CharacterRecord the native editor reads).
                try {
                    const fcpId = payload.charId; if (!fcpId) break;
                    const fcpChar = await loadCharacter(fcpId);
                    if (!fcpChar) { await broadcastToTM(EVT_CHAR_PROFILE, { id: fcpId, error: 'Not found' }); break; }
                    const fcpCfg = await loadConfig();
                    const fcpOut = await buildCharProfilePayload(fcpChar, fcpCfg);
                    await broadcastToTM(EVT_CHAR_PROFILE, fcpOut);
                } catch (e) { api.v1.log('[AE:bridge] AE_FETCH_CHAR_PROFILE error:', e); }
                break;
            }

            case 'AE_SAVE_CHAR_FIELD': {
                // Bridge wrote one field in the HUD profile. Merge into the record, keep the
                // linked lorebook entry in sync, then push a fresh profile + coalesced roster
                // refresh so every surface reflects the change. fieldKey routing:
                //   direct string fields | coreValues | nicknames | custom.<id> | sheet.<cat>.<fld> | flag.<name>
                try {
                    const scfId = payload.charId;
                    const scfKey: string = payload.fieldKey || '';
                    if (!scfId || !scfKey) break;
                    let scfChar = await loadCharacter(scfId); if (!scfChar) break;
                    const scfVal = payload.value;
                    const SCF_DIRECT: string[] = ['name','conceptDump','species','age','gender','occupationRole','briefDescription','physicalDescription','personalityCore','voiceAndMannerisms','background'];
                    let scfHandled = true;
                    if (SCF_DIRECT.indexOf(scfKey) >= 0) {
                        (scfChar as any)[scfKey] = String(scfVal === undefined || scfVal === null ? '' : scfVal);
                    } else if (scfKey === 'coreValues') {
                        if (Array.isArray(scfVal)) scfChar.coreValues = scfVal.map(function(x: any) { return String(x).trim(); }).filter(Boolean);
                        else scfChar.coreValues = String(scfVal || '').split(';').map(function(x) { return x.trim(); }).filter(Boolean);
                    } else if (scfKey === 'nicknames') {
                        if (Array.isArray(scfVal)) scfChar.nicknames = scfVal.map(function(x: any) { return String(x).trim(); }).filter(Boolean);
                        else scfChar.nicknames = String(scfVal || '').split(',').map(function(x) { return x.trim(); }).filter(Boolean);
                    } else if (scfKey.indexOf('custom.') === 0) {
                        let scfCfId = scfKey.slice(7);
                        if (!scfChar.customFieldValues) scfChar.customFieldValues = {};
                        scfChar.customFieldValues[scfCfId] = String(scfVal === undefined ? '' : scfVal);
                    } else if (scfKey.indexOf('sheet.') === 0) {
                        let scfRef = scfKey.slice(6);
                        let scfParts = scfRef.split('.');
                        if (scfParts.length === 2) {
                            let scfDot = scfParts[0] + '.' + scfParts[1];
                            let scfUnd = scfParts[0] + '_' + scfParts[1];
                            if (!scfChar.sheetValues) scfChar.sheetValues = {};
                            scfChar.sheetValues[scfDot] = String(scfVal === undefined ? '' : scfVal);
                            scfChar.sheetValues[scfUnd] = scfChar.sheetValues[scfDot];
                        } else { scfHandled = false; }
                    } else if (scfKey.indexOf('flag.') === 0) {
                        let scfFlag = scfKey.slice(5);
                        let scfBool = !!scfVal;
                        if (scfFlag === 'charContextEnabled') scfChar.charContextEnabled = scfBool;
                        else if (scfFlag === 'autoUpdateEnabled') scfChar.autoUpdateEnabled = scfBool;
                        else if (scfFlag === 'autoThoughtsEnabled') scfChar.autoThoughtsEnabled = scfBool;
                        else if (scfFlag === 'hooksEnabled') scfChar.hooksEnabled = scfBool;
                        else scfHandled = false;
                    } else {
                        scfHandled = false;
                    }
                    if (!scfHandled) { api.v1.log('[AE:bridge] AE_SAVE_CHAR_FIELD unknown key: ' + scfKey); break; }
                    await saveCharacter(scfChar);
                    try { await syncLorebookEntry(scfChar.id, true); } catch (eScfLb) { /* non-fatal: lore sync best-effort */ }
                    const scfCfg = await loadConfig();
                    const scfOut = await buildCharProfilePayload(scfChar, scfCfg);
                    await broadcastToTM(EVT_CHAR_PROFILE, scfOut);
                    queueCharacterDataBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_CHAR_FIELD error:', e); }
                break;
            }

            case 'AE_REGEN_CHAR_FIELD': {
                // Regenerate ONE narrative field from the concept dump (seed-and-go). Reuses
                // generateCharacterFields, applies only the requested key, pushes refreshed profile.
                try {
                    const rcfId = payload.charId;
                    const rcfKey: string = payload.fieldKey || '';
                    if (!rcfId || !rcfKey) break;
                    if (REGENERABLE_CHAR_FIELDS.indexOf(rcfKey) < 0) { api.v1.log('[AE:bridge] AE_REGEN_CHAR_FIELD non-regenerable key: ' + rcfKey); break; }
                    let rcfChar = await loadCharacter(rcfId); if (!rcfChar) break;
                    if (!(rcfChar.conceptDump || '').trim()) {
                        api.v1.ui.toast('No concept profile to regenerate from \u2014 add a concept dump first.', { type: 'warning', autoClose: 2500 });
                        break;
                    }
                    api.v1.ui.toast('Regenerating ' + rcfKey + ' for ' + rcfChar.name + '\u2026', { type: 'info', autoClose: 1500 });
                    // [v0.9.100] Per-field generation with optional hint for the four narrative
                    // fields (matches the native editor's auto-generate buttons via generateFieldContent).
                    // Other fields fall back to dump-only generateCharacterFields.
                    let rcfHint: string = (payload.hint || '').toString();
                    let rcfDef = STATIC_FIELD_DEFS.find(function(d: any) { return d.key === rcfKey; });
                    if (rcfDef) {
                        let rcfCfg = await loadConfig();
                        let rcfLabel = (rcfCfg.fieldLabels && rcfCfg.fieldLabels[rcfKey]) || rcfDef.label;
                        let rcfInst  = (rcfCfg.fieldInstructions && rcfCfg.fieldInstructions[rcfKey]) || rcfDef.defaultInstructions;
                        let rcfBudget = (rcfCfg.fieldBudgets && rcfCfg.fieldBudgets[rcfKey]) || rcfDef.defaultBudget;
                        let rcfVal = await generateFieldContent(rcfChar, rcfLabel, rcfInst, rcfCfg.generalStyle || '', rcfHint, rcfBudget);
                        if (rcfVal === null) { api.v1.ui.toast('Regeneration failed.', { type: 'error' }); break; }
                        (rcfChar as any)[rcfKey] = rcfVal;
                    } else {
                        let rcfFields = await generateCharacterFields(rcfChar.name, rcfChar.conceptDump || '');
                        if (!rcfFields) { api.v1.ui.toast('Regeneration failed.', { type: 'error' }); break; }
                        if (rcfKey === 'coreValues') rcfChar.coreValues = (rcfFields as any).coreValues || [];
                        else (rcfChar as any)[rcfKey] = (rcfFields as any)[rcfKey] || '';
                    }
                    await saveCharacter(rcfChar);
                    try { await syncLorebookEntry(rcfChar.id, true); } catch (eRcfLb) { /* non-fatal: lore sync best-effort */ }
                    const rcfCfg = await loadConfig();
                    const rcfOut = await buildCharProfilePayload(rcfChar, rcfCfg);
                    await broadcastToTM(EVT_CHAR_PROFILE, rcfOut);
                    queueCharacterDataBroadcast();
                } catch (e) { api.v1.log('[AE:bridge] AE_REGEN_CHAR_FIELD error:', e); }
                break;
            }

            case 'AE_WIZ_FETCH_STATE': {
                try { await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload()); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZ_FETCH_STATE error:', e); }
                break;
            }

            case 'AE_SET_PROJECT': {
                // [v0.9.7.0 SETUP] HUD Setup tab writes project name/genre/concept; echo fresh state.
                try {
                    await mutConfig(function(c) {
                        if (payload.name !== undefined)    c.projectName = String(payload.name);
                        if (payload.genre !== undefined)   c.projectGenre = String(payload.genre);
                        if (payload.concept !== undefined) c.projectConcept = String(payload.concept);
                    });
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_PROJECT error:', e); }
                break;
            }

            case 'AE_WIZ_NEW_CHAT': {
                try {
                    const wncTopic = payload.topicId || (DEFAULT_WIZARD_TOPICS[0] ? DEFAULT_WIZARD_TOPICS[0].id : 'topic_concept');
                    const wncChat = await createWizardChat(wncTopic, payload.title || 'New Chat');
                    await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, wncChat.id);
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_NEW_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_SELECT_CHAT': {
                try {
                    if (payload.chatId) await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, payload.chatId);
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_SELECT_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_DELETE_CHAT': {
                try {
                    if (payload.chatId) {
                        await deleteWizardChat(payload.chatId);
                        let wdActive = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_ACTIVE_CHAT, '') as string;
                        if (wdActive === payload.chatId) await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, '');
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_DELETE_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_RENAME_CHAT': {
                try {
                    if (payload.chatId && payload.title !== undefined) {
                        let wrChat = await loadWizardChat(payload.chatId);
                        if (wrChat) { wrChat.title = String(payload.title).slice(0, 80) || 'Untitled'; await saveWizardChat(wrChat); }
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_RENAME_CHAT error:', e); }
                break;
            }

            case 'AE_WIZ_SEND': {
                // Run one wizard chat turn (yoink generation, no budget cost). The turn
                // function persists both messages; we then push reply signal + fresh state.
                try {
                    const wsId = payload.chatId;
                    const wsText: string = payload.text || '';
                    if (!wsId) break;
                    let wsReply = await runWizardChatTurn(wsId, wsText);
                    await broadcastToTM(EVT_WIZ_REPLY, { chatId: wsId, ok: wsReply !== null, error: wsReply === null ? 'Generation failed' : '' });
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) {
                    api.v1.log('[AE:bridge] AE_WIZ_SEND error:', e);
                    try { await broadcastToTM(EVT_WIZ_REPLY, { chatId: payload.chatId, ok: false, error: 'Turn failed' }); } catch (eWs2) {}
                }
                break;
            }

            case 'AE_WIZ_LIST_CONTEXT_SOURCES': {
                try { await broadcastToTM(EVT_WIZ_CONTEXT_SOURCES, await buildWizardSourcesPayload(payload.chatId || '')); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZ_LIST_CONTEXT_SOURCES error:', e); }
                break;
            }

            case 'AE_WIZ_SET_CHAT_CONTEXT': {
                // Persist a chat's context selection. characterIds resolve to their linked
                // lorebook entries (created lazily if missing), then merged into lorebookEntryIds
                // so buildWizardContext picks them up with no new context source.
                try {
                    const wscId = payload.chatId;
                    if (!wscId) break;
                    let wscChat = await loadWizardChat(wscId);
                    if (!wscChat) break;
                    wscChat.contextChatIds = Array.isArray(payload.contextChatIds) ? payload.contextChatIds : [];
                    wscChat.includeStory = !!payload.includeStory;
                    wscChat.lorebookEntryIds = Array.isArray(payload.lorebookEntryIds) ? payload.lorebookEntryIds : [];
                    wscChat.characterIds = Array.isArray(payload.characterIds) ? payload.characterIds : [];
                    await saveWizardChat(wscChat);
                    await broadcastToTM(EVT_WIZ_CONTEXT_SOURCES, await buildWizardSourcesPayload(wscId));
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_SET_CHAT_CONTEXT error:', e); }
                break;
            }

            case 'AE_WIZ_EDIT_MSG': {
                try {
                    let wemChat = await loadWizardChat(payload.chatId);
                    let wemIdx = payload.index;
                    if (wemChat && wemChat.messages && wemIdx >= 0 && wemIdx < wemChat.messages.length && payload.content !== undefined) {
                        wemChat.messages[wemIdx].content = String(payload.content);
                        await saveWizardChat(wemChat);
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_EDIT_MSG error:', e); }
                break;
            }

            case 'AE_WIZ_DELETE_MSG': {
                try {
                    let wdmChat = await loadWizardChat(payload.chatId);
                    let wdmIdx = payload.index;
                    if (wdmChat && wdmChat.messages && wdmIdx >= 0 && wdmIdx < wdmChat.messages.length) {
                        wdmChat.messages.splice(wdmIdx, 1);
                        await saveWizardChat(wdmChat);
                    }
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_DELETE_MSG error:', e); }
                break;
            }

            case 'AE_WIZ_GENERATE': {
                // Unified review/commit dispatcher. Routes a kind to its existing batch
                // function (no recreation), then pushes a result + the relevant refresh.
                try {
                    const wgKind: string = payload.kind || '';
                    const wgCount: number = Math.max(1, Math.min(10, payload.count || 1));
                    const wgSrc: string[] = Array.isArray(payload.sourceChatIds) ? payload.sourceChatIds : [];
                    let wgMade = 0; let wgOk = true;
                    api.v1.ui.toast('Generating ' + wgKind + '\u2026', { type: 'info', autoClose: 1500 });
                    if (wgKind === 'species')        wgMade = await runWizardSpeciesBatch(wgCount, wgSrc);
                    else if (wgKind === 'factions')  wgMade = await runWizardFactionsBatch(wgCount, wgSrc);
                    else if (wgKind === 'archetypes') wgMade = await runWizardArchetypesBatch(wgCount, wgSrc);
                    else if (wgKind === 'locations') wgMade = await runWizardLocationsBatch(wgCount, payload.parentId || null, wgSrc);
                    else if (wgKind === 'characters') wgMade = await runWizardCharactersBatch(wgCount, wgSrc);
                    else if (wgKind === 'web')       wgMade = await runWizardWebBatch(wgCount, wgSrc);
                    else if (wgKind === 'narratives') wgMade = await runWizardNarrativesBatch(wgCount, wgSrc);
                    else if (wgKind === 'hooks')     wgMade = await runWizardHooksBatch(Array.isArray(payload.charIds) ? payload.charIds : [], wgSrc);
                    // [v1.6.3 INTRO-STAGE] 'intro' now stages an editable draft (no story write);
                    // commit happens separately (native wizard Commit button / commitIntroDraft).
                    else if (wgKind === 'intro')     { wgOk = await generateIntroDraft(payload.locationId || '', wgSrc); wgMade = wgOk ? 1 : 0; }
                    else { api.v1.log('[AE:bridge] AE_WIZ_GENERATE unknown kind: ' + wgKind); wgOk = false; }
                    if (wgKind === 'characters' || wgKind === 'hooks' || wgKind === 'web') queueCharacterDataBroadcast();
                    await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: wgKind, count: wgMade, ok: wgOk });
                    await broadcastToTM(EVT_WIZ_STATE, await buildWizardStatePayload());
                } catch (e) {
                    api.v1.log('[AE:bridge] AE_WIZ_GENERATE error:', e);
                    try { await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: payload.kind, count: 0, ok: false }); } catch (eWg2) {}
                }
                break;
            }

            case 'AE_WIZ_COMMIT_MEMORY': {
                try {
                    api.v1.ui.toast('Building memory\u2026', { type: 'info', autoClose: 1500 });
                    let wcmCount = await runWizardMemoryFanout(payload.chatId || '');
                    let wcmCfg = await loadConfig();
                    let wcmOk = await commitWizardMemory(wcmCfg);
                    await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: 'memory', count: wcmCount, ok: wcmOk });
                } catch (e) {
                    api.v1.log('[AE:bridge] AE_WIZ_COMMIT_MEMORY error:', e);
                    try { await broadcastToTM(EVT_WIZ_GEN_RESULT, { kind: 'memory', count: 0, ok: false }); } catch (eWcm2) {}
                }
                break;
            }

            case 'AE_SYNC_LOREBOOK': {
                // [v0.9.7.6] Tab-level "Sync to Lorebook": create-or-update every entry
                // of one kind (species|factions|characters|locations). Reuses the engine's
                // existing per-item create/sync fns (silent), with one summary toast.
                try {
                    const slKind: string = payload.kind || '';
                    let slCreated = 0; let slSynced = 0; let slFailed = 0; let slSkipped = 0;
                    if (slKind === 'species') {
                        const slCfgSp = await loadConfig();
                        for (const sp of ((slCfgSp.species || []) as any[])) {
                            try {
                                if (sp.lorebookEntryId) { await syncSpeciesLorebookEntry(sp.id, true); slSynced++; }
                                else { await createLinkedSpeciesLorebookEntry(sp.id, true); slCreated++; }
                            } catch (eSp) { slFailed++; }
                        }
                    } else if (slKind === 'factions') {
                        const slCfgFa = await loadConfig();
                        for (const fa of ((slCfgFa.factions || []) as any[])) {
                            try {
                                if (fa.lorebookEntryId) { await syncFactionLorebookEntry(fa.id, true); slSynced++; }
                                else { await createLinkedFactionLorebookEntry(fa.id, true); slCreated++; }
                            } catch (eFa) { slFailed++; }
                        }
                    } else if (slKind === 'characters') {
                        const slIdx = await loadIndex();
                        for (const slCm of slIdx) {
                            try {
                                const slCh = await loadCharacter(slCm.id);
                                if (!slCh) { slSkipped++; continue; }
                                if (slCh.lorebookEntryId) { await syncLorebookEntry(slCm.id, true); slSynced++; }
                                else { await createLinkedLorebookEntry(slCm.id, true); slCreated++; }
                            } catch (eCh) { slFailed++; }
                        }
                    } else if (slKind === 'locations') {
                        const slEnts = await loadEntityIndex();
                        for (const slLm of slEnts) {
                            if ((slLm as any).type !== 'location') continue;
                            try {
                                const slLoc = await loadEntity(slLm.id);
                                if (!slLoc) { slSkipped++; continue; }
                                if ((slLoc as any).lorebookEntryId) { await syncEntityLorebookEntry(slLm.id, true); slSynced++; }
                                else if (((slLoc as any).lorebookText || '').trim()) { await createLinkedEntityLorebookEntry(slLm.id, true); slCreated++; }
                                else { slSkipped++; }
                            } catch (eLc) { slFailed++; }
                        }
                    } else {
                        api.v1.ui.toast('Unknown lorebook sync kind.', { type: 'error', autoClose: 2500 });
                        break;
                    }
                    let slMsg = 'Lorebook: ' + slCreated + ' created, ' + slSynced + ' updated';
                    if (slSkipped) slMsg += ', ' + slSkipped + ' skipped';
                    if (slFailed)  slMsg += ', ' + slFailed + ' failed';
                    slMsg += '.';
                    api.v1.ui.toast(slMsg, { type: slFailed ? 'warning' : 'success', autoClose: 3500 });
                    try { await broadcastToTM('AE_SYNC_LOREBOOK_RESULT', { kind: slKind, text: slMsg, ok: !slFailed }); } catch (eSLb) { api.v1.log('[AE:bridge] sync result broadcast failed'); }
                } catch (eSL) {
                    api.v1.log('[AE:bridge] AE_SYNC_LOREBOOK error:', eSL);
                    api.v1.ui.toast('Lorebook sync failed.', { type: 'error', autoClose: 3000 });
                }
                break;
            }

            case 'AE_WIZ_LIST_ENTITIES': {
                try { await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(payload.kind || '')); }
                catch (e) { api.v1.log('[AE:bridge] AE_WIZ_LIST_ENTITIES error:', e); }
                break;
            }

            case 'AE_WIZ_CREATE_ENTITY': {
                // Create a blank named entity so its fields can then be generated.
                try {
                    const wceKind: string = payload.kind || '';
                    const wceName: string = (payload.name || '').toString().trim();
                    if (wceKind === 'memory') {
                        await mutConfig(function(c) {
                            if (!c.wizardSections) c.wizardSections = [];
                            c.wizardSections.push({ id: 'wsec_' + generateId(), label: wceName || 'New Section', enabled: true, content: '', instructions: '', target: 'memory' });
                        });
                    } else if (wceKind === 'species' || wceKind === 'factions') {
                        let wceEk = (wceKind === 'factions') ? 'faction' : 'species';
                        let wceId = await addBlankWizardEntity(wceEk);
                        if (wceName) {
                            await mutConfig(function(c) {
                                let arr: any[] = (wceEk === 'faction') ? (c.factions || []) : (c.species || []);
                                let t = arr.find(function(x) { return x.id === wceId; });
                                if (t) t.name = wceName;
                            });
                            if (wceEk === 'faction') await syncFactionLorebookEntry(wceId).catch(function() {});
                            else await syncSpeciesLorebookEntry(wceId).catch(function() {});
                        }
                    }
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wceKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_CREATE_ENTITY error:', e); }
                break;
            }

            case 'AE_WIZ_SAVE_ENTITY': {
                try {
                    const wseKind: string = payload.kind || '';
                    const wseId: string = payload.id || '';
                    if (!wseId) break;
                    if (wseKind === 'memory') {
                        await mutConfig(function(c) {
                            let sec = (c.wizardSections || []).find(function(s) { return s.id === wseId; });
                            if (!sec) return;
                            if (payload.name !== undefined) sec.label = String(payload.name);
                            if (payload.content !== undefined) sec.content = String(payload.content);
                            if (payload.enabled !== undefined) sec.enabled = !!payload.enabled;
                            if (payload.target !== undefined && (payload.target === 'memory' || payload.target === 'an')) sec.target = payload.target;
                            if (payload.instructions !== undefined) sec.instructions = String(payload.instructions);
                        });
                    } else if (wseKind === 'species' || wseKind === 'factions') {
                        let wseEk = (wseKind === 'factions') ? 'faction' : 'species';
                        await mutConfig(function(c) {
                            let arr: any[] = (wseEk === 'faction') ? (c.factions || []) : (c.species || []);
                            let t = arr.find(function(x) { return x.id === wseId; });
                            if (!t) return;
                            if (payload.name !== undefined) t.name = String(payload.name);
                            if (payload.content !== undefined) t.description = String(payload.content);
                            if (wseEk === 'faction' && Array.isArray(payload.relationshipStates)) {
                                t.relationshipStates = payload.relationshipStates.map(function(rs: any) { return String(rs); }).filter(function(rs: string) { return rs.trim().length > 0; });
                            }
                        });
                        if (wseEk === 'faction') await syncFactionLorebookEntry(wseId).catch(function() {});
                        else await syncSpeciesLorebookEntry(wseId).catch(function() {});
                    }
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wseKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_SAVE_ENTITY error:', e); }
                break;
            }

            case 'AE_WIZ_REGEN_ENTITY': {
                try {
                    const wreKind: string = payload.kind || '';
                    const wreId: string = payload.id || '';
                    const wreHint: string = (payload.hint || '').toString();
                    const wreSrc: string[] = Array.isArray(payload.sourceChatIds) ? payload.sourceChatIds : [];
                    if (!wreId) break;
                    api.v1.ui.toast('Regenerating\u2026', { type: 'info', autoClose: 1200 });
                    let wreOk = false;
                    if (wreKind === 'memory') { let r = await regenerateWizardSection(wreId, wreSrc[0] || '', wreHint); wreOk = r !== null; }
                    else if (wreKind === 'species') { let r = await regenerateWizardEntity('species', wreId, wreSrc, wreHint); wreOk = r !== null; }
                    else if (wreKind === 'factions') { let r = await regenerateWizardEntity('faction', wreId, wreSrc, wreHint); wreOk = r !== null; }
                    if (!wreOk) api.v1.ui.toast('Regeneration failed.', { type: 'error', autoClose: 2000 });
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wreKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_REGEN_ENTITY error:', e); }
                break;
            }

            case 'AE_WIZ_DELETE_ENTITY': {
                try {
                    const wdeKind: string = payload.kind || '';
                    const wdeId: string = payload.id || '';
                    if (!wdeId) break;
                    if (wdeKind === 'memory') {
                        await mutConfig(function(c) { c.wizardSections = (c.wizardSections || []).filter(function(s) { return s.id !== wdeId; }); });
                    } else if (wdeKind === 'species' || wdeKind === 'factions') {
                        await mutConfig(function(c) {
                            if (wdeKind === 'factions') c.factions = (c.factions || []).filter(function(x: any) { return x.id !== wdeId; });
                            else c.species = (c.species || []).filter(function(x: any) { return x.id !== wdeId; });
                        });
                    }
                    await broadcastToTM(EVT_WIZ_ENTITIES, await buildWizardEntitiesPayload(wdeKind));
                } catch (e) { api.v1.log('[AE:bridge] AE_WIZ_DELETE_ENTITY error:', e); }
                break;
            }

            case 'AE_FETCH_GALLERY_LOCATIONS': {
                // [v0.9.94 LOCHIER] Enhanced payload: adds parentId, childCount, lorebookText,
                // icon so the bridge can build a true hierarchy navigator.
                try {
                    const listMeta = await loadEntityIndex();
                    const locations = [];
                    for (const m of listMeta) {
                        if (m.type === 'location') {
                            const rec = await loadEntity(m.id);
                            if (rec) {
                                locations.push({
                                    id: rec.id,
                                    name: rec.name,
                                    parentId: rec.parentId,
                                    description: rec.description || '',
                                    atmosphere: rec.atmosphere || '',
                                    locationVisuals: (rec as any).locationVisuals || '',
                                    lorebookText: rec.lorebookText || '',
                                    lorebookEntryId: rec.lorebookEntryId || '',
                                    icon: rec.icon || '',
                                    childCount: m.childCount || 0
                                });
                            }
                        }
                    }
                    await broadcastToTM('AE_GALLERY_LOCATIONS_RESPONSE', { locations: locations });
                } catch (e) { api.v1.log('[AE:bridge] AE_FETCH_GALLERY_LOCATIONS error:', e); }
                break;
            }

            case 'AE_SAVE_LOCATION_VISUALS': {
                // [v0.9.94 LOCHIER] Now accepts description + lorebookText from the HUD
                // location profile in addition to the existing visuals field.
                try {
                    const vlId = payload.locationId;
                    if (vlId) {
                        const vlRec = await loadEntity(vlId);
                        if (vlRec) {
                            if (payload.visuals     !== undefined) (vlRec as any).locationVisuals = payload.visuals;
                            if (payload.description !== undefined) vlRec.description = payload.description;
                            if (payload.lorebookText !== undefined) vlRec.lorebookText = payload.lorebookText;
                            await saveEntity(vlRec);
                            try {
                                // Re-sync the linked lorebook entry if one exists
                                if (vlRec.lorebookEntryId) {
                                    const vlEntry = await api.v1.lorebook.entry(vlRec.lorebookEntryId);
                                    if (vlEntry) {
                                        let vlText = vlRec.description || '';
                                        if (vlRec.lorebookText) vlText += '\n\n' + vlRec.lorebookText;
                                        vlEntry.text = vlText.trim();
                                        await api.v1.lorebook.updateEntry(vlRec.lorebookEntryId, vlEntry);
                                    }
                                }
                            } catch (eLocLb) { /* non-fatal: lorebook re-sync best-effort */ }
                            api.v1.ui.toast('\u2713 Location saved', { type: 'success', autoClose: 1500 });
                        }
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_LOCATION_VISUALS error:', e); }
                break;
            }

            case 'AE_ASK_RESPONSE': {
                // [v0.9.23 X2] Bridge resolved an __ask__ picker; unblock the waiting Promise.
                try {
                    let askRes = _pendingBridgeResolves[payload.promptId];
                    if (askRes) { delete _pendingBridgeResolves[payload.promptId]; askRes(payload.value !== undefined ? payload.value : null); }
                } catch (e) { api.v1.log('[AE] AE_ASK_RESPONSE error:', e); }
                break;
            }

            case 'AE_TARGET_SELECTED': {
                // [v0.9.23 X1] Bridge resolved a target pick; unblock the waiting Promise.
                try {
                    let tgtRes = _pendingBridgeResolves[payload.promptId];
                    if (tgtRes) { delete _pendingBridgeResolves[payload.promptId]; tgtRes(payload.targetId || null); }
                } catch (e) { api.v1.log('[AE] AE_TARGET_SELECTED error:', e); }
                break;
            }

            case 'AE_SET_PLAYER_FLAVOR': {
                // [v0.9.22 E5] Bridge sends player flavor before firing an action.
                // Empty string clears any pending flavor.
                try {
                    let flavorTxt = String(payload.text || '').trim();
                    if (flavorTxt) {
                        await api.v1.tempStorage.set(STORAGE_PENDING_FLAVOR, flavorTxt).catch(function(_e: any) {});
                    } else {
                        await api.v1.tempStorage.remove(STORAGE_PENDING_FLAVOR).catch(function(_e: any) {});
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_PLAYER_FLAVOR error:', e); }
                break;
            }

            case 'AE_SET_PLAYER_EMOTION': {
                try {
                    const activeEmo = payload.emotion || 'neutral';
                    await api.v1.tempStorage.set('ae_player_emotion', activeEmo);
                    api.v1.log('[AE:engine] Active player emotion tracked: ' + activeEmo);
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_PLAYER_EMOTION error:', e); }
                break;
            }

            case 'AE_SAVE_PRESET': {
                // Bridge presets panel saved one slot. index 0-4, preset has all fields.
                try {
                    const spIdx = typeof payload.index === 'number' ? payload.index : -1;
                    if (spIdx < 0 || spIdx > 4) break;
                    if (!payload.preset) break;
                    if (!profiles[spIdx]) profiles[spIdx] = {};
                    Object.assign(profiles[spIdx], payload.preset);
                    await saveImageSettings();
                    if (spIdx === activeIndex) {
                        await broadcastToTM('PRESET_SYNC', { preset: getActivePresetData() });
                    }
                } catch (e) { api.v1.log('[AE:bridge] AE_SAVE_PRESET error:', e); }
                break;
            }

            case 'AE_SET_ACTIVE_PRESET': {
                // Bridge selected a different active preset slot.
                try {
                    const sapIdx = typeof payload.index === 'number' ? payload.index : -1;
                    if (sapIdx < 0 || sapIdx > 4) break;
                    activeIndex = sapIdx;
                    await saveImageSettings();
                    await broadcastToTM('PRESET_SYNC', { preset: getActivePresetData() });
                    await broadcastToTM('AE_ALL_PRESETS_SYNC', { presets: profiles.slice(), activeIndex: activeIndex });
                } catch (e) { api.v1.log('[AE:bridge] AE_SET_ACTIVE_PRESET error:', e); }
                break;
            }

            case 'AE_INSPECT_LOCATION': {
                // Bridge requests description/atmosphere for a location node.
                try {
                    const ilId: string = payload.locationId;
                    if (!ilId) break;
                    let ilEnt: EntityRecord | null = null;
                    try { ilEnt = await loadEntity(ilId); } catch(_e2) {}
                    await broadcastToTM('AE_INSPECT_RESPONSE', {
                        locationId: ilId,
                        name:        ilEnt ? ilEnt.name : ilId,
                        description: (ilEnt as any)?.description  || '',
                        atmosphere:  (ilEnt as any)?.atmosphere   || '',
                        travelCost:  (ilEnt as any)?.travelCost   || null,
                        locked:      (ilEnt as any)?.isLocked     || false
                    });
                } catch (e) { api.v1.log('[AE:map] AE_INSPECT_LOCATION error:', e); }
                break;
            }

            case 'AE_PACK_TO_LOREBOOK': {
                // [v0.9.7.10] Pack full world config to a hidden lorebook entry for
                // scenario sharing. Also callable from the Worldbuilding menu buttons.
                try { await packConfigToLorebook(); }
                catch (ePkMsg) { api.v1.log('[AE:bridge] AE_PACK_TO_LOREBOOK error:', ePkMsg); }
                break;
            }

            case 'AE_TIME_ADVANCE': {
                // [v0.9.9.2] Manual relative time change (+hour / +day). Re-resolves
                // schedules and fires time-gated auto-triggers so manual changes behave
                // like a turn passing. Bails while the engine is mid-generation.
                try {
                    let taHours = Math.floor(Number(payload.hours) || 0);
                    let taClk = await loadClock();
                    await applyClockChange(taClk.hours + taHours);
                } catch (e) { api.v1.error('[AE:bridge] AE_TIME_ADVANCE error:', e); }
                break;
            }

            case 'AE_TIME_SET': {
                // [v0.9.9.2] Manual absolute set. payload.hours = absolute clock hours.
                try {
                    let tsAbs = Number(payload.hours);
                    if (!isNaN(tsAbs)) { await applyClockChange(Math.floor(tsAbs)); }
                } catch (e) { api.v1.error('[AE:bridge] AE_TIME_SET error:', e); }
                break;
            }

            case 'AE_SET_NARRATIVE_DATE': {
                // [v0.9.9.2] Set/clear a narrative's absolute day target (drives the AN
                // countdown when that narrative is the tracked one). Null/empty clears it.
                try {
                    let sndId = payload.narrativeId || payload.entityId || '';
                    if (sndId) {
                        let sndEnt = await loadEntity(sndId);
                        if (sndEnt) {
                            if (payload.day === null || payload.day === undefined || payload.day === '') {
                                sndEnt.eventDayTarget = undefined;
                            } else {
                                sndEnt.eventDayTarget = Math.max(0, Math.floor(Number(payload.day) || 0));
                            }
                            await saveEntity(sndEnt);
                            await refreshSidebar();
                            await broadcastSceneState();
                            api.v1.ui.toast('Event date updated.', { type: 'success', autoClose: 1800 });
                        }
                    }
                } catch (e) { api.v1.error('[AE:bridge] AE_SET_NARRATIVE_DATE error:', e); }
                break;
            }

            // [v1.7.0 JOURNAL] Bridge → engine journal control. State mutations run the
            // same Section 10b verbs the native HUD uses, then rebroadcast AE_JOURNAL_STATE.
            case 'AE_JOURNAL_REQ': {
                await broadcastJournal();
                break;
            }

            case 'AE_JOURNAL_ACTION': {
                try {
                    const jOp = String(payload.op || '');
                    if (jOp === 'add')            await journalAddBubble(String(payload.text || ''), !!payload.stamped);
                    else if (jOp === 'update')    await journalUpdateBubble(String(payload.id || ''), String(payload.text || ''));
                    else if (jOp === 'delete')    await journalDeleteBubble(String(payload.id || ''));
                    else if (jOp === 'stamp')     await journalToggleStamp(String(payload.id || ''));
                    else if (jOp === 'archive')   await journalSetArchived(String(payload.id || ''), true);
                    else if (jOp === 'unarchive') await journalSetArchived(String(payload.id || ''), false);
                    else if (jOp === 'merge')     await journalMergeDown();
                    else api.v1.log('[AE:bridge] AE_JOURNAL_ACTION unknown op:', jOp);
                } catch (e) { api.v1.error('[AE:bridge] AE_JOURNAL_ACTION error:', e); }
                await broadcastJournal();
                break;
            }

            case 'AE_JOURNAL_GEN': {
                // Rewrite/compress a passage. Returns text only — the HUD reviews and then
                // commits via AE_JOURNAL_ACTION 'update' (mirrors the native review flow).
                const gOp = String(payload.op || '');
                const gId = String(payload.id || '');
                try {
                    const gSrc = String(payload.text || '');
                    let gOut: string | null = null;
                    if (gOp === 'rewrite')       gOut = await journalGenerateRewrite(gSrc);
                    else if (gOp === 'compress') gOut = await journalGenerateCompress(gSrc);
                    await broadcastToTM('AE_JOURNAL_GEN_RESULT', { id: gId, op: gOp, text: gOut || '', ok: !!gOut });
                } catch (e) {
                    api.v1.error('[AE:bridge] AE_JOURNAL_GEN error:', e);
                    try { await broadcastToTM('AE_JOURNAL_GEN_RESULT', { id: gId, op: gOp, text: '', ok: false }); } catch (e2) {}
                }
                break;
            }

            default:
                api.v1.log('[AE:bridge] Unhandled bridge message, event:', event, payload);
        }
    } catch (e) {
        api.v1.log('[AE:bridge] handleBridgeMessage error:', e);
    }
}


// ============================================================================
// SECTION 18b — LOREBOOK WORLD-PACK  [v0.9.7.9]
// packConfigToLorebook(): serialises the full AE world into a single hidden,
// disabled lorebook entry (AE_LOREBOOK_PACK_NAME). The entry travels with the
// story's .scenario export, so any user who imports the scenario gets the
// world pre-configured. The entry is NEVER injected into context (enabled:false,
// no keys, forceActivation:false). It can be re-packed at any time; the engine
// finds the existing entry by displayName and updates it in place.
//
// loadConfigFromLorebook(): called from onScriptsLoaded. If the sentinel entry
// exists AND storyStorage has no config yet (fresh story from scenario), imports
// the full world automatically and logs a summary. Non-destructive — existing
// stories are never overwritten.
// ============================================================================

// ============================================================================
// [v0.98] PLAIN-JSON IMPORT / EXPORT
// Uses api.v1.file.save() and api.v1.file.prompt() — no bridge required.
// Produces a human-readable, tool-friendly JSON file using the importPayload()
// schema, fully compatible with the existing smart importer.
// ============================================================================

async function exportAll(): Promise<void> {
    try {
        const xaCfg    = await loadConfig();
        const xaChars  = await loadAllCharacters();
        const xaEntIdx = await loadEntityIndex();
        const xaEnts: EntityRecord[] = [];
        for (const xaM of xaEntIdx.filter(Boolean)) {
            const xaE = await loadEntity(xaM.id);
            if (xaE) xaEnts.push(xaE);
        }
        const xaNpcWeb    = typeof loadNpcWeb    === 'function' ? await (loadNpcWeb as any)().catch(function() { return []; })    : [];
        const xaPartyState = typeof loadPartyState === 'function' ? await (loadPartyState as any)().catch(function() { return { resourceValues: {} }; }) : { resourceValues: {} };

        const xaData = {
            _ae:        true,
            aeVersion:  '0.9.9.2',
            exportedAt: new Date().toISOString(),
            config:     xaCfg,
            characters: xaChars,
            entities:   xaEnts,
            npcWeb:     xaNpcWeb,
            partyState: xaPartyState
        };

        const xaSafeName = ((xaCfg as any).projectName || 'ae_world').replace(/[^a-z0-9]/gi, '_').toLowerCase();
        await api.v1.file.save(xaSafeName + '_export.json', JSON.stringify(xaData, null, 2));
        api.v1.ui.toast('Exported: ' + xaChars.length + ' characters, ' + xaEnts.length + ' nodes.', { type: 'success', autoClose: 3000 });
    } catch (e) {
        api.v1.error('[AE] exportAll failed:', e);
        api.v1.ui.toast('Export failed — see engine log.', { type: 'error' });
    }
}

async function importData(): Promise<void> {
    try {
        const raw = await api.v1.file.prompt({ accept: '.json,application/json,text/plain,*/*', readAs: 'text' });
        if (!raw || typeof raw !== 'string') return;

        const data = JSON.parse(raw);
        const result = await importPayload(data);

        const parts: string[] = [];
        if (result.configImported)     parts.push('settings');
        if (result.charCount > 0)      parts.push(result.charCount + ' character' + (result.charCount !== 1 ? 's' : ''));
        if (result.entityCount > 0)    parts.push(result.entityCount + ' node' + (result.entityCount !== 1 ? 's' : ''));
        if (result.npcWebImported)     parts.push('NPC web');
        if (result.partyStateImported) parts.push('party state');

        if (!parts.length) {
            api.v1.ui.toast('File loaded but no recognisable AE data found.', { type: 'warning', autoClose: 3500 });
            return;
        }
        api.v1.ui.toast('Imported: ' + parts.join(', ') + '.', { type: 'success', autoClose: 3500 });
        await refreshSidebar();
        queueSceneStateBroadcast();
    } catch (e) {
        api.v1.error('[AE] importData failed:', e);
        api.v1.ui.toast('Import failed — check that the file is valid JSON.', { type: 'error' });
    }
}

async function packConfigToLorebook(): Promise<void> {
    api.v1.log('[AE:pack] Packing world config to lorebook...');
    try {
        // -- Gather storyStorage data -----------------------------------------
        const pkCfg   = await api.v1.storyStorage.get(STORAGE_CONFIG);
        const pkIdx   = await api.v1.storyStorage.getOrDefault(STORAGE_INDEX, []) as CharacterMeta[];
        const pkEntIdx = await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_INDEX, []) as EntityMeta[];
        const pkParty  = await api.v1.storyStorage.getOrDefault(STORAGE_PARTY, null);
        const pkWebRaw = await api.v1.storyStorage.get(STORAGE_NPC_WEB) as string | undefined;
        const pkQI     = await api.v1.storyStorage.getOrDefault('ae_quick_instances', []);
        const pkWizRaw = await api.v1.storyStorage.getOrDefault(STORAGE_WIZ_CHATS, '[]') as string;

        // -- Characters (sequential load) -------------------------------------
        let pkCharRecs: Record<string, any> = {};
        for (const pkCm of pkIdx) {
            try {
                const pkCh = await api.v1.storyStorage.get(STORAGE_CHAR_PFX + pkCm.id);
                if (pkCh) pkCharRecs[pkCm.id] = pkCh;
            } catch (eChPk) { api.v1.log('[AE:pack] char load skip:', pkCm.id, eChPk); }
        }

        // -- Entities (sequential load) ---------------------------------------
        let pkEntRecs: Record<string, any> = {};
        for (const pkEm of pkEntIdx) {
            try {
                const pkEnt = await api.v1.storyStorage.getOrDefault(STORAGE_ENTITY_PFX + pkEm.id, null);
                if (pkEnt) pkEntRecs[pkEm.id] = pkEnt;
            } catch (eEntPk) { api.v1.log('[AE:pack] entity load skip:', pkEm.id, eEntPk); }
        }

        // -- Image settings (in-memory, from global api.v1.storage) ----------
        // profiles/activeIndex/globalSettings are module-level; re-read to be safe.
        const pkImgProf = await api.v1.storage.get(STORAGE_KEY_PROFILES);
        const pkImgIdx  = await api.v1.storage.get(STORAGE_KEY_ACTIVE);
        const pkImgGlob = await api.v1.storage.get(STORAGE_KEY_GLOBAL);

        // -- Assemble package -------------------------------------------------
        const pkPayload = JSON.stringify({
            v:            1,
            aeVersion:    '0.9.7.9',
            packedAt:     Date.now(),
            config:       pkCfg     || null,
            charIndex:    pkIdx,
            charRecords:  pkCharRecs,
            entIndex:     pkEntIdx,
            entRecords:   pkEntRecs,
            party:        pkParty   || null,
            npcWeb:       pkWebRaw  || null,
            quickInstances: pkQI,
            wizChats:     pkWizRaw,
            imageProfiles:    pkImgProf || null,
            imageActiveIndex: (pkImgIdx !== null && pkImgIdx !== undefined) ? pkImgIdx : 0,
            imageGlobal:      pkImgGlob || null
        });

        const pkBytes = pkPayload.length; // character count; JSON is mostly ASCII so ~= bytes
        api.v1.log('[AE:pack] Payload size:', pkBytes, 'bytes;', pkIdx.length, 'chars,', pkEntIdx.length, 'entities.');

        // -- Find existing sentinel entry or create new -----------------------
        let pkExisting: any = null;
        try {
            const pkAllEntries = await api.v1.lorebook.entries();
            pkExisting = pkAllEntries.find(function(pkE: any) { return pkE.displayName === AE_LOREBOOK_PACK_NAME; });
        } catch (eEntries) { api.v1.log('[AE:pack] entries() error:', eEntries); }

        if (pkExisting) {
            await api.v1.lorebook.updateEntry(pkExisting.id, { text: pkPayload });
            api.v1.log('[AE:pack] Updated existing lorebook entry id:', pkExisting.id);
        } else {
            const pkNewId = api.v1.uuid();
            await api.v1.lorebook.createEntry({
                id:              pkNewId,
                displayName:     AE_LOREBOOK_PACK_NAME,
                text:            pkPayload,
                keys:            [],
                enabled:         false,
                hidden:          true,
                forceActivation: false
            });
            api.v1.log('[AE:pack] Created new lorebook entry id:', pkNewId);
        }
        api.v1.ui.toast('World packed to lorebook (' + Math.round(pkBytes / 1024) + ' KB). Export scenario to share.', { type: 'success', autoClose: 4000 });
    } catch (ePack) {
        api.v1.error('[AE:pack] packConfigToLorebook error:', ePack);
        api.v1.ui.toast('Pack failed - see engine log.', { type: 'error', autoClose: 3000 });
    }
}

// Returns true if config was imported, false if skipped (entry missing or
// config already present). Called from onScriptsLoaded.
// Pass forced=true to import even when storyStorage already has a config.
async function loadConfigFromLorebook(forced?: boolean): Promise<boolean> {
    try {
        // -- Find sentinel entry ----------------------------------------------
        let lcEntry: any = null;
        try {
            const lcAll = await api.v1.lorebook.entries();
            lcEntry = lcAll.find(function(lcE: any) { return lcE.displayName === AE_LOREBOOK_PACK_NAME; });
        } catch (eLcList) { api.v1.log('[AE:pack] loadConfigFromLorebook entries() error:', eLcList); return false; }
        if (!lcEntry || !lcEntry.text) return false;

        // -- Only import if storyStorage has no config yet (fresh scenario) ---
        const lcExistingCfg = await api.v1.storyStorage.get(STORAGE_CONFIG);
        if (!forced && lcExistingCfg !== null && lcExistingCfg !== undefined) {
            api.v1.log('[AE:pack] Lorebook pack found but storyStorage already has config; skipping auto-import.');
            return false;
        }

        // -- Parse ------------------------------------------------------------
        let lcData: any;
        try { lcData = JSON.parse(lcEntry.text); }
        catch (eLcParse) { api.v1.error('[AE:pack] loadConfigFromLorebook: JSON parse failed:', eLcParse); return false; }

        api.v1.log('[AE:pack] Importing from lorebook pack v' + (lcData.v || '?') + ' packed at', lcData.packedAt, 'aeVersion', lcData.aeVersion);

        // -- Restore storyStorage: config -------------------------------------
        if (lcData.config) await api.v1.storyStorage.set(STORAGE_CONFIG, lcData.config);

        // -- Restore storyStorage: character index + records ------------------
        if (Array.isArray(lcData.charIndex) && lcData.charIndex.length > 0) {
            await api.v1.storyStorage.set(STORAGE_INDEX, lcData.charIndex);
            let lcCharCount = 0;
            const lcCharRecs = lcData.charRecords || {};
            for (const lcCharId in lcCharRecs) {
                try { await api.v1.storyStorage.set(STORAGE_CHAR_PFX + lcCharId, lcCharRecs[lcCharId]); lcCharCount++; }
                catch (eLcChar) { api.v1.log('[AE:pack] char restore skip:', lcCharId, eLcChar); }
            }
            api.v1.log('[AE:pack] Restored', lcCharCount, 'character records.');
        }

        // -- Restore storyStorage: entity index + records ---------------------
        if (Array.isArray(lcData.entIndex) && lcData.entIndex.length > 0) {
            await api.v1.storyStorage.set(STORAGE_ENTITY_INDEX, lcData.entIndex);
            let lcEntCount = 0;
            const lcEntRecs = lcData.entRecords || {};
            for (const lcEntId in lcEntRecs) {
                try { await api.v1.storyStorage.set(STORAGE_ENTITY_PFX + lcEntId, lcEntRecs[lcEntId]); lcEntCount++; }
                catch (eLcEnt) { api.v1.log('[AE:pack] entity restore skip:', lcEntId, eLcEnt); }
            }
            api.v1.log('[AE:pack] Restored', lcEntCount, 'entity records.');
        }

        // -- Restore storyStorage: ancillary data -----------------------------
        if (lcData.party)          await api.v1.storyStorage.set(STORAGE_PARTY,         lcData.party);
        if (lcData.npcWeb)         await api.v1.storyStorage.set(STORAGE_NPC_WEB,        lcData.npcWeb);
        if (lcData.quickInstances) await api.v1.storyStorage.set('ae_quick_instances',   lcData.quickInstances);
        if (lcData.wizChats)       await api.v1.storyStorage.set(STORAGE_WIZ_CHATS,      lcData.wizChats);

        // -- Restore global api.v1.storage: image settings -------------------
        if (lcData.imageProfiles)                                   await api.v1.storage.set(STORAGE_KEY_PROFILES, lcData.imageProfiles);
        if (lcData.imageActiveIndex !== null && lcData.imageActiveIndex !== undefined) await api.v1.storage.set(STORAGE_KEY_ACTIVE, lcData.imageActiveIndex);
        if (lcData.imageGlobal)                                     await api.v1.storage.set(STORAGE_KEY_GLOBAL,   lcData.imageGlobal);

        const lcCharLen  = Object.keys(lcData.charRecords || {}).length;
        const lcEntLen   = Object.keys(lcData.entRecords  || {}).length;
        api.v1.log('[AE:pack] Import complete:', lcCharLen, 'chars,', lcEntLen, 'entities.');
        api.v1.ui.toast('World imported from lorebook pack (' + lcCharLen + ' chars, ' + lcEntLen + ' locations). Reload to activate.', { type: 'success', autoClose: 5000 });
        return true;
    } catch (eLcMain) {
        api.v1.error('[AE:pack] loadConfigFromLorebook error:', eLcMain);
        return false;
    }
}

// Takes already-parsed lorebook pack data (packConfigToLorebook format: charIndex/
// charRecords/entIndex/entRecords) and restores the full world into storyStorage
// and api.v1.storage. Called from pickAndImportFromLorebook and showNewStoryPrompt.
// Distinct from importPayload(), which handles the plain-JSON export format.
async function importFromLorebookPack(data: any): Promise<void> {
    if (data.config) await api.v1.storyStorage.set(STORAGE_CONFIG, data.config);

    if (Array.isArray(data.charIndex) && data.charIndex.length > 0) {
        await api.v1.storyStorage.set(STORAGE_INDEX, data.charIndex);
        let ifpCharRecs = data.charRecords || {};
        for (let ifpCId in ifpCharRecs) {
            try { await api.v1.storyStorage.set(STORAGE_CHAR_PFX + ifpCId, ifpCharRecs[ifpCId]); } catch (eIfpC) {}
        }
    }

    if (Array.isArray(data.entIndex) && data.entIndex.length > 0) {
        await api.v1.storyStorage.set(STORAGE_ENTITY_INDEX, data.entIndex);
        let ifpEntRecs = data.entRecords || {};
        for (let ifpEId in ifpEntRecs) {
            try { await api.v1.storyStorage.set(STORAGE_ENTITY_PFX + ifpEId, ifpEntRecs[ifpEId]); } catch (eIfpE) {}
        }
    }

    if (data.party)          await api.v1.storyStorage.set(STORAGE_PARTY,         data.party);
    if (data.npcWeb)         await api.v1.storyStorage.set(STORAGE_NPC_WEB,        data.npcWeb);
    if (data.quickInstances) await api.v1.storyStorage.set('ae_quick_instances',   data.quickInstances);
    if (data.wizChats)       await api.v1.storyStorage.set(STORAGE_WIZ_CHATS,      data.wizChats);

    if (data.imageProfiles)                                                    await api.v1.storage.set(STORAGE_KEY_PROFILES, data.imageProfiles);
    if (data.imageActiveIndex !== null && data.imageActiveIndex !== undefined) await api.v1.storage.set(STORAGE_KEY_ACTIVE,   data.imageActiveIndex);
    if (data.imageGlobal)                                                      await api.v1.storage.set(STORAGE_KEY_GLOBAL,   data.imageGlobal);
}

// Scans all lorebook entries for AE world packs (any entry whose text parses to
// JSON containing an aeVersion field), presents a modal picker, and calls
// importFromLorebookPack on the selected entry. Entry-point for the Import button
// in Settings → Adventure Module Management and the Characters tab header.
async function pickAndImportFromLorebook(): Promise<void> {
    let pklPacks: { entry: any; data: any }[] = [];
    try {
        let pklAll = await api.v1.lorebook.entries();
        for (let pklE of pklAll) {
            if (!pklE.text) continue;
            try {
                let pklD = JSON.parse(pklE.text);
                if (pklD && pklD.aeVersion) pklPacks.push({ entry: pklE, data: pklD });
            } catch (ePklParse) {}
        }
    } catch (ePklScan) {
        api.v1.ui.toast('Failed to scan lorebook entries.', { type: 'error' });
        return;
    }

    if (pklPacks.length === 0) {
        api.v1.ui.toast('No AE world packs found in the lorebook. Use "Pack to Lorebook" first.', { type: 'warning', autoClose: 4000 });
        return;
    }

    let pklContent: any[] = [
        { type: 'text', text: 'Select a world pack to import. This will overwrite the current world data.', style: { marginBottom: '14px', fontSize: '12px', lineHeight: '1.5' } }
    ];
    let pklModal: any;

    for (let pklI = 0; pklI < pklPacks.length; pklI++) {
        (function(pklEnt: any, pklDat: any) {
            let pklCC  = Object.keys(pklDat.charRecords || {}).length;
            let pklEC  = Object.keys(pklDat.entRecords  || {}).length;
            let pklLbl = (pklEnt.displayName || '[AE World]') + ' — ' + pklCC + ' chars, ' + pklEC + ' locations';
            pklContent.push({
                type: 'button',
                text: '📥 Import: ' + pklLbl,
                style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.15)', border: '1px solid rgba(136,204,255,0.4)', color: '#88ccff', fontWeight: 'bold' },
                disabledWhileCallbackRunning: true,
                callback: async function() {
                    try {
                        await importFromLorebookPack(pklDat);
                        if (pklModal) pklModal.close();
                        api.v1.ui.toast('World imported. Reload the sidebar to activate.', { type: 'success', autoClose: 4000 });
                        await refreshSidebar();
                        queueSceneStateBroadcast();
                    } catch (ePklImp) {
                        api.v1.error('[AE] pickAndImportFromLorebook import failed:', ePklImp);
                        api.v1.ui.toast('Import failed — see engine log.', { type: 'error' });
                    }
                }
            });
        })(pklPacks[pklI].entry, pklPacks[pklI].data);
    }

    pklContent.push({ type: 'button', text: 'Cancel', style: { width: '100%', marginTop: '8px' }, callback: function() { if (pklModal) pklModal.close(); } });
    pklModal = await openEngineModal({ id: 'ae-pick-import', title: '📥 Import from Lorebook', size: 'small', content: pklContent });
}

// ============================================================================
// SECTION 19 — ACTION EXECUTION ENGINE
// All functions related to executing entity actions, travel, encounters, and
// pathfinding. These are the game mechanic primitives called by both the NAI
// sidebar UI (Sections 20+) and the bridge message handler (Section 18).
//
// [CHANGE] All renderSceneHUD() calls replaced with queueSceneStateBroadcast().
//          renderSceneHUD no longer exists in the merged system.
//
// [CHANGE] executeAction: Math.random() → await api.v1.random.roll('1d6')
//          for consistent seedable dice across probability systems.
//
// [CHANGE] executeTravelTo: adjustResource() dead return value (wasRelocated)
//          removed from the ruleTriggeredMove check. adjustResource() always
//          returns false so the check was never meaningful. The comment about
//          this dead code in Section 11 is resolved here.
//
// ASSEMBLY NOTE: getSkillModifier and resolveEntityTokens were originally
// defined deep in the AE source (lines 7402 and 1441). Moved here because
// they are solely used by this section's functions and have no other call sites.
// ============================================================================

// ── Token Substitution ────────────────────────────────────────────────────────

function resolveEntityTokens(text: string, ent: EntityRecord, targetEnt?: EntityRecord | null): string {
    // Replaces __self__ and __target__ tokens in action outcome notes with entity names.
    // Preserved verbatim from AE source.
    if (!text || !ent) return text || '';
    let result = text.replace(/__self__/g, ent.name);
    if (targetEnt) result = result.replace(/__target__/g, targetEnt.name);
    return result;
}

// ── Skill Modifier Resolution ─────────────────────────────────────────────────

async function getSkillModifier(protag: CharacterRecord, tag: string, cfg: GlobalConfig): Promise<SkillModifierResult> {
    // Returns the total modifier (sheet + equipped items) for a skill tag.
    // Preserved verbatim from AE source.
    const empty: SkillModifierResult = { total: 0, sheetMod: 0, itemMods: [] };
    if (!tag) return empty;
    const cleanTag = tag.replace('#', '').trim().toLowerCase();

    // Sheet modifier — scan category fields for a matching name
    let sheetMod = 0;
    for (const cat of (cfg.sheetCategories || [])) {
        for (const field of (cat.fields || [])) {
            if (field.name.toLowerCase() === cleanTag) {
                const combinedId = cat.id + '.' + field.id;
                const val = protag.sheetValues[combinedId] !== undefined
                    ? protag.sheetValues[combinedId]
                    : protag.sheetValues[field.id];
                if (val !== undefined && val !== null) {
                    if (typeof val === 'number') {
                        sheetMod = val;
                    } else if (typeof val === 'string') {
                        // Numeric sheet fields (e.g. the Four Fs) are saved as strings by
                        // the numberInput editor, so a numeric string IS the modifier.
                        const numVal = Number(val);
                        if (val.trim() !== '' && !isNaN(numVal)) sheetMod = numVal;
                    }
                }
            }
        }
    }

    // Equipped item bonuses
    const itemMods: { name: string; mod: number }[] = [];
    for (const itemId of (protag.equippedItemIds || [])) {
        try {
            const itemEnt = await loadEntity(itemId);
            if (!itemEnt || !itemEnt.skillBonuses) continue;
            for (const bonus of itemEnt.skillBonuses) {
                const bonusTag = bonus.skillTag.replace('#', '').trim().toLowerCase();
                if (bonusTag === cleanTag && bonus.modifier !== 0) {
                    itemMods.push({ name: itemEnt.name, mod: bonus.modifier });
                }
            }
        } catch (_) { /* non-fatal */ }
    }

    const itemTotal = itemMods.reduce(function(acc, b) { return acc + b.mod; }, 0);

    // Active modifiers — temporary bonuses/penalties applied by action effects
    let activeTotal = 0;
    try {
        let activeMods = await api.v1.historyStorage.getOrDefault(STORAGE_ACTIVE_MODIFIERS, []) as ActiveModifier[];
        for (const am of (activeMods || [])) {
            if (am.charId === protag.id && am.skillTag === cleanTag) {
                activeTotal += am.delta;
                itemMods.push({ name: am.sourceLabel || 'Active Effect', mod: am.delta });
            }
        }
    } catch (_e: any) {}

    return { total: sheetMod + itemTotal + activeTotal, sheetMod: sheetMod, itemMods: itemMods };
}

// ── Visibility & Field Condition Evaluation ───────────────────────────────────

async function evaluateFieldCondition(rule: ActionRule, protag: CharacterRecord | null, ent: EntityRecord, cfg: GlobalConfig, resolvedTarget?: EntityRecord | null): Promise<boolean> {
    // Evaluates a single ActionRule condition (visibility-gate or set-field precondition).
    // Preserved verbatim from AE source. Called by both executeAction and buildSceneStatePayload.
    if (!rule.fieldKey || !rule.fieldValue) return true;
    let actual: string | undefined;

    if (rule.targetType === 'entity') {
        let evTargetEnt: EntityRecord | null = null;
        if (rule.targetId === '__target__') { evTargetEnt = resolvedTarget || null; }
        else if (rule.targetId === '__self__') { evTargetEnt = ent; }
        else if (rule.targetId === '__protag__') {
            const evChars = await loadAllCharacters();
            const evP = evChars.find(function(c) { return c.isProtagonist; });
            if (evP && evP.entityId) evTargetEnt = await loadEntity(evP.entityId);
        } else if (rule.targetId === '__protag_loc__') {
            const evChars2 = await loadAllCharacters();
            const evP2 = evChars2.find(function(c) { return c.isProtagonist; });
            if (evP2 && evP2.entityId) {
                const evBody = await loadEntity(evP2.entityId);
                if (evBody && evBody.parentId) evTargetEnt = await loadEntity(evBody.parentId);
            }
        } else { evTargetEnt = await loadEntity(rule.targetId || ''); }
        if (!evTargetEnt) return false;
        actual = String((evTargetEnt as any)[rule.fieldKey] !== undefined ? (evTargetEnt as any)[rule.fieldKey] : '');
        if (actual === 'null' || actual === 'undefined') actual = '';
        let evExpected = rule.fieldValue || '';
        if (rule.fieldKey === 'parentId') {
            if (evExpected === '__protag__') {
                const mgChars = await loadAllCharacters();
                const mgP = mgChars.find(function(c) { return c.isProtagonist; });
                evExpected = (mgP && mgP.entityId) || '';
            } else if (evExpected === '__protag_loc__') {
                const mgChars2 = await loadAllCharacters();
                const mgP2 = mgChars2.find(function(c) { return c.isProtagonist; });
                if (mgP2 && mgP2.entityId) { const mgBod = await loadEntity(mgP2.entityId); evExpected = (mgBod && mgBod.parentId) || ''; }
                else { evExpected = ''; }
            } else if (evExpected === '__root__') { evExpected = ''; }
        }
        return actual === evExpected;
    } else if (rule.targetType === 'character') {
        let targetChar: CharacterRecord | null = null;
        if (rule.targetId === '__player__' || rule.targetId === '__protag__') { targetChar = protag; }
        else if (rule.targetId === '__self_char__') { const ecAllC = await loadAllCharacters(); targetChar = ecAllC.find(function(c) { return c.entityId === ent.id; }) || null; }
        else if (rule.targetId === '__target__') {
            if (resolvedTarget) { const tAllC = await loadAllCharacters(); targetChar = tAllC.find(function(c) { return c.entityId === resolvedTarget.id; }) || null; }
            else { targetChar = null; }
        }
        else { targetChar = await loadCharacter(rule.targetId || ''); }
        if (!targetChar) return false;
        let fk2 = rule.fieldKey || '';
        if (fk2.startsWith('__pfac__')) {
            const pfacId = fk2.replace('__pfac__', '');
            const pfacDef = (cfg.factions || []).find(function(f) { return f.id === pfacId; });
            if (!pfacDef) return false;
            const party2 = await loadPartyState();
            actual = ((pfacDef.relationshipStates || [])[(party2.factionRelationships && party2.factionRelationships[pfacId]) || 0]) || '';
        } else if (fk2.startsWith('__fac__')) {
            const facId2 = fk2.replace('__fac__', '');
            const facDef2 = (cfg.factions || []).find(function(f) { return f.id === facId2; });
            if (!facDef2) return false;
            const idx2 = (targetChar.charFactionRelationships && targetChar.charFactionRelationships[facId2]) || 0;
            actual = (facDef2.relationshipStates || [])[idx2] || '';
        } else if (fk2.startsWith('__cres__')) {
            const resId2 = fk2.replace('__cres__', '');
            const resDef2 = (targetChar.charResourceDefs || []).find(function(r) { return r.id === resId2; });
            if (!resDef2) return false;
            const val2 = (targetChar.charResourceValues && targetChar.charResourceValues[resId2]) || 0;
            actual = resDef2.type === 'track' ? ((resDef2.states || [])[val2] || '') : String(val2);
        } else if (fk2.startsWith('__equip__')) {
            const itemId2 = fk2.replace('__equip__', '');
            actual = (targetChar.equippedItemIds || []).indexOf(itemId2) >= 0 ? 'equipped' : 'unequipped';
        } else if (fk2.includes('.')) {
            actual = (targetChar.sheetValues || {})[fk2] || '';
        } else {
            actual = String((targetChar as any)[fk2] !== undefined ? (targetChar as any)[fk2] : '');
        }
    } else if (rule.targetType === 'resource') {
        const resDef = (cfg.resources || []).find(function(r) { return r.tag === rule.resourceTag; });
        if (!resDef) return false;
        const party = await loadPartyState();
        actual = String((party.resourceValues && party.resourceValues[resDef.id]) || 0);
    }

    return actual === (rule.fieldValue || '');
}

// ── Set-Field Rule Application ────────────────────────────────────────────────

async function applySetFieldRule(rule: ActionRule, protag: CharacterRecord | null, ent: EntityRecord, cfg: GlobalConfig, resolvedTarget?: EntityRecord | null): Promise<void> {
    // Applies a set-field rule to the target record. Preserved verbatim from AE source.
    if (!rule.fieldKey) return;

    if (rule.targetType === 'entity') {
        let targetEnt: EntityRecord | null = null;
        if (rule.targetId === '__target__') { targetEnt = resolvedTarget || null; }
        else if (rule.targetId === '__self__') { targetEnt = ent; }
        else { targetEnt = await loadEntity(rule.targetId || ''); }
        if (!targetEnt) return;
        let sfFinalValue: any = rule.fieldValue;
        if (rule.fieldKey === 'parentId') {
            if (sfFinalValue === '__protag__') {
                const sfChars = await loadAllCharacters(); const sfP = sfChars.find(function(c) { return c.isProtagonist; });
                sfFinalValue = (sfP && sfP.entityId) || null;
            } else if (sfFinalValue === '__protag_loc__') {
                const sfChars = await loadAllCharacters(); const sfP = sfChars.find(function(c) { return c.isProtagonist; });
                if (sfP && sfP.entityId) { const sfBody = await loadEntity(sfP.entityId); sfFinalValue = (sfBody && sfBody.parentId) || null; } else sfFinalValue = null;
            } else if (sfFinalValue === '__root__') { sfFinalValue = null; }
        }
        if (rule.fieldKey === 'gated') sfFinalValue = sfFinalValue === 'true' ? true : sfFinalValue === 'false' ? false : !!sfFinalValue;
        (targetEnt as any)[rule.fieldKey] = sfFinalValue;
        await saveEntity(targetEnt);
    } else if (rule.targetType === 'character') {
        let targetChar: CharacterRecord | null = null;
        if (rule.targetId === '__player__' || rule.targetId === '__protag__') { targetChar = protag; }
        else if (rule.targetId === '__self_char__') { const scAllC = await loadAllCharacters(); targetChar = scAllC.find(function(c) { return c.entityId === ent.id; }) || null; }
        else if (rule.targetId === '__target__') {
            if (resolvedTarget) { const tAllC2 = await loadAllCharacters(); targetChar = tAllC2.find(function(c) { return c.entityId === resolvedTarget.id; }) || null; }
            else { targetChar = null; }
        }
        else { targetChar = await loadCharacter(rule.targetId || ''); }
        if (!targetChar) return;
        const fk = rule.fieldKey || '';

        if (fk === '__kill__') {
            await killCharacter(targetChar.id);
        } else if (fk.startsWith('__pfac__')) {
            const pfacId2 = fk.replace('__pfac__', '');
            const pfacDef2 = cfg ? (cfg.factions || []).find(function(f) { return f.id === pfacId2; }) : undefined;
            if (!pfacDef2) return;
            const pfacStateIdx = ((pfacDef2 as any).relationshipStates || []).indexOf(rule.fieldValue || '');
            if (pfacStateIdx >= 0) {
                const partyForFac = await loadPartyState();
                if (!partyForFac.factionRelationships) partyForFac.factionRelationships = {};
                partyForFac.factionRelationships[pfacId2] = pfacStateIdx;
                await savePartyState(partyForFac);
            }
        } else if (fk.startsWith('__fac__')) {
            const facId = fk.replace('__fac__', '');
            const facDef = cfg ? (cfg.factions || []).find(function(f) { return f.id === facId; }) : undefined;
            if (!facDef) return;
            const stateIdx = ((facDef as any).relationshipStates || []).indexOf(rule.fieldValue || '');
            if (stateIdx >= 0) {
                if (!targetChar.charFactionRelationships) targetChar.charFactionRelationships = {};
                targetChar.charFactionRelationships[facId] = stateIdx;
                await saveCharacter(targetChar);
            }
        } else if (fk.startsWith('__cres__')) {
            const resId = fk.replace('__cres__', '');
            const resDef = (targetChar.charResourceDefs || []).find(function(r) { return r.id === resId; });
            if (!resDef) return;
            if (!targetChar.charResourceValues) targetChar.charResourceValues = {};
            if (resDef.type === 'track') {
                const stateIdx2 = (resDef.states || []).indexOf(rule.fieldValue || '');
                if (stateIdx2 >= 0) targetChar.charResourceValues[resId] = stateIdx2;
            } else {
                const num = parseInt(rule.fieldValue || '0', 10);
                if (!isNaN(num)) targetChar.charResourceValues[resId] = num;
            }
            await saveCharacter(targetChar);
        } else if (fk.startsWith('__equip__')) {
            const itemId = fk.replace('__equip__', '');
            if (!targetChar.equippedItemIds) targetChar.equippedItemIds = [];
            if (rule.fieldValue === 'equipped') {
                if (targetChar.equippedItemIds.indexOf(itemId) < 0) targetChar.equippedItemIds.push(itemId);
            } else {
                targetChar.equippedItemIds = targetChar.equippedItemIds.filter(function(id) { return id !== itemId; });
            }
            await saveCharacter(targetChar);
            // [v0.9.8.5] No lorebook re-sync — equipment now rides an ephemeral temp entry.
        } else if (fk === 'entityParentId') {
            if (!targetChar.entityId) return;
            const charMovedBody = await loadEntity(targetChar.entityId);
            if (!charMovedBody) return;
            let newParentForChar: string | null = rule.fieldValue || null;
            if (rule.fieldValue === '__protag_entity__') {
                const pIdx2 = await loadIndex(); const pMeta5 = pIdx2.find(function(m) { return !!m.isProtagonist; });
                const pC = pMeta5 ? await loadCharacter(pMeta5.id) : null;
                newParentForChar = (pC && pC.entityId) || null;
            } else if (rule.fieldValue === '__room__') {
                const rmChars2 = await loadAllCharacters();
                const rmProtag2 = rmChars2.find(function(c) { return c.isProtagonist; });
                if (rmProtag2 && rmProtag2.entityId) {
                    const rmBody2 = await loadEntity(rmProtag2.entityId);
                    newParentForChar = (rmBody2 && rmBody2.parentId) || null;
                } else { newParentForChar = null; }
            } else if (rule.fieldValue === '__self_room__') {
                newParentForChar = ent.parentId || null;
            }
            charMovedBody.parentId = newParentForChar;
            await saveEntity(charMovedBody);
            await recalculateScenePresence();
        } else if (fk.includes('.')) {
            if (!targetChar.sheetValues) targetChar.sheetValues = {};
            targetChar.sheetValues[fk] = rule.fieldValue || '';
            await saveCharacter(targetChar);
        } else {
            let val: any = rule.fieldValue;
            if (val === 'true') val = true;
            else if (val === 'false') val = false;
            (targetChar as any)[fk] = val;
            await saveCharacter(targetChar);
        }
    } else if (rule.targetType === 'resource' && rule.resourceTag) {
        const amount = parseInt(rule.fieldValue || '0', 10);
        if (!isNaN(amount)) await adjustResource(rule.resourceTag, amount);
    }
}

// ── Player Choice Helpers ─────────────────────────────────────────────────────

async function getPlayerChoiceOptions(rule: ActionRule, ent: EntityRecord, cfg: GlobalConfig, resolvedTarget?: EntityRecord | null): Promise<{ label: string; value: string }[]> {
    // Returns the set of valid options for a player-choice set-field rule.
    // Preserved verbatim from AE source.
    if (!rule.fieldKey) return [];
    const fk = rule.fieldKey;
    let opts: { label: string; value: string }[] = [];

    if (rule.targetType === 'entity') {
        let tEnt: EntityRecord | null = null;
        if (rule.targetId === '__self__') { tEnt = ent; }
        else if (rule.targetId === '__target__') { tEnt = resolvedTarget || null; }
        if (!tEnt) return [];

        if (fk === 'state') {
            opts = Object.keys(tEnt.stateDescriptions || {}).map(function(k) { return { label: k, value: k }; });
        } else if (fk === 'storyState') {
            opts = [{ label: '🔒 Locked', value: 'locked' }, { label: '🔥 Active', value: 'active' }, { label: '✅ Completed', value: 'completed' }];
        } else if (fk === 'active' || fk === 'gated' || fk === 'scenePresent') {
            opts = [{ label: 'True', value: 'true' }, { label: 'False', value: 'false' }];
        } else if (fk === 'parentId') {
            opts.push({ label: '🎒 Player Inventory', value: '__protag__' });
            opts.push({ label: '📍 Current Room',     value: '__protag_loc__' });
            opts.push({ label: '🌌 The Void (Root)',  value: '__root__' });
            const allEnts2 = await loadEntityIndex();
            for (const l of allEnts2.filter(function(n) { return n.type === 'location' || n.type === 'character'; })) {
                const icon = l.type === 'character' ? '👤 ' : '🌍 ';
                opts.push({ label: icon + l.name, value: l.id });
            }
        }
    } else if (rule.targetType === 'character') {
        let tChar: CharacterRecord | null = null;
        if (rule.targetId === '__player__' || rule.targetId === '__protag__') {
            const allIdx = await loadIndex(); const pM = allIdx.find(function(m) { return !!m.isProtagonist; });
            if (pM) tChar = await loadCharacter(pM.id);
        } else if (rule.targetId === '__self_char__') {
            const gpcAllC = await loadAllCharacters();
            tChar = gpcAllC.find(function(c) { return c.entityId === ent.id; }) || null;
        } else { tChar = await loadCharacter(rule.targetId || ''); }
        if (!tChar) return [];

        if (fk === 'scenePresent' || fk === 'active') { opts = [{ label: 'True', value: 'true' }, { label: 'False', value: 'false' }]; }
        else if (fk.startsWith('__pfac__')) {
            const pfDef = (cfg.factions || []).find(function(f) { return f.id === fk.replace('__pfac__', ''); });
            if (pfDef) opts = ((pfDef as any).relationshipStates || []).map(function(s: string) { return { label: s, value: s }; });
        } else if (fk.startsWith('__fac__')) {
            const fDef = (cfg.factions || []).find(function(f) { return f.id === fk.replace('__fac__', ''); });
            if (fDef) opts = ((fDef as any).relationshipStates || []).map(function(s: string) { return { label: s, value: s }; });
        } else if (fk.startsWith('__cres__')) {
            const rDef = (tChar.charResourceDefs || []).find(function(r) { return r.id === fk.replace('__cres__', ''); });
            if (rDef && rDef.type === 'track') opts = (rDef.states || []).map(function(s) { return { label: s, value: s }; });
        } else if (fk.startsWith('__equip__')) {
            opts = [{ label: '✓ Equipped', value: 'equipped' }, { label: 'Unequipped', value: 'unequipped' }];
        } else if (fk.includes('.')) {
            const cParts = fk.split('.');
            const cat = (cfg.sheetCategories || []).find(function(c) { return c.id === cParts[0]; });
            if (cat && cat.fieldType === 'enum' && cat.enumValues) opts = cat.enumValues.map(function(v) { return { label: v, value: v }; });
        } else if (fk === 'entityParentId') {
            const pIdx = await loadIndex();
            const pMeta4 = pIdx.find(function(m) { return !!m.isProtagonist; });
            opts.push({ label: '👑 Player (' + (pMeta4 ? pMeta4.name : 'Protagonist') + ')', value: '__protag_entity__' });
            opts.push({ label: '📍 Current Room', value: '__room__' });
            for (const sc of pIdx.filter(function(m) { return m.scenePresent && m.active && !m.isProtagonist && !!m.entityId; })) {
                opts.push({ label: '👤 ' + sc.name, value: sc.entityId! });
            }
        }
    }
    return opts;
}

function getRuleFieldLabel(rule: ActionRule): string {
    const fk = rule.fieldKey || '';
    if (fk === 'state') return 'Atmosphere State';
    if (fk === 'storyState') return 'Story State';
    if (fk === 'parentId' || fk === 'entityParentId') return 'Move To';
    if (fk === 'scenePresent') return 'Scene Present';
    if (fk === 'active') return 'Active';
    if (fk.startsWith('__fac__')) return 'Faction Relationship';
    if (fk.startsWith('__cres__')) return 'Character Resource';
    if (fk.startsWith('__equip__')) return 'Equipment State';
    if (fk.includes('.')) return 'Sheet Field';
    return fk || 'Value';
}

// ── Target Candidate Builder ──────────────────────────────────────────────────

async function buildTargetCandidates(act: EntityAction, sourceEnt: EntityRecord): Promise<EntityRecord[]> {
    // Builds the list of valid target entities for a player_pick action.
    // Characters: scene-present characters' entity nodes.
    // Non-character entities: entities in protagonist's current room.
    // Preserved verbatim from AE source.
    const allNodes = await loadEntityIndex();
    const idx = await loadIndex();
    const protagMeta = idx.find(function(m) { return !!m.isProtagonist; });
    const protag = protagMeta ? await loadCharacter(protagMeta.id) : null;

    const filter = act.targetEntityFilter || [];
    const includeChars   = filter.length === 0 || filter.includes('character');
    const nonCharTypes   = filter.filter(function(t) { return t !== 'character'; });
    const includeNonChar = filter.length === 0 || nonCharTypes.length > 0;

    const candidates: EntityRecord[] = [];
    const addedIds = new Set<string>();

    if (includeChars) {
        const sceneChars = idx.filter(function(m) { return m.scenePresent && m.active && !m.isProtagonist && !!m.entityId; });
        for (const sc of sceneChars) {
            if (addedIds.has(sc.entityId!)) continue;
            const e = await loadEntity(sc.entityId!);
            if (e) { candidates.push(e); addedIds.add(e.id); }
        }
    }

    if (includeNonChar && protag && protag.entityId) {
        const protagBody = await loadEntity(protag.entityId);
        const roomId = protagBody && protagBody.parentId;
        if (roomId) {
            for (const meta of allNodes) {
                if ((meta as any).parentId !== roomId) continue;
                if (meta.id === (protag.entityId || '')) continue;
                if (addedIds.has(meta.id)) continue;
                if (nonCharTypes.length > 0 && !nonCharTypes.includes((meta as any).type || '')) continue;
                const e = await loadEntity(meta.id);
                if (e) { candidates.push(e); addedIds.add(e.id); }
            }
        }
    }

    return candidates;
}

// ── Action Execution with Choices ─────────────────────────────────────────────

// ============================================================================
// NEW ACTION RUNTIME (WP-5) — typed ActionInstance executor + resolution engine
// Consumes the Action Studio shape (cfg.actionTemplates / entity.actionInstances).
// Reuses proven helpers: checkResource / adjustResource / getSkillModifier /
// resolveEntityTokens / loadEntity / loadConfig / openEngineModal. Additive: the
// old EntityAction system stays live until this path is verified, then retired.
// ============================================================================

interface AERule { id: string; type: string; args?: Record<string, any>; invert?: boolean; }

interface AEOutcomeBand { id: string; min: number; max: number; label: string; effects: AERule[]; gmNote?: string; }   // [v0.9.69] succinct GM directive injected on this band

interface AEResolution {
    type?: string;            // 'd20_check' | 'fail_forward_2d6' | 'custom_1d6' | undefined(=auto-success)
    dice?: string;            // explicit dice notation (NdN[+M]); overrides the type's default dice
    useDC?: boolean;
    dc?: number;
    skillTag?: string;        // modifier skill (#combat etc.)
    crit?: boolean;           // enable natural-max / natural-1 crits on single-die DC checks
    bands?: AEOutcomeBand[];  // outcome-range bands (PbtA-style); take precedence over DC
    bonusModifier?: number;   // [vNEXT] flat add-on to the modifier total (e.g. a luck spend)
    args?: Record<string, any>;
}

interface ActionBranch {
    id: string;
    name: string;
    conditions: AERule[];
    resolution?: AEResolution;
    successEffects: AERule[];
    failureEffects?: AERule[];
    alwaysEffects?: AERule[];
}

interface ActionInstance {
    id: string;
    templateId?: string;                  // links instance back to the library template it was copied from
    name: string;
    appliesTo?: string[];                 // entity types this template can attach to ('' / absent = all)
    conditions: AERule[];
    branches?: ActionBranch[];
    resolution?: AEResolution;
    successEffects: AERule[];
    failureEffects?: AERule[];
    hidden?: boolean;
    silent?: boolean;
    oneShot?: boolean;
    outcomeNote?: string;
    targetMode?: 'none' | 'player_pick';
    targetFilter?: string[];              // entity types shown in the target picker
    alwaysEffects?: AERule[];             // fires regardless of resolution outcome
    tags?: string[];                      // library organisation tags (e.g. 'combat', 'magic')
    autoTrigger?: boolean;                // evaluated automatically post-generation when conditions pass
    globalAutoTrigger?: boolean;          // [v0.9.16] auto-trigger fires every turn regardless of player location
}

interface AEResOutcome {
    success: boolean;
    partial: boolean;
    crit: string | null;                  // 'success' | 'fail' | null
    total: number;
    breakdown: string;
    band: AEOutcomeBand | null;
}

interface AEScope {
    sourceEnt: EntityRecord;
    protag: CharacterRecord | null;
    protagEnt: EntityRecord | null;
    target: EntityRecord | null;
    parentEnt: EntityRecord | null;   // [WP-5] source entity's parent location (for __parent__ scope)
    specificEnts?: Record<string, EntityRecord>; // pre-loaded specific entity targets (by ID)
    __silent?: boolean;               // set during auto-trigger runs to suppress user-facing toasts
    __chainDepth?: number;            // [v0.9.16] chain recursion guard; incremented per chain_action, capped at 5
}

// ── Player flavor composition ─────────────────────────────────────────────────
// [v0.9.22 E5] Weaves player flavor text into an action's > prompt.
//   Empty flavor    — base unchanged.
//   Empty base      — flavor with first letter uppercased.
//   Flavor ends .!? — appended as a new sentence (base kept intact).
//   Flavor fragment  — base trailing .!? stripped, comma-joined, period added.
// Player is responsible for second-person phrasing; the bridge field
// placeholder guides them ("e.g. drawing your sword slowly").
function composeActionPrompt(base: string, flavor: string): string {
    let b = base.trim();
    let f = flavor.trim();
    if (!f) return b;
    if (!b) { return f.charAt(0).toUpperCase() + f.slice(1); }
    let flavorComplete = /[.!?]$/.test(f);
    if (flavorComplete) { return b + ' ' + f; }
    let stripped = b.replace(/[.!?]\s*$/, '');
    return stripped + ', ' + f + '.';
}

// ── Token substitution ────────────────────────────────────────────────────────
function aeSubstituteTokens(text: string, scope: AEScope): string {
    if (!text) return '';
    let out = text;
    const actorName = scope.protag ? scope.protag.name : (scope.sourceEnt ? scope.sourceEnt.name : 'You');
    const targetName = scope.target ? scope.target.name : (scope.sourceEnt ? scope.sourceEnt.name : '');
    out = out.replace(/\{Actor\}/g, actorName);
    out = out.replace(/\{Target\}/g, targetName);
    // also honour the legacy __self__ / __target__ tokens via the existing resolver
    out = resolveEntityTokens(out, scope.sourceEnt, scope.target);
    return out;
}

// ── Target record resolution for a rule scope ──────────────────────────────────
function aeResolveTargetRecord(rule: AERule, scope: AEScope): EntityRecord | null {
    const args = rule.args || {};
    const sc = args.scope || '__target__';
    if (sc === '__self__') return scope.sourceEnt;
    if (sc === '__parent__') return scope.parentEnt ? scope.parentEnt : scope.sourceEnt; // [WP-5] true parent location
    if (sc === '__player__') return scope.protagEnt;
    if (sc === '__target__') return scope.target ? scope.target : scope.sourceEnt;
    return scope.target ? scope.target : scope.sourceEnt;
}

// ── Resolution roller ──────────────────────────────────────────────────────────
// Returns success/partial/crit/total/breakdown/band. Uses api.v1.random.roll(),
// reading the documented object return ({ total, rolls:[{dice}], breakdown }).
async function aeRollResolution(res: AEResolution | undefined, cfg: GlobalConfig, protag: CharacterRecord | null): Promise<AEResOutcome> {
    let dice = '';
    let useDC = false;
    let dc: number | undefined = undefined;
    let isPbta = false;

    if (!res || (!res.type && !res.dice)) {
        return { success: true, partial: false, crit: null, total: 0, breakdown: 'auto-success', band: null };
    }

    if (res.dice) {
        dice = res.dice;
        useDC = !!res.useDC;
        dc = typeof res.dc === 'number' ? res.dc : undefined;
    } else if (res.type === 'd20_check') {
        dice = '1d20'; useDC = true; dc = typeof res.dc === 'number' ? res.dc : (Number((cfg as any).defaultDC) || 10);
    } else if (res.type === 'fail_forward_2d6') {
        dice = '2d6'; isPbta = true;
    } else if (res.type === 'custom_1d6') {
        dice = '1d6'; useDC = true; dc = typeof res.dc === 'number' ? res.dc : (Number((cfg as any).defaultDC) || 4);
    } else {
        dice = '1d20'; useDC = true; dc = typeof res.dc === 'number' ? res.dc : (Number((cfg as any).defaultDC) || 10);
    }

    let mod = 0;
    let modStr = '';
    if (res.skillTag && protag) {
        const mr = await getSkillModifier(protag, res.skillTag, cfg);
        mod = mr.total;
    }
    if (typeof res.bonusModifier === 'number' && res.bonusModifier) mod += res.bonusModifier;
    if (mod !== 0) modStr = (mod >= 0 ? ' +' : ' ') + mod;

    const rolled = api.v1.random.roll(dice);
    const total = rolled.total + mod;

    // Outcome bands take precedence. A specific roll (e.g. a single-value band where
    // min===max===20) only does something special if the author defined a band for it.
    // First matching band wins, so authors should order narrow/specific bands first.
    if (res.bands && res.bands.length) {
        let band: AEOutcomeBand | null = null;
        for (const b of res.bands) {
            if (total >= b.min && total <= b.max) { band = b; break; }
        }
        const bandSuccess = band ? !/fail/i.test(band.label) : false;
        const bandStr = dice + modStr + ' = ' + total + (band ? ' \u2192 ' + band.label : '');
        return { success: bandSuccess, partial: band ? /partial/i.test(band.label) : false, crit: null, total: total, breakdown: bandStr, band: band };
    }

    if (isPbta) {
        const pbtaSuccess = total >= 7;
        const label = total >= 10 ? ' (Strong Hit)' : (total >= 7 ? ' (Partial)' : ' (Miss)');
        return { success: pbtaSuccess, partial: total >= 7 && total <= 9, crit: null, total: total, breakdown: '2d6' + modStr + ' = ' + total + label, band: null };
    }

    if (useDC && typeof dc === 'number') {
        const dcSuccess = total >= dc;
        return { success: dcSuccess, partial: false, crit: null, total: total, breakdown: dice + modStr + ' = ' + total + ' vs DC ' + dc, band: null };
    }

    // Roll with no DC and no bands → any roll succeeds
    return { success: true, partial: false, crit: null, total: total, breakdown: dice + modStr + ' = ' + total, band: null };
}

// ── Default Stakes resolution template ──────────────────────────────────────────
// [vNEXT] Builds the effect rules for one side (player/target) of one band of a
// StakeDef. A blank tag or zero amount means "no effect" for that slot. Sign of
// amount determines add (gain) vs subtract (cost).
function aeStakeSideEffects(side: StakeBandSide | undefined, scope: string, hasTarget: boolean): AERule[] {
    if (!side || !side.tag || !side.amount) return [];
    if (scope === '__target__' && !hasTarget) return [];
    const amt = Math.abs(side.amount);
    const op = side.amount > 0 ? 'add' : 'subtract';
    // [v0.9.8.4] Route faction standing changes to the party-level effect.
    // Faction standings are party-wide, so __target__ scope is a no-op.
    if (side.type === 'faction') {
        if (scope !== '__player__') return [];
        return [{ id: generateId(), type: 'modify_faction_standing', args: { factionId: side.tag, op: op, amount: amt } }];
    }
    // [v0.9.8.5] Relationship stage: advances/retreats the target character's
    // primaryRelationship stage index. Only meaningful for __target__ scope;
    // player's relationship stage could also be affected but is uncommon.
    if (side.type === 'rel_stage') {
        return [{ id: generateId(), type: 'modify_rel_stage', args: { scope: scope, op: op, amount: amt } }];
    }
    return [{ id: generateId(), type: 'modify_char_resource', args: { scope: scope, tag: side.tag, op: op, amount: amt } }];
}

// [PATCH] aeBindStakeDef now preserves any custom effects a template author adds
// to a band (chain_action, inject_message, pop_up, kill_char, etc). Only the
// literal '#stake' placeholder effect(s) get substituted, in place, with the
// properly-bound resource effect for the chosen StakeDef + side. Order is
// preserved so an author can put a finishing chain_action AFTER the stake
// spend and have it see the already-updated resource value.
function aeBindStakeDef(tpl: ActionInstance | null, stakeDef: StakeDef | null, skillTag: string, hasTarget: boolean): AEResolution {
    const shellBands: { id: string; min: number; max: number; label: string; gmNote?: string; effects: AERule[] }[] =
        (tpl && tpl.resolution && tpl.resolution.bands && tpl.resolution.bands.length)
            ? tpl.resolution.bands.map(function(b) {
                return { id: b.id, min: b.min, max: b.max, label: b.label, gmNote: (b as any).gmNote, effects: (((b as any).effects || []) as AERule[]) };
              })
            : [
                { id: 'band_miss',    min: -999, max: 6,   label: 'Failure',         effects: [] },
                { id: 'band_partial', min: 7,    max: 9,   label: 'Partial Success', effects: [] },
                { id: 'band_strong',  min: 10,   max: 999, label: 'Strong Hit',      effects: [] }
              ];

    const outBands: AEOutcomeBand[] = shellBands.map(function(b) {
        let slot: StakeBand | undefined = undefined;
        if (stakeDef) {
            if (/partial/i.test(b.label)) slot = stakeDef.partial;
            else if (/fail/i.test(b.label)) slot = stakeDef.miss;
            else slot = stakeDef.strong;
        }

        const playerFx: AERule[] = slot ? aeStakeSideEffects(slot.player, '__player__', hasTarget) : [];
        const targetFx: AERule[] = slot ? aeStakeSideEffects(slot.target, '__target__', hasTarget) : [];
        let playerConsumed = false;
        let targetConsumed = false;

        const fx: AERule[] = [];
        try {
            (b.effects || []).forEach(function(e) {
                const isStakePlaceholder = e && e.type === 'modify_char_resource' && e.args && e.args.tag === '#stake';
                if (!isStakePlaceholder) { fx.push(e); return; }
                const sc = e.args && e.args.scope;
                if (sc === '__player__' && !playerConsumed) { fx.push.apply(fx, playerFx); playerConsumed = true; }
                else if (sc === '__target__' && !targetConsumed) { fx.push.apply(fx, targetFx); targetConsumed = true; }
                // duplicate/extra placeholder for a side already consumed — drop it,
                // don't double-apply the stake spend
            });
        } catch (eBind) {
            api.v1.log('[AE:stakes] aeBindStakeDef effect merge error:', eBind);
        }
        // Safety net — a StakeDef side with no matching placeholder in the template
        // still needs to resolve, so append anything unconsumed.
        if (!playerConsumed) fx.push.apply(fx, playerFx);
        if (!targetConsumed) fx.push.apply(fx, targetFx);

        return { id: generateId(), min: b.min, max: b.max, label: b.label, gmNote: b.gmNote, effects: fx };
    });

    return { type: 'fail_forward_2d6', skillTag: skillTag, bands: outBands };
}

// Lightweight gate: relationship-stage toasts suppressed during auto-trigger runs.
function isSilentScope(scope: AEScope): boolean {
    return !!(scope && (scope as any).__silent);
}

// Resolve a comparison value to a numeric index for a track/discrete/pool resource.
// Accepts a number (index) or a state name (matched case-insensitively against states[]).
// Returns NaN if a name was given that doesn't match any state.
function aeResolveResourceCompareValue(raw: any, states: string[] | undefined): number {
    let s = String(raw === undefined || raw === null ? '' : raw).trim();
    if (s === '') return NaN;
    let asNum = Number(s);
    if (!isNaN(asNum)) return asNum;
    if (states && states.length) {
        let idx = states.findIndex(function(st) { return String(st).toLowerCase() === s.toLowerCase(); });
        if (idx >= 0) return idx;
    }
    return NaN;
}

// [UNIFY] Resolve a character's current skill value to an integer, treating an
// enum field as a ladder (index into the category's enumValues) and a number
// field as its raw value. fieldRef is 'catId.fieldId'. Mirrors how a track
// resource resolves: name → index, number → value. Returns NaN if unreadable.
function aeResolveSkillValue(char: CharacterRecord, fieldRef: string, cfg: GlobalConfig): number {
    if (!char || !fieldRef) return NaN;
    let parts = String(fieldRef).split('.');
    let cat = (cfg.sheetCategories || []).find(function(cc) { return cc.id === parts[0]; });
    if (!cat) return NaN;
    let sv = char.sheetValues || {};
    let raw = (sv[fieldRef] !== undefined) ? sv[fieldRef]
            : (sv[parts[0] + '_' + parts[1]] !== undefined) ? sv[parts[0] + '_' + parts[1]]
            : (sv[parts[1]] !== undefined ? sv[parts[1]] : '');
    if (cat.fieldType === 'enum') return aeResolveResourceCompareValue(raw, cat.enumValues);
    let n = Number(String(raw).trim());
    return isNaN(n) ? 0 : n; // numeric attribute: blank = 0 (untrained baseline)
}

// [UNIFY] Write an integer skill value back. Enum → store the ladder label at that
// index (clamped); number → store the integer as a string (the numberInput editor
// reads numeric strings). Keeps the legacy underscore + bare-id keys in sync the
// same way set_char_sheet does.
function aeWriteSkillValue(char: CharacterRecord, fieldRef: string, value: number, cfg: GlobalConfig): void {
    let parts = String(fieldRef).split('.');
    let cat = (cfg.sheetCategories || []).find(function(cc) { return cc.id === parts[0]; });
    if (!cat) return;
    if (!char.sheetValues) char.sheetValues = {};
    let out: string;
    if (cat.fieldType === 'enum') {
        let mx = Math.max(0, (cat.enumValues || []).length - 1);
        let idx = Math.max(0, Math.min(mx, Math.round(value)));
        out = (cat.enumValues || [])[idx] || '';
    } else {
        out = String(Math.round(value));
    }
    char.sheetValues[fieldRef] = out;
    char.sheetValues[parts[0] + '_' + parts[1]] = out;
    char.sheetValues[parts[1]] = out;
}

// ── Numeric comparison for resource conditions ─────────────────────────────────
function aeCompare(x: number, op: string, y: number): boolean {
    if (op === '<=') return x <= y;
    if (op === '>') return x > y;
    if (op === '<') return x < y;
    if (op === '==') return x === y;
    return x >= y; // default '>='
}

// ── Resolve a scope token to an EntityRecord already in scope ───────────────────
function aeEntForToken(token: string, scope: AEScope): EntityRecord | null {
    if (token === '__self__') return scope.sourceEnt;
    if (token === '__player__') return scope.protagEnt;
    if (token === '__parent__') return scope.parentEnt ? scope.parentEnt : scope.sourceEnt;
    if (token === '__target__') return scope.target ? scope.target : scope.sourceEnt;
    // Specific entity — pre-loaded into scope.specificEnts by preloadSpecificEnts()
    if (scope.specificEnts && scope.specificEnts[token]) return scope.specificEnts[token];
    return scope.target ? scope.target : scope.sourceEnt;
}

// ── Pre-load specific entity targets referenced by raw ID in rule args ──────────
// Called once per runActionInstance before effect evaluation. Populates scope.specificEnts
// so aeEntForToken can resolve author-specified entity IDs without being async.
async function preloadSpecificEnts(inst: ActionInstance, scope: AEScope): Promise<void> {
    let knownTokens = new Set(['__self__', '__player__', '__target__', '__parent__', '']);
    let bandEffects: AERule[] = [];
    let allResolutions = [inst.resolution];
    if (inst.branches) { inst.branches.forEach((b:any) => allResolutions.push(b.resolution)); }
    
    for (const res of allResolutions) {
        if (res && res.bands) {
            for (const b of res.bands) { for (const r of (b.effects || [])) bandEffects.push(r); }
        }
    }

    let allRules: AERule[] = [
        ...(inst.conditions || []),
        ...(inst.successEffects || []),
        ...(inst.failureEffects || []),
        ...((inst as any).alwaysEffects || []),
        ...bandEffects
    ];
    if (inst.branches) {
        for (const br of inst.branches) {
            allRules.push(...(br.conditions || []));
            allRules.push(...(br.successEffects || []));
            allRules.push(...(br.failureEffects || []));
            allRules.push(...(br.alwaysEffects || []));
        }
    }
    
    let idsToLoad = new Set<string>();
    for (const rule of allRules) {
        let ra = rule.args || {};
        for (const key of ['scope', 'itemScope', 'charScope']) {
            let rv = String(ra[key] || '');
            if (rv && !knownTokens.has(rv)) idsToLoad.add(rv);
        }
    }
    if (!idsToLoad.size) return;
    if (!scope.specificEnts) scope.specificEnts = {};
    for (const sid of Array.from(idsToLoad)) {
        try { let se = await loadEntity(sid); if (se) scope.specificEnts[sid] = se; } catch (_e: any) {}
    }
}

// ── Resolve a scope token to the CharacterRecord behind an entity ───────────────
async function aeCharForToken(token: string, scope: AEScope): Promise<CharacterRecord | null> {
    if (token === '__player__') return scope.protag;
    let ent = aeEntForToken(token, scope);
    if (!ent) return null;
    let allC = await loadAllCharacters();
    let found = allC.find(function(c) { return c.entityId === ent.id; });
    return found ? found : null;
}

// ── Equip / unequip an item to a character (entity + char + lorebook in sync) ───
async function aeSetEquip(itemEnt: EntityRecord | null, charRec: CharacterRecord | null, equip: boolean): Promise<void> {
    if (!itemEnt) return;
    let freshItem = await loadEntity(itemEnt.id);
    if (!freshItem) return;
    freshItem.isEquipped = equip;
    freshItem.equippedToCharId = (equip && charRec) ? charRec.id : undefined;
    await saveEntity(freshItem);
    if (charRec) {
        let freshChar = await loadCharacter(charRec.id);
        if (freshChar) {
            if (!freshChar.equippedItemIds) freshChar.equippedItemIds = [];
            if (equip) { if (freshChar.equippedItemIds.indexOf(freshItem.id) < 0) freshChar.equippedItemIds.push(freshItem.id); }
            else { freshChar.equippedItemIds = freshChar.equippedItemIds.filter(function(id) { return id !== freshItem.id; }); }
            await saveCharacter(freshChar);
            // [v0.9.8.5] No lorebook re-sync — equipment now rides an ephemeral temp entry.
        }
    }
}

// ── Runtime player-prompted field choice (the '__ask__' sentinel) ───────────────
// [PATCH v0999] Central switch for every runtime, in-fiction prompt/popup an action
// can trigger (pop_up, ask_text, __ask__ field-choice, player-pick target). 'bridge'
// and 'both' both have the bridge script mounted and listening for these broadcasts;
// 'native' does not, so a bridge-only broadcast either vanishes silently (pop_up,
// fire-and-forget) or hangs the ENTIRE effects pipeline forever (ask_text/__ask__/
// target-pick, which block on a bridge reply that will never arrive). Every runtime
// prompt below must branch on this instead of assuming the bridge is listening.
function aeUsesBridgePrompts(cfg: GlobalConfig): boolean {
    let mode = (cfg as any).interfaceMode || 'native';
    return mode === 'bridge' || mode === 'both';
}

// [PATCH v0999] Native fallback for a blocking button-list prompt — mirrors the
// bridge's AE_ASK_REQUEST / AE_TARGET_PICKER_REQUEST roundtrip as a real modal.
// Resolves null on Cancel AND on any other modal dismissal (X, escape, tap-away)
// via handle.closed, so the effects pipeline can never hang on a modal the player
// simply closed some other way.
async function aeNativeBlockingPicker(title: string, items: { id: string; label: string }[], cancelLabel: string = 'Cancel'): Promise<string | null> {
    return await new Promise<string | null>(async function(resolve) {
        let resolved = false;
        let handle: any = null;
        const done = function(val: string | null) { if (resolved) return; resolved = true; resolve(val); };
        const content: UIPart[] = items.map(function(it) {
            return { type: 'button', text: it.label, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() { if (handle) await handle.close(); done(it.id); } } as UIPart;
        });
        if (!content.length) content.push({ type: 'text', text: 'No options available.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } } as UIPart);
        content.push({ type: 'button', text: cancelLabel, style: { width: '100%', marginTop: '4px', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.15)' }, callback: async function() { if (handle) await handle.close(); done(null); } } as UIPart);
        handle = await openEngineModal({ title: title, size: 'small', content: content });
        if (handle && handle.closed) handle.closed.then(function() { done(null); });
    });
}

// [PATCH v0999] Native fallback for the "How do you do it?" free-text prompt
// (ask_text effect). Same close-always-resolves safety net as above.
async function aeNativeTextPrompt(title: string, instructions: string, placeholder: string): Promise<string | null> {
    return await new Promise<string | null>(async function(resolve) {
        let resolved = false;
        let handle: any = null;
        let draft = '';
        const done = function(val: string | null) { if (resolved) return; resolved = true; resolve(val); };
        const content: UIPart[] = [];
        if (instructions) content.push({ type: 'text', text: instructions, style: { fontSize: '11px', opacity: '0.75', marginBottom: '8px' } } as UIPart);
        content.push({ type: 'multilineTextInput', placeholder: placeholder, initialValue: '', style: { minHeight: '60px' }, onChange: async function(v: string) { draft = v; } } as UIPart);
        content.push({ type: 'row', style: { gap: '6px', marginTop: '8px' }, content: [
            { type: 'button', text: 'Submit', style: { flex: '1 1 0', margin: 0 }, callback: async function() { if (handle) await handle.close(); done(draft); } },
            { type: 'button', text: 'Cancel', style: { flex: '1 1 0', margin: 0, backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.15)' }, callback: async function() { if (handle) await handle.close(); done(null); } }
        ] } as UIPart);
        handle = await openEngineModal({ title: title, size: 'medium', content: content });
        if (handle && handle.closed) handle.closed.then(function() { done(null); });
    });
}

// [PATCH v0999] Native fallback for the pop_up effect. Fire-and-forget like the
// bridge path — callers don't await this, they just don't block the pipeline on it.
async function aeNativePopup(title: string, text: string): Promise<void> {
    let handle: any = null;
    handle = await openEngineModal({ title: title, size: 'small', content: [
        { type: 'text', text: text, markdown: true, style: { marginBottom: '10px', whiteSpace: 'pre-wrap' } },
        { type: 'button', text: 'OK', style: { width: '100%' }, callback: async function() { if (handle) await handle.close(); } }
    ] });
}

async function aePromptFieldChoice(optionsSource: string, scope: AEScope, cfg: GlobalConfig, label: string, ctx?: any): Promise<string | null> {
    let opts: { label: string; value: string }[] = [];
    if (optionsSource === 'storyState') {
        opts = [{ label: '\ud83d\udd12 Locked', value: 'locked' }, { label: '\ud83d\udd25 Active', value: 'active' }, { label: '\u2705 Completed', value: 'completed' }];
    } else if (optionsSource === 'bool') {
        opts = [{ label: 'True', value: 'true' }, { label: 'False', value: 'false' }];
    } else if (optionsSource === 'entityState') {
        let e = (ctx && ctx.ent) ? ctx.ent : null;
        if (e && e.stateDescriptions) opts = Object.keys(e.stateDescriptions).map(function(k) { return { label: k, value: k }; });
    } else if (optionsSource === 'factionState') {
        let fid = (ctx && ctx.factionId) ? ctx.factionId : '';
        let fdef = (cfg.factions || []).find(function(f) { return f.id === fid; });
        if (fdef) { let _afn = (fdef.relationshipStates || []).length; opts = (fdef.relationshipStates || []).map(function(s, i) { return { label: i + ' \u2014 ' + s + ' (of ' + (_afn - 1) + ')', value: String(i) }; }); }
    } else if (optionsSource === 'locationParent') {
        let li = await loadEntityIndex();
        opts.push({ label: '\ud83c\udf92 Player Inventory', value: '__player__' });
        opts.push({ label: '\ud83d\udccd Current Room', value: '__current_room__' });
        opts.push({ label: '\ud83c\udf0c Root (Void)', value: '__root__' });
        li.filter(function(n) { return n.type === 'location' || n.type === 'character'; }).forEach(function(l) { opts.push({ label: (l.type === 'character' ? '\ud83d\udc64 ' : '\ud83c\udf0d ') + l.name, value: l.id }); });
    } else if (optionsSource === 'resourceState') {
        let rtagP = (ctx && ctx.tag) ? ctx.tag : '';
        let rdefP = (cfg.resources || []).find(function(r) { return r.tag === rtagP; });
        if (rdefP && rdefP.states) { let _nP = (rdefP.states || []).length; opts = (rdefP.states || []).map(function(s: string, i: number) { return { label: i + ' \u2014 ' + s + ' (of ' + (_nP - 1) + ')', value: String(i) }; }); } // [UNIFY] index-first label
    }
    if (!opts.length) return null;
    // [PATCH v0999] Native mode: no bridge listening, so use a real modal instead
    // of a broadcast that would never get a reply (permanent pipeline hang).
    if (!aeUsesBridgePrompts(cfg)) {
        return await aeNativeBlockingPicker(label || 'Choose', opts.map(function(o) { return { id: o.value, label: o.label }; }));
    }
    // [v0.9.23 X2] Bridge picker roundtrip: store resolve by promptId,
    // broadcast AE_ASK_REQUEST, await AE_ASK_RESPONSE to unblock.
    let askId = 'ask_' + (++_bridgeReqSeq);
    return await new Promise(function(resolve) {
        _pendingBridgeResolves[askId] = function(val: any) { resolve(val !== undefined ? String(val) : null); };
        broadcastToTM('AE_ASK_REQUEST', { promptId: askId, label: label || 'Choose', options: opts }).catch(function() {});
    });
}

// [v0.9.26 ACT1] Runtime free-text prompt — the "How do you do it?" outcome.
// Blocks the effects pipeline, shows a HUD modal with dev-authored instructions and
// a second-person helper placeholder, returns the player's typed text (or null if
// cancelled). Mirrors aePromptFieldChoice's bridge roundtrip pattern.
async function aePromptText(cfg: GlobalConfig, title: string, instructions: string, placeholder: string): Promise<string | null> {
    // [PATCH v0999] Native mode has no bridge listening — use a real modal instead
    // of a broadcast whose reply will never arrive (permanent pipeline hang).
    if (!aeUsesBridgePrompts(cfg)) {
        return await aeNativeTextPrompt(title || 'How do you do it?', instructions || '', placeholder || 'Describe how you do it\u2026');
    }
    let ptId = 'asktext_' + (++_bridgeReqSeq);
    return await new Promise(function(resolve) {
        _pendingBridgeResolves[ptId] = function(val: any) { resolve((val !== undefined && val !== null) ? String(val) : null); };
        broadcastToTM('AE_ASK_TEXT_REQUEST', {
            promptId: ptId,
            title: title || 'How do you do it?',
            instructions: instructions || '',
            placeholder: placeholder || 'Describe how you do it…'
        }).catch(function() {});
    });
}

// ── Condition evaluation ────────────────────────────────────────────────────────
async function aeCheckConditions(conds: AERule[], scope: AEScope): Promise<boolean> {
    let cfgC = await loadConfig();
    let _clk: ClockState | undefined;   // [v0.9.9.2] loaded lazily only when a time condition is evaluated
    for (const c of (conds || [])) {
        let cPass = await (async function() {
            const a = c.args || {};
            const t = c.type;
            if (t === 'has_resource') {
                const okR = await checkResource(String(a.tag || ''), Number(a.minAmount) || 0);
                if (!okR) return false;
            } else if (t === 'field_equals') {
                const recF = aeResolveTargetRecord(c, scope);
                const haveF = recF ? String((recF as any)[a.field]) : undefined;
                if (haveF !== String(a.value)) return false;
            } else if (t === 'entity_state') {
                const eS = aeEntForToken(String(a.scope || '__self__'), scope);
                if (!eS || String(eS.state || '') !== String(a.state || '')) return false;
            } else if (t === 'entity_story_state') {
                const eSS = aeEntForToken(String(a.scope || '__self__'), scope);
                if (!eSS || String(eSS.storyState || '') !== String(a.value || '')) return false;
            } else if (t === 'entity_locked') {
                const eL = aeEntForToken(String(a.scope || '__self__'), scope);
                if (!eL || (!!eL.gated) !== (String(a.value) === 'true')) return false;
            } else if (t === 'entity_parent') {
                const eP = aeEntForToken(String(a.scope || '__self__'), scope);
                if (!eP) return false;
                // [v0.9.31 COND1] Resolve dynamic parent tokens; mirrors the effect-side resolution
                // so __current_room__ in a condition matches the same room that set_entity_parent uses.
                let epWantId = String(a.parentId || '');
                if (epWantId === '__current_room__') epWantId = (scope.protagEnt && scope.protagEnt.parentId) ? scope.protagEnt.parentId : '';
                else if (epWantId === '__player__') epWantId = scope.protagEnt ? scope.protagEnt.id : '';
                else if (epWantId === '__root__') epWantId = '';
                if (String(eP.parentId || '') !== epWantId) return false;
            } else if (t === 'is_equipped') {
                const eE = aeEntForToken(String(a.scope || '__self__'), scope);
                if (!eE || (!!eE.isEquipped) !== (String(a.value) === 'true')) return false;
            } else if (t === 'in_vehicle') {
                // Passes when the protagonist's body entity is parented to a vehicle entity.
                // Used on travel actions to gate vehicle-only connections.
                if (!scope.protagEnt || !scope.protagEnt.parentId) return false;
                let ivParent = await loadEntity(scope.protagEnt.parentId);
                if (!(ivParent && !!(ivParent as any).isVehicle)) return false;
            } else if (t === 'char_scene_present') {
                const chS = await aeCharForToken(String(a.scope || '__target__'), scope);
                if (!chS || (!!chS.scenePresent) !== (String(a.value) === 'true')) return false;
            } else if (t === 'char_active') {
                const chA = await aeCharForToken(String(a.scope || '__target__'), scope);
                if (!chA || (!!chA.active) !== (String(a.value) === 'true')) return false;
            } else if (t === 'char_faction') {
                const chF = await aeCharForToken(String(a.scope || '__target__'), scope);
                const fdefC = (cfgC.factions || []).find(function(f) { return f.id === String(a.factionId || ''); });
                if (!chF || !fdefC) return false;
                const wantIdx = aeResolveResourceCompareValue(a.state, fdefC.relationshipStates);
                const haveIdx = (chF.charFactionRelationships && chF.charFactionRelationships[fdefC.id] !== undefined) ? chF.charFactionRelationships[fdefC.id] : 0;
                if (isNaN(wantIdx) || haveIdx !== wantIdx) return false;
            } else if (t === 'char_resource') {
                const chR = await aeCharForToken(String(a.scope || '__target__'), scope);
                if (!chR) return false;
                const rdefC = (chR.charResourceDefs || []).find(function(r) { return r.tag === String(a.tag || ''); });
                if (!rdefC) return false;
                const valR = (chR.charResourceValues && chR.charResourceValues[rdefC.id]) || 0;
                // amount may be a number OR a state name (for track/discrete resources)
                const wantCR = aeResolveResourceCompareValue(a.amount, rdefC.states);
                if (isNaN(wantCR) || !aeCompare(valR, String(a.op || '>='), wantCR)) return false;
            } else if (t === 'player_faction') {
                const partyF = await loadPartyState();
                const pfdef = (cfgC.factions || []).find(function(f) { return f.id === String(a.factionId || ''); });
                if (!pfdef) return false;
                const pwant = aeResolveResourceCompareValue(a.state, pfdef.relationshipStates);
                const phave = (partyF.factionRelationships && partyF.factionRelationships[pfdef.id] !== undefined) ? partyF.factionRelationships[pfdef.id] : 0;
                if (isNaN(pwant) || phave !== pwant) return false;
            } else if (t === 'resource_state') {
                const partyRS = await loadPartyState();
                const rdefRS = (cfgC.resources || []).find(function(r) { return r.tag === String(a.tag || ''); });
                if (!rdefRS) return false;
                const curRS = (partyRS.resourceValues && partyRS.resourceValues[rdefRS.id]) || 0;
                // state may be a numeric index OR a state name
                const wantRS = aeResolveResourceCompareValue(a.state, rdefRS.states);
                if (isNaN(wantRS) || !aeCompare(curRS, String(a.op || '=='), wantRS)) return false;
            } else if (t === 'rel_archetype') {
                const chRA = await aeCharForToken(String(a.scope || '__target__'), scope);
                if (!chRA || !chRA.primaryRelationship) return false;
                const defRA = findArchetypeDef(cfgC, chRA.primaryRelationship);
                if (!defRA || defRA.id !== String(a.archetypeId || '')) return false;
            } else if (t === 'rel_stage') {
                const chRSt = await aeCharForToken(String(a.scope || '__target__'), scope);
                if (!chRSt || !chRSt.primaryRelationship) return false;
                const curStage = (typeof chRSt.primaryRelationship.stageIndex === 'number') ? chRSt.primaryRelationship.stageIndex : 0;
                if (!aeCompare(curStage, String(a.op || '=='), Number(a.amount) || 0)) return false;
            } else if (t === 'char_skill') {
                const chSk = await aeCharForToken(String(a.scope || '__target__'), scope);
                if (!chSk) return false;
                const skParts = String(a.fieldRef || '').split('.');
                const skCat = (cfgC.sheetCategories || []).find(function(cc) { return cc.id === skParts[0]; });
                const haveSk = aeResolveSkillValue(chSk, String(a.fieldRef || ''), cfgC);
                const wantSk = aeResolveResourceCompareValue(a.amount, skCat ? skCat.enumValues : undefined);
                if (isNaN(haveSk) || isNaN(wantSk) || !aeCompare(haveSk, String(a.op || '>='), wantSk)) return false;
            } else if (t === 'time_between') {
                if (!_clk) _clk = await loadClock(cfgC);
                let tbH = clockHourOfDay(_clk.hours);
                let tbS = ((Math.floor(Number(a.startHour) || 0)) % 24 + 24) % 24;
                let tbE = ((Math.floor(Number(a.endHour) || 0)) % 24 + 24) % 24;
                let tbIn = (tbS <= tbE) ? (tbH >= tbS && tbH < tbE) : (tbH >= tbS || tbH < tbE);
                if (!tbIn) return false;
            } else if (t === 'time_band_is') {
                if (!_clk) _clk = await loadClock(cfgC);
                if (clockBandFor(clockHourOfDay(_clk.hours), cfgC.timeBands || []) !== String(a.band || '')) return false;
            } else if (t === 'day_of_cycle_is') {
                if (!_clk) _clk = await loadClock(cfgC);
                if (!aeCompare(clockDayOfCycle(_clk.hours), String(a.op || '=='), Number(a.day) || 0)) return false;
            } else if (t === 'day_of_week_is') {
                if (!_clk) _clk = await loadClock(cfgC);
                if (clockDayOfWeek(_clk.hours) !== (Number(a.dayOfWeek) || 0)) return false;
            } else if (t === 'date_is') {
                if (!_clk) _clk = await loadClock(cfgC);
                if (!aeCompare(clockAbsoluteDay(_clk.hours), String(a.op || '=='), Number(a.day) || 0)) return false;
            } else {
                api.v1.log('[AE:action] unknown condition type (skipped):', t);
            }
            return true;
        })();
        
        // Finalize inversion and checks
        if (c.invert) cPass = !cPass;
        if (!cPass) return false;
    }
    return true;
}

// ── Effect application ──────────────────────────────────────────────────────────
async function aeApplyEffects(effects: AERule[], scope: AEScope, cfg: GlobalConfig): Promise<void> {
    for (const e of (effects || [])) {
        const a = e.args || {};
        const t = e.type;
        if (t === 'modify_resource') {
            let mrOp = String(a.op || 'add');
            let mrAmount = Number(a.amount) || 0;
            if (mrOp === 'subtract') mrAmount = -Math.abs(mrAmount);
            if (mrOp === 'set') {
                let mrCfg = await loadConfig();
                let mrParty = await loadPartyState();
                let mrDef = (mrCfg.resources || []).find(function(r) { return r.tag === String(a.tag || ''); });
                if (mrDef) {
                    if (!mrParty.resourceValues) mrParty.resourceValues = {};
                    let mrNewVal = mrAmount;
                    if (mrDef.type === 'track' || mrDef.type === 'discrete') {
                        let mrMax = (mrDef.states || []).length - 1;
                        mrNewVal = Math.max(0, Math.min(Math.max(0, mrMax), Math.round(mrAmount)));
                    } else if (mrDef.hasBounds) {
                        mrNewVal = Math.max(mrDef.min || 0, Math.min(mrDef.max !== undefined ? mrDef.max : 9999, mrAmount));
                    }
                    mrParty.resourceValues[mrDef.id] = mrNewVal;
                    await savePartyState(mrParty);
                    api.v1.ui.toast('Set ' + mrDef.name + ' → ' + mrNewVal, { type: 'info', autoClose: 2000 });
                    queueSceneStateBroadcast();
                } else {
                    // [v0.9.63] Not a global — set on the protagonist's personal resource.
                    let mrPid = await getProtagonistId();
                    let mrPch = mrPid ? await loadCharacter(mrPid) : null;
                    let mrPdef = mrPch ? (mrPch.charResourceDefs || []).find(function(r) { return r.tag === String(a.tag || ''); }) : null;
                    if (mrPch && mrPdef) {
                        if (!mrPch.charResourceValues) mrPch.charResourceValues = {};
                        let mrPVal = mrAmount;
                        if (mrPdef.type === 'track' || mrPdef.type === 'discrete') {
                            let mrPMax = (mrPdef.states || []).length - 1;
                            mrPVal = Math.max(0, Math.min(Math.max(0, mrPMax), Math.round(mrAmount)));
                        } else if (mrPdef.hasBounds) {
                            mrPVal = Math.max(mrPdef.min || 0, Math.min(mrPdef.max !== undefined ? mrPdef.max : 9999, mrAmount));
                        }
                        mrPch.charResourceValues[mrPdef.id] = mrPVal;
                        await saveCharacter(mrPch);
                        api.v1.ui.toast('Set ' + mrPdef.name + ' → ' + mrPVal, { type: 'info', autoClose: 2000 });
                    }
                }
            } else {
                await adjustResource(String(a.tag || ''), mrAmount);
            }
        } else if (t === 'advance_time') {
            // [v0.9.9.2] Relative time cost. Whole hours added to the world clock.
            let atHrs = Math.floor(Number(a.hours) || 0);
            if (atHrs !== 0) {
                let atClk = await loadClock(cfg);
                atClk.hours = Math.max(0, atClk.hours + atHrs);
                await saveClock(atClk);
                if (!isSilentScope(scope)) api.v1.ui.toast(clockFormatStamp(atClk.hours, cfg), { type: 'info', autoClose: 2000 });
                queueSceneStateBroadcast();
            }
        } else if (t === 'set_time') {
            // [v0.9.9.2] Jump FORWARD to the next occurrence of an hour-of-day; never
            // rewinds (so countdowns/order stay intact). Already at the hour = no-op.
            let stTarget = ((Math.floor(Number(a.hour) || 0)) % 24 + 24) % 24;
            let stClk = await loadClock(cfg);
            let stDelta = (stTarget - clockHourOfDay(stClk.hours) + 24) % 24;
            if (stDelta > 0) {
                stClk.hours = Math.max(0, stClk.hours + stDelta);
                await saveClock(stClk);
                if (!isSilentScope(scope)) api.v1.ui.toast(clockFormatStamp(stClk.hours, cfg), { type: 'info', autoClose: 2000 });
                queueSceneStateBroadcast();
            }
        } else if (t === 'inject_narrative') {
            const txt = aeSubstituteTokens(String(a.text || ''), scope);
            if (txt.trim()) {
                // [v0.9.22 E5] Consume pending player flavor at the first narrative
                // prompt (covers travel and effect-only action paths).
                let nnFlavor = await api.v1.tempStorage.get(STORAGE_PENDING_FLAVOR).catch(function() { return undefined; }) as string | undefined;
                if (nnFlavor && nnFlavor.trim()) {
                    await api.v1.tempStorage.remove(STORAGE_PENDING_FLAVOR).catch(function(_e: any) {});
                    await api.v1.document.appendParagraph({ text: '> ' + composeActionPrompt(txt.trim(), nnFlavor.trim()) });
                } else {
                    await api.v1.document.appendParagraph({ text: '> ' + txt });
                }
                await api.v1.document.appendParagraph({ text: '' });
            }
        } else if (t === 'move_player_to_self') {
            // Travel action movement: commits the protagonist to scope.sourceEnt.
            // In an entry action, sourceEnt IS the destination (action is stored on the destination).
            // Narrative injection must happen BEFORE this effect (inject_narrative fires first).
            if (scope.sourceEnt && scope.sourceEnt.type === 'location') {
                let mvGlobalSilent = await getSilentMode();
                let mvIsSilent = !!(scope as any).__silent || mvGlobalSilent;
                api.v1.log('[AE:TRACE] move_player_to_self dest=' + scope.sourceEnt.name + '(' + scope.sourceEnt.id + ') scopeSilent=' + !!(scope as any).__silent + ' globalSilent=' + mvGlobalSilent + ' -> isSilent=' + mvIsSilent);
                await commitTravel(scope.sourceEnt.id, mvIsSilent);
            }
        } else if (t === 'set_entity_state') {
            const eS = aeEntForToken(String(a.scope || '__self__'), scope);
            if (eS) {
                let valS = String(a.state || '');
                if (valS === '__ask__') { let pS = await aePromptFieldChoice('entityState', scope, cfg, 'Set state', { ent: eS }); if (pS === null) continue; valS = pS; }
                let fresh = await loadEntity(eS.id); if (fresh) { fresh.state = valS; await saveEntity(fresh); }
            }
        } else if (t === 'set_entity_story_state') {
            const eSS = aeEntForToken(String(a.scope || '__self__'), scope);
            if (eSS) {
                let valSS = String(a.value || '');
                if (valSS === '__ask__') { let pSS = await aePromptFieldChoice('storyState', scope, cfg, 'Set story state'); if (pSS === null) continue; valSS = pSS; }
                let fresh2 = await loadEntity(eSS.id); if (fresh2) { (fresh2 as any).storyState = valSS; await saveEntity(fresh2); }
            }
        } else if (t === 'set_entity_locked') {
            const eL = aeEntForToken(String(a.scope || '__self__'), scope);
            if (eL) { let fresh3 = await loadEntity(eL.id); if (fresh3) { fresh3.gated = (String(a.value) === 'true'); await saveEntity(fresh3); } }
        } else if (t === 'set_entity_parent') {
            const eP = aeEntForToken(String(a.scope || '__self__'), scope);
            if (eP) {
                let valP = String(a.parentId || '');
                if (valP === '__ask__') { let pP = await aePromptFieldChoice('locationParent', scope, cfg, 'Move to'); if (pP === null) continue; valP = pP; }
                let resolvedParent: string | null = valP;
                if (valP === '__root__') resolvedParent = null;
                else if (valP === '__current_room__') { resolvedParent = (scope.protagEnt && scope.protagEnt.parentId) ? scope.protagEnt.parentId : null; }
                else if (valP === '__player__') { resolvedParent = scope.protagEnt ? scope.protagEnt.id : null; }
                let fresh4 = await loadEntity(eP.id); if (fresh4) { fresh4.parentId = resolvedParent; await saveEntity(fresh4); await recalculateScenePresence(); }
            }
        } else if (t === 'set_equipped') {
            const itemEnt = aeEntForToken(String(a.itemScope || '__self__'), scope);
            const charRec = await aeCharForToken(String(a.charScope || '__player__'), scope);
            await aeSetEquip(itemEnt, charRec, String(a.mode || 'equip') === 'equip');
        } else if (t === 'set_char_active') {
            // [v0.9.28 ACT3] Switch a character active/inactive (drives index visibility,
            // dynamics eligibility, and dramatis personae). Defaults to active.
            const chSA = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chSA) {
                let fcSA = await loadCharacter(chSA.id);
                if (fcSA) {
                    let wantActive = (a.value === undefined) ? true : (String(a.value) === 'true');
                    fcSA.active = wantActive;
                    await saveCharacter(fcSA);
                    await recalculateScenePresence();
                    if (!isSilentScope(scope)) api.v1.ui.toast((wantActive ? '✅ ' : '⭕ ') + fcSA.name + (wantActive ? ' is now Active' : ' is now Inactive'), { type: 'info', autoClose: 2000 });
                }
            }
        } else if (t === 'set_char_scene') {
            const chS = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chS) { let fc = await loadCharacter(chS.id); if (fc) { fc.scenePresent = (String(a.value) === 'true'); await saveCharacter(fc); await recalculateScenePresence(); } }
        } else if (t === 'set_char_sheet') {
            // [v0.9.28 SHEET1] Set a character sheet field value. fieldRef = 'catId.fieldId'.
            const chSS = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chSS) {
                let fcSS = await loadCharacter(chSS.id);
                if (fcSS) {
                    let fieldRef = String(a.fieldRef || '');
                    let valSS = aeSubstituteTokens(String(a.value || ''), scope);
                    if (fieldRef) {
                        if (!fcSS.sheetValues) fcSS.sheetValues = {};
                        fcSS.sheetValues[fieldRef] = valSS;
                        await saveCharacter(fcSS);
                        if (!isSilentScope(scope)) api.v1.ui.toast('📝 ' + fcSS.name + ' sheet updated', { type: 'info', autoClose: 1800 });
                    }
                }
            }
        } else if (t === 'kill_char') {
            const chK = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chK) await killCharacter(chK.id);
        } else if (t === 'spawn_minor_npc') {
            const smArch = (((cfg as any).npcArchetypes || []) as NpcArchetypeDef[]).find(function(x) { return !!x && x.id === String(a.archetypeId || ''); });
            if (smArch) {
                let smCount = Math.max(1, Math.min(10, Math.floor(Number(a.count) || 1)));
                let smLoc = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
                let smNames: string[] = [];
                for (let smI = 0; smI < smCount; smI++) {
                    let smRes = await spawnMinorNpc('', '', smLoc, smArch, true);
                    if (smRes) smNames.push(smRes.name);
                }
                if (smNames.length > 0 && !isSilentScope(scope)) api.v1.ui.toast('🐾 ' + smNames.join(', ') + (smNames.length === 1 ? ' appears.' : ' appear.'), { type: 'info', autoClose: 2500 });
            }
        } else if (t === 'generate_image') {
            // [vNEXT] Fire an image via the existing snapshot/bridge pipeline. All
            // resolution (macros, cached visuals, scene tags, preset, caption) lives
            // in aeGenerateActionImage so the branch stays a thin call.
            await aeGenerateActionImage(a, scope);
        } else if (t === 'set_char_faction') {
            const chF = await aeCharForToken(String(a.scope || '__target__'), scope);
            const fdefE = (cfg.factions || []).find(function(f) { return f.id === String(a.factionId || ''); });
            if (chF && fdefE) {
                let valF = String(a.state || '');
                if (valF === '__ask__') { let pF = await aePromptFieldChoice('factionState', scope, cfg, 'Set faction standing', { factionId: fdefE.id }); if (pF === null) continue; valF = pF; }
                const sIdx = aeResolveResourceCompareValue(valF, fdefE.relationshipStates);
                if (!isNaN(sIdx)) { let fc2 = await loadCharacter(chF.id); if (fc2) { if (!fc2.charFactionRelationships) fc2.charFactionRelationships = {}; fc2.charFactionRelationships[fdefE.id] = Math.max(0, Math.min((fdefE.relationshipStates || []).length - 1, sIdx)); await saveCharacter(fc2); } }
            }
        } else if (t === 'modify_char_resource') {
            const chR = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chR) {
                let fc3 = await loadCharacter(chR.id);
                if (fc3) {
                    const rdefE = (fc3.charResourceDefs || []).find(function(r) { return r.tag === String(a.tag || ''); });
                    if (rdefE) {
                        if (!fc3.charResourceValues) fc3.charResourceValues = {};
                        let crOp = String(a.op || 'add');
                        let crAmt = Number(a.amount) || 0;
                        if (crOp === 'subtract') crAmt = -Math.abs(crAmt);
                        if (crOp === 'set') {
                            let crMax = (rdefE.type === 'pool') ? (rdefE.hasBounds && rdefE.max !== undefined ? rdefE.max : 9999) : Math.max(0, (rdefE.states || []).length - 1);
                            let crMin = (rdefE.type === 'pool') ? (rdefE.hasBounds && rdefE.min !== undefined ? rdefE.min : 0) : 0;
                            fc3.charResourceValues[rdefE.id] = Math.max(crMin, Math.min(crMax, crAmt));
                        } else {
                            let cur = fc3.charResourceValues[rdefE.id] || 0;
                            cur += crAmt;
                            if (rdefE.type === 'track' || rdefE.type === 'discrete') { let mx = Math.max(0, (rdefE.states || []).length - 1); cur = Math.max(0, Math.min(mx, cur)); }
                            else if (rdefE.hasBounds) { if (rdefE.min !== undefined && cur < rdefE.min) cur = rdefE.min; if (rdefE.max !== undefined && cur > rdefE.max) cur = rdefE.max; }
                            fc3.charResourceValues[rdefE.id] = cur;
                        }
                        await saveCharacter(fc3);
                    }
                }
            }
        } else if (t === 'modify_char_skill') {
            const chSkE = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chSkE) {
                let fcSk = await loadCharacter(chSkE.id);
                if (fcSk) {
                    let skRef = String(a.fieldRef || '');
                    let skParts2 = skRef.split('.');
                    let skCat2 = (cfg.sheetCategories || []).find(function(cc) { return cc.id === skParts2[0]; });
                    if (skCat2 && skRef) {
                        let skOp = String(a.op || 'add');
                        let skAmt = Number(a.amount) || 0;
                        // Range: enum → ladder index bounds; number → wide value bounds.
                        let skMax = (skCat2.fieldType === 'enum') ? Math.max(0, (skCat2.enumValues || []).length - 1) : 9999;
                        let skMin = (skCat2.fieldType === 'enum') ? 0 : -9999;
                        let skNew: number;
                        if (skOp === 'set') {
                            skNew = skAmt;
                        } else {
                            let skCur = aeResolveSkillValue(fcSk, skRef, cfg);
                            if (isNaN(skCur)) skCur = 0;
                            skNew = skCur + (skOp === 'subtract' ? -Math.abs(skAmt) : skAmt);
                        }
                        skNew = Math.max(skMin, Math.min(skMax, skNew));
                        aeWriteSkillValue(fcSk, skRef, skNew, cfg);
                        await saveCharacter(fcSk);
                        if (!isSilentScope(scope)) {
                            let skLbl = (skCat2.fieldType === 'enum') ? ((skCat2.enumValues || [])[skNew] || ('rung ' + skNew)) : String(skNew);
                            api.v1.ui.toast('🎯 ' + fcSk.name + ' ' + (skParts2[1] || 'skill') + ' → ' + skLbl, { type: 'info', autoClose: 1800 });
                        }
                    }
                }
            }
        } else if (t === 'set_player_faction') {
            const partyE = await loadPartyState();
            const pfdefE = (cfg.factions || []).find(function(f) { return f.id === String(a.factionId || ''); });
            if (pfdefE) {
                let valPF = String(a.state || '');
                if (valPF === '__ask__') { let pPF = await aePromptFieldChoice('factionState', scope, cfg, 'Set faction standing', { factionId: pfdefE.id }); if (pPF === null) continue; valPF = pPF; }
                const pIdx = aeResolveResourceCompareValue(valPF, pfdefE.relationshipStates);
                if (!isNaN(pIdx)) { if (!partyE.factionRelationships) partyE.factionRelationships = {}; partyE.factionRelationships[pfdefE.id] = Math.max(0, Math.min((pfdefE.relationshipStates || []).length - 1, pIdx)); await savePartyState(partyE); }
            }
        } else if (t === 'modify_faction_standing') {
            // [v0.9.8.4] Party-level faction standing delta (stake effects & manual edits).
            // args: { factionId: string, op: 'add' | 'subtract', amount: number }
            const fdefMFS = (cfg.factions || []).find(function(f: any) { return f.id === String(a.factionId || ''); });
            if (fdefMFS) {
                const partyMFS = await loadPartyState();
                let curMFS = (partyMFS.factionRelationships && partyMFS.factionRelationships[fdefMFS.id]) || 0;
                let amtMFS = Number(a.amount) || 0;
                if (String(a.op || 'add') === 'subtract') amtMFS = -Math.abs(amtMFS);
                const maxMFS = Math.max(0, (fdefMFS.relationshipStates || []).length - 1);
                const newMFS = Math.max(0, Math.min(maxMFS, Math.round(curMFS + amtMFS)));
                if (!partyMFS.factionRelationships) partyMFS.factionRelationships = {};
                partyMFS.factionRelationships[fdefMFS.id] = newMFS;
                await savePartyState(partyMFS);
                const lblMFS = (fdefMFS.relationshipStates || [])[newMFS] || ('stage ' + newMFS);
                if (!isSilentScope(scope)) api.v1.ui.toast(fdefMFS.name + ' standing: ' + lblMFS, { type: 'info', autoClose: 2000 });
            }
        } else if (t === 'set_rel_archetype') {
            let chSRA = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chSRA) {
                let fSRA = await loadCharacter(chSRA.id);
                if (fSRA && fSRA.primaryRelationship) {
                    let defSRA = (cfg.relationshipArchetypes || []).find(function(d) { return d.id === String(a.archetypeId || ''); });
                    if (defSRA) {
                        fSRA.primaryRelationship.archetypeId = defSRA.id;
                        fSRA.primaryRelationship.archetype   = defSRA.name;
                        // Reset stage to a sensible default unless author asked to preserve it.
                        if (String(a.keepStage || '') !== 'true') fSRA.primaryRelationship.stageIndex = 0;
                        await saveCharacter(fSRA);
                    }
                }
            }
        } else if (t === 'modify_rel_stage') {
            let chMRS = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (chMRS) {
                let fMRS = await loadCharacter(chMRS.id);
                if (fMRS && fMRS.primaryRelationship) {
                    let defMRS = findArchetypeDef(cfg, fMRS.primaryRelationship);
                    let maxStage = (defMRS && defMRS.stages) ? Math.max(0, defMRS.stages.length - 1) : 0;
                    let opMRS = String(a.op || 'add');
                    let amtMRS = Number(a.amount) || 0;
                    let curMRS = (typeof fMRS.primaryRelationship.stageIndex === 'number') ? fMRS.primaryRelationship.stageIndex : 0;
                    let newMRS = curMRS;
                    if (opMRS === 'set') newMRS = amtMRS;
                    else if (opMRS === 'subtract') newMRS = curMRS - Math.abs(amtMRS);
                    else newMRS = curMRS + amtMRS;
                    newMRS = Math.max(0, Math.min(maxStage, Math.round(newMRS)));
                    fMRS.primaryRelationship.stageIndex = newMRS;
                    await saveCharacter(fMRS);
                    if (!isSilentScope(scope)) {
                        let lblMRS = (defMRS && defMRS.stages && defMRS.stages[newMRS]) ? defMRS.stages[newMRS] : ('stage ' + newMRS);
                        api.v1.ui.toast('💞 ' + fMRS.name + ': ' + lblMRS, { type: 'info', autoClose: 2000 });
                    }
                }
            }
        } else if (t === 'set_resource_state') {
            const partySR = await loadPartyState();
            const rdefSR = (cfg.resources || []).find(function(r) { return r.tag === String(a.tag || ''); });
            if (rdefSR) {
                let valStateRaw = String(a.state || '');
                if (valStateRaw === '__ask__') { let pSR = await aePromptFieldChoice('resourceState', scope, cfg, 'Set ' + rdefSR.name, { tag: rdefSR.tag }); if (pSR === null) continue; valStateRaw = pSR; }
                let idxSR = Number(valStateRaw);
                if (!isNaN(idxSR)) {
                    if (rdefSR.type === 'track') { let mxSR = (rdefSR.states || []).length - 1; if (mxSR < 0) mxSR = 0; idxSR = Math.max(0, Math.min(mxSR, idxSR)); }
                    if (!partySR.resourceValues) partySR.resourceValues = {};
                    partySR.resourceValues[rdefSR.id] = idxSR;
                    await savePartyState(partySR);
                    queueSceneStateBroadcast();
                }
            }
        } else if (t === 'add_hook') {
            let ahChar = await aeCharForToken(String(a.scope || '__target__'), scope);
            if (ahChar) {
                let ahFresh = await loadCharacter(ahChar.id);
                if (ahFresh) {
                    let ahHook: UnresolvedHook = {
                        id: api.v1.uuid(),
                        targetName: scope.protag ? scope.protag.name : '',
                        description: aeSubstituteTokens(String(a.description || ''), scope),
                        pressureLevel: Math.max(0, Math.min(100, Number(a.pressure) || 50)),
                        developmentNotes: [],
                        resolved: false
                    };
                    if (!ahFresh.hooks) ahFresh.hooks = [];
                    ahFresh.hooks.push(ahHook);
                    await saveCharacter(ahFresh);
                }
            }
        } else if (t === 'add_modifier') {
            let amChar = await aeCharForToken(String(a.charScope || '__player__'), scope);
            if (amChar) {
                let amList = await api.v1.historyStorage.getOrDefault(STORAGE_ACTIVE_MODIFIERS, []) as ActiveModifier[];
                let amNew: ActiveModifier = {
                    id: generateId(),
                    charId: amChar.id,
                    skillTag: String(a.skillTag || '').replace('#', '').trim().toLowerCase(),
                    delta: Number(a.delta) || 0,
                    sourceLabel: aeSubstituteTokens(String(a.label || 'Modifier'), scope)
                };
                amList.push(amNew);
                await api.v1.historyStorage.set(STORAGE_ACTIVE_MODIFIERS, amList);
            }
        } else if (t === 'remove_modifier') {
            let rmChar = await aeCharForToken(String(a.charScope || '__player__'), scope);
            if (rmChar) {
                let rmTag = String(a.skillTag || '').replace('#', '').trim().toLowerCase();
                let rmList = await api.v1.historyStorage.getOrDefault(STORAGE_ACTIVE_MODIFIERS, []) as ActiveModifier[];
                rmList = rmList.filter(function(m) { return !(m.charId === rmChar.id && m.skillTag === rmTag); });
                await api.v1.historyStorage.set(STORAGE_ACTIVE_MODIFIERS, rmList);
            }
        } else if (t === 'inject_message') {
            let imText = aeSubstituteTokens(String(a.text || ''), scope);
            if (imText.trim()) {
                await api.v1.tempStorage.set(STORAGE_PENDING_INJECT, imText.trim()).catch(function(_e: any) {});
            }
        } else if (t === 'ask_text') {
            // [v0.9.26 ACT1] "How do you do it?" — blocking free-text prompt.
            // Stores the player's reply as pending flavor, composed into the next
            // action prompt by the existing flavor pipeline (STORAGE_PENDING_FLAVOR).
            let atTitle = 'How do you do it?'; // [v0.9.27 ACT2] fixed title
            let atInstr = aeSubstituteTokens(String(a.instructions || ''), scope);
            let atPlace = String(a.placeholder || 'Describe how you do it…');
            let atReply = await aePromptText(cfg, atTitle, atInstr, atPlace);
            if (atReply !== null && atReply.trim()) {
                let atKey = String(a.flavorKey || STORAGE_PENDING_FLAVOR);
                await api.v1.tempStorage.set(atKey, atReply.trim()).catch(function(_e: any) {});
            }
        } else if (t === 'pop_up') {
            let ppTitle = aeSubstituteTokens(String(a.title || 'Message'), scope);
            let ppText  = aeSubstituteTokens(String(a.text  || ''),       scope);
            if (ppText.trim()) {
                // [PATCH v0999] Route by HUD mode: bridge/both -> bridge-rendered
                // popup (matches bridge styling, was already correct); native -> a
                // real modal, since the old bridge-only broadcast simply vanished
                // with nobody listening for it in native mode.
                if (aeUsesBridgePrompts(cfg)) {
                    // [v0.9.23 X2] Bridge renders popup inline; fire-and-forget.
                    // Effects pipeline continues immediately (no await).
                    broadcastToTM('AE_POPUP_SHOW', { title: ppTitle, text: ppText }).catch(function() {});
                } else {
                    aeNativePopup(ppTitle, ppText).catch(function() {});
                }
            }
        } else if (t === 'chain_action') {
            // [v0.9.16] Chain into another action (Library template or a specific
            // entity's instance). Inherits actor/target; always silent; depth-capped.
            let chainId = String(a.actionId || '');
            let chainSrc = String(a.source || '__library__');
            if (chainId) {
                let chainDepth = Number((scope as any).__chainDepth || 0);
                if (chainDepth >= 5) {
                    api.v1.log('[AE:chain] max depth (5) reached, aborting:', chainId);
                } else {
                    let chainCfg = await loadConfig();
                    let chainTpl: ActionInstance | null = null;
                    let chainSourceEnt: EntityRecord = scope.sourceEnt;
                    let chainParentEnt: EntityRecord | null = scope.parentEnt;
                    if (chainSrc === '__library__') {
                        let _ct = ((chainCfg.actionTemplates || []) as ActionInstance[]).find(function(tpl) { return tpl.id === chainId; });
                        chainTpl = _ct ? _ct : null;
                    } else {
                        let chainEnt = await loadEntity(chainSrc).catch(function() { return null; });
                        if (chainEnt) {
                            let _ci = (((chainEnt as any).actionInstances || []) as ActionInstance[]).find(function(inst2) { return inst2.id === chainId; });
                            if (_ci) {
                                chainTpl = _ci;
                                chainSourceEnt = chainEnt;
                                chainParentEnt = chainEnt.parentId ? await loadEntity(chainEnt.parentId).catch(function() { return null; }) : null;
                            }
                        }
                    }
                    if (!chainTpl) {
                        api.v1.log('[AE:chain] action not found:', chainSrc, chainId);
                    } else {
                        let chainOneShotKey = (chainSrc === '__library__') ? ('ae_inst_1shot_chain_' + chainId) : ('ae_inst_1shot_' + chainSourceEnt.id + '_' + chainId);
                        let chainBlocked = false;
                        if (chainTpl.oneShot) {
                            let usedChain = await api.v1.historyStorage.getOrDefault(chainOneShotKey, false) as boolean;
                            if (usedChain) { chainBlocked = true; api.v1.log('[AE:chain] one-shot already fired:', chainTpl.name); }
                        }
                        if (!chainBlocked) {
                            let chainScope: AEScope = {
                                sourceEnt: chainSourceEnt,
                                protag: scope.protag,
                                protagEnt: scope.protagEnt,
                                target: scope.target,
                                parentEnt: chainParentEnt,
                                specificEnts: scope.specificEnts ? Object.assign({}, scope.specificEnts) : undefined,
                                __silent: true,
                                __chainDepth: chainDepth + 1
                            };
                            let chainPass = await aeCheckConditions(chainTpl.conditions || [], chainScope);
                            if (!chainPass) {
                                api.v1.log('[AE:chain] conditions failed, skipping:', chainTpl.name);
                            } else {
                                let chainOutcome = await aeRollResolution(chainTpl.resolution, chainCfg, scope.protag);
                                if (chainTpl.resolution && (chainTpl.resolution.type || chainTpl.resolution.dice)) {
                                    api.v1.ui.toast('⛓ ' + (chainTpl.name || 'Chain') + ': ' + chainOutcome.breakdown + ' → ' + (chainOutcome.success ? 'Success' : 'Failure'), { type: chainOutcome.success ? 'success' : 'warning', autoClose: 2500 });
                                }
                                await preloadSpecificEnts(chainTpl, chainScope);
                                if (chainOutcome.band && chainOutcome.band.effects) {
                                    await aeApplyEffects(chainOutcome.band.effects, chainScope, chainCfg);
                                } else if (chainOutcome.success) {
                                    await aeApplyEffects(chainTpl.successEffects || [], chainScope, chainCfg);
                                } else {
                                    await aeApplyEffects((chainTpl as any).failureEffects || [], chainScope, chainCfg);
                                }
                                await aeApplyEffects((chainTpl as any).alwaysEffects || [], chainScope, chainCfg);
                                if (chainTpl.oneShot) await api.v1.historyStorage.set(chainOneShotKey, true);
                                api.v1.log('[AE:chain] fired:', chainTpl.name, 'depth:', chainDepth + 1);
                            }
                        }
                        // [v0.9.27 CHN1] Library fan-out: fire every entity INSTANCE whose
                        // templateId matches this library template, each against its own
                        // entity. Lets "trigger Template 1" cascade to A's and B's copies
                        // without naming them. Only for __library__ chains; depth-guarded.
                        if (chainSrc === '__library__') {
                            let fanIdx = await loadEntityIndex();
                            for (const fanMeta of fanIdx) {
                                let fanEnt = await loadEntity(fanMeta.id).catch(function() { return null; });
                                if (!fanEnt) continue;
                                let fanInsts = (((fanEnt as any).actionInstances || []) as ActionInstance[]).filter(function(fi) { return fi.templateId === chainId; });
                                if (!fanInsts.length) continue;
                                let fanParent = fanEnt.parentId ? await loadEntity(fanEnt.parentId).catch(function() { return null; }) : null;
                                for (const fanInst of fanInsts) {
                                    let fanOneShotKey = 'ae_inst_1shot_' + fanEnt.id + '_' + fanInst.id;
                                    if (fanInst.oneShot) {
                                        let fanUsed = await api.v1.historyStorage.getOrDefault(fanOneShotKey, false) as boolean;
                                        if (fanUsed) continue;
                                    }
                                    let fanScope: AEScope = {
                                        sourceEnt: fanEnt,
                                        protag: scope.protag,
                                        protagEnt: scope.protagEnt,
                                        target: fanEnt, // instance acts on its own entity
                                        parentEnt: fanParent,
                                        __silent: true,
                                        __chainDepth: chainDepth + 1
                                    };
                                    let fanPass = await aeCheckConditions(fanInst.conditions || [], fanScope);
                                    if (!fanPass) continue;
                                    let fanOutcome = await aeRollResolution(fanInst.resolution, chainCfg, scope.protag);
                                    await preloadSpecificEnts(fanInst, fanScope);
                                    if (fanOutcome.band && fanOutcome.band.effects) await aeApplyEffects(fanOutcome.band.effects, fanScope, chainCfg);
                                    else if (fanOutcome.success) await aeApplyEffects(fanInst.successEffects || [], fanScope, chainCfg);
                                    else await aeApplyEffects((fanInst as any).failureEffects || [], fanScope, chainCfg);
                                    await aeApplyEffects((fanInst as any).alwaysEffects || [], fanScope, chainCfg);
                                    if (fanInst.oneShot) await api.v1.historyStorage.set(fanOneShotKey, true);
                                    api.v1.log('[AE:chain] fan-out fired on', fanEnt.name, ':', fanInst.name);
                                }
                            }
                        }
                    }
                }
            }
        } else {
            api.v1.log('[AE:action] unknown effect type (skipped):', t);
        }
    }
}

// ── Player-pick target via engine modal (resolves to a record or null) ──────────
async function aePickTarget(inst: ActionInstance, sourceEnt: EntityRecord, protagEnt: EntityRecord | null, cfg: GlobalConfig): Promise<EntityRecord | null> {
    // [v0.9.23 X1] Bridge-native target picker via AE_TARGET_PICKER_REQUEST roundtrip.
    // HUD stays visible; bridge renders the candidate list inline.
    const ptIdx = await loadEntityIndex();
    // [FIX] room = the player's CURRENT LOCATION (the entity containing the player
    // body), not the player entity itself.
    let ptRoomId: string | null = (protagEnt && protagEnt.parentId) ? protagEnt.parentId : null;
    if (!ptRoomId) ptRoomId = await loadPlayerLocation();
    if (!ptRoomId && sourceEnt) ptRoomId = sourceEnt.parentId;
    // [v0.9.27 TGT1] Candidate set = current-room siblings PLUS the player's own
    // hierarchy (equipment, party members, anything parented under the player body).
    // This lets actions target your own gear/companions, not only things in the room.
    let ptPlayerId = protagEnt ? protagEnt.id : null;
    let ptCandidates = ptIdx.filter(function(m) {
        if (m.id === sourceEnt.id) return false;
        if (m.parentId === ptRoomId) return true;                 // in the room
        if (ptPlayerId && m.parentId === ptPlayerId) return true; // under the player (gear/party)
        return false;
    });
    const ptFilter = inst.targetFilter || [];
    if (ptFilter.length) ptCandidates = ptCandidates.filter(function(m) { return ptFilter.indexOf(m.type) >= 0; });

    if (!ptCandidates.length) {
        api.v1.ui.toast('No valid targets in scene.', { type: 'info', autoClose: 2000 });
        return null;
    }

    let ptPickedId: string | null;
    // [PATCH v0999] Native mode: no bridge listening, so use a real modal instead
    // of a broadcast whose reply will never arrive (permanent pipeline hang).
    if (!aeUsesBridgePrompts(cfg)) {
        ptPickedId = await aeNativeBlockingPicker('Choose a Target', ptCandidates.map(function(m) {
            return { id: m.id, label: aeIconPfx(m.icon) + m.name + ' (' + m.type + ')' };
        }));
    } else {
        let ptPromptId = 'target_' + (++_bridgeReqSeq);
        ptPickedId = await new Promise(function(resolve) {
            _pendingBridgeResolves[ptPromptId] = function(id: any) { resolve(id || null); };
            broadcastToTM('AE_TARGET_PICKER_REQUEST', {
                promptId: ptPromptId,
                candidates: ptCandidates.map(function(m) { return { id: m.id, name: m.name, icon: m.icon || '', type: m.type }; })
            }).catch(function() {});
        });
    }
    if (!ptPickedId) return null;
    return await loadEntity(ptPickedId).catch(function() { return null; });
}

// [v1.6.3 ROLL-DELTAS] Summarize the resource changes declared by a set of effects into
// short ASCII tokens for the Last Roll HUD diagnostic. Reports DECLARED amounts (pre-clamp),
// covering global/player resources (modify_resource) and per-character resources
// (modify_char_resource); target/self scope is annotated. Not an audit of actually-applied
// values after clamping — a lightweight readout that sits next to the roll line.
function aeSummarizeResourceDeltas(effs: AERule[]): string[] {
    let out: string[] = [];
    for (const e of (effs || [])) {
        if (!e || (e.type !== 'modify_resource' && e.type !== 'modify_char_resource')) continue;
        let ea: any = e.args || {};
        let tag = String(ea.tag || '').trim();
        if (!tag) continue;
        let op = String(ea.op || 'add');
        let amt = Math.abs(Number(ea.amount) || 0);
        let scopeTxt = '';
        if (e.type === 'modify_char_resource') {
            let sc = String(ea.scope || '__player__');
            if (sc === '__target__') scopeTxt = ' (target)';
            else if (sc === '__self__') scopeTxt = ' (self)';
        }
        let token = '';
        if (op === 'set') token = tag + '=' + amt + scopeTxt;
        else if (op === 'subtract') token = '-' + amt + ' ' + tag + scopeTxt;
        else token = '+' + amt + ' ' + tag + scopeTxt;
        out.push(token);
    }
    return out;
}

// ── Orchestrator: conditions → resolution → effects → narrative/generate ────────
async function runActionInstance(inst: ActionInstance, sourceEnt: EntityRecord, cfg: GlobalConfig, opts?: { target?: EntityRecord | null; silentOverride?: boolean }): Promise<void> {
    try {
        let idx = await loadIndex();
        let protagMeta = idx.find(function(m) { return !!(m as any).isProtagonist; });
        let protag = protagMeta ? await loadCharacter(protagMeta.id) : null;
        let protagEnt = (protag && (protag as any).entityId) ? await loadEntity((protag as any).entityId) : null;
        let isSilent = (!!opts && !!opts.silentOverride) || !!inst.silent;

        if (inst.oneShot) {
            let osKey = 'ae_inst_1shot_' + sourceEnt.id + '_' + inst.id;
            let used = await api.v1.historyStorage.getOrDefault(osKey, false) as boolean;
            if (used) { api.v1.ui.toast('Already used.', { type: 'info', autoClose: 1500 }); return; }
        }

        let target: EntityRecord | null = (opts && opts.target !== undefined) ? (opts.target as EntityRecord | null) : null;
        if (!target && inst.targetMode === 'player_pick') {
            target = await aePickTarget(inst, sourceEnt, protagEnt, cfg);
            if (target === null) return; // cancelled
        }

        let parentEnt = (sourceEnt && sourceEnt.parentId) ? await loadEntity(sourceEnt.parentId) : null; // [WP-5]
        let scope: AEScope = { sourceEnt: sourceEnt, protag: protag, protagEnt: protagEnt, target: target, parentEnt: parentEnt };

        // 1. CONDITIONS
        let pass = await aeCheckConditions(inst.conditions || [], scope);
        if (!pass) {
            if (!inst.hidden) api.v1.ui.toast('Requirements not met.', { type: 'warning', autoClose: 1800 });
            return;
        }

        // 1b. BRANCHES
        let activeBranch: ActionBranch | null = null;
        if (inst.branches && inst.branches.length > 0) {
            for (const br of inst.branches) {
                let brPass = await aeCheckConditions(br.conditions || [], scope);
                if (brPass) {
                    activeBranch = br;
                    break;
                }
            }
        }

        // 2. RESOLUTION
        let activeRes = activeBranch ? activeBranch.resolution : inst.resolution;
        let outcome = await aeRollResolution(activeRes, cfg, protag);
        let rollLine = '';
        if (activeRes && (activeRes.type || activeRes.dice)) {
            api.v1.ui.toast('\ud83c\udfb2 ' + outcome.breakdown + ' \u2192 ' + (outcome.success ? 'Success' : 'Failure'), { type: outcome.success ? 'success' : 'warning' });
            rollLine = '[ Resolution: ' + outcome.breakdown + ' \u2192 ' + (outcome.success ? 'Success' : 'Failure') + ' ]';
        }
        // [FIX] persist the roll as a diagnostic for the HUD Actions tab (not the story).
        if (rollLine) await api.v1.tempStorage.set('ae_last_roll', { name: inst.name || 'Action', breakdown: outcome.breakdown, success: outcome.success, band: (outcome.band ? outcome.band.label : '') }).catch(function(_e) {});

        // 2b. PRE-LOAD specific entity targets referenced by raw ID in any rule args
        await preloadSpecificEnts(inst, scope);

        // 3. EFFECTS (band overrides; else success/failure branch)
        let activeSuccess = activeBranch ? activeBranch.successEffects : inst.successEffects;
        let activeFailure = activeBranch ? activeBranch.failureEffects : inst.failureEffects;
        let activeAlways = activeBranch ? activeBranch.alwaysEffects : (inst as any).alwaysEffects;

        if (outcome.band && outcome.band.effects) {
            await aeApplyEffects(outcome.band.effects, scope, cfg);
        } else if (outcome.success) {
            await aeApplyEffects(activeSuccess || [], scope, cfg);
        } else {
            await aeApplyEffects(activeFailure || [], scope, cfg);
        }

        // 3b. ALWAYS EFFECTS — fire unconditionally after the success/failure branch
        await aeApplyEffects(activeAlways || [], scope, cfg);

        // [v1.6.3 ROLL-DELTAS] Re-write the Last Roll diagnostic with the resource changes
        // from whichever effect branch actually fired, so the HUD Actions tab shows them
        // next to the roll. Declared amounts (pre-clamp). The full object is rewritten (not
        // read-modify-written) so a nested chain_action's own roll can't leave stale deltas.
        if (rollLine) {
            let firedFx: AERule[] = [];
            if (outcome.band && outcome.band.effects) firedFx = firedFx.concat(outcome.band.effects);
            else if (outcome.success) firedFx = firedFx.concat(activeSuccess || []);
            else firedFx = firedFx.concat(activeFailure || []);
            firedFx = firedFx.concat(activeAlways || []);
            let rollDeltas = aeSummarizeResourceDeltas(firedFx);
            await api.v1.tempStorage.set('ae_last_roll', { name: inst.name || 'Action', breakdown: outcome.breakdown, success: outcome.success, band: (outcome.band ? outcome.band.label : ''), deltas: rollDeltas }).catch(function(_e) {});
        }

        if (inst.oneShot) await api.v1.historyStorage.set('ae_inst_1shot_' + sourceEnt.id + '_' + inst.id, true);

        await refreshSidebar();
        queueSceneStateBroadcast();

        // 4. NARRATIVE + GENERATE
        if (!isSilent) {
            // [v0.9.33 TRAVEL1] If a move_player_to_self effect already called commitTravel
            // (which calls generate() internally), skip the second generate here to avoid
            // a double-generate that produces a spurious second AI response.
            let travelGenConsumed = await api.v1.tempStorage.get('ae_travel_gen_consumed').catch(function() { return undefined; });
            if (travelGenConsumed) {
                await api.v1.tempStorage.remove('ae_travel_gen_consumed').catch(function() {});
            } else {
                // [FIX] the resolution roll is NOT written to the story — only the author's outcome text is.
                // [v0.9.22 E5] If inject_narrative already consumed flavor, pendingFl is empty.
                // If not (outcomeNote-only or no-prompt actions), flavor is consumed here.
                let note = inst.outcomeNote ? aeSubstituteTokens(inst.outcomeNote, scope) : '';
                let pendingFl = await api.v1.tempStorage.get(STORAGE_PENDING_FLAVOR).catch(function() { return undefined; }) as string | undefined;
                if (pendingFl && pendingFl.trim()) {
                    await api.v1.tempStorage.remove(STORAGE_PENDING_FLAVOR).catch(function(_e: any) {});
                    let composed = composeActionPrompt(note, pendingFl.trim());
                    if (composed.trim()) {
                        await api.v1.document.appendParagraph({ text: '> ' + composed });
                        await api.v1.document.appendParagraph({ text: '' });
                    }
                } else if (note.trim()) {
                    await api.v1.document.appendParagraph({ text: '> ' + note });
                    await api.v1.document.appendParagraph({ text: '' });
                }
                // [BUGFIX vNEXT] Per-band GM directive is an instruction for the upcoming
                // generation only — it must never be written into the visible story
                // document. Routed through the existing STORAGE_PENDING_INJECT one-shot
                // slot (same mechanism inject_message effects and silent auto-trigger
                // notes already use), picked up and cleared by the onContextBuilt
                // Imperative block. Appended rather than overwritten in case an
                // inject_message effect from this same resolution already set it.
                if (outcome.band && (outcome.band as any).gmNote) {
                    let gmText = String((outcome.band as any).gmNote).trim();
                    if (gmText) {
                        let existingInject = await api.v1.tempStorage.get(STORAGE_PENDING_INJECT).catch(function() { return undefined; }) as string | undefined;
                        let combinedInject = (existingInject && existingInject.trim()) ? (existingInject.trim() + ' ' + gmText) : gmText;
                        await api.v1.tempStorage.set(STORAGE_PENDING_INJECT, combinedInject).catch(function(_e: any) {});
                    }
                }
                await aeEditorGenerate('actionInstance');
            }
        } else {
            api.v1.ui.toast('\ud83d\udd15 Action executed silently.', { type: 'info', autoClose: 1500 });
        }
        // [v0.9.37 DEFER1] This action's own step-4 generate (or its silence) is
        // authoritative; consume any pending flag a move effect set so it cannot leak
        // into the next travel's finalize. (The now-inert ae_travel_gen_consumed branch
        // above always takes the else path since commitTravel no longer sets it.)
        ae_pendingGenerate = false;
    } catch (e) {
        api.v1.log('[AE] runActionInstance error:', e);
        api.v1.ui.toast('Action failed: ' + ((e && (e as any).message) ? (e as any).message : e), { type: 'error' });
    }
}

// [v0.9.8.6] Composes a Quick Action (player goal+approach) into an ActionInstance
// and runs it. Extracted verbatim from the RUN_QUICK_INSTANCE message handler so the
// native Action modal and the bridge share one execution path. `qi` is a resolved
// quick-instance object. opts.silentOverride lets the native composer pass its own
// Story/Silent toggle; otherwise the stored mode is used.
async function runQuickInstance(qi: any, opts?: { silentOverride?: boolean }): Promise<void> {
    try {
        let qiCfg = await loadConfig();
        let qiSilent = (opts && opts.silentOverride !== undefined) ? !!opts.silentOverride : await getSilentMode();
        let qiIdx = await loadIndex();
        let qiProtagMeta = qiIdx.find(function(m) { return !!(m as any).isProtagonist; });
        let qiProtag = qiProtagMeta ? await loadCharacter(qiProtagMeta.id) : null;
        let qiSourceId = (qiProtag && (qiProtag as any).entityId) ? (qiProtag as any).entityId : null;
        let qiSource = qiSourceId ? await loadEntity(qiSourceId) : null;
        if (!qiSource) { api.v1.ui.toast('No scene context for quick action.', { type: 'warning' }); return; }

        let qiTarget: EntityRecord | null = null;
        if (qi.targetType === 'self' && qiSource) {
            qiTarget = qiSource;
        } else if (qi.targetId) {
            qiTarget = await loadEntity(qi.targetId);
        }

        let qiStakeDefId = qi.stakeDefId ? String(qi.stakeDefId) : '';
        let qiStakeDef: StakeDef | null = qiStakeDefId ? ((qiCfg.stakeDefs || []).find(function(s: any) { return s.id === qiStakeDefId; }) || null) : null;
        let qiHasTarget = (qi.targetType === 'entity' && !!qiTarget);
        let qiLuckSpend = Math.max(0, Number(qi.luckSpend) || 0);

		// [PATCH] runQuickInstance now inherits the resolution template's alwaysEffects
		// (previously discarded — only the luck-spend deduction ever made it through).
		// ...inside runQuickInstance, replacing the existing block...
		let resolution: AEResolution | undefined = undefined;
		let successEffects: AERule[] = [];
		let alwaysEffects: AERule[] = [];
		if (qi.skillTag) {
		    let qiResTpl = (qiCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_resolution'; }) || null;
		    resolution = aeBindStakeDef(qiResTpl, qiStakeDef, qi.skillTag, qiHasTarget);
		    if (qiLuckSpend > 0) resolution.bonusModifier = qiLuckSpend;
		    if (qiResTpl && Array.isArray((qiResTpl as any).alwaysEffects)) {
		        alwaysEffects = ((qiResTpl as any).alwaysEffects as AERule[]).slice();
		    }
		} else if (qiStakeDef) {
		    successEffects = aeStakeSideEffects(qiStakeDef.strong.player, '__player__', qiHasTarget)
		        .concat(aeStakeSideEffects(qiStakeDef.strong.target, '__target__', qiHasTarget));
		}
		if (qiLuckSpend > 0) {
		    alwaysEffects.push({ id: generateId(), type: 'modify_char_resource', args: { scope: '__player__', tag: '#luck', op: 'subtract', amount: qiLuckSpend } });
		}

        let qiInst: ActionInstance = {
            id: qi.id,
            name: qi.name,
            conditions: [],
            resolution: resolution,
            successEffects: successEffects,
            failureEffects: [],
            alwaysEffects: alwaysEffects,
            outcomeNote: qi.prompt
        };
        await runActionInstance(qiInst, qiSource, qiCfg, { target: qiTarget, silentOverride: qiSilent });
    } catch (e) { api.v1.log('[AE] runQuickInstance error:', e); }
}

// ── Spatial Helpers ───────────────────────────────────────────────────────────

async function loadPlayerLocation(): Promise<string | null> {
    // Returns the protagonist's current location entity ID.
    // Preserved verbatim from AE source.
    const idx = await loadIndex();
    const pMeta = idx.find(function(m) { return !!m.isProtagonist; });
    if (!pMeta) return null;

    const protag = await loadCharacter(pMeta.id);
    if (!protag) return null;

    let physicalRoomId: string | null = null;
    if (protag.entityId) {
        const protagBody = await loadEntity(protag.entityId);
        if (protagBody && protagBody.parentId) physicalRoomId = protagBody.parentId;
    }

    if (protag.currentLocationId) {
        const allNodes = await loadEntityIndex();
        const focusNode = allNodes.find(function(n) { return n.id === protag.currentLocationId; });
        const isCameraFocus = focusNode && focusNode.type !== 'location';
        if (isCameraFocus) return protag.currentLocationId;
    }

    if (physicalRoomId) {
        if (protag.currentLocationId !== physicalRoomId) {
            protag.currentLocationId = physicalRoomId;
            await saveCharacter(protag);
        }
        return physicalRoomId;
    }

    return null;
}

function getEffectiveRoomId(entityId: string, allNodes: EntityMeta[]): string | null {
    // Walks up the entity tree until a 'location' node is found.
    // Preserved verbatim from AE source.
    if (!entityId) return null;
    let currentId: string | null = entityId;
    let sanity = 0;
    while (currentId && sanity < 10) {
        const node = allNodes.find(function(n) { return n.id === currentId; });
        if (!node) return null;
        if (node.type === 'location') return node.id;
        currentId = node.parentId || null;
        sanity++;
    }
    return currentId;
}

// [vNEXT] Manual scene-presence controls, shared by native HUD (called directly)
// and bridge HUD (via message handlers).

// Authoritative "where is the player" resolution: the protagonist's effective
// room, resolved exactly the way recalculateScenePresence does — so co-locating a
// character here guarantees they read as present. (STORAGE_PLAYER_LOC is a cached
// value that can diverge from the protagonist's real body location.)
async function aeGetPlayerRoomId(): Promise<string | null> {
    try {
        const idx = await loadEntityIndex();
        const chars = await loadAllCharacters();
        const protag = chars.find(function(c) { return c.isProtagonist; });
        if (!protag || !protag.entityId) return null;
        return getEffectiveRoomId(protag.entityId, idx);
    } catch (e) { api.v1.log('[AE] aeGetPlayerRoomId:', e); return null; }
}

// Exclude/Include is the same scenePresent switch surfaced elsewhere — just set it.
// A recalc (travel or Detect) re-evaluates co-location afterwards, matching the
// behaviour of the existing switch.
async function aeSetCharScenePresent(charId: string, present: boolean): Promise<void> {
    try {
        const c = await loadCharacter(charId);
        if (!c) return;
        c.scenePresent = !!present;
        await saveCharacter(c);
        queueSceneStateBroadcast();
    } catch (e) { api.v1.log('[AE] aeSetCharScenePresent:', e); }
}

async function aeMoveCharToScene(charId: string): Promise<void> {
    try {
        const c = await loadCharacter(charId);
        if (!c || !c.entityId) return;
        const room = await aeGetPlayerRoomId();   // co-locate in the player's actual room
        const body = await loadEntity(c.entityId);
        if (body) { body.parentId = room; await saveEntity(body); }
        await saveCharacter(c);
        await recalculateScenePresence();
        queueSceneStateBroadcast();
    } catch (e) { api.v1.log('[AE] aeMoveCharToScene:', e); }
}

async function aeRefreshPresence(): Promise<void> {
    try {
        await recalculateScenePresence();
        queueSceneStateBroadcast();
    } catch (e) { api.v1.log('[AE] aeRefreshPresence:', e); }
}

async function recalculateScenePresence(): Promise<void> {
    // Updates scenePresent for all characters based on co-location with the protagonist.
    // Preserved verbatim from AE source.
    try {
        const allChars = await loadAllCharacters();
        const protag   = allChars.find(function(c) { return c.isProtagonist; });
        if (!protag || !protag.entityId) return;

        const freshEntIdx = await loadEntityIndex();
        const protagRoom  = getEffectiveRoomId(protag.entityId, freshEntIdx);
        if (!protagRoom) return;

        for (const c of allChars) {
            if (!c.active || c.id === protag.id) continue;
            if (!c.entityId) {
                // No body in the world graph — cannot be co-located with anyone.
                if (c.scenePresent) { c.scenePresent = false; await saveCharacter(c); }
                continue;
            }
            const cRoom = getEffectiveRoomId(c.entityId, freshEntIdx);
            const shouldBePresent = (cRoom !== null) && (cRoom === protagRoom);
            if (c.scenePresent !== shouldBePresent) {
                c.scenePresent = shouldBePresent;
                await saveCharacter(c);
            }
        }
    } catch (e) {
        api.v1.log('[AE] recalculateScenePresence error:', e);
    }
}

// ── Travel Engine ─────────────────────────────────────────────────────────────

// commitTravel: movement infrastructure — no gate, no narrative, no resource spend.
// Called by the move_player_to_self effect after an action's effects have already
// handled narrative injection and resource costs.
// [v0.9.9.2] Reposition offstage NPCs to the location their hourly schedule dictates
// for the current hour. A character's location is their body entity's parentId, so a
// scheduled move is just a parent change (same mechanism as set_entity_parent). Any
// NPC currently co-present with the player is left alone (no vanishing while watched);
// schedules can still move an NPC INTO the player's room so the player can wait for an
// arrival. Called from the travel commit points and from manual time changes only -
// never per-generation - so background overhead stays a non-issue.
async function resolveSchedules(): Promise<void> {
    try {
        let rsCfg = await loadConfig();
        let rsClk = await loadClock(rsCfg);
        let rsHour = clockHourOfDay(rsClk.hours);
        let rsPlayerLoc = await loadPlayerLocation();
        let rsChars = await loadAllCharacters();
        for (let rci = 0; rci < rsChars.length; rci++) {
            let rsChar = rsChars[rci];
            if (!rsChar || !rsChar.active || rsChar.isProtagonist) continue;
            if (!rsChar.scheduleEnabled || !rsChar.schedule || rsChar.schedule.length === 0 || !rsChar.entityId) continue;
            let rsRows = rsChar.schedule.slice().sort(function(x, y) { return Math.floor(x.startHour) - Math.floor(y.startHour); });
            let rsPick: ScheduleRow | null = null;
            for (let ri = 0; ri < rsRows.length; ri++) { if (Math.floor(rsRows[ri].startHour) <= rsHour) rsPick = rsRows[ri]; }
            if (!rsPick) rsPick = rsRows[rsRows.length - 1];   // before the first slot: carry over the last slot from 'yesterday'
            if (!rsPick || !rsPick.locationId) continue;
            let rsBody = await loadEntity(rsChar.entityId);
            if (!rsBody) continue;
            let rsCurLoc = rsBody.parentId !== null ? rsBody.parentId : undefined;
            if (rsCurLoc === rsPlayerLoc) continue;       // co-present with the player: leave them be
            if (rsCurLoc === rsPick.locationId) continue; // already where the schedule wants them
            rsBody.parentId = rsPick.locationId;
            await saveEntity(rsBody);
        }
    } catch (e) { api.v1.error('[AE] resolveSchedules error:', e); }
}

async function commitTravel(targetId: string, isSilent: boolean): Promise<void> {
    try {
        const ctTarget = await loadEntity(targetId);
        if (!ctTarget) return;
        api.v1.log('[AE:TRACE] commitTravel ENTER target=' + ctTarget.name + '(' + targetId + ') isSilent=' + isSilent + ' ae_lock=' + ae_lock);
        const ctIsSpatial = ctTarget.type === 'location';
        await api.v1.tempStorage.set(STORAGE_LAST_TRAVEL, Date.now());

        const ctChars  = await loadAllCharacters();
        const ctProtag = ctChars.find(function(c) { return c.isProtagonist; });
        if (!ctProtag || !ctProtag.entityId) return;

        // Move body
        if (ctIsSpatial) {
            const ctBody = await loadEntity(ctProtag.entityId);
            if (ctBody && ctBody.id !== targetId) { api.v1.log('[AE:TRACE] commitTravel body move ' + ctBody.parentId + ' -> ' + targetId); ctBody.parentId = targetId; await saveEntity(ctBody); }
            else { api.v1.log('[AE:TRACE] commitTravel body NOT moved (ctBody=' + (ctBody ? ctBody.id : 'null') + ' target=' + targetId + ')'); }
        }

        // Camera
        const ctFreshProtag = await loadCharacter(ctProtag.id);
        if (ctFreshProtag) { ctFreshProtag.currentLocationId = targetId; await saveCharacter(ctFreshProtag); }

        // Pre-generation auto-triggers
        if (ctIsSpatial) { await runAutoTriggers(); }

        // [v0.9.9.2] Position offstage NPCs per their hourly schedule for the current
        // hour before computing who is scene-present at the destination.
        if (ctIsSpatial) { await resolveSchedules(); }

        // Scene presence
        const ctFreshIdx = await loadEntityIndex();
        const ctProtagRoom = getEffectiveRoomId(ctProtag.entityId, ctFreshIdx);
        for (const c of ctChars) {
            if (!c.active || c.id === ctProtag.id) continue;
            if (!c.entityId) { if (c.scenePresent) { c.scenePresent = false; await saveCharacter(c); } continue; }
            const cRoom = getEffectiveRoomId(c.entityId, ctFreshIdx);
            const shouldBePresent = (cRoom === ctProtagRoom) && (cRoom !== null);
            if (c.scenePresent !== shouldBePresent) { c.scenePresent = shouldBePresent; await saveCharacter(c); }
        }

        // History
        const ctHist = await loadEntityHistory();
        ctHist.unshift(targetId);
        await saveEntityHistory(ctHist);

        // Quest arrival check
        if (ctIsSpatial) {
            try {
                const ctNarrId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
                if (ctNarrId) {
                    const ctNarr = await loadEntity(ctNarrId);
                    if (ctNarr && ctNarr.questTarget) {
                        const ctQIdx = await loadEntityIndex();
                        const ctQTgt = ctQIdx.find(function(m) { return m.id === ctNarr.questTarget; });
                        if (ctQTgt) {
                            const ctNavId = ctQTgt.type === 'location' ? ctQTgt.id : (ctQTgt.parentId || '');
                            if (ctNavId && targetId === ctNavId) {
                                await api.v1.storyStorage.set(STORAGE_TRACKED_NARRATIVE, '');
                                api.v1.ui.toast('🎯 Reached: ' + ctQTgt.name + ' — quest tracking cleared.', { type: 'success', autoClose: 3000 });
                            }
                        }
                    }
                }
            } catch (_) {}
        }

        // [v0.9.25 E4] Encounter roll removed from commitTravel

        await refreshSidebar();
        queueSceneStateBroadcast();

        if (!isSilent) {
            // [v0.9.37 DEFER1] Do NOT generate inline. move_player_to_self can sit in the
            // MIDDLE of an effects list (e.g. before inject_narrative); generating here
            // blocks the editor so any later inject_narrative/inject_message throws
            // 'editor is currently blocked' and the narrative never lands. Set a pending
            // flag; the top-level handler generates ONCE after every effect completes.
            api.v1.log('[AE:TRACE] commitTravel DEFER generate (target=' + targetId + ')');
            ae_pendingGenerate = true;
        } else {
            api.v1.log('[AE:TRACE] commitTravel SILENT SKIP generate (target=' + targetId + ')');
            api.v1.ui.toast('🔕 Moved silently.', { type: 'info', autoClose: 1500, id: 'travel_toast' });
        }
    } catch (e) {
        api.v1.log('[AE] commitTravel error:', e);
    }
}

async function executeTravelTo(fromLoc: EntityRecord, targetId: string, entIdx: EntityMeta[], reqRes?: string, costAmount: number = 0, isConnectionSilent: boolean = false, connLabel?: string): Promise<void> {
    try {
        const globalSilent = await getSilentMode();
        const isSilentMode = globalSilent || isConnectionSilent;

        const isUpwardImplicit   = (fromLoc && fromLoc.parentId === targetId);
        const shouldGenerateNarrative = !isSilentMode && !isUpwardImplicit;

        if (reqRes && costAmount > 0) {
            const hasRes = await checkResource(reqRes, costAmount);
            if (!hasRes) { api.v1.ui.toast('Cannot interact: Insufficient ' + reqRes + '.', { type: 'error' }); return; }
        }

        const targetLoc = await loadEntity(targetId);
        if (!targetLoc) { api.v1.ui.toast('Destination not found.', { type: 'error' }); return; }

        const chars  = await loadAllCharacters();
        const protag = chars.find(function(c) { return c.isProtagonist; });
        if (!protag || !protag.entityId) return;

        // [CHANGE] Dead code removed: adjustResource() always returns false, so the old
        // `if (ruleTriggeredMove)` block was never entered. Simplified to a direct call.
        if (reqRes && costAmount > 0) {
            const cfg    = await loadConfig();
            const resDef = (cfg.resources || []).find(function(r: any) { return r.tag === reqRes; });
            const isTrack = resDef && resDef.type === 'track';
            await adjustResource(reqRes, isTrack ? costAmount : -costAmount);
        }

        // 1. DYNAMIC NARRATIVE
        const isSpatial = targetLoc.type === 'location';
        await api.v1.tempStorage.set(STORAGE_LAST_TRAVEL, Date.now());

        if (shouldGenerateNarrative) {
            let travelText: string;
            if (connLabel && connLabel.trim()) {
                travelText = connLabel.trim();
            } else if (isSpatial) {
                const companions = chars.filter(function(c) {
                    if (!c.active || c.id === protag.id || !c.entityId) return false;
                    const cEnt = entIdx.find(function(m) { return m.id === c.entityId; });
                    return cEnt && cEnt.parentId === protag.entityId;
                });
                const names    = companions.map(function(c) { return c.name; }).filter(Boolean);
                const withText = names.length > 0 ? ' with ' + names.join(', ') : '';
                travelText = 'You leave' + withText + ' for ' + targetLoc.name + '.';
            } else if (targetLoc.type === 'item') {
                travelText = 'You examine the ' + targetLoc.name + '.';
            } else if (targetLoc.type === 'character') {
                travelText = targetLoc.id === protag.entityId
                    ? 'You check your inventory and status.'
                    : 'You approach ' + targetLoc.name + '.';
            } else if (targetLoc.type === 'narrative') {
                travelText = 'You engage with the situation: ' + targetLoc.name + '.';
            } else {
                travelText = 'You move to ' + targetLoc.name + '.';
            }
            await api.v1.document.appendParagraph({ text: '> ' + travelText });
            await api.v1.document.appendParagraph({ text: '' });
        }

        // 2. SPATIAL MOVEMENT
        if (isSpatial) {
            const protagBody = await loadEntity(protag.entityId);
            if (protagBody && protagBody.id !== targetId) {
                protagBody.parentId = targetId;
                await saveEntity(protagBody);
            }
        }

        // 3. MOVE THE CAMERA
        const freshProtag = await loadCharacter(protag.id);
        if (freshProtag) {
            freshProtag.currentLocationId = targetId;
            await saveCharacter(freshProtag);
        }

        // 3b. PRE-GENERATION AUTO-TRIGGERS
        // Fires silently before the arrival scene is generated so that any
        // character movements triggered by current conditions (e.g. a schedule
        // action on the player entity watching a time-resource state) are
        // reflected in scene presence when the AI builds context.
        // Safe to call here: protagonist body is already at targetId and
        // saveEntity() has updated the entity index, so the player entity
        // falls within the scan scope (parentId === new locId).
        // The onGenerationEnd call remains for regular turn-by-turn triggers.
        if (isSpatial) {
            await runAutoTriggers();
        }

        // 4. AUTO-SCENE PRESENCE
        // freshEntIdx is loaded after runAutoTriggers(), so any entity moves
        // made by triggers are already reflected in the index.
        const freshEntIdx = await loadEntityIndex();
        const protagEffectiveRoom = getEffectiveRoomId(protag.entityId, freshEntIdx);

        for (const c of chars) {
            if (!c.active || c.id === protag.id) continue;
            if (!c.entityId) {
                if (c.scenePresent) { c.scenePresent = false; await saveCharacter(c); }
                continue;
            }
            const cEffectiveRoom = getEffectiveRoomId(c.entityId, freshEntIdx);
            const shouldBePresent = (cEffectiveRoom === protagEffectiveRoom) && (cEffectiveRoom !== null);
            if (c.scenePresent !== shouldBePresent) {
                c.scenePresent = shouldBePresent;
                await saveCharacter(c);
            }
        }

        // 4b. HISTORY UPDATE
        const hist = await loadEntityHistory();
        hist.unshift(targetId);
        await saveEntityHistory(hist);

        // 4c. QUEST ARRIVAL CHECK
        if (isSpatial) {
            try {
                const trackedNarrId = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
                if (trackedNarrId) {
                    const trackedNarr = await loadEntity(trackedNarrId);
                    if (trackedNarr && trackedNarr.questTarget) {
                        const qAllIdx = await loadEntityIndex();
                        const qTgt    = qAllIdx.find(function(m) { return m.id === trackedNarr.questTarget; });
                        if (qTgt) {
                            const navId = qTgt.type === 'location' ? qTgt.id : (qTgt.parentId || '');
                            if (navId && targetId === navId) {
                                await api.v1.storyStorage.set(STORAGE_TRACKED_NARRATIVE, '');
                                api.v1.ui.toast('🎯 Reached: ' + qTgt.name + ' — quest tracking cleared.', { type: 'success', autoClose: 3000 });
                            }
                        }
                    }
                }
            } catch (_) {}
        }

        // [v0.9.25 E4] Encounter roll removed from simple travel

        // 5. WRAP UP
        await refreshSidebar();
        // [CHANGE] renderSceneHUD() → queueSceneStateBroadcast()
        queueSceneStateBroadcast();

        if (shouldGenerateNarrative) {
            await aeEditorGenerate('executeTravelTo');
        } else {
            const toastMsg = isUpwardImplicit ? '🔕 Backed out silently.' : '🔕 Movement executed silently.';
            api.v1.ui.toast(toastMsg, { type: 'info', autoClose: 1500, id: 'travel_toast' });
        }
    } catch (e) {
        api.v1.log('[AE] executeTravelTo error:', e);
    }
}

// ── Encounter Engine ──────────────────────────────────────────────────────────

// [v0.9.25 E4] rollEncounter removed — replaced by action system

// ── Pathfinding ───────────────────────────────────────────────────────────────

async function findTravelPath(fromId: string, toId: string): Promise<string[] | null> {
    // BFS pathfinding over the entity graph (implicit parent-child + explicit connections).
    // Preserved verbatim from AE source.
    if (fromId === toId) return [fromId];
    try {
        const allMeta = await loadEntityIndex();

        const parentOf:   Record<string, string | null> = {};
        const childrenOf: Record<string, string[]>      = {};
        for (const m of allMeta) {
            parentOf[m.id] = m.parentId;
            if (m.parentId) {
                if (!childrenOf[m.parentId]) childrenOf[m.parentId] = [];
                childrenOf[m.parentId].push(m.id);
            }
        }

        // Load all entities to get explicit connections
        const entCache: Record<string, EntityRecord | null> = {};
        for (const m of allMeta) { entCache[m.id] = await loadEntity(m.id); }

        // Build full adjacency: implicit + explicit (bidirectional unless oneWay)
        const adj: Record<string, string[]> = {};
        for (const m of allMeta) {
            if (!adj[m.id]) adj[m.id] = [];
            if (parentOf[m.id]) adj[m.id].push(parentOf[m.id]!);
            for (const c of (childrenOf[m.id] || [])) adj[m.id].push(c);
            const ent = entCache[m.id];
            if (ent) {
                for (const conn of (ent.connectedEntityIds || [])) {
                    if (!adj[m.id].includes(conn.targetId)) adj[m.id].push(conn.targetId);
                    if (!conn.oneWay) {
                        if (!adj[conn.targetId]) adj[conn.targetId] = [];
                        if (!adj[conn.targetId].includes(m.id)) adj[conn.targetId].push(m.id);
                    }
                }
            }
        }

        // BFS
        const visited = new Set<string>([fromId]);
        const queue: { id: string; path: string[] }[] = [{ id: fromId, path: [fromId] }];

        while (queue.length > 0) {
            const curr = queue.shift()!;
            for (const nId of (adj[curr.id] || [])) {
                if (nId === toId) return curr.path.concat([toId]);
                if (!visited.has(nId)) {
                    visited.add(nId);
                    queue.push({ id: nId, path: curr.path.concat([nId]) });
                }
            }
        }
        return null;
    } catch (e) {
        api.v1.log('[AE] findTravelPath error:', e);
        return null;
    }
}

async function findVehicleAncestor(startId: string): Promise<EntityRecord | null> {
    // Walks up the entity tree to find the nearest vehicle ancestor.
    // Preserved verbatim from AE source.
    let currentId: string | null = startId;
    for (let depth = 0; depth < 8; depth++) {
        if (!currentId) break;
        const vEnt = await loadEntity(currentId);
        if (!vEnt) break;
        if (!!(vEnt as any).isVehicle && vEnt.type === 'location') return vEnt;
        currentId = vEnt.parentId;
    }
    return null;
}

async function executeVehicleTravel(vehicle: EntityRecord, destinationId: string, reqResTag?: string, costAmount: number = 0): Promise<void> {
    // Moves a vehicle entity (and all its children) to a new parent location.
    // [CHANGE] renderSceneHUD() → queueSceneStateBroadcast().
    try {
        const globalSilent = await getSilentMode();

        if (vehicle.parentId === destinationId) { api.v1.ui.toast('Already there.', { type: 'info' }); return; }

        if (reqResTag && costAmount > 0) {
            const hasRes = await checkResource(reqResTag, costAmount);
            if (!hasRes) { api.v1.ui.toast('Cannot travel: Insufficient ' + reqResTag + '.', { type: 'error' }); return; }
        }

        await api.v1.tempStorage.set(STORAGE_LAST_TRAVEL, Date.now());

        const destEnt  = await loadEntity(destinationId);
        const destName = destEnt ? destEnt.name : 'destination';

        if (reqResTag && costAmount > 0) {
            const vcfg    = await loadConfig();
            const vResDef = (vcfg.resources || []).find(function(r) { return r.tag === reqResTag; });
            const vIsTrack = vResDef && vResDef.type === 'track';
            await adjustResource(reqResTag, vIsTrack ? costAmount : -costAmount);
        }

        vehicle.parentId = destinationId;
        await saveEntity(vehicle);

        // [v0.9.25 E4] Encounter roll removed from vehicle travel

        await resolveSchedules();   // [v0.9.9.2] schedule-position offstage NPCs before presence recompute
        await recalculateScenePresence();
        await refreshSidebar();
        // [CHANGE] renderSceneHUD() → queueSceneStateBroadcast()
        queueSceneStateBroadcast();

        if (!globalSilent) {
            await api.v1.document.appendParagraph({ text: '> ' + vehicle.name + ' arrives at ' + destName + '.' });
            await api.v1.document.appendParagraph({ text: '' });
            await aeEditorGenerate('executeVehicleTravel');
        } else {
            api.v1.ui.toast('🚀 ' + vehicle.name + ' → ' + destName, { type: 'info', autoClose: 2000 });
        }
    } catch (e) { api.v1.log('[AE] executeVehicleTravel error:', e); api.v1.ui.toast('Vehicle travel failed.', { type: 'error' }); }
}

async function executeDestinationTravel(destinationId: string): Promise<void> {
    // Pathfinding travel: finds the shortest route and walks it, stopping at encounters.
    // [CHANGE] renderSceneHUD() → queueSceneStateBroadcast().
    try {
        const globalSilent = await getSilentMode();

        const locId = await loadPlayerLocation();
        if (!locId) { api.v1.ui.toast('Current location unknown.', { type: 'warning' }); return; }
        if (locId === destinationId) { api.v1.ui.toast('Already there.', { type: 'info' }); return; }

        const path = await findTravelPath(locId, destinationId);
        if (!path || path.length < 2) { api.v1.ui.toast('No route to destination.', { type: 'warning' }); return; }

        const allMeta = await loadEntityIndex();
        const chars   = await loadAllCharacters();
        const protag  = chars.find(function(c) { return c.isProtagonist; });
        if (!protag || !protag.entityId) return;

        const steps          = path.slice(1);
        const visitedNames: string[] = [];
        const startMeta = allMeta.find(function(m) { return m.id === locId; });
        if (startMeta) visitedNames.push(startMeta.name);

        // [v0.9.25 E4] encounterHit removed — encounter system replaced by actions
        const finalLocId = destinationId;

        for (let si = 0; si < steps.length; si++) {
            const stepId  = steps[si];
            const stepEnt = await loadEntity(stepId);
            if (!stepEnt) continue;
            visitedNames.push(stepEnt.name);
        }

        // Move protagonist body to final location
        const protagBody = await loadEntity(protag.entityId);
        if (protagBody) { protagBody.parentId = finalLocId; await saveEntity(protagBody); }
        await api.v1.storyStorage.set(STORAGE_PLAYER_LOC, finalLocId);

        const freshProtag = await loadCharacter(protag.id);
        if (freshProtag) { freshProtag.currentLocationId = finalLocId; await saveCharacter(freshProtag); }

        await resolveSchedules();   // [v0.9.9.2] schedule-position offstage NPCs before presence recompute
        await recalculateScenePresence();

        if (!globalSilent) {
            const journeyLine = visitedNames.length > 1 ? visitedNames.join(' → ') : '';
            if (visitedNames.length > 1) {
                await api.v1.document.appendParagraph({ text: '> ' + journeyLine });
                await api.v1.document.appendParagraph({ text: '' });
            }
        }

        await refreshSidebar();
        // [CHANGE] renderSceneHUD() → queueSceneStateBroadcast()
        queueSceneStateBroadcast();

        if (!globalSilent) {
            await aeEditorGenerate('executeDestinationTravel');
        } else {
            const finalName = allMeta.find(function(m) { return m.id === finalLocId; });
            api.v1.ui.toast('Traveled to ' + (finalName ? finalName.name : 'destination') + '.', { type: 'info', autoClose: 2000 });
        }
    } catch (e) {
        api.v1.log('[AE] executeDestinationTravel error:', e);
        api.v1.ui.toast('Travel failed.', { type: 'error' });
    }
}

// ae-merged-s20-s27.txt — Sections 20 through 27 (UI, Hooks, Startup)
// Continuation of ae-merged-s1-s15.txt + ae-merged-s16-s19.txt

// ============================================================================
// SECTION 20 — SIDEBAR
// refreshSidebar, buildSidebar, buildCharCard, killCharacter,
// openCharEditModal and all character sub-section builders.
//
// [CHANGE] renderSceneHUD() -> queueSceneStateBroadcast() throughout.
// [CHANGE] typeof renderSceneHUD guards removed — call directly.
// [CHANGE] refreshSidebar no longer calls renderSceneHUD:
//          queueSceneStateBroadcast() is called instead.
// ============================================================================

async function refreshSidebar(): Promise<void> {
    // [CHANGE] renderSceneHUD() removed — bridge owns the HUD now.
    //          queueSceneStateBroadcast() fires so bridge HUD stays in sync.
    await api.v1.ui.update([{ type: 'sidebarPanel', id: 'ce-panel', name: '🗺 Adventure', content: await buildSidebar() } as any]);
    queueSceneStateBroadcast();
}

async function buildSidebar(): Promise<UIPart[]> {
    const activeTab = await api.v1.tempStorage.getOrDefault(STORAGE_ACTIVE_TAB, 'characters') as string;
    const parts: UIPart[] = [];
    
    parts.push({ type: 'row', alignment: 'center', style: { marginBottom: '10px', gap: '6px' }, content: [
        { type: 'button', text: 'World-Build Wizard', iconId: 'message-square', style: { fontWeight: 'bold', fontSize: '12px', flex: '1 1 0', margin: 0, padding: '4px 8px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, callback: async function() { if (typeof openWizardModal === 'function') await openWizardModal(); } },
        { type: 'button', text: 'World Settings', style: { margin: 0, padding: '4px 8px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff', border: '1px solid #88ccff' }, callback: async function() { 
            if (typeof openWorldbuildingModal === 'function') await openWorldbuildingModal(); 
        } },
        { type: 'button', text: 'Sys', iconId: 'settings', style: { margin: 0 }, callback: async function() { await openConfigModal(); } }
    ] });

    const _hudModeCfg = await loadConfig();
    const _hudMode = (_hudModeCfg as any).interfaceMode || 'native';
    function hudModeBtn(mode: string, label: string, icon: any): UIPart {
        const on = _hudMode === mode;
        return { type: 'button', text: label, iconId: icon, style: { flex: '1 1 0', margin: 0, fontSize: '11px', fontWeight: on ? 'bold' : 'normal', backgroundColor: on ? 'rgba(126,200,160,0.18)' : 'transparent', color: on ? '#7ec8a0' : undefined, border: on ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.12)', opacity: on ? '1' : '0.7' }, callback: async function() { await setInterfaceMode(mode); } } as UIPart;
    }
    parts.push({ type: 'row', style: { marginBottom: '8px', gap: '6px' }, content: [
        hudModeBtn('native', 'Native', 'cloud-off'),
        hudModeBtn('bridge', 'Bridge', 'cloud'),
        hudModeBtn('both', 'Both', 'layers')
    ] });

    function tabBtn(id: string, label: string): UIPart {
        const isActive = activeTab === id;
        return { type: 'button', text: label, style: { flex: '1 1 0', margin: '0', padding: '4px 2px', fontSize: '11px', fontWeight: isActive ? 'bold' : 'normal', borderBottom: isActive ? '2px solid #7ec8a0' : '2px solid transparent', borderRadius: '4px 4px 0 0', backgroundColor: isActive ? 'rgba(126,200,160,0.12)' : 'transparent', opacity: isActive ? '1' : '0.65' }, callback: async function() { await api.v1.tempStorage.set(STORAGE_ACTIVE_TAB, id); await refreshSidebar(); } } as UIPart;
    }
    
    parts.push({ type: 'row', style: { marginBottom: '10px', gap: '2px', borderBottom: '1px solid rgba(255,255,255,0.08)', paddingBottom: '2px' }, content: [
        tabBtn('characters', '👥 Characters'), 
        tabBtn('drama', '💅 Drama'),
        tabBtn('entities', '🌍 World'),
        tabBtn('actions', '🎬 Action')
    ] });

    try {
        if (activeTab === 'actions') {
            parts.push(...await buildActionTab());
        }else if (activeTab === 'drama') {
            parts.push(...await buildDramaTabContent());
        } else if (activeTab === 'entities') {
            parts.push(...await buildEntitiesTab());
        } else {
            // ── CHARACTERS TAB (Default) ──────────────────────────────────
            const index = await loadIndex(); 
            const cfg = await loadConfig();
            const entIdx = await loadEntityIndex();
            const searchQuery = await api.v1.tempStorage.getOrDefault('temp:ae_char_search', '') as string;
            
            // 1. TOP ROW: ADD & IMPORT & HELP
            parts.push({ type: 'row', style: { gap: '8px', marginBottom: '8px' }, content: [
                { type: 'button', text: 'Character', iconId: 'plus', style: { flex: '1 1 0', margin: 0 }, disabledWhileCallbackRunning: true, callback: async function() {
                    try {
                        let addCfg = await loadConfig();
                        let addEnt = makeDefaultEntity('New Character');
                        addEnt.type = 'character';
                        addEnt.parentId = null;
                        await saveEntity(addEnt);
                        let addChar = makeDefaultCharacter('New Character', addCfg);
                        addChar.entityId = addEnt.id;
                        await saveCharacter(addChar);
                        try { await createLinkedLorebookEntry(addChar.id); } catch (lbErr) {}
                        if (typeof openCharEditModal === 'function') await openCharEditModal(addChar.id);
                        await refreshSidebar();
                    } catch (e) {
                        api.v1.error('[AE] Create character failed:', e);
                        api.v1.ui.toast('Failed to create character.', { type: 'error' });
                    }
                } },
                { type: 'button', text: '📥 Import', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(136,204,255,0.15)', border: '1px solid rgba(136,204,255,0.3)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() { 
                    await pickAndImportFromLorebook(); 
                } },
                { type: 'button', text: '🐾', style: { flex: '0 1 auto', margin: 0, fontSize: '11px', padding: '4px 8px' }, callback: async function() { await openBestiaryModal(); } },
                { type: 'button', text: '❓', style: { flex: '0 1 auto', margin: 0, fontSize: '11px', padding: '4px 8px' }, callback: async function() {
                    await openEngineModal({ title: 'Characters Tab Help', size: 'medium', content: [
                        { type: 'text', text: 'This tab contains the master list of all characters in your world.', style: { marginBottom: '8px' } },
                        { type: 'text', text: 'Active:', style: { fontWeight: 'bold', fontSize: '12px' } },
                        { type: 'text', text: 'Removes the character from all context injections entirely, as if they don\'t exist.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                        { type: 'text', text: 'Scene:', style: { fontWeight: 'bold', fontSize: '12px' } },
                        { type: 'text', text: 'Manually overrides scene presence. This will be automatically reset to the correct value when you change locations.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                        { type: 'text', text: 'Dynamic:', style: { fontWeight: 'bold', fontSize: '12px' } },
                        { type: 'text', text: 'Toggles all background AI updates for this character (thoughts, goals, hooks).', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                        { type: 'text', text: 'Location:', style: { fontWeight: 'bold', fontSize: '12px' } },
                        { type: 'text', text: 'Changes where the character\'s physical body is located in the world graph.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                        { type: 'text', text: 'Kill:', style: { fontWeight: 'bold', fontSize: '12px' } },
                        { type: 'text', text: 'Sets the character to Inactive, drops their inventory at their last location, and moves their body to a "Graveyard" location. They can be restored by moving them out of the Graveyard and setting them back to Active.', style: { fontSize: '11px', opacity: '0.8' } }
                    ]});
                } }
            ] });

            // 2. SEARCH BAR
            parts.push({
                type: 'textInput', 
                placeholder: '🔍 Search characters...', 
                initialValue: searchQuery,
                style: { marginBottom: '12px' }, 
                onChange: async function(v: string) {
                    await api.v1.tempStorage.set('temp:ae_char_search', v);
                    await refreshSidebar();
                }
            });
            
            if (index.length === 0) {
                parts.push({ type: 'text', text: 'No characters yet.', style: { fontSize: '12px', opacity: '0.6', marginBottom: '8px' } });
            }
            
            // 3. FILTER & SORT LOGIC
            let displayIndex = index.filter(m => m && (m as any).npcClass !== 'minor'); // Everyone major incl. protagonist; minors get the compact roster below
            
            if (searchQuery) {
                const sq = searchQuery.toLowerCase();
                displayIndex = displayIndex.filter(m => (m.name || '').toLowerCase().includes(sq));
            }

            displayIndex.sort(function(a, b) {
                // Tier 0 Sort: Protagonist always at the absolute top
                if (a.isProtagonist !== b.isProtagonist) return a.isProtagonist ? -1 : 1;

                // Tier 1 Sort: Pinned
                const aPinned = !!(a as any).pinned;
                const bPinned = !!(b as any).pinned;
                if (aPinned !== bPinned) return aPinned ? -1 : 1;
                
                // Tier 2 Sort: Scene Present
                const aScene = !!a.scenePresent;
                const bScene = !!b.scenePresent;
                if (aScene !== bScene) return aScene ? -1 : 1;
                
                // Tier 3 Sort: Fallback to underlying array order (retains natural order)
                return 0; 
            });

            // 4. RENDER CARDS
            for (let i = 0; i < displayIndex.length; i++) {
                const meta = displayIndex[i];
                if (meta) {
                    // Extract global position so Up/Down manual-sort buttons know true array bounds
                    const globalPos = index.findIndex(m => m.id === meta.id);
                    parts.push(buildCharCard(meta, cfg, entIdx, globalPos, index.length)); 
                }
            }

            // [vNEXT] Compact minor-NPC roster — promote or delete; no full cards.
            const minorMetas = index.filter(m => m && (m as any).npcClass === 'minor');
            if (minorMetas.length > 0) {
                parts.push({ type: 'collapsibleSection', title: '🐾 Minor NPCs (' + minorMetas.length + ')', initialCollapsed: true, storageKey: 'temp:ae_minor_roster', content: minorMetas.map(function(mm) {
                    return { type: 'row', style: { gap: '4px', marginBottom: '3px', alignItems: 'center' }, content: [
                        { type: 'text', text: mm.name + (mm.scenePresent ? ' · in scene' : ''), style: { flex: '1 1 0', fontSize: '11px' } },
                        { type: 'button', text: 'Edit', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, callback: async function() { try { await openCharEditModal(mm.id); } catch (eEd) { api.v1.error('[AE] minor edit:', eEd); } } },
                        { type: 'button', text: '↑ Promote', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, disabledWhileCallbackRunning: true, callback: async function() { let pmc = await loadCharacter(mm.id); if (pmc && pmc.entityId) { await promoteMinorNpc(pmc.entityId); await refreshSidebar(); } } },
                        { type: 'button', text: '✕', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, callback: async function() { await deleteCharacter(mm.id); await refreshSidebar(); } }
                    ] } as UIPart;
                }) } as UIPart);
            }
        }
    } catch (e) {
        api.v1.error('[AE] Tab render error:', e);
        parts.push({ type: 'box', style: { backgroundColor: 'rgba(255,107,107,0.1)', padding: '12px', borderRadius: '6px', margin: '8px 0' }, content: [
            { type: 'text', text: '⚠ Tab failed to load', style: { fontWeight: 'bold', fontSize: '12px', color: '#ff6b6b', marginBottom: '4px' } },
            { type: 'text', text: String(e), style: { fontSize: '10px', fontFamily: 'monospace', opacity: '0.8', whiteSpace: 'pre-wrap', color: '#ff6b6b' } }
        ] });
    }
    
    return parts.filter(Boolean) as UIPart[];
}

function buildCharResWidget(res: CharResourceDef, val: number, charId: string): UIPart {
    if (res.type === 'pool') {
        return { type: 'box', style: { flex: '1 1 0', padding: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '6px', borderLeft: '3px solid #88ccff' }, content: [
            { type: 'text', text: res.name, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '4px' } },
            { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                { type: 'button', iconId: 'minus', style: { margin: 0, padding: '2px 6px' }, disabled: (res.hasBounds && res.min !== undefined && val <= res.min), callback: async function() { await adjustCharResource(charId, res.tag, -1); queueSceneStateBroadcast(); } },
                { type: 'text', text: String(val) + (res.hasBounds && res.max !== undefined ? '/' + res.max : ''), style: { fontSize: '12px', fontWeight: 'bold', minWidth: '30px', textAlign: 'center' } },
                { type: 'button', iconId: 'plus', style: { margin: 0, padding: '2px 6px' }, disabled: (res.hasBounds && res.max !== undefined && val >= res.max), callback: async function() { await adjustCharResource(charId, res.tag, 1); queueSceneStateBroadcast(); } }
            ] }
        ] } as UIPart;
    }
    let states = res.states || [];
    return { type: 'box', style: { flex: '1 1 0', padding: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '6px', borderLeft: '3px solid #e8a87c' }, content: [
        { type: 'text', text: res.name, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '4px' } },
        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
            { type: 'button', iconId: 'chevron-left', style: { margin: 0, padding: '2px 4px' }, disabled: val <= 0, callback: async function() { await adjustCharResource(charId, res.tag, -1); queueSceneStateBroadcast(); } },
            { type: 'text', text: states[val] || '?', style: { fontSize: '10px', fontWeight: 'bold', flex: '1 1 0', textAlign: 'center', color: '#e8a87c' } },
            { type: 'button', iconId: 'chevron-right', style: { margin: 0, padding: '2px 4px' }, disabled: val >= states.length - 1, callback: async function() { await adjustCharResource(charId, res.tag, 1); queueSceneStateBroadcast(); } }
        ] }
    ] } as UIPart;
}

// [CHANGE] buildResWidget removed — dead code; NAI sidebar scene HUD was removed in the merger.


// ============================================================================
// ACTION TAB UI
// ============================================================================

// [v0.9.8.4] ── Stake editor helpers ──────────────────────────────────────────────

// Build the flat list of track items shown in the per-band-side picker.
// Includes global character resources and faction standings.
// [v0.9.8.5] Async — loads the full union of charResourceDefs across all characters
// so character-specific resources (not in cfg.resources) appear in the picker.
async function buildStakeTrackItems(cfg2: GlobalConfig): Promise<{ pickId: string; tag: string; trackType: string; label: string; sublabel: string; }[]> {
    const items: { pickId: string; tag: string; trackType: string; label: string; sublabel: string; }[] = [];

    // Build a union of all character resource defs across all loaded characters.
    // Seed with cfg.resources first (covers resources not yet synced to any char).
    const resMap: Record<string, { name: string; sublabel: string }> = {};
    for (const r of (cfg2.resources || [])) {
        let sub2 = r.type as string;
        if (r.type === 'track' && r.states && r.states.length) sub2 = r.states.join(' → ');
        else if (r.type === 'pool') sub2 = 'pool' + (r.hasBounds ? ' ' + (r.min || 0) + '–' + r.max : '');
        if (!resMap[r.tag]) resMap[r.tag] = { name: r.name, sublabel: sub2 };
    }
    try {
        const allChT = await loadAllCharacters();
        for (const chT of allChT) {
            for (const rdT of (chT.charResourceDefs || [])) {
                if (!resMap[rdT.tag]) {
                    let subT: string = rdT.type;
                    if (rdT.type === 'track' && rdT.states && rdT.states.length) subT = rdT.states.join(' → ');
                    else if (rdT.type === 'pool') subT = 'pool' + (rdT.hasBounds ? ' ' + (rdT.min || 0) + '–' + rdT.max : '');
                    resMap[rdT.tag] = { name: rdT.name, sublabel: subT };
                }
            }
        }
    } catch (eTrk) { api.v1.log('[AE:stakes] buildStakeTrackItems char load failed:', eTrk); }
    for (const tagK of Object.keys(resMap)) {
        items.push({ pickId: 'res:' + tagK, tag: tagK, trackType: 'char_resource', label: resMap[tagK].name, sublabel: resMap[tagK].sublabel });
    }

    // Faction standings (party-level; player scope only at runtime).
    for (const f of (cfg2.factions || [])) {
        const sub3 = (f.relationshipStates || []).join(' → ');
        items.push({ pickId: 'fac:' + f.id, tag: f.id, trackType: 'faction', label: f.name + ' Standing', sublabel: sub3 });
    }

    // Relationship stage — advances/retreats the character's primaryRelationship stageIndex.
    // Applies to __player__ or __target__ scope; most useful on the Target side.
    items.push({ pickId: 'rel_stage', tag: '__rel_stage__', trackType: 'rel_stage', label: 'Relationship Stage', sublabel: 'advance or retreat the character\'s relationship arc stage' });

    return items;
}

// Resolve a stored StakeBandSide to a human-readable label for the button.
function stakeTrackDisplayLabel(tag2: string, trackType2: string, cfg2: GlobalConfig): string {
    if (trackType2 === 'rel_stage') return 'Relationship Stage';
    if (!tag2) return 'None';
    if (trackType2 === 'faction') {
        const ff = (cfg2.factions || []).find(function(f: any) { return f.id === tag2; });
        return ff ? ff.name + ' Standing' : tag2;
    }
    // char_resource: search cfg.resources first, fall back to stripping #.
    const rr = (cfg2.resources || []).find(function(r: any) { return r.tag === tag2; });
    return rr ? rr.name : tag2.replace(/^#/, '');
}

// Four F-skill attribute tags (no # — normalized for display; stored with # for compat).
const STAKE_F_SKILLS: { tag: string; label: string }[] = [
    { tag: '#force',   label: 'Force'   },
    { tag: '#finesse', label: 'Finesse' },
    { tag: '#focus',   label: 'Focus'   },
    { tag: '#flair',   label: 'Flair'   }
];

async function buildActionTab(): Promise<UIPart[]> {
    const cfg = await loadConfig();
    const parts: UIPart[] = [];

    // ── Last Action Diagnostic ────────────────────────────────────────────────
    const diagLog  = await api.v1.tempStorage.getOrDefault('ce_diagnostic_log', []) as UIPart[];
    const lastRollDiag = await api.v1.tempStorage.getOrDefault('ae_last_roll', null) as any;
    const diagContent: UIPart[] = [];
    diagContent.push({ type: 'text', text: 'Live readout of the last probability check or action roll.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } } as UIPart);
    if (lastRollDiag && lastRollDiag.name) {
        diagContent.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.25)', padding: '8px', borderRadius: '4px', marginBottom: '6px' }, content: [
            { type: 'text', text: '[ Action: ' + lastRollDiag.name + ' ]', style: { color: '#88ccff', fontFamily: 'monospace', fontSize: '11px', marginBottom: '2px' } } as UIPart,
            { type: 'text', text: 'Roll: ' + lastRollDiag.breakdown, style: { fontFamily: 'monospace', fontSize: '11px', marginBottom: '2px' } } as UIPart,
            { type: 'text', text: 'Result: ' + (lastRollDiag.success ? '\u2713 ' : '\u2717 ') + (lastRollDiag.band || (lastRollDiag.success ? 'Success' : 'Failure')), style: { fontFamily: 'monospace', fontSize: '11px', color: lastRollDiag.success ? '#7ec8a0' : '#ff6b6b' } } as UIPart,
            // [v1.6.3 ROLL-DELTAS] Show the resource changes from the fired branch, if any.
            ...((Array.isArray(lastRollDiag.deltas) && lastRollDiag.deltas.length > 0) ? [{ type: 'text', text: 'Changes: ' + lastRollDiag.deltas.join(', '), style: { fontFamily: 'monospace', fontSize: '11px', marginTop: '2px', color: '#d8b46a' } } as UIPart] : [])
        ] } as UIPart);
    }
    if (diagLog && diagLog.length > 0) {
        diagContent.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '8px', borderRadius: '4px', fontFamily: 'monospace', fontSize: '11px' }, content: diagLog } as UIPart);
    }
    if (!lastRollDiag && (!diagLog || diagLog.length === 0)) {
        diagContent.push({ type: 'text', text: 'No actions logged this session.', style: { opacity: '0.5', fontSize: '11px' } } as UIPart);
    }
    parts.push({ type: 'collapsibleSection', title: '\ud83d\udd0d Last Action Diagnostic', initialCollapsed: true, storageKey: 'temp:ce_diag_panel', content: diagContent } as UIPart);

    // ========================================================================
    // SECTION 1: STAKES LIBRARY
    // ========================================================================
    // [vNEXT] Replaces the old dead "Default Engine" picker (wrote a field nothing
    // read) and the Custom Rank Modifiers / Default Outcomes editors (which only fed
    // the now-retired freeform #tag 1d6 roller). Stakes are named, editable wagers
    // for the Quick Action composer's Stakes picker — each is its own band x side
    // table (Strong Hit / Partial / Failure, Player / Target), independent resources
    // and signed amounts per slot. A blank tag means no effect for that slot.
    const stakeRows: UIPart[] = [];
    stakeRows.push({ type: 'text', text: 'Define what each side risks or gains on a 2d6 check. Leave a tag blank for no effect on that slot; amount can be negative (cost) or positive (gain).', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

    const stakeBandDefs: { key: 'strong' | 'partial' | 'miss'; label: string }[] = [
        { key: 'strong',  label: '✨ Strong Hit' },
        { key: 'partial', label: '⚠️ Partial' },
        { key: 'miss',    label: '✗ Failure' }
    ];

    (cfg.stakeDefs || []).forEach(function(sd: any, si: number) {
        // [v0.9.8.4] Rebuilt with F-skill toggle pills + openPickerModal track picker.
        const stakeBox: UIPart[] = [];

        // ─ Name + Delete ──────────────────────────────────────────────────────────────────────────
        stakeBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
            { type: 'textInput', initialValue: sd.name, placeholder: 'Stake name', style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.stakeDefs[si].name = v; }); } },
            { type: 'button', iconId: 'trash', style: { margin: 0 }, callback: async function() { await mutConfig(function(c) { c.stakeDefs.splice(si, 1); }); await refreshSidebar(); } }
        ] });

        // ─ Default F-skill toggles ────────────────────────────────────────────────────────
        stakeBox.push({ type: 'text', text: 'Auto-selects for:', style: { fontSize: '10px', opacity: '0.6', marginBottom: '3px' } });
        const attrs2 = sd.defaultForAttrs || [];
        const skillPills: UIPart[] = STAKE_F_SKILLS.map(function(sk) {
            const on2 = attrs2.indexOf(sk.tag) >= 0;
            return { type: 'button', text: sk.label, style: { margin: '0 3px 3px 0', padding: '2px 10px', fontSize: '10px', borderRadius: '10px', backgroundColor: on2 ? 'rgba(136,204,255,0.25)' : 'transparent', border: '1px solid ' + (on2 ? '#88ccff' : 'rgba(255,255,255,0.2)'), color: on2 ? '#88ccff' : 'inherit' }, callback: async function() {
                await mutConfig(function(c) {
                    let cur2 = c.stakeDefs[si].defaultForAttrs || [];
                    if (cur2.indexOf(sk.tag) >= 0) cur2 = cur2.filter(function(a2: string) { return a2 !== sk.tag; });
                    else cur2 = cur2.concat([sk.tag]);
                    c.stakeDefs[si].defaultForAttrs = cur2;
                });
                await refreshSidebar();
            } } as UIPart;
        });
        stakeBox.push({ type: 'row', style: { gap: '0px', flexWrap: 'wrap', marginBottom: '8px' }, content: skillPills });

        // ─ Per-band side pickers ──────────────────────────────────────────────────────────
        // trkItems preloaded above before forEach.
        const bandDefs2: { key: 'strong' | 'partial' | 'miss'; label: string; color: string }[] = [
            { key: 'strong',  label: 'Strong Hit (10+)', color: '#7ec8a0' },
            { key: 'partial', label: 'Partial (7–9)',    color: '#e0b341' },
            { key: 'miss',    label: 'Failure (≤6)',      color: '#e74c4c' }
        ];
        bandDefs2.forEach(function(bd2) {
            const band2 = sd[bd2.key] || { player: { tag: '', amount: 0 }, target: { tag: '', amount: 0 } };
            stakeBox.push({ type: 'text', text: bd2.label, style: { fontSize: '10px', fontWeight: 'bold', color: bd2.color, marginTop: '6px', marginBottom: '4px' } });

            ['player', 'target'].forEach(function(side2: string) {
                const side2Obj = (band2 as any)[side2] as StakeBandSide;
                const curTag2 = side2Obj.tag || '';
                const curType2 = side2Obj.type || 'char_resource';
                const curAmt2  = side2Obj.amount || 0;
                const dispLbl2 = stakeTrackDisplayLabel(curTag2, curType2, cfg);

                // Track picker button
                const trackBtnParts: UIPart[] = [
                    { type: 'text', text: side2 === 'player' ? 'Player' : 'Target', style: { fontSize: '10px', opacity: '0.5', width: '38px', flexShrink: '0' } },
                    { type: 'button', text: dispLbl2, style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: curTag2 ? 'rgba(136,204,255,0.08)' : 'transparent', border: '1px solid rgba(255,255,255,0.15)' }, callback: async function() {
                        // [v0.9.8.5] selId2 uses tag-keyed pickIds ('res:<tag>', 'fac:<id>', 'rel_stage').
                        const selId2 = curType2 === 'rel_stage' ? 'rel_stage'
                            : curType2 === 'faction' ? (curTag2 ? 'fac:' + curTag2 : '')
                            : (curTag2 ? 'res:' + curTag2 : '');
                        await openPickerModal({
                            title: 'Pick Track — ' + (side2 === 'player' ? 'Player' : 'Target'),
                            items: trkItems,
                            getId: function(it: any) { return it.pickId; },
                            getLabel: function(it: any) { return it.label; },
                            getSublabel: function(it: any) { return it.sublabel || undefined; },
                            selectedId: selId2,
                            searchable: trkItems.length > 6,
                            pinnedOptions: [{ id: 'none', label: 'None', sublabel: 'No effect', onSelect: async function() {
                                await mutConfig(function(c: any) { c.stakeDefs[si][bd2.key][side2].tag = ''; c.stakeDefs[si][bd2.key][side2].type = 'char_resource'; c.stakeDefs[si][bd2.key][side2].amount = 0; });
                                await refreshSidebar();
                            } }],
                            onSelect: async function(it: any) {
                                await mutConfig(function(c: any) { c.stakeDefs[si][bd2.key][side2].tag = it.tag; c.stakeDefs[si][bd2.key][side2].type = it.trackType; });
                                await refreshSidebar();
                            },
                            emptyText: 'No tracks defined. Add Resources or Factions first.'
                        });
                    } },
                    // Amount stepper (only shown when a track is picked)
                    ...(curTag2 ? [
                        { type: 'button', text: '−', style: { margin: 0, padding: '2px 8px', fontWeight: 'bold' }, callback: async function() { await mutConfig(function(c: any) { c.stakeDefs[si][bd2.key][side2].amount = (c.stakeDefs[si][bd2.key][side2].amount || 0) - 1; }); await refreshSidebar(); } } as UIPart,
                        { type: 'text', text: String(curAmt2 > 0 ? '+' + curAmt2 : curAmt2), style: { fontSize: '12px', fontWeight: 'bold', minWidth: '28px', textAlign: 'center', color: curAmt2 > 0 ? '#7ec8a0' : curAmt2 < 0 ? '#e74c4c' : 'inherit' } } as UIPart,
                        { type: 'button', text: '+', style: { margin: 0, padding: '2px 8px', fontWeight: 'bold' }, callback: async function() { await mutConfig(function(c: any) { c.stakeDefs[si][bd2.key][side2].amount = (c.stakeDefs[si][bd2.key][side2].amount || 0) + 1; }); await refreshSidebar(); } } as UIPart
                    ] : [])
                ];
                stakeBox.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: trackBtnParts });
            });
        });

        stakeRows.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.25)', padding: '8px', borderRadius: '4px', marginBottom: '8px' }, content: stakeBox });
    });

    if (!cfg.stakeDefs || cfg.stakeDefs.length === 0) {
        stakeRows.push({ type: 'text', text: 'No stakes defined.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });
    }

    const trkItems = await buildStakeTrackItems(cfg);
    stakeRows.push({ type: 'button', text: '+ Add Stake', style: { marginTop: '2px', fontSize: '11px' }, callback: async () => {
        await mutConfig(c => {
            if (!c.stakeDefs) c.stakeDefs = [];
            c.stakeDefs.push({
                id: 'stake_' + generateId(), name: 'New Stake', defaultForAttrs: [],
                strong:  { player: { tag: '', amount: 0 }, target: { tag: '', amount: 0 } },
                partial: { player: { tag: '', amount: 0 }, target: { tag: '', amount: 0 } },
                miss:    { player: { tag: '', amount: 0 }, target: { tag: '', amount: 0 } }
            });
        });
        await refreshSidebar();
    } });

    parts.push({
        type: 'collapsibleSection',
        title: '⚖️ Stakes Library',
        initialCollapsed: true,
        storageKey: 'temp:ae_stakes_library',
        content: stakeRows
    });

    // ========================================================================
    // SECTION 2: GLOBAL ACTION LIBRARY (TEMPLATES)
    // ========================================================================
    parts.push({ type: 'row', spacing: 'space-between', alignment: 'center', style: { marginTop: '12px', marginBottom: '8px' }, content: [
        { type: 'text', text: '📚 Action Library', style: { fontWeight: 'bold', fontSize: '13px' } },
        { type: 'button', text: '+ New Action', style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(126,200,160,0.2)' }, callback: async () => { 
            const newId = generateId(); 
            await mutConfig(c => {
                if (!c.actionTemplates) c.actionTemplates = [];
                c.actionTemplates.push({ id: newId, name: 'New Action', conditions: [], successEffects: [], alwaysEffects: [] });
            });
            await openActionBuilderModal(newId); 
            await refreshSidebar();
        } }
    ]});

    const templates = cfg.actionTemplates || [];
    if (templates.length === 0) {
        parts.push({ type: 'text', text: 'No global actions created yet.', style: { fontSize: '11px', opacity: '0.6', fontStyle: 'italic', textAlign: 'center', margin: '16px 0' } });
    } else {
        // Search + tag filter (only worth showing once the library grows)
        const libTerm = ((await api.v1.tempStorage.getOrDefault('temp:ce_lib_search', '')) as string).toLowerCase();
        const libTag = (await api.v1.tempStorage.getOrDefault('temp:ce_lib_tag', '')) as string;
        const allTags: string[] = [];
        templates.forEach((t: any) => { (t.tags || []).forEach((tg: string) => { if (tg && allTags.indexOf(tg) < 0) allTags.push(tg); }); });

        if (templates.length > 5) {
            parts.push({ type: 'textInput', placeholder: '🔍 Search actions…', initialValue: libTerm, onChange: async (v: string) => { await api.v1.tempStorage.set('temp:ce_lib_search', v); await refreshSidebar(); } });
        }
        if (allTags.length > 0) {
            const tagBtns: UIPart[] = [
                { type: 'button', text: libTag ? 'All' : '• All', style: { margin: '0 4px 4px 0', padding: '2px 8px', fontSize: '10px', backgroundColor: libTag ? 'rgba(255,255,255,0.04)' : 'rgba(126,200,160,0.2)' }, callback: async () => { await api.v1.tempStorage.set('temp:ce_lib_tag', ''); await refreshSidebar(); } } as UIPart
            ];
            allTags.forEach((tg) => { tagBtns.push({ type: 'button', text: (libTag === tg ? '• ' : '') + tg, style: { margin: '0 4px 4px 0', padding: '2px 8px', fontSize: '10px', backgroundColor: libTag === tg ? 'rgba(126,200,160,0.2)' : 'rgba(255,255,255,0.04)' }, callback: async () => { await api.v1.tempStorage.set('temp:ce_lib_tag', tg); await refreshSidebar(); } } as UIPart); });
            parts.push({ type: 'row', style: { flexWrap: 'wrap', marginBottom: '6px' }, content: tagBtns });
        }

        const filtered = templates.filter((t: any) => {
            if ((t.tags || []).includes('_travel')) return false;  // internal travel actions — not in library
            if (libTerm && !(t.name || '').toLowerCase().includes(libTerm)) return false;
            if (libTag && (!(t.tags) || t.tags.indexOf(libTag) < 0)) return false;
            return true;
        });
        if (!filtered.length) parts.push({ type: 'text', text: 'No actions match the filter.', style: { fontSize: '11px', opacity: '0.5', textAlign: 'center', margin: '12px 0' } });
        filtered.forEach((template: any) => {
            const tagLine = (template.tags && template.tags.length) ? ('  🏷 ' + template.tags.join(', ')) : '';
            parts.push({
                type: 'box', style: { backgroundColor: 'rgba(255,255,255,0.03)', padding: '8px', borderRadius: '4px', marginBottom: '6px', borderLeft: '3px solid #88ccff' }, content: [
                    { type: 'row', spacing: 'space-between', alignment: 'center', content: [
                        { type: 'text', text: template.name + (template.autoTrigger ? '  ⚙' : ''), style: { fontWeight: 'bold' } },
                        { type: 'row', style: { gap: '4px' }, content: [
                            { type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px' }, callback: async () => { await openActionBuilderModal(template.id); } },
                            { type: 'button', text: '📡 Push', style: { margin: 0, padding: '4px 6px', fontSize: '10px', backgroundColor: 'transparent', color: '#ffb432' }, callback: async () => {
                                let updateCount = 0;
                                if (template.id === 'sys_default_travel') {
                                    const travelTemplates = (cfg.actionTemplates || []).filter(function(t: any) {
                                        return t.id !== 'sys_default_travel' && t.tags && t.tags.includes('_travel');
                                    });
                                    for (const tpl of travelTemplates) {
                                        const oldId = tpl.id;
                                        const oldName = tpl.name;
                                        const oldTags = tpl.tags;
                                        const oldHidden = tpl.hidden;
                                        Object.assign(tpl, JSON.parse(JSON.stringify(template)));
                                        tpl.id = oldId;
                                        tpl.name = oldName;
                                        tpl.tags = oldTags;
                                        tpl.hidden = oldHidden;
                                        updateCount++;
                                    }
                                    await saveConfig(cfg);
                                } else {
                                    const pushEntIdx = await loadEntityIndex();
                                    for (const m of pushEntIdx) {
                                        const entForUpdate = await loadEntity(m.id);
                                        if (!entForUpdate) continue;
                                        let changed = false;
                                        const insts = (entForUpdate as any).actionInstances || [];
                                        for (let j = 0; j < insts.length; j++) {
                                            if (insts[j].templateId === template.id || insts[j].name === template.name) {
                                                const oldId = insts[j].id;
                                                insts[j] = JSON.parse(JSON.stringify(template));
                                                insts[j].id = oldId;
                                                insts[j].templateId = template.id;
                                                changed = true;
                                                updateCount++;
                                            }
                                        }
                                        if (changed) await saveEntity(entForUpdate);
                                    }
                                }
                                api.v1.ui.toast(`Pushed template update to ${updateCount} child instances.`, { type: 'success' });
                                queueSceneStateBroadcast();
                            } },
                            { type: 'button', text: '📋', style: { margin: 0, padding: '4px', fontSize: '12px', backgroundColor: 'transparent' }, callback: async () => {
                                const dupId = generateId();
                                const dupSrc = JSON.parse(JSON.stringify(template));
                                dupSrc.id   = dupId;
                                dupSrc.name = (dupSrc.name || 'Action') + ' (Copy)';
                                (dupSrc.conditions    || []).forEach(function(r: any) { r.id = generateId(); });
                                (dupSrc.successEffects|| []).forEach(function(r: any) { r.id = generateId(); });
                                (dupSrc.failureEffects|| []).forEach(function(r: any) { r.id = generateId(); });
                                (dupSrc.alwaysEffects || []).forEach(function(r: any) { r.id = generateId(); });
                                await mutConfig(function(c: any) {
                                    if (!c.actionTemplates) c.actionTemplates = [];
                                    c.actionTemplates.push(dupSrc);
                                });
                                await openActionBuilderModal(dupId);
                                await refreshSidebar();
                            } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '4px', color: '#ff6b6b', display: (template.id === 'sys_default_travel' || template.id === 'sys_return_travel' || template.id === 'sys_default_resolution') ? 'none' : '' }, callback: async () => { 
                                await mutConfig(c => c.actionTemplates = c.actionTemplates.filter((t:any) => t.id !== template.id)); 
                                await refreshSidebar(); 
                            } }
                        ]}
                    ]},
                    { type: 'text', text: `${template.conditions?.length || 0} Conditions | ${template.successEffects?.length || 0} Effects${tagLine}`, style: { fontSize: '10px', opacity: '0.5', marginTop: '4px' } }
                ]
            });
        });
    }

    return parts;
}

// ============================================================================
// SECTION 3: ACTION STUDIO MODAL & UI MANIFEST (⚠️ under development)
// ============================================================================

type UIArgType = 'string' | 'number' | 'longtext' | 'select' | 'scope';
interface UIRuleArg { key: string; label: string; type: UIArgType; optionsSource?: string; placeholder?: string; }
interface UIRuleDef { name: string; desc: string; args: UIRuleArg[]; }

const SCOPE_ARG: UIRuleArg = { key: 'scope', label: 'Applies to', type: 'scope' };

const UIRuleManifest: Record<string, UIRuleDef> = {
    // ── CONDITIONS ──
    'has_resource':       { name: 'Requires Resource (Global)', desc: 'A global/world resource must be at least N. (For a character\u2019s personal resource use Character Resource.)', args: [{ key: 'tag', label: 'Resource', type: 'select', optionsSource: 'resource' }, { key: 'minAmount', label: 'Min Amount', type: 'number' }] },
    'field_equals':       { name: 'Raw Field Check', desc: 'Escape hatch: a named record field must equal a value (advanced).', args: [SCOPE_ARG, { key: 'field', label: 'Field', type: 'string', placeholder: 'isLocked' }, { key: 'value', label: 'Equals', type: 'string' }] },
    'entity_state':       { name: 'Entity State Is', desc: 'The entity\u2019s current default/atmosphere state must match.', args: [SCOPE_ARG, { key: 'state', label: 'State', type: 'select', optionsSource: 'entityState' }] },
    'entity_story_state': { name: 'Story State Is', desc: 'Narrative gate state (locked / active / completed).', args: [SCOPE_ARG, { key: 'value', label: 'Story State', type: 'select', optionsSource: 'storyState' }] },
    'entity_locked':      { name: 'Gate Is', desc: 'Whether the entity\u2019s travel/interaction gate is locked.', args: [SCOPE_ARG, { key: 'value', label: 'Locked', type: 'select', optionsSource: 'bool' }] },
    'entity_parent':      { name: 'Located In', desc: 'The entity\u2019s parent (containing location) must match.', args: [SCOPE_ARG, { key: 'parentId', label: 'Parent', type: 'select', optionsSource: 'locationParent' }] },
    'is_equipped':        { name: 'Is Equipped', desc: 'Whether the item entity is currently equipped.', args: [SCOPE_ARG, { key: 'value', label: 'Equipped', type: 'select', optionsSource: 'bool' }] },
    'in_vehicle':         { name: 'Player Is In Vehicle', desc: 'Passes when the protagonist is inside a vehicle entity. Use on travel actions to gate ship/vehicle-only routes.', args: [] },
    'char_scene_present': { name: 'Character In Scene', desc: 'Whether the character is currently present in the scene.', args: [SCOPE_ARG, { key: 'value', label: 'Present', type: 'select', optionsSource: 'bool' }] },
    'char_active':        { name: 'Character Alive', desc: 'Whether the character is active (not killed/removed).', args: [SCOPE_ARG, { key: 'value', label: 'Active', type: 'select', optionsSource: 'bool' }] },
    'char_faction':       { name: 'Character Faction Standing', desc: 'A character\u2019s standing with a faction must match.', args: [SCOPE_ARG, { key: 'factionId', label: 'Faction', type: 'select', optionsSource: 'faction' }, { key: 'state', label: 'Standing', type: 'select', optionsSource: 'factionState' }] },
    // [PATCH v0998] amount retyped string -> number: indices are the canonical
    // representation now (see Character Resources editor). Legacy string state-names
    // (e.g. "dead") are resolved to their index once by migrateConfig, not re-parsed
    // on every evaluation — aeResolveResourceCompareValue's name-lookup fallback
    // still exists at runtime as a safety net for anything the migration missed.
    'char_resource':      { name: 'Character Resource', desc: 'Compare a character resource. For a pool, enter its number. For a track/condition, enter the state index (0 = first) — e.g. a Health track of Dead→Healthy, 0 = Dead.', args: [SCOPE_ARG, { key: 'tag', label: 'Resource', type: 'select', optionsSource: 'charResource' }, { key: 'op', label: 'Compare', type: 'select', optionsSource: 'compareOp' }, { key: 'amount', label: 'Value or Index', type: 'number', placeholder: '0 = first state' }] },
    'player_faction':     { name: 'Party Faction Standing', desc: 'The party\u2019s shared standing with a faction must match (the whole party\u2019s standing, distinct from a single character\u2019s).', args: [{ key: 'factionId', label: 'Faction', type: 'select', optionsSource: 'faction' }, { key: 'state', label: 'Standing', type: 'select', optionsSource: 'factionState' }] },
    'rel_archetype':      { name: 'Relationship Archetype Is', desc: 'A character\u2019s primary-relationship archetype must match.', args: [SCOPE_ARG, { key: 'archetypeId', label: 'Archetype', type: 'select', optionsSource: 'archetype' }] },
    'rel_stage':          { name: 'Relationship Stage', desc: 'Compare a character\u2019s relationship stage index (0 = earliest).', args: [SCOPE_ARG, { key: 'op', label: 'Compare', type: 'select', optionsSource: 'compareOp' }, { key: 'amount', label: 'Stage Index', type: 'number' }] },
    // [PATCH v0998] amount retyped string -> number, same rationale as char_resource.
    'char_skill':         { name: 'Character Skill / Attribute', desc: 'Compare a character\u2019s skill or attribute. Numeric attributes (the Four Fs) compare by value; ladder (enum) skills compare by their index (0 = lowest rung). Pick the value from the index-labelled list.', args: [SCOPE_ARG, { key: 'fieldRef', label: 'Skill', type: 'select', optionsSource: 'skillField' }, { key: 'op', label: 'Compare', type: 'select', optionsSource: 'compareOp' }, { key: 'amount', label: 'Value or Rung', type: 'number', optionsSource: 'skillFieldState', placeholder: '2  or  pick a rung' }] },
    'resource_state':     { name: 'Global Resource State (Track)', desc: 'Compare a global/world track resource\u2019s current state index (0 = first state).', args: [{ key: 'tag', label: 'Resource', type: 'select', optionsSource: 'resource' }, { key: 'op', label: 'Compare', type: 'select', optionsSource: 'compareOp' }, { key: 'state', label: 'State', type: 'select', optionsSource: 'resourceState' }] },
    'time_between':       { name: 'Time of Day Between', desc: 'Passes when the current hour-of-day is in the window (start inclusive, end exclusive). If start is later than end the window wraps past midnight (22 to 6 = night).', args: [{ key: 'startHour', label: 'From hour (0-23)', type: 'number' }, { key: 'endHour', label: 'To hour (0-23)', type: 'number' }] },
    'time_band_is':       { name: 'Time Band Is', desc: 'Passes when the current time falls in a named band (Morning, Evening, ...). Bands are defined in World Settings.', args: [{ key: 'band', label: 'Band', type: 'select', optionsSource: 'timeBand' }] },
    'day_of_cycle_is':    { name: 'Day of Cycle Is', desc: 'Compare the day within the 28-day cycle (1-28). Recurs every cycle - use for "every Day 14" style events.', args: [{ key: 'op', label: 'Compare', type: 'select', optionsSource: 'compareOp' }, { key: 'day', label: 'Day (1-28)', type: 'number' }] },
    'day_of_week_is':     { name: 'Day of Week Is', desc: 'Passes on a specific weekday (1-7). Recurs weekly - use for "market day" style events.', args: [{ key: 'dayOfWeek', label: 'Weekday', type: 'select', optionsSource: 'dayOfWeek' }] },
    'date_is':            { name: 'Absolute Day Is', desc: 'Compare the absolute day count since the campaign began (0-based, climbs forever). For one-time dated events and countdowns - e.g. at least 45 fires on/after the 46th day.', args: [{ key: 'op', label: 'Compare', type: 'select', optionsSource: 'compareOp' }, { key: 'day', label: 'Absolute day', type: 'number' }] },
    // ── EFFECTS ──
    'advance_time':           { name: 'Advance Time', desc: 'Adds whole hours to the world clock (relative). Use for travel/rest costs; drop it in any effect bucket. Time-gated auto-triggers re-evaluate on the next generation, not mid-effect.', args: [{ key: 'hours', label: 'Hours', type: 'number' }] },
    'set_time':               { name: 'Set Time (Next Occurrence)', desc: 'Jumps the clock FORWARD to the next time it is this hour-of-day (never rewinds, so order and countdowns stay intact). Set to 6 = sleep until morning.', args: [{ key: 'hour', label: 'Hour (0-23)', type: 'number' }] },
    'modify_resource':        { name: 'Modify Global Resource', desc: 'Add / subtract / set a global world resource such as a shared supply or a world counter. Values are numeric; for a track resource the value is the state index (0 = first state). Use Modify Character Resource for personal resources like gold or health.', args: [{ key: 'tag', label: 'Resource', type: 'select', optionsSource: 'resource' }, { key: 'op', label: 'Operation', type: 'select', optionsSource: 'resOp' }, { key: 'amount', label: 'Amount', type: 'number' }] },
    'move_player_to_self':    { name: 'Move Player Here', desc: 'Commits protagonist movement to this entity (the destination). Place AFTER inject_narrative in successEffects. Handles body move, scene presence, auto-triggers, and generation.', args: [] },
    'inject_narrative':       { name: 'Inject Story Text', desc: 'Writes a line into the story. Supports {Actor} / {Target}.', args: [{ key: 'text', label: 'Flavor Text', type: 'longtext', placeholder: '{Actor} strikes {Target}!' }] },
    'set_entity_state':       { name: 'Set Entity State', desc: 'Switch the entity\u2019s default/atmosphere state.', args: [SCOPE_ARG, { key: 'state', label: 'State', type: 'select', optionsSource: 'entityState' }] },
    'set_entity_story_state': { name: 'Set Story State', desc: 'Lock / activate / complete a narrative gate.', args: [SCOPE_ARG, { key: 'value', label: 'Story State', type: 'select', optionsSource: 'storyState' }] },
    'set_entity_locked':      { name: 'Set Gate', desc: 'Lock or unlock an entity\u2019s gate.', args: [SCOPE_ARG, { key: 'value', label: 'Locked', type: 'select', optionsSource: 'bool' }] },
    'set_entity_parent':      { name: 'Move Entity', desc: 'Relocate the entity to a new parent location.', args: [SCOPE_ARG, { key: 'parentId', label: 'Move To', type: 'select', optionsSource: 'locationParent' }] },
    'set_equipped':           { name: 'Equip / Unequip Item', desc: 'Equip or unequip an item entity to a character.', args: [{ key: 'itemScope', label: 'Item', type: 'scope' }, { key: 'charScope', label: 'On Character', type: 'scope' }, { key: 'mode', label: 'Mode', type: 'select', optionsSource: 'equipOp' }] },
    'set_char_scene':         { name: 'Set Scene Presence', desc: 'Bring a character into / out of the scene.', args: [SCOPE_ARG, { key: 'value', label: 'Present', type: 'select', optionsSource: 'bool' }] },
    'set_char_active':        { name: 'Set Character Active', desc: 'Switch a character to Active (or Inactive). Active characters appear in the index, dramatis personae, and receive auto-dynamics.', args: [SCOPE_ARG, { key: 'value', label: 'Active', type: 'select', optionsSource: 'bool' }] },
    'set_char_sheet':         { name: '📝 Set Character Sheet Field', desc: 'Set a value on a character sheet category→field. Supports {Actor}/{Target} in the value.', args: [SCOPE_ARG, { key: 'fieldRef', label: 'Field', type: 'select', optionsSource: 'sheetField' }, { key: 'value', label: 'Value', type: 'string', optionsSource: 'sheetFieldValue', placeholder: 'New value' }] },
    'kill_char':              { name: '\ud83d\udc80 Kill Character', desc: 'Deactivate a character (drops inventory in their room).', args: [SCOPE_ARG] },
    'spawn_minor_npc':        { name: '🐾 Spawn Minor NPC', desc: 'Creates one or more minor NPCs from a Bestiary archetype at the player\u2019s current location. {a|b|c} alternations in the archetype expand per instance. Put different counts on different resolution bands for encounter variety.', args: [{ key: 'archetypeId', label: 'Archetype', type: 'select', optionsSource: 'npcArchetype' }, { key: 'count', label: 'How many (1-10)', type: 'number' }] },
    'generate_image':         { name: '📸 Generate Image', desc: 'Fires an image through the bridge (same pipeline as Snapshot) and drops it into a captioned phantom widget, saved to the gallery. The Prompt is appended after the scene tags. In Character 1 / 2, type a name or a macro \u2014 each matched character\u2019s stored visual tags are pulled in automatically. Header and Body caption the phantom widget. All text fields support {Actor} / {Target} / __self__ / __target__. Requires the bridge; no-op in native-only mode.', args: [{ key: 'prompt', label: 'Prompt (extra tags / prose)', type: 'longtext', placeholder: '{Target} recoiling, dramatic lighting, wide shot' }, { key: 'char1', label: 'Character 1 (name or macro)', type: 'string', placeholder: '{Actor}' }, { key: 'char2', label: 'Character 2 (name or macro)', type: 'string', placeholder: '{Target}' }, { key: 'header', label: 'Caption Header', type: 'string', placeholder: 'A Sudden Betrayal' }, { key: 'body', label: 'Caption Body', type: 'longtext', placeholder: '{Actor} turns on {Target} without warning\u2026' }, { key: 'includeScene', label: 'Include scene tags', type: 'select', optionsSource: 'bool' }] },
    'set_char_faction':       { name: 'Set Character Faction', desc: 'Set a character\u2019s standing with a faction.', args: [SCOPE_ARG, { key: 'factionId', label: 'Faction', type: 'select', optionsSource: 'faction' }, { key: 'state', label: 'Standing', type: 'select', optionsSource: 'factionState' }] },
    'modify_char_resource':   { name: 'Modify Character Resource', desc: 'Add / subtract / set a personal resource on the targeted character (set Applies to = The Player for the protagonist). Higher value is better/more; for a track resource the value is the state index that translates to a label (e.g. Health: higher = healthier).', args: [SCOPE_ARG, { key: 'tag', label: 'Resource', type: 'select', optionsSource: 'charResource' }, { key: 'op', label: 'Operation', type: 'select', optionsSource: 'resOp' }, { key: 'amount', label: 'Amount', type: 'number' }] },
    'set_player_faction':     { name: 'Set Party Faction', desc: 'Set the party\u2019s shared standing with a faction (party-wide, distinct from a single character\u2019s standing).', args: [{ key: 'factionId', label: 'Faction', type: 'select', optionsSource: 'faction' }, { key: 'state', label: 'Standing', type: 'select', optionsSource: 'factionState' }] },
    'set_rel_archetype':      { name: 'Set Relationship Archetype', desc: 'Switch a character\u2019s archetype (resets stage to 0 unless told otherwise).', args: [SCOPE_ARG, { key: 'archetypeId', label: 'Archetype', type: 'select', optionsSource: 'archetype' }, { key: 'keepStage', label: 'Keep Stage', type: 'select', optionsSource: 'bool' }] },
    'modify_rel_stage':       { name: 'Modify Relationship Stage', desc: 'Advance / retreat / set a character\u2019s stage. +amount moves toward the LAST (warmest) stage, -amount toward the FIRST (coldest). Clamped to defined stages.', args: [SCOPE_ARG, { key: 'op', label: 'Operation', type: 'select', optionsSource: 'resOp' }, { key: 'amount', label: 'Amount (+ = toward warmest)', type: 'number' }] },
    'modify_char_skill':      { name: 'Modify Character Skill / Attribute', desc: 'Add / subtract / set a character\u2019s skill or attribute. For a ladder (enum) skill the amount is rungs to move (set = target rung index); for a numeric attribute it is the value. Clamped to the field\u2019s range. Higher = stronger.', args: [SCOPE_ARG, { key: 'fieldRef', label: 'Skill', type: 'select', optionsSource: 'skillField' }, { key: 'op', label: 'Operation', type: 'select', optionsSource: 'resOp' }, { key: 'amount', label: 'Amount', type: 'number' }] },
    'set_resource_state':     { name: 'Set Global Resource State (Track)', desc: 'Set a global/world track resource to a specific state (index-labelled picker).', args: [{ key: 'tag', label: 'Resource', type: 'select', optionsSource: 'resource' }, { key: 'state', label: 'State', type: 'select', optionsSource: 'resourceState' }] },
    'add_hook':               { name: 'Add Narrative Hook', desc: 'Plants a pressurised story tension on a character. Surfaces in hooks panel and context.', args: [SCOPE_ARG, { key: 'description', label: 'Hook', type: 'longtext', placeholder: 'She overheard what {Actor} said.' }, { key: 'pressure', label: 'Pressure (0-100)', type: 'number' }] },
    'add_modifier':           { name: 'Add Skill Modifier', desc: 'Temporary bonus or penalty to a skill. Reverts on undo. Pair with Remove Modifier to clear.', args: [{ key: 'charScope', label: 'Character', type: 'scope' }, { key: 'skillTag', label: 'Skill', type: 'select', optionsSource: 'skill' }, { key: 'delta', label: 'Bonus / Penalty', type: 'number' }, { key: 'label', label: 'Source Label', type: 'string', placeholder: 'Empowered Blade' }] },
    'remove_modifier':        { name: 'Remove Skill Modifier', desc: 'Clears all active modifiers for a character + skill tag. Pair with Add Modifier.', args: [{ key: 'charScope', label: 'Character', type: 'scope' }, { key: 'skillTag', label: 'Skill', type: 'select', optionsSource: 'skill' }] },
    'inject_message':         { name: 'Inject GM Message', desc: 'Hidden directive to the AI on next generation. Not written to the story document. Supports {Actor}/{Target}.', args: [{ key: 'text', label: 'Message', type: 'longtext', placeholder: 'Describe the explosion in vivid detail.' }] },
    'pop_up':                 { name: 'Pop-up Message', desc: 'Displays a message panel to the player. Not sent to the AI. Supports {Actor}/{Target}.', args: [{ key: 'title', label: 'Title', type: 'string', placeholder: 'Lore Reveal' }, { key: 'text', label: 'Body', type: 'longtext', placeholder: 'Message content...' }] },
    'chain_action':           { name: '⛓ Chain Action', desc: 'Runs another action (Library template or a specific entity’s action). Inherits actor + target; runs silently; max chain depth 5.', args: [{ key: 'source', label: 'From', type: 'select', optionsSource: 'chainSource' }, { key: 'actionId', label: 'Action', type: 'select', optionsSource: 'chainAction' }] },
    'ask_text':               { name: '❓ Ask "How do you do it?"', desc: 'Pauses and prompts the player with a free-text field titled "How do you do it?". Their answer becomes flavor composed into the next Inject Story Text effect — so place this BEFORE that effect. Supports {Actor}/{Target} in instructions.', args: [{ key: 'instructions', label: 'Dev Instructions (shown above field)', type: 'longtext', placeholder: 'Optional guidance to the player about this moment…' }, { key: 'placeholder', label: 'Field Helper Text (second person)', type: 'string', placeholder: 'e.g. drawing your blade slowly, eyes locked on theirs…' }] },
    // [v0.9.87 FIX] Was in AE_EFFECT_TYPES but had no manifest entry — crashed Add Effect picker with 'cannot read name of undefined'.
    'modify_faction_standing': { name: 'Modify Party Faction Standing', desc: 'Add or subtract steps from the party’s standing with a faction. Positive = toward most friendly state; negative = toward most hostile. Clamped to defined states.', args: [{ key: 'factionId', label: 'Faction', type: 'select', optionsSource: 'faction' }, { key: 'op', label: 'Operation', type: 'select', optionsSource: 'resOp' }, { key: 'amount', label: 'Steps', type: 'number' }] }
};

const AE_COND_TYPES = ['has_resource', 'entity_state', 'entity_story_state', 'entity_locked', 'entity_parent', 'is_equipped', 'in_vehicle', 'char_scene_present', 'char_active', 'char_faction', 'char_resource', 'char_skill', 'player_faction', 'rel_archetype', 'rel_stage', 'time_between', 'time_band_is', 'day_of_cycle_is', 'day_of_week_is', 'date_is', 'field_equals'];
const AE_EFFECT_TYPES = ['move_player_to_self', 'inject_narrative', 'inject_message', 'pop_up', 'add_hook', 'add_modifier', 'remove_modifier', 'modify_resource', 'set_entity_state', 'set_entity_story_state', 'set_entity_locked', 'set_entity_parent', 'set_equipped', 'set_char_scene', 'kill_char', 'set_char_faction', 'modify_char_resource', 'modify_char_skill', 'set_player_faction', 'modify_faction_standing', 'set_rel_archetype', 'modify_rel_stage', 'chain_action', 'ask_text', 'set_char_active', 'set_char_sheet', 'advance_time', 'set_time', 'spawn_minor_npc', 'generate_image'];

// [v0.9.16] Author-time data bundle — preloaded once at modal open. Replaces the
// per-template Reference Entity. entityStates: union of all entity state names;
// charResources: union of all character resource tags; charByEntityId: char lookup;
// instancesByEntityId: { id, name }[] of each entity's actionInstances (chain picker).
interface AEAuthorData {
    entityStates: { label: string; value: string }[];
    charResources: { label: string; value: string }[];
    charByEntityId: Record<string, CharacterRecord>;
    instancesByEntityId: Record<string, { id: string; name: string }[]>;
}

// Build select options synchronously from cfg + preloaded author data + entity index.
function aeSelectOptions(source: string, rule: any, cfg: GlobalConfig, authorData: AEAuthorData, entIdx: any[], allowAsk: boolean): { label: string; value: string }[] {
    let out: { label: string; value: string }[] = [];
    if (source === 'resource') {
        // [PATCH v0998] show the index range right in the picker, e.g. "Health (#health) [0-4]".
        out = (cfg.resources || []).map(function(r) {
            let rangeSfx = (r.type === 'track' && r.states && r.states.length) ? ` [0-${r.states.length - 1}]` : '';
            return { label: r.name + ' (' + r.tag + ')' + rangeSfx, value: r.tag };
        });
    } else if (source === 'charResource') {
        let csc = (rule && rule.args) ? String(rule.args.scope || rule.args.charScope || '') : '';
        let scopedChar = (csc && authorData.charByEntityId[csc]) ? authorData.charByEntityId[csc] : null;
        if (scopedChar && scopedChar.charResourceDefs) {
            out = scopedChar.charResourceDefs.map(function(r) {
                let rangeSfx = (r.type === 'track' && r.states && r.states.length) ? ` [0-${r.states.length - 1}]` : '';
                return { label: r.name + ' (' + r.tag + ')' + rangeSfx, value: r.tag };
            });
        } else {
            // [PATCH v0998] best-effort range lookup against the project template —
            // per-character defs can technically diverge, so this is a hint, not a guarantee.
            out = authorData.charResources.map(function(o) {
                let tdef = (cfg.characterResourceDefs || []).find(function(r) { return r.tag === o.value; });
                let rangeSfx = (tdef && tdef.type === 'track' && tdef.states && tdef.states.length) ? ` [0-${tdef.states.length - 1}]` : '';
                return rangeSfx ? { label: o.label + rangeSfx, value: o.value } : o;
            });
        }
    } else if (source === 'chainSource') {
        out.push({ label: '📚 Action Library', value: '__library__' });
        (entIdx || []).forEach(function(m) { out.push({ label: aeIconPfx(m.icon) + m.name + ' (' + m.type + ')', value: m.id }); });
    } else if (source === 'chainAction') {
        let csrc = (rule && rule.args) ? String(rule.args.source || '__library__') : '__library__';
        if (csrc === '__library__') {
            out = ((cfg.actionTemplates || []) as any[]).map(function(t) { return { label: (t.name || 'Action') + ((t.tags && t.tags.length) ? '  🏷 ' + t.tags.join(', ') : ''), value: t.id }; });
        } else {
            let insts = authorData.instancesByEntityId[csrc] || [];
            out = insts.map(function(i) { return { label: i.name || 'Action', value: i.id }; });
        }
    } else if (source === 'faction') {
        out = (cfg.factions || []).map(function(f) { return { label: f.name, value: f.id }; });
    } else if (source === 'factionState') {
        let fid = rule && rule.args ? rule.args.factionId : '';
        let fdef = (cfg.factions || []).find(function(f) { return f.id === fid; });
        if (fdef) { let _fn = (fdef.relationshipStates || []).length; out = (fdef.relationshipStates || []).map(function(s, i) { return { label: i + ' \u2014 ' + s + ' (of ' + (_fn - 1) + ')', value: String(i) }; }); }
    } else if (source === 'storyState') {
        out = [{ label: '\ud83d\udd12 Locked', value: 'locked' }, { label: '\ud83d\udd25 Active', value: 'active' }, { label: '\u2705 Completed', value: 'completed' }];
    } else if (source === 'bool') {
        out = [{ label: 'True', value: 'true' }, { label: 'False', value: 'false' }];
    } else if (source === 'entityState') {
        out = authorData.entityStates.slice();
    } else if (source === 'locationParent') {
        out.push({ label: '\ud83c\udf92 Player Inventory', value: '__player__' });
        out.push({ label: '\ud83d\udccd Current Room', value: '__current_room__' });
        out.push({ label: '\ud83c\udf0c Root (Void)', value: '__root__' });
        (entIdx || []).filter(function(n) { return n.type === 'location' || n.type === 'character'; }).forEach(function(l) { out.push({ label: (l.type === 'character' ? '\ud83d\udc64 ' : '\ud83c\udf0d ') + l.name, value: l.id }); });
    } else if (source === 'resourceState') {
        let rtag = rule && rule.args ? rule.args.tag : '';
        let rdef = (cfg.resources || []).find(function(r) { return r.tag === rtag; });
        if (rdef && rdef.states) { let _n = (rdef.states || []).length; out = (rdef.states || []).map(function(s: string, i: number) { return { label: i + ' \u2014 ' + s + ' (of ' + (_n - 1) + ')', value: String(i) }; }); } // [UNIFY] index-first label
    } else if (source === 'archetype') {
        out = (cfg.relationshipArchetypes || []).map(function(d) { return { label: d.name + (d.stages && d.stages.length ? ' (' + d.stages.length + ' stages)' : ''), value: d.id }; });
    } else if (source === 'npcArchetype') {
        out = (((cfg as any).npcArchetypes || []) as any[]).map(function(d: any) { return { label: aeIconPfx(d.icon) + d.name, value: d.id }; });
    } else if (source === 'resOp') {
        out = [{ label: 'Add (+, toward last/right)', value: 'add' }, { label: 'Subtract (−, toward first/left)', value: 'subtract' }, { label: 'Set (direct index/value)', value: 'set' }];
    } else if (source === 'equipOp') {
        out = [{ label: 'Equip', value: 'equip' }, { label: 'Unequip', value: 'unequip' }];
    } else if (source === 'compareOp') {
        out = [{ label: '\u2265 (at least)', value: '>=' }, { label: '\u2264 (at most)', value: '<=' }, { label: '= (exactly)', value: '==' }, { label: '> (more than)', value: '>' }, { label: '< (less than)', value: '<' }];
    } else if (source === 'skill') {
        (cfg.sheetCategories || []).forEach(function(cat) { (cat.fields || []).forEach(function(fld) { out.push({ label: fld.name, value: '#' + fld.name }); }); });
    } else if (source === 'sheetField') {
        // [v0.9.28 SHEET1] catId.fieldId references for set_char_sheet.
        (cfg.sheetCategories || []).forEach(function(cat) { (cat.fields || []).forEach(function(fld) { out.push({ label: cat.name + ' → ' + fld.name, value: cat.id + '.' + fld.id }); }); });
    } else if (source === 'skillField') {
        // [UNIFY] catId.fieldId references for the Skill condition/effect. Enum
        // categories are ladders (index-addressed); number categories are values.
        (cfg.sheetCategories || []).forEach(function(cat) {
            let kind = cat.fieldType === 'enum' ? ' [ladder]' : (cat.fieldType === 'number' ? ' [value]' : ' [text]');
            (cat.fields || []).forEach(function(fld) { out.push({ label: cat.name + ' → ' + fld.name + kind, value: cat.id + '.' + fld.id }); });
        });
    } else if (source === 'skillFieldState') {
        // [UNIFY] Index-labelled ladder options for an enum skill, mirroring
        // resourceState. Empty for numeric/text fields → renderer falls back to a
        // number/text input, which is exactly what a numeric attribute wants.
        let sfsRef = (rule && rule.args) ? String(rule.args.fieldRef || '') : '';
        if (sfsRef) {
            let sfsParts = sfsRef.split('.');
            let sfsCat = (cfg.sheetCategories || []).find(function(cc) { return cc.id === sfsParts[0]; });
            if (sfsCat && sfsCat.fieldType === 'enum') {
                let _sn = (sfsCat.enumValues || []).length;
                out = (sfsCat.enumValues || []).map(function(v, i) { return { label: i + ' \u2014 ' + v + ' (of ' + (_sn - 1) + ')', value: String(i) }; });
            }
        }
    } else if (source === 'sheetFieldValue') {
        // [v0.9.31 SHEET2] Enum options for the currently-selected sheet field.
        // Returns empty for text/number fields so the renderer falls back to text input.
        let sfvRef = (rule && rule.args) ? String(rule.args.fieldRef || '') : '';
        if (sfvRef) {
            let sfvParts = sfvRef.split('.');
            let sfvCat = (cfg.sheetCategories || []).find(function(c) { return c.id === sfvParts[0]; });
            let sfvFld = sfvCat ? (sfvCat.fields || []).find(function(f) { return f.id === sfvParts[1]; }) : null;
            if (sfvFld && sfvCat && sfvCat.fieldType === 'enum') {
                out = (sfvCat.enumValues || []).map(function(v) { return { label: v, value: v }; });
            }
        }
    } else if (source === 'timeBand') {
        out = (cfg.timeBands || []).map(function(b) { return { label: b.label + ' (' + b.startHour + ':00-' + b.endHour + ':00)', value: b.label }; });
    } else if (source === 'dayOfWeek') {
        for (let dwI = 1; dwI <= 7; dwI++) {
            let dwNm = (cfg.timeDayNames || [])[dwI - 1];
            out.push({ label: (dwNm && String(dwNm).trim()) ? String(dwNm).trim() : ('Weekday ' + dwI), value: String(dwI) });
        }
    }
    if (allowAsk && (source === 'entityState' || source === 'storyState' || source === 'factionState' || source === 'locationParent' || source === 'bool' || source === 'resourceState')) {
        out.push({ label: '\ud83c\udfaf Ask player at runtime', value: '__ask__' });
    }
    return out;
}

// Render a select/scope arg as a picker button. All pickers route through the
// unified openSearchPicker (searchable when > 5 options). [v0.9.16]
// [PATCH v0998] Never hand a non-string value to a schema-validated textInput.
// Numbers/booleans stringify safely; objects/arrays can't be a text field value,
// so they're JSON-stringified as a last resort rather than silently dropped —
// this should be rare and only hit truly malformed legacy data.
function aeSafeStringInitial(v: any): string {
    if (v === undefined || v === null) return '';
    if (typeof v === 'string') return v;
    if (typeof v === 'number' || typeof v === 'boolean') return String(v);
    try { return JSON.stringify(v); } catch { return ''; }
}

// [PATCH v0998] Compact index-map hint for track/enum resources, e.g.
// "0=Dead  1=Injured  2=Healthy" or, past 6 levels, "5 levels: 0=Dead … 4=Vigorous".
function aeTrackHintText(states: string[] | undefined | null): string {
    if (!states || !states.length) return '';
    if (states.length > 6) return `${states.length} levels: 0=${states[0]} \u2026 ${states.length - 1}=${states[states.length - 1]}`;
    return states.map(function(s, i) { return i + '=' + s; }).join('  ');
}

// [vNEXT] Macro helper text for message-bearing effect fields. Message fields run
// through aeSubstituteTokens (Actor/Target) + resolveEntityTokens (legacy __self__
// etc.), so the same token set applies to every field below. Returned as a static
// string per effectType+argKey — pure lookup, no scans, evaluated only at the moment
// the effect editor renders that field. Empty string = no hint (field isn't a
// message field). Keep this in sync with aeSubstituteTokens / resolveEntityTokens.
var AE_MACRO_HINT_COMMON = 'Macros: {Actor}, {Target} (names) \u00b7 __self__, __target__, __player__, __parent__ (entity names)';
function aeMacroHintFor(effectType: string, argKey: string): string {
    // Only the free-text bodies that pass through token substitution get a hint.
    if (effectType === 'inject_message'  && argKey === 'text')        return AE_MACRO_HINT_COMMON;
    if (effectType === 'inject_narrative'&& argKey === 'text')        return AE_MACRO_HINT_COMMON;
    if (effectType === 'pop_up'          && (argKey === 'text' || argKey === 'title')) return AE_MACRO_HINT_COMMON;
    if (effectType === 'add_hook'        && argKey === 'description')  return AE_MACRO_HINT_COMMON;
    if (effectType === 'ask_text'        && argKey === 'instructions') return AE_MACRO_HINT_COMMON;
    if (effectType === 'add_modifier'    && argKey === 'label')        return AE_MACRO_HINT_COMMON;
    if (effectType === 'generate_image'  && (argKey === 'prompt' || argKey === 'char1' || argKey === 'char2' || argKey === 'header' || argKey === 'body')) return AE_MACRO_HINT_COMMON;
    return '';
}

// [PATCH v0998] Resolve the states/enumValues array backing a select source, so
// pickers and amount fields can show an index-map hint under the control.
function aeGetTrackStatesForHint(source: string, rule: any, cfg: GlobalConfig): string[] | undefined {
    if (!rule || !rule.args) return undefined;
    if (source === 'resource' || source === 'resourceState') {
        const rdef = (cfg.resources || []).find(function(r) { return r.tag === rule.args.tag; });
        return rdef ? rdef.states : undefined;
    }
    if (source === 'charResource') {
        const rdef = (cfg.characterResourceDefs || []).find(function(r) { return r.tag === rule.args.tag; });
        return rdef ? rdef.states : undefined;
    }
    if (source === 'factionState') {
        const fdef = (cfg.factions || []).find(function(f) { return f.id === rule.args.factionId; });
        return fdef ? fdef.relationshipStates : undefined;
    }
    if (source === 'skillFieldState') {
        const parts = String(rule.args.fieldRef || '').split('.');
        const cat = (cfg.sheetCategories || []).find(function(c) { return c.id === parts[0]; });
        return (cat && cat.fieldType === 'enum') ? cat.enumValues : undefined;
    }
    return undefined;
}

// [PATCH v0998] Reusable indexed levels/states editor. Replaces every "type your
// states as one comma-separated string" field project-wide with an explicit,
// always-visible index -> label list: click to add/remove/reorder a level, index 0
// is always the first row, and renaming a level never risks mistyping the whole list.
// `states` must be the CURRENT array at render time (captured fresh each rebuild).
// `onUpdate` persists the new array (mutConfig / saveCharacter / etc, caller's choice).
// `refresh` re-renders the host modal — passed separately from onUpdate because label
// edits (onChange) intentionally skip it to avoid stealing focus mid-keystroke, while
// add/remove/reorder (structural changes) always call it.
function aeRenderIndexedStatesEditor(states: string[], onUpdate: (next: string[]) => Promise<void>, refresh: () => Promise<void>, addLabelPrefix: string = 'Level'): UIPart {
    const rows: UIPart[] = states.map(function(label, idx) {
        return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
            { type: 'text', text: String(idx), style: { width: '18px', flexShrink: '0', fontSize: '11px', fontWeight: 'bold', opacity: '0.55', textAlign: 'center' } },
            { type: 'textInput', initialValue: label, placeholder: 'Level label', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, onChange: async function(v: string) {
                const next = states.slice(); next[idx] = v; await onUpdate(next);
            } },
            { type: 'button', iconId: 'chevron-up', disabled: idx === 0, style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: idx === 0 ? '0.2' : '0.8' }, callback: async function() {
                if (idx === 0) return;
                const next = states.slice(); const tmp = next[idx]; next[idx] = next[idx - 1]; next[idx - 1] = tmp;
                await onUpdate(next); await refresh();
            } },
            { type: 'button', iconId: 'chevron-down', disabled: idx === states.length - 1, style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: idx === states.length - 1 ? '0.2' : '0.8' }, callback: async function() {
                if (idx === states.length - 1) return;
                const next = states.slice(); const tmp = next[idx]; next[idx] = next[idx + 1]; next[idx + 1] = tmp;
                await onUpdate(next); await refresh();
            } },
            { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async function() {
                const next = states.slice(); next.splice(idx, 1);
                await onUpdate(next); await refresh();
            } }
        ] } as UIPart;
    });
    rows.push({ type: 'button', text: `+ Add Level (becomes index ${states.length})`, style: { margin: '2px 0 4px 0', fontSize: '10px', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
        const next = states.slice(); next.push(addLabelPrefix + ' ' + states.length);
        await onUpdate(next); await refresh();
    } });
    if (!states.length) rows.unshift({ type: 'text', text: 'No levels yet — index 0 is always the first one you add.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '2px' } } as UIPart);
    return { type: 'box', style: { marginTop: '2px', marginBottom: '4px' }, content: rows } as UIPart;
}

function aeRenderSelectArg(arg: UIRuleArg, rule: any, cfg: GlobalConfig, authorData: AEAuthorData, entIdx: any[], allowAsk: boolean, refresh: () => Promise<void>): UIPart {
    if (!rule.args) rule.args = {};
    let source = arg.type === 'scope' ? 'scope' : (arg.optionsSource || '');
    // Scope args merge the four logical scopes with every concrete entity into one
    // searchable list — no separate "Specific Entity…" sub-modal needed.
    let opts: { label: string; value: string }[];
    if (arg.type === 'scope') {
        opts = [{ label: 'This entity (self)', value: '__self__' }, { label: 'The player', value: '__player__' }, { label: 'Chosen target', value: '__target__' }, { label: 'Parent location', value: '__parent__' }];
        (entIdx || []).forEach(function(m: any) { opts.push({ label: '📍 ' + aeIconPfx(m.icon) + m.name + ' (' + m.type + ')', value: m.id }); });
    } else {
        opts = aeSelectOptions(source, rule, cfg, authorData, entIdx, allowAsk);
    }
    let cur = rule.args[arg.key];
    let curLabel = '(choose…)';
    let match = opts.find(function(o) { return o.value === cur; });
    if (match) curLabel = match.label;
    else if (cur && arg.type === 'scope') {
        let entMatch = entIdx.find(function(m: any) { return m.id === cur; });
        curLabel = entMatch ? ('📍 ' + entMatch.name) : String(cur).substring(0, 20);
    } else if (cur) curLabel = String(cur);
    const row: UIPart = { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
        { type: 'text', text: arg.label, style: { fontSize: '11px', width: '80px', opacity: '0.8' } },
        { type: 'button', text: curLabel, style: { flex: '1', margin: 0, backgroundColor: 'rgba(255,255,255,0.08)', textAlign: 'left', fontSize: '11px' }, callback: async function() {
            // Live per-entity state resolution: an entityState picker scoped to a
            // concrete entity loads that entity's own states (not the project union).
            let liveOpts = opts;
            if (source === 'entityState') {
                let esc = String(rule.args.scope || '');
                if (esc && esc.indexOf('__') !== 0) {
                    let seEnt = await loadEntity(esc).catch(function() { return null; });
                    if (seEnt && (seEnt as any).stateDescriptions) liveOpts = Object.keys((seEnt as any).stateDescriptions).map(function(k) { return { label: k, value: k }; });
                }
            }
            if (allowAsk && source === 'entityState') { liveOpts = liveOpts.slice(); liveOpts.push({ label: '🎯 Ask player at runtime', value: '__ask__' }); }
            if (!liveOpts.length && arg.type !== 'scope') {
                let msg = (source === 'entityState') ? 'No entity states found. Add states to the target entity in the Entity Editor.'
                    : (source === 'charResource') ? 'No character resources defined — add them on a character in the Characters tab.'
                    : (source === 'chainAction') ? 'No actions on that source yet. Pick a different source, or build a Library action first.'
                    : (source === 'resource' || source === 'resourceState') ? 'No party resources defined yet — add one in Worldbuilding → Global Resources.'
                    : (source === 'faction' || source === 'factionState') ? 'No factions defined yet — add one in Worldbuilding.'
                    : (source === 'archetype') ? 'No relationship archetypes defined — add one in Worldbuilding.'
                    : (source === 'skill') ? 'No skills defined — add sheet categories/fields in Worldbuilding.'
                    : 'No options available for this field.';
                api.v1.ui.toast(msg, { type: 'info', autoClose: 2800 }); return;
            }
            let items: PickItem[] = liveOpts.map(function(o) { return { id: o.value, label: o.label, selected: o.value === cur }; });
            await openSearchPicker('Select ' + arg.label, items, async function(val) {
                // [PATCH v0998] Keep number-typed args numeric even when set via a
                // string-valued picker option (e.g. a stringified rung index).
                rule.args[arg.key] = (arg.type === 'number' && !isNaN(Number(val))) ? Number(val) : val;
                await refresh();
            });
        } }
    ] } as UIPart;
    // [PATCH v0998] Append a compact index-map hint under the picker when the
    // resolved value belongs to a track/enum, so authors always see what the
    // stored index means without leaving the field.
    const hintStates = aeGetTrackStatesForHint(source, rule, cfg);
    const hintTxt = aeTrackHintText(hintStates);
    if (!hintTxt) return row;
    return { type: 'box', style: { marginBottom: '2px' }, content: [
        row,
        { type: 'text', text: hintTxt, style: { fontSize: '9px', opacity: '0.5', marginLeft: '84px', marginTop: '0', marginBottom: '2px' } }
    ] } as UIPart;
}
 
async function openActionBuilderModal(templateId: string): Promise<void> {
    const cfg = await loadConfig(); 
    const template = cfg.actionTemplates.find((t: any) => t.id === templateId);
    if (!template) return;

    // [v0.9.16] Author-data bundle replaces the old per-template Reference Entity.
    // Preloaded once here (async) so the synchronous option builders can enumerate
    // states/resources/instances without an async dependency at render time.
    let entIdxForPicker: any[] = await loadEntityIndex();
    let _allChForData: CharacterRecord[] = await loadAllCharacters();
    let _charByEntityId: Record<string, CharacterRecord> = {};
    for (const _c of _allChForData) { if ((_c as any).entityId) _charByEntityId[(_c as any).entityId] = _c; }
    let _stateSet: Record<string, boolean> = {};
    let _resSet: Record<string, string> = {};
    let _instById: Record<string, { id: string; name: string }[]> = {};
    for (const _m of entIdxForPicker) {
        let _e = await loadEntity(_m.id).catch(function() { return null; });
        if (!_e) continue;
        if ((_e as any).stateDescriptions) { for (const _k of Object.keys((_e as any).stateDescriptions)) _stateSet[_k] = true; }
        let _eInsts = (((_e as any).actionInstances || []) as ActionInstance[]);
        if (_eInsts.length) _instById[_m.id] = _eInsts.map(function(i) { return { id: i.id, name: i.name || 'Action' }; });
    }
    for (const _c2 of _allChForData) { for (const _rd of (((_c2 as any).charResourceDefs || []) as any[])) { if (!_resSet[_rd.tag]) _resSet[_rd.tag] = _rd.name; } }
    let authorData: AEAuthorData = {
        entityStates: Object.keys(_stateSet).map(function(k) { return { label: k, value: k }; }),
        charResources: Object.keys(_resSet).map(function(t) { return { label: _resSet[t] + ' (' + t + ')', value: t }; }),
        charByEntityId: _charByEntityId,
        instancesByEntityId: _instById
    };

    let pm: any; 

    const refreshThisModal = async () => {
        await saveConfig(cfg);
        // [FIX] update content in place instead of close()/reopen — eliminates flicker.
        if (pm && !pm.isClosed()) { await pm.update({ content: buildContent() }); }
    };

    const buildContent = (): UIPart[] => {
    let modalContent: UIPart[] = [];

    // --- HEADER ---
    modalContent.push({
        type: 'row', alignment: 'center', style: { marginBottom: '10px', gap: '8px' }, content: [
            { type: 'textInput', initialValue: template.name, style: { flex: '1', margin: 0 }, onChange: async (v) => { template.name = v; } },
            { type: 'text', text: 'Builder', style: { fontSize: '11px', color: '#88ccff' } }
        ]
    });

    // [v0.9.16] FLAGS — action-level settings live at the top now (apply to the whole process).
    let mkFlag = function(lbl: string, key: string): UIPart {
        let on = !!(template as any)[key];
        return { type: 'button', text: (on ? '☑ ' : '☐ ') + lbl, style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: on ? 'rgba(136,204,255,0.18)' : 'rgba(255,255,255,0.04)' }, callback: async () => { (template as any)[key] = !(template as any)[key]; await refreshThisModal(); } } as UIPart;
    };
    modalContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
        { type: 'text', text: 'Flags:', style: { fontSize: '10px', width: '50px', opacity: '0.6' } },
        mkFlag('Silent', 'silent'), mkFlag('Hidden', 'hidden'), mkFlag('One-shot', 'oneShot'), mkFlag('Auto', 'autoTrigger')
    ] });
    if ((template as any).autoTrigger) {
        let gOn = !!(template as any).globalAutoTrigger;
        modalContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
            { type: 'text', text: '', style: { width: '50px' } },
            { type: 'button', text: (gOn ? '☑ ' : '☐ ') + '⚙ Global (fire every turn, any location)', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: gOn ? 'rgba(232,168,124,0.18)' : 'rgba(255,255,255,0.04)' }, callback: async () => { (template as any).globalAutoTrigger = !(template as any).globalAutoTrigger; await refreshThisModal(); } }
        ] });
        modalContent.push({ type: 'text', text: '⚙ Auto: evaluated each generation turn when conditions pass; always runs silently. Use conditions to restrict when it fires. Global lifts the current-room/adjacency limit.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px', color: '#88ccff' } });
    }

    // [v0.9.16] TAGS — also a whole-action property; moved up beside the flags.
    modalContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '8px' }, content: [
        { type: 'text', text: 'Tags:', style: { fontSize: '10px', width: '50px', opacity: '0.6' } },
        { type: 'textInput', initialValue: ((template as any).tags || []).join(', '), placeholder: 'combat, magic (comma-separated)', style: { flex: '1', margin: 0, fontSize: '11px' }, onChange: async (v: string) => { (template as any).tags = String(v || '').split(',').map(function(s) { return s.trim(); }).filter(Boolean); } }
    ] });

    // [v0.9.16] TARGETING — when ON, the player picks a target (limited to entities
    // in the current room); {Target} / "Chosen target" scope resolve to it.
    let tmOn = (template as any).targetMode === 'player_pick';
    modalContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
        { type: 'text', text: 'Target:', style: { fontSize: '10px', width: '50px', opacity: '0.6' } },
        { type: 'button', text: (tmOn ? '☑ ' : '☐ ') + 'Needs a target (player picks)', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: tmOn ? 'rgba(136,204,255,0.18)' : 'rgba(255,255,255,0.04)' }, callback: async () => { (template as any).targetMode = tmOn ? undefined : 'player_pick'; await refreshThisModal(); } }
    ]});
    if (tmOn) {
        let tf: string[] = (((template as any).targetFilter || []) as string[]);
        let mkTf = function(lbl: string, ty: string): UIPart {
            let on = tf.indexOf(ty) >= 0;
            return { type: 'button', text: (on ? '☑ ' : '☐ ') + lbl, style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: on ? 'rgba(136,204,255,0.18)' : 'rgba(255,255,255,0.04)' }, callback: async () => { let cur = (((template as any).targetFilter || []) as string[]).slice(); let i = cur.indexOf(ty); if (i >= 0) cur.splice(i, 1); else cur.push(ty); (template as any).targetFilter = cur; await refreshThisModal(); } } as UIPart;
        };
        modalContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
            { type: 'text', text: 'Limit to:', style: { fontSize: '10px', width: '50px', opacity: '0.6' } },
            mkTf('Characters', 'character'), mkTf('Items', 'item'), mkTf('Locations', 'location')
        ]});
        modalContent.push({ type: 'text', text: 'Empty = any entity in the scene. Targets are always limited to the player’s current room.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });
    }

    modalContent.push({ 
        type: 'text', 
        text: 'Actions flow from top to bottom. First, the engine checks **Conditions**. If they pass, it rolls the **Resolution**. Finally, it applies the resulting **Outcomes**.', 
        markdown: true, style: { fontSize: '12px', opacity: '0.8', marginBottom: '16px', backgroundColor: 'rgba(255,255,255,0.05)', padding: '8px', borderRadius: '4px' } 
    });

    // --- HELPER: RENDER RULE LIST ---
    const renderRuleList = (rulesArray: any[], listLabel: string, availableRules: string[], allowAsk: boolean, isCondition: boolean = false) => {
        let listParts: UIPart[] = [];
        
        rulesArray.forEach((rule, idx) => {
            const manifest = UIRuleManifest[rule.type];
            if (!manifest) {
                listParts.push({ type: 'text', text: `⚠ Unknown Rule: ${rule.type}`, style: { color: 'red' } });
                return;
            }

            let headerKids: UIPart[] = [];
            if (isCondition) {
                headerKids.push({ type: 'checkboxInput', label: 'NOT', initialValue: !!rule.invert, onChange: async (v: boolean) => { rule.invert = v; await refreshThisModal(); } } as UIPart);
            }
            headerKids.push(
                { type: 'button', iconId: 'chevron-up', disabled: idx === 0, style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: idx === 0 ? '0.2' : '0.8' }, callback: async () => {
                    const temp = rulesArray[idx];
                    rulesArray[idx] = rulesArray[idx - 1];
                    rulesArray[idx - 1] = temp;
                    await refreshThisModal();
                }},
                { type: 'button', iconId: 'chevron-down', disabled: idx === rulesArray.length - 1, style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: idx === rulesArray.length - 1 ? '0.2' : '0.8' }, callback: async function() {
                    const temp = rulesArray[idx];
                    rulesArray[idx] = rulesArray[idx + 1];
                    rulesArray[idx + 1] = temp;
                    await refreshThisModal();
                }},
                { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async () => {
                    rulesArray.splice(idx, 1);
                    await refreshThisModal();
                }}
            );

            let ruleCard: UIPart[] = [
                { type: 'row', spacing: 'space-between', alignment: 'center', style: { marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.1)', paddingBottom: '4px' }, content: [
                    { type: 'text', text: manifest.name, style: { fontWeight: 'bold', fontSize: '12px', color: '#e8a87c' } },
                    { type: 'row', style: { gap: '4px', margin: 0 }, content: headerKids }
                ]}
            ];

            manifest.args.forEach(arg => {
                if (!rule.args) rule.args = {};

                if (arg.type === 'string' || arg.type === 'number') {
                    // [v0.9.31 SHEET2] Promote to picker when optionsSource has options (enum fields).
                    // [PATCH v0998] Promotion now also covers 'number' args (e.g. the
                    // retyped char_skill.amount) so string->number didn't cost the
                    // ladder-rung picker — aeRenderSelectArg's onSelect coerces the
                    // picked value back to a real number when arg.type === 'number'.
                    let _sfvPromoted = false;
                    if (arg.optionsSource) {
                        let _sfvOpts = aeSelectOptions(arg.optionsSource, rule, cfg, authorData, entIdxForPicker, false);
                        if (_sfvOpts.length > 0) {
                            ruleCard.push(aeRenderSelectArg(arg, rule, cfg, authorData, entIdxForPicker, false, refreshThisModal));
                            _sfvPromoted = true;
                        }
                    }
                    if (!_sfvPromoted && arg.type === 'string') {
                        ruleCard.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                            { type: 'text', text: arg.label, style: { fontSize: '11px', width: '80px', opacity: '0.8' } },
                            // [PATCH v0998] aeSafeStringInitial — legacy data can hold a
                            // number/boolean here; a raw non-string initialValue crashes
                            // the whole enclosing modal (schema-validated textInput).
                            { type: 'textInput', initialValue: aeSafeStringInitial(rule.args[arg.key]), placeholder: arg.placeholder, style: { flex: '1', margin: 0 }, onChange: async (v) => { rule.args[arg.key] = v; } }
                        ]});
                        // [vNEXT] Macro helper caption for token-bearing string fields.
                        let _mhStr = aeMacroHintFor(rule.type, arg.key);
                        if (_mhStr) ruleCard.push({ type: 'text', text: _mhStr, style: { fontSize: '9px', opacity: '0.5', marginTop: '-1px', marginBottom: '4px' } });
                    } else if (!_sfvPromoted && arg.type === 'number') {
                        ruleCard.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                            { type: 'text', text: arg.label, style: { fontSize: '11px', width: '80px', opacity: '0.8' } },
                            // [FIX] text-parsed number so negatives (costs) are enterable; numberInput blocked the leading '-'.
                            { type: 'textInput', initialValue: (rule.args[arg.key] !== undefined && rule.args[arg.key] !== null) ? String(rule.args[arg.key]) : '0', placeholder: '0 (negatives allowed)', style: { width: '110px', margin: 0 }, onChange: async (v) => { let pn = parseFloat(v); rule.args[arg.key] = isNaN(pn) ? 0 : pn; } }
                        ]});
                        // [PATCH v0998] char_resource.amount / char_skill.amount are now
                        // canonical numeric indices — show what the index means so authors
                        // (human or LLM-generated) don't have to hold the track in their head.
                        if (arg.key === 'amount' && (rule.type === 'char_resource' || rule.type === 'char_skill')) {
                            let hintStates: string[] | undefined;
                            if (rule.type === 'char_resource') {
                                let rdefH = (cfg.characterResourceDefs || []).find(function(r: any) { return r.tag === rule.args.tag; });
                                hintStates = rdefH ? rdefH.states : undefined;
                            } else {
                                let fieldRefH = String(rule.args.fieldRef || '');
                                let catH = (cfg.sheetCategories || []).find(function(c: any) { return c.id === fieldRefH.split('.')[0]; });
                                hintStates = (catH && catH.fieldType === 'enum') ? catH.enumValues : undefined;
                            }
                            let hintTextH = aeTrackHintText(hintStates);
                            if (hintTextH) ruleCard.push({ type: 'text', text: hintTextH, style: { fontSize: '9px', opacity: '0.5', marginTop: '-2px', marginBottom: '4px' } });
                        }
                    }
                } else if (arg.type === 'longtext') {
                    ruleCard.push({ type: 'text', text: arg.label, style: { fontSize: '11px', opacity: '0.8', marginTop: '4px' } });
                    ruleCard.push({ type: 'textInput', initialValue: aeSafeStringInitial(rule.args[arg.key]), placeholder: arg.placeholder, style: { margin: 0 }, onChange: async (v) => { rule.args[arg.key] = v; } });
                    // [vNEXT] Macro helper caption for token-bearing longtext bodies.
                    let _mhLong = aeMacroHintFor(rule.type, arg.key);
                    if (_mhLong) ruleCard.push({ type: 'text', text: _mhLong, style: { fontSize: '9px', opacity: '0.5', marginTop: '-2px', marginBottom: '4px' } });
                } else if (arg.type === 'select' || arg.type === 'scope') {
                    ruleCard.push(aeRenderSelectArg(arg, rule, cfg, authorData, entIdxForPicker, allowAsk, refreshThisModal));
                }
            });

            listParts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.3)', padding: '6px', borderRadius: '4px', marginBottom: '6px' }, content: ruleCard });
        });

        // Fixed: Replaced Dropdown with a Button that opens a picker modal
        listParts.push({
            type: 'button',
            text: `+ Add ${listLabel}...`,
            style: { margin: 0, backgroundColor: 'rgba(255,255,255,0.05)', fontSize: '11px' },
            callback: async () => {
                const pickerModal = await openEngineModal({
                    title: `Select ${listLabel}`,
                    size: 'small',
                    content: availableRules.map(typeKey => {
                        const man = UIRuleManifest[typeKey];
                        // [v0.9.87 FIX] Guard against a type key present in AE_EFFECT_TYPES
                        // but missing from UIRuleManifest — previously crashed with
                        // 'cannot read property name of undefined'.
                        if (!man) return { type: 'text', text: '\u26a0 ' + typeKey + ' (no manifest entry)', style: { fontSize: '10px', opacity: '0.5', padding: '4px 8px' } } as UIPart;
                        return {
                            type: 'box', style: { marginBottom: '6px', padding: '6px', backgroundColor: 'rgba(255,255,255,0.05)', borderRadius: '4px' },
                            content: [
                                { type: 'button', text: man.name, style: { fontWeight: 'bold', margin: 0, padding: '4px 8px', backgroundColor: 'transparent' }, callback: async () => {
                                    pickerModal.close();
                                    rulesArray.push({ id: generateId(), type: typeKey, args: {} });
                                    await refreshThisModal();
                                } },
                                { type: 'text', text: man.desc, style: { fontSize: '10px', opacity: '0.7', padding: '0 8px', marginTop: '2px' } }
                            ]
                        } as UIPart;
                    })
                });
            }
        });

        return listParts;
    };

    // --- REUSABLE RESOLUTION BOX RENDERER ---
    const renderResolutionBox = (targetObj: any): UIPart => {
        if (targetObj.resolution && !targetObj.resolution.args) targetObj.resolution.args = {};
        let res = targetObj.resolution;
        let resTypeLabel = !res ? 'Auto-Success (No Roll)'
            : (res.dice && !res.type) ? ('Custom dice: ' + res.dice)
            : res.type === 'd20_check' ? 'D20 vs DC'
            : res.type === 'fail_forward_2d6' ? '2d6 Fail Forward (PbtA)'
            : res.type === 'custom_1d6' ? 'Custom 1d6 vs DC'
            : (res.type || 'Roll');

        let resBox: UIPart[] = [
            { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                { type: 'text', text: 'Engine:', style: { fontSize: '12px', width: '60px' } },
                { type: 'button', text: resTypeLabel, style: { flex: '1', margin: 0, backgroundColor: 'rgba(255,255,255,0.1)' }, callback: async () => {
                    let rp: any = null;
                    let mkOpt = function(label: string, build: () => AEResolution | undefined): UIPart {
                        return { type: 'button', text: label, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async () => { targetObj.resolution = build(); if (rp) rp.close(); await refreshThisModal(); } } as UIPart;
                    };
                    rp = await openEngineModal({ title: 'Select Resolution Engine', size: 'small', content: [
                        mkOpt('Auto-Success (No Roll)', function() { return undefined; }),
                        mkOpt('D20 vs DC (D&D)', function() { return { type: 'd20_check', useDC: true, dc: 10, args: {} }; }),
                        mkOpt('2d6 Fail Forward (PbtA)', function() { return { type: 'fail_forward_2d6', args: {} }; }),
                        mkOpt('Custom 1d6 vs DC', function() { return { type: 'custom_1d6', useDC: true, dc: 4, args: {} }; }),
                        mkOpt('Custom Dice (NdN+M)', function() { return { dice: '1d20', useDC: true, dc: 10, args: {} }; })
                    ] });
                } }
            ] }
        ];

        if (res) {
            resBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Dice:', style: { fontSize: '11px', width: '60px', opacity: '0.8' } },
                { type: 'textInput', initialValue: res.dice || '', placeholder: res.type === 'fail_forward_2d6' ? '2d6 (fixed by engine)' : 'type default, or e.g. 1d20+2', style: { flex: '1', margin: 0, fontSize: '11px' }, onChange: async (v: string) => { let tt = (v || '').trim(); if (targetObj.resolution) { if (tt) targetObj.resolution.dice = tt; else delete targetObj.resolution.dice; } } }
            ] });

            let useDcOn = !!res.useDC;
            resBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'button', text: (useDcOn ? '\u2611' : '\u2610') + ' Check vs DC', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: useDcOn ? 'rgba(136,204,255,0.18)' : 'rgba(255,255,255,0.04)' }, callback: async () => { if (targetObj.resolution) targetObj.resolution.useDC = !useDcOn; await refreshThisModal(); } },
                useDcOn ? ({ type: 'numberInput', initialValue: typeof res.dc === 'number' ? res.dc : 10, style: { width: '70px', margin: 0 }, onChange: async (v: number) => { if (targetObj.resolution) targetObj.resolution.dc = v || 0; } } as UIPart) : ({ type: 'box', style: { width: '0' }, content: [] } as UIPart)
            ] });

            let skillFields: { label: string; value: string }[] = [];
            (cfg.sheetCategories || []).forEach(function(cat: any) { (cat.fields || []).forEach(function(fld: any) { skillFields.push({ label: fld.name, value: '#' + fld.name }); }); });
            let curSkillLabel = res.skillTag ? res.skillTag : '(none)';
            resBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Skill mod:', style: { fontSize: '11px', width: '60px', opacity: '0.8' } },
                { type: 'button', text: curSkillLabel, style: { flex: '1', margin: 0, fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.08)', textAlign: 'left' }, callback: async () => {
                    let sp: any = null;
                    let sopts: UIPart[] = [ { type: 'button', text: '(none)', style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async () => { if (targetObj.resolution) delete targetObj.resolution.skillTag; if (sp) sp.close(); await refreshThisModal(); } } as UIPart ];
                    skillFields.forEach(function(sf) { sopts.push({ type: 'button', text: sf.label + ' (' + sf.value + ')', style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async () => { if (targetObj.resolution) targetObj.resolution.skillTag = sf.value; if (sp) sp.close(); await refreshThisModal(); } } as UIPart); });
                    if (!skillFields.length) sopts.push({ type: 'text', text: 'No character-sheet fields defined yet.', style: { fontSize: '11px', opacity: '0.5' } } as UIPart);
                    sp = await openEngineModal({ title: 'Skill Modifier', size: 'small', content: sopts });
                } }
            ] });

            let critOn = !!res.crit;
            resBox.push({ type: 'button', text: (critOn ? '\u2611' : '\u2610') + ' Natural max / natural 1 crits (single die)', style: { margin: 0, marginBottom: '6px', fontSize: '11px', backgroundColor: critOn ? 'rgba(232,168,124,0.18)' : 'rgba(255,255,255,0.04)' }, callback: async () => { if (targetObj.resolution) targetObj.resolution.crit = !critOn; await refreshThisModal(); } });

            if (!res.bands) res.bands = [];
            resBox.push({ type: 'row', alignment: 'center', style: { justifyContent: 'space-between', marginTop: '4px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Outcome Bands (' + (res.bands || []).length + ')', style: { fontSize: '11px', fontWeight: 'bold', opacity: '0.8' } },
                { type: 'button', text: '+ Band', style: { margin: 0, fontSize: '10px', backgroundColor: 'rgba(136,204,255,0.12)' }, callback: async () => { if (!targetObj.resolution) return; if (!targetObj.resolution.bands) targetObj.resolution.bands = []; targetObj.resolution.bands.push({ id: generateId(), min: 0, max: 0, label: 'Outcome', effects: [] }); await refreshThisModal(); } }
            ] });
            resBox.push({ type: 'text', text: 'A band maps a total-roll range to a labelled outcome with its own effects. First match wins (order specific bands first). A label containing "fail" counts as failure; "partial" marks a partial hit.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px' } });
            (res.bands || []).forEach(function(band: AEOutcomeBand, bi: number) {
                let bandCard: UIPart[] = [
                    { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
                        { type: 'textInput', initialValue: band.label, placeholder: 'Label', style: { flex: '1', margin: 0, fontSize: '11px' }, onChange: async (v: string) => { let f = targetObj.resolution; if (f && f.bands && f.bands[bi]) f.bands[bi].label = v; } },
                        { type: 'numberInput', initialValue: band.min, style: { width: '52px', margin: 0 }, onChange: async (v: number) => { let f = targetObj.resolution; if (f && f.bands && f.bands[bi]) f.bands[bi].min = v || 0; } },
                        { type: 'text', text: '\u2013', style: { opacity: '0.5' } },
                        { type: 'numberInput', initialValue: band.max, style: { width: '52px', margin: 0 }, onChange: async (v: number) => { let f = targetObj.resolution; if (f && f.bands && f.bands[bi]) f.bands[bi].max = v || 0; } },
                        { type: 'button', iconId: 'chevron-up', disabled: bi === 0, style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: bi === 0 ? '0.2' : '0.8' }, callback: async () => {
                            let f = targetObj.resolution;
                            if (f && f.bands) {
                                const temp = f.bands[bi];
                                f.bands[bi] = f.bands[bi - 1];
                                f.bands[bi - 1] = temp;
                                await refreshThisModal();
                            }
                        }},
                        { type: 'button', iconId: 'chevron-down', disabled: bi === res.bands.length - 1, style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: bi === res.bands.length - 1 ? '0.2' : '0.8' }, callback: async function() {
                            let f = targetObj.resolution;
                            if (f && f.bands) {
                                const temp = f.bands[bi];
                                f.bands[bi] = f.bands[bi + 1];
                                f.bands[bi + 1] = temp;
                                await refreshThisModal();
                            }
                        }},
                        { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px', color: '#ff6b6b' }, callback: async () => { let f = targetObj.resolution; if (f && f.bands) { f.bands.splice(bi, 1); await refreshThisModal(); } } }
                    ] },
                    { type: 'textInput', initialValue: band.gmNote || '', placeholder: 'GM note (optional) \u2014 a short instruction for how this outcome should read', style: { margin: '0 0 4px 0', fontSize: '10px' }, onChange: async (v: string) => { let f = targetObj.resolution; if (f && f.bands && f.bands[bi]) f.bands[bi].gmNote = v; } }
                ];
                let bandEffects = renderRuleList(band.effects, 'Effect', AE_EFFECT_TYPES, true, false);
                bandCard = bandCard.concat(bandEffects);
                resBox.push({ type: 'box', style: { padding: '6px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.02)', borderRadius: '4px', borderLeft: '2px solid #88ccff' }, content: bandCard });
            });
        }

        return { type: 'box', style: { borderLeft: '3px solid #88ccff', padding: '8px', backgroundColor: 'rgba(136, 204, 255, 0.05)', marginBottom: '12px' }, content: resBox } as UIPart;
    };

    // --- REUSABLE EFFECTS BOX RENDERER ---
    const renderEffectsBox = (targetObj: any): UIPart => {
        if (!targetObj.successEffects) targetObj.successEffects = [];
        if (!targetObj.failureEffects) targetObj.failureEffects = [];
        if (!targetObj.alwaysEffects) targetObj.alwaysEffects = [];
        const isRolling = !!targetObj.resolution;

        return { type: 'box', style: { borderLeft: '3px solid #7ec8a0', padding: '8px', backgroundColor: 'rgba(126, 200, 160, 0.05)', marginBottom: '12px' }, content: [
            { type: 'text', text: isRolling ? '🟩 On Success:' : '⚡ Effects to Apply:', style: { fontSize: '11px', fontWeight: 'bold', marginTop: '8px', marginBottom: '4px', color: '#7ec8a0' } },
            ...renderRuleList(targetObj.successEffects, 'Effect', AE_EFFECT_TYPES, true, false),

            ...(isRolling ? [
                { type: 'text', text: '🟥 On Failure:', style: { fontSize: '11px', fontWeight: 'bold', marginTop: '12px', marginBottom: '4px', color: '#ff6b6b' } },
                ...renderRuleList(targetObj.failureEffects, 'Effect', AE_EFFECT_TYPES, true, false)
            ] : []),

            ...(isRolling ? [
                { type: 'text', text: '⬜ Always (regardless of roll):', style: { fontSize: '11px', fontWeight: 'bold', marginTop: '12px', marginBottom: '4px', color: '#aaa' } },
                { type: 'text', text: 'Fires after the outcome branch unconditionally. Good for resource costs, global consequences, status clears.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px' } },
                ...renderRuleList(targetObj.alwaysEffects, 'Effect', AE_EFFECT_TYPES, true, false)
            ] : [])
        ]};
    };

    // --- PHASE 1: CONDITIONS ---
    if (!template.conditions) template.conditions = [];
    modalContent.push({ type: 'box', style: { borderLeft: '3px solid #ffb432', padding: '8px', backgroundColor: 'rgba(255, 180, 50, 0.05)', marginBottom: '12px' }, content: [
        { type: 'text', text: '1️⃣ Requirements (Base Conditions)', style: { fontWeight: 'bold', marginBottom: '4px' } },
        { type: 'text', text: 'Checked before the action runs. If these fail, the action is hidden or blocked.', style: { fontSize: '10px', opacity: '0.6', marginBottom: '8px' } },
        ...renderRuleList(template.conditions, 'Condition', AE_COND_TYPES, false, true)
    ]});

    // --- PHASE 2: RESOLUTION (full authoring) ---
    modalContent.push({ type: 'text', text: '2️⃣ Base Resolution & Outcomes', style: { fontWeight: 'bold', marginBottom: '4px' } });
    modalContent.push(renderResolutionBox(template));

    // --- PHASE 3: EFFECTS ---
    modalContent.push(renderEffectsBox(template));

    // --- PHASE 4: BRANCHES (ALTERNATIVE RESOLUTIONS & OUTCOMES) ---
    if (!template.branches) template.branches = [];
    let branchesBox: UIPart[] = [];
    branchesBox.push({ type: 'text', text: '🌿 Branches (Alternative Outcomes)', style: { fontWeight: 'bold', marginBottom: '4px' } });
    branchesBox.push({ type: 'text', text: 'If a branch’s conditions are met, it overrides the base resolution and outcomes. First matching branch wins.', style: { fontSize: '10px', opacity: '0.6', marginBottom: '8px' } });

    template.branches.forEach((branch: any, brIdx: number) => {
        branchesBox.push({ type: 'collapsibleSection', title: branch.name || `Branch ${brIdx + 1}`, initialCollapsed: true, storageKey: `temp:ae_branch_${(template as any).id || 't'}_${branch.id || brIdx}`, content: [
            { type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [
                { type: 'textInput', initialValue: branch.name, placeholder: 'Branch Name', style: { flex: '1', margin: 0, fontWeight: 'bold' }, onChange: async (v) => { branch.name = v; } },
                { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '4px', color: '#ff6b6b' }, callback: async () => { template.branches.splice(brIdx, 1); await refreshThisModal(); } }
            ]},
            { type: 'text', text: 'Branch Conditions', style: { fontWeight: 'bold', marginTop: '8px', marginBottom: '4px', color: '#ffb432' } },
            ...renderRuleList(branch.conditions, 'Condition', AE_COND_TYPES, false, true),
            { type: 'text', text: 'Branch Resolution', style: { fontWeight: 'bold', marginTop: '12px', marginBottom: '4px', color: '#88ccff' } },
            renderResolutionBox(branch),
            { type: 'text', text: 'Branch Outcomes', style: { fontWeight: 'bold', marginTop: '12px', marginBottom: '4px', color: '#7ec8a0' } },
            renderEffectsBox(branch)
        ]});
    });

    branchesBox.push({ type: 'button', text: '+ Add Branch', style: { marginTop: '8px', backgroundColor: 'rgba(179,136,255,0.1)' }, callback: async () => {
        template.branches.push({
            id: generateId(),
            name: `Branch ${template.branches.length + 1}`,
            conditions: [],
            resolution: template.resolution ? JSON.parse(JSON.stringify(template.resolution)) : undefined,
            successEffects: JSON.parse(JSON.stringify(template.successEffects || [])),
            failureEffects: JSON.parse(JSON.stringify(template.failureEffects || [])),
            alwaysEffects: JSON.parse(JSON.stringify((template as any).alwaysEffects || []))
        });
        const reId = (arr: any[]) => { if(arr) arr.forEach(r => { r.id = generateId(); }); };
        const newBr = template.branches[template.branches.length - 1];
        if (newBr.resolution && newBr.resolution.bands) {
            newBr.resolution.bands.forEach((b:any) => { b.id = generateId(); reId(b.effects || []); });
        }
        reId(newBr.successEffects);
        reId(newBr.failureEffects);
        reId(newBr.alwaysEffects);
        await refreshThisModal();
    }});

    modalContent.push({ type: 'box', style: { borderLeft: '3px solid #b388ff', padding: '8px', backgroundColor: 'rgba(179, 136, 255, 0.05)', marginBottom: '12px' }, content: branchesBox });

    // --- CLOSE BUTTON (API COMPLIANT) ---
    modalContent.push({
        type: 'button',
        text: 'Done',
        style: { marginTop: '20px', backgroundColor: 'rgba(126,200,160,0.2)' },
        callback: async () => {
            await saveConfig(cfg);
            await refreshSidebar();
            if (pm) pm.close();
        }
    });

        return modalContent;
    };

    // OPEN MODAL WITHOUT 'buttons' KEY
    pm = await openEngineModal({
        title: `🛠️ Action Studio`,
        content: buildContent(),
        onClose: async () => {
            await saveConfig(cfg);
            await refreshSidebar(); 
        }
    });
}

// ============================================================================
// SIDEBAR — CHARACTERS TAB
// ============================================================================

async function moveChar(id: string, direction: number) {
    const idx = await loadIndex();
    const pos = idx.findIndex(m => m.id === id);
    if (pos < 0) return;
    const newPos = pos + direction;
    if (newPos < 0 || newPos >= idx.length) return;
    
    const temp = idx[pos];
    idx[pos] = idx[newPos];
    idx[newPos] = temp;
    
    await saveIndex(idx);
    await refreshSidebar();
}

// ── Characters Tab: Card & Kill ──────────────────────────────────────────────

function buildCharCard(meta: any, cfg: GlobalConfig, entIdx: any[], idxPos: number, idxLength: number): UIPart {
    const isScene = meta.scenePresent;
    const isPinned = !!meta.pinned;
    const isStatic = !!meta.isStatic;
    const isProtag = !!meta.isProtagonist;
    let avatarCol: UIPart | null = null;
    
    // Left edge highlight for scene presence (Major/Minor logic removed)
    const cardBorderLeft = isScene ? '4px solid #7ec8a0' : '4px solid rgba(255,255,255,0.05)';

    // ── RIGHT COLUMN ──────────────────────────────────────────────────
    // Row 1: Name + Dynamic/Static + Pin
    const hasCritHookMeta = !!meta.hasCriticalHook;
    const protagPrefix = isProtag ? '👑 ' : '';
    const nameRow: UIPart = { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
        { type: 'text', text: protagPrefix + (hasCritHookMeta ? '🔥 ' : '') + (meta.name || 'Unnamed'), style: { fontSize: '13px', fontWeight: 'bold', flex: '1 1 0', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis', color: isProtag ? '#ffb432' : undefined } },
        { type: 'button', text: isStatic ? '▫️Static' : '⚡️Dynamic', style: { margin: 0, padding: '2px 4px', fontSize: '9px', backgroundColor: isStatic ? 'rgba(255,255,255,0.05)' : 'rgba(136,204,255,0.15)', color: isStatic ? '#888' : '#88ccff', border: 'none' }, callback: async function() {
            const f = await loadCharacter(meta.id); if (!f) return;
            f.isStatic = !f.isStatic;
            // Master gate: flip all dynamic flags in sync with card toggle
            const nowDynamic = !f.isStatic;
            f.charContextEnabled = nowDynamic;
            f.autoUpdateEnabled = nowDynamic;
            f.autoThoughtsEnabled = nowDynamic;
            f.hooksEnabled = nowDynamic;
            await saveCharacter(f);
            
            // Sync to index for immediate UI refresh
            const idx = await loadIndex();
            const mMatch = idx.find(function(m) { return m.id === meta.id; });
            if (mMatch) { (mMatch as any).isStatic = f.isStatic; await saveIndex(idx); }
            await refreshSidebar();
        } },
        // [vNEXT] Dynamic-priority rank. Hidden for the protagonist (never dynamic) and
        // minor NPCs (they ride the combined scene entry). Shows the current rank or a
        // neutral marker when unranked; tapping opens the swap-enforced rank picker.
        (isProtag || (meta as any).npcClass === 'minor') ? { type: 'text', text: '', style: { width: '0px' } } : { type: 'button', text: (typeof meta.dynamicPriorityRank === 'number' && meta.dynamicPriorityRank > 0) ? ('#' + meta.dynamicPriorityRank) : '#–', title: 'Dynamic priority rank', style: { margin: 0, padding: '2px 4px', fontSize: '9px', backgroundColor: (typeof meta.dynamicPriorityRank === 'number' && meta.dynamicPriorityRank > 0) ? 'rgba(232,168,124,0.15)' : 'rgba(255,255,255,0.05)', color: (typeof meta.dynamicPriorityRank === 'number' && meta.dynamicPriorityRank > 0) ? '#e8a87c' : '#888', border: 'none' }, callback: async function() {
            await openDynamicRankPicker(meta.id, async function() { await refreshSidebar(); });
        } },
        { type: 'button', text: (isPinned || isProtag) ? '📌' : '📌', style: { margin: 0, padding: '2px 4px', fontSize: '10px', backgroundColor: 'transparent', opacity: (isPinned || isProtag) ? '1' : '0.3', border: 'none' }, disabled: isProtag, callback: async function() {
            const f = await loadCharacter(meta.id); if (!f) return;
            f.pinned = !f.pinned; await saveCharacter(f);
            
            const idx = await loadIndex();
            const mMatch = idx.find(function(m) { return m.id === meta.id; });
            if (mMatch) { (mMatch as any).pinned = f.pinned; await saveIndex(idx); }
            await refreshSidebar();
        } }
    ] };

    // Row 2: Species, Age, Gender, Role
    let detailsArr: string[] = [];
    if (meta.species) detailsArr.push(meta.species);
    if (meta.age) detailsArr.push(meta.age);
    if (meta.gender) detailsArr.push(meta.gender);
    if (meta.occupationRole) detailsArr.push(meta.occupationRole);
    const detailsStr = detailsArr.length > 0 ? detailsArr.join(' · ') : 'No details';
    
    const descRow: UIPart = { type: 'text', text: detailsStr, style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } };

    // Row 3: Equipped items (if any)
    const equipped = (meta.equippedItemNames || []).filter(Boolean);
    const equipRow: UIPart | null = equipped.length > 0 ? {
        type: 'text', text: `🎒 ${equipped.join(', ')}`, style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px', fontStyle: 'italic', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }
    } : null;

    // Row 4: Action Row (Scene Toggle + Location + Kill + Sort + Edit)
    const locName = meta.currentLocationId
        ? ((entIdx || []).find(function(l: any) { return l.id === meta.currentLocationId; })?.name || 'Unknown')
        : 'No Location';

    const sceneBtn: UIPart = {
        type: 'button',
        text: isScene ? '🟢 Scene' : '⚫ Away',
        style: { margin: 0, padding: '4px 6px', fontSize: '10px', backgroundColor: isScene ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: isScene ? '#7ec8a0' : '#888', border: 'none' },
        callback: async function() {
            const f = await loadCharacter(meta.id); if (!f) return;
            f.scenePresent = !f.scenePresent; await saveCharacter(f); await refreshSidebar();
        }
    };

    const locationBtn: UIPart = { type: 'button', text: `📍 ${locName}`, style: { flex: '1 1 0', margin: 0, padding: '4px 6px', fontSize: '10px', textAlign: 'left', opacity: '0.8', borderRadius: '4px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }, callback: async function() {
        const freshEntIdx = await loadEntityIndex();
        const spatialNodes = freshEntIdx.filter(function(n: any) { return n.type !== 'character'; });
        const pm = await openEngineModal({ title: 'Set Location', size: 'medium', content: [
            { type: 'button', text: '✕ No Location', style: { width: '100%', marginBottom: '8px' }, callback: async function() {
                const f = await loadCharacter(meta.id); if (!f) { pm.close(); return; }
                if (f.entityId) { let locEnt = await loadEntity(f.entityId); if (locEnt) { locEnt.parentId = null; await saveEntity(locEnt); } }
                await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshSidebar();
            } },
            ...spatialNodes.filter(Boolean).map(function(l: any) {
                return { type: 'button', text: `📍 ${l.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: meta.currentLocationId === l.id ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                    const f = await loadCharacter(meta.id); if (!f) { pm.close(); return; }
                    if (f.entityId) { let locEnt2 = await loadEntity(f.entityId); if (locEnt2) { locEnt2.parentId = l.id; await saveEntity(locEnt2); } }
                    await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshSidebar();
                } } as UIPart;
            })
        ]});
    } };

    const actionRowContent: UIPart[] = [ sceneBtn, locationBtn ];
    if (!isProtag) {
        actionRowContent.push({
            type: 'button', text: '💀', style: { margin: 0, padding: '4px 6px', fontSize: '11px', backgroundColor: 'transparent', color: '#ff6b6b', border: '1px solid rgba(255,107,107,0.2)' },
            callback: async function() { await killCharacter(meta.id); await refreshSidebar(); }
        } as UIPart);
    }
    actionRowContent.push(
        { type: 'button', iconId: 'arrow-up', style: { margin: 0, padding: '4px', backgroundColor: 'transparent', opacity: idxPos > 0 ? '1' : '0.2' }, disabled: idxPos === 0, callback: async function() { await moveChar(meta.id, -1); } },
        { type: 'button', iconId: 'arrow-down', style: { margin: 0, padding: '4px', backgroundColor: 'transparent', opacity: idxPos < idxLength - 1 ? '1' : '0.2' }, disabled: idxPos >= idxLength - 1, callback: async function() { await moveChar(meta.id, 1); } },
        { type: 'button', iconId: 'edit-2', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openCharEditModal(meta.id); } }
    );

    const actionRow: UIPart = { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '4px' }, content: actionRowContent };

    const rightCol: UIPart = { type: 'column', style: { flex: '1 1 0', gap: '0', overflow: 'hidden' }, content: [
        nameRow, descRow,
        ...(equipRow ? [equipRow] : []),
        actionRow
    ] };

    return {
        type: 'box',
        style: { marginBottom: '8px', padding: '8px', borderRadius: '8px', backgroundColor: 'rgba(255,255,255,0.02)', border: '1px solid rgba(255,255,255,0.05)', borderLeft: cardBorderLeft, opacity: meta.active ? '1' : '0.45' },
        content: [{ type: 'row', style: { gap: '10px' }, content: avatarCol ? [avatarCol, rightCol] : [rightCol] }]
    };
}

// ============================================================================
// [vNEXT] MINOR NPC LIFECYCLE
// Lightweight, drop-in-and-out NPCs: a real (starved) CharacterRecord twin so
// every char-targeting rule works, flagged npcClass:'minor' + isStatic so the
// dynamic engine, dramatis personae, and lorebook sync all skip them. Presence
// reaches the model via one combined ephemeral lorebook entry (see
// buildSceneLorebookActivation). No dossier, no permanent lorebook.
// ============================================================================

// [vNEXT] Expand {a|b|c} alternation groups in a template string, picking one
// option per group via the seeded RNG. Runs ONCE at spawn time and the result is
// baked into the record — deliberately kept out of the live |macro| evaluator,
// which re-evaluates every generation and would re-roll the choice each turn.
function aeExpandAlternations(txt: string): string {
    let outAlt = String(txt || '');
    let guardAlt = 0;
    while (guardAlt < 24) {
        let mAlt = outAlt.match(/\{([^{}|]*(?:\|[^{}|]*)+)\}/);
        if (!mAlt) break;
        let optsAlt = mAlt[1].split('|');
        let idxAlt = 0;
        try { idxAlt = api.v1.random.roll('1d' + optsAlt.length).total - 1; } catch (eAlt) { idxAlt = 0; }
        if (idxAlt < 0 || idxAlt >= optsAlt.length) idxAlt = 0;
        let posAlt = (typeof mAlt.index === 'number') ? mAlt.index : 0;
        outAlt = outAlt.substring(0, posAlt) + optsAlt[idxAlt].trim() + outAlt.substring(posAlt + mAlt[0].length);
        guardAlt++;
    }
    return outAlt;
}

async function spawnMinorNpc(name: string, brief: string, locId: string | null, archetype?: NpcArchetypeDef | null, quiet?: boolean): Promise<{ id: string; name: string } | null> {
    try {
        const cfg = await loadConfig();
        if (!locId) { locId = await aeGetPlayerRoomId(); }   // [vNEXT] default to the player's actual room
        let baseName = aeExpandAlternations(name || (archetype ? archetype.name : '') || 'Someone').trim();
        if (!baseName) baseName = 'Someone';
        let finalBrief = aeExpandAlternations(brief || (archetype ? archetype.briefTemplate : '') || '').trim();

        // Numbered suffix on collision with any active character (Skeleton, Skeleton 2...).
        const nsIdx = await loadIndex();
        let finalName = baseName;
        let nsN = 2;
        while (nsIdx.some(function(m) { return !!m && m.active && (m.name || '') === finalName; }) && nsN < 50) {
            finalName = baseName + ' ' + nsN;
            nsN++;
        }

        const body = makeDefaultEntity(finalName);
        body.type = 'character';
        body.parentId = locId ? locId : null;
        body.description = finalBrief;
        if (archetype && archetype.icon) (body as any).icon = archetype.icon;
        if (archetype && archetype.actionInstances && archetype.actionInstances.length) {
            (body as any).actionInstances = JSON.parse(JSON.stringify(archetype.actionInstances));
        }
        if (archetype && archetype.tagSubscriptions && archetype.tagSubscriptions.length) {
            (body as any).tagSubscriptions = archetype.tagSubscriptions.slice();   // live tag refs resolve from the library at runtime
        }
        await saveEntity(body);

        const rec = makeDefaultCharacter(finalName, cfg);
        rec.entityId = body.id;
        (rec as any).npcClass = 'minor';
        (rec as any).isStatic = true;
        rec.charContextEnabled = false;
        rec.autoUpdateEnabled = false;
        rec.autoThoughtsEnabled = false;
        rec.hooksEnabled = false;
        rec.briefDescription = finalBrief;
        rec.active = true;
        rec.scenePresent = true;

        if (archetype) {
            (rec as any).npcArchetypeId = archetype.id;
            if (archetype.charResourceDefs && archetype.charResourceDefs.length) {
                if (!rec.charResourceDefs) rec.charResourceDefs = [];
                if (!rec.charResourceValues) rec.charResourceValues = {};
                for (const adef of archetype.charResourceDefs) {
                    // makeDefaultCharacter seeds personal defaults (health etc.) — an
                    // archetype def with the same tag REPLACES the seeded one so the
                    // record never carries two defs for one tag.
                    let existDef = rec.charResourceDefs.find(function(d) { return d.tag === adef.tag; });
                    if (existDef) {
                        delete rec.charResourceValues[existDef.id];
                        rec.charResourceDefs = rec.charResourceDefs.filter(function(d) { return d.id !== existDef.id; });
                    }
                    const nDefId = generateId();
                    rec.charResourceDefs.push({ id: nDefId, name: adef.name, tag: adef.tag, type: adef.type, hasBounds: adef.hasBounds, min: adef.min, max: adef.max, states: adef.states ? adef.states.slice() : undefined });
                    if (adef.type === 'pool') rec.charResourceValues[nDefId] = (adef.max !== undefined ? adef.max : 0);
                    else rec.charResourceValues[nDefId] = adef.states ? (adef.states.length - 1) : 0;
                }
            }
        }
        await saveCharacter(rec);

        await recalculateScenePresence();
        queueSceneStateBroadcast();
        if (!quiet) api.v1.ui.toast('Minor NPC "' + finalName + '" added.', { type: 'success', autoClose: 2000 });
        return { id: rec.id, name: finalName };
    } catch (e) {
        api.v1.error('[AE] spawnMinorNpc:', e);
        api.v1.ui.toast('Failed to add minor NPC.', { type: 'error' });
        return null;
    }
}

async function promoteMinorNpc(entityId: string): Promise<void> {
    try {
        const cfg = await loadConfig();
        const all = await loadAllCharacters();
        const rec = all.filter(function(c) { return c.entityId === entityId; })[0];
        if (!rec) { api.v1.ui.toast('Character not found.', { type: 'warning' }); return; }

        const body = await loadEntity(entityId);
        (rec as any).npcClass = undefined;
        (rec as any).isStatic = false;
        rec.charContextEnabled = true;
        rec.autoUpdateEnabled = cfg.autoUpdateDefault;
        rec.autoThoughtsEnabled = cfg.autoThoughtsDefault;
        rec.hooksEnabled = true;

        // Seed the concept dump from the brief + the body description + recent story so
        // the existing field-generation wizard has something to work from.
        if (!(rec.conceptDump || '').trim()) {
            const seedBits: string[] = [];
            if ((rec.briefDescription || '').trim()) seedBits.push(rec.briefDescription.trim());
            if (body && (body.description || '').trim()) seedBits.push(body.description.trim());
            rec.conceptDump = seedBits.join('\n');
        }
        await saveCharacter(rec);

        try { await createLinkedLorebookEntry(rec.id); } catch (lbErr) { /* non-fatal */ }
        await recalculateScenePresence();
        queueSceneStateBroadcast();
        api.v1.ui.toast(rec.name + ' promoted to major. Open the Characters tab to generate their dossier fields.', { type: 'success', autoClose: 3500 });
    } catch (e) {
        api.v1.error('[AE] promoteMinorNpc:', e);
        api.v1.ui.toast('Failed to promote NPC.', { type: 'error' });
    }
}

// Native HUD: render a set of minor-NPC entity-detail children like the item
// section (description + entity actions), plus Promote and Edit affordances.
function _aeMinorNpcSection(minors: any[], refreshFn: () => Promise<void>): UIPart[] {
    return (minors || []).map(function(m: any) {
        let body: UIPart[] = [];
        body.push({ type: 'text', text: m.description || 'No description.', style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);
        (m.actionInstances || []).forEach(function(inst: any) {
            body.push({ type: 'button', text: inst.name, iconId: 'zap', style: { width: '100%', fontSize: '11px', marginBottom: '3px' }, callback: async function() { await aeRunEntityAction(m.id, inst.id); await refreshFn(); } } as UIPart);
        });
        body.push({ type: 'button', text: 'Promote to Major', iconId: 'arrow-up-circle', style: { width: '100%', fontSize: '11px', marginTop: '4px', marginBottom: '3px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, callback: async function() { await promoteMinorNpc(m.id); await refreshFn(); } } as UIPart);
        body.push({ type: 'button', text: 'Edit Entity', iconId: 'tool', style: { width: '100%', fontSize: '11px', opacity: '0.75' }, callback: async function() { try { await openEntityEditModal(m.id); } catch (e) {} } } as UIPart);
        return { type: 'collapsibleSection', title: (m.icon ? m.icon + ' ' : '\ud83d\udc65 ') + m.name, initialCollapsed: true, storageKey: 'temp:ae_minor_' + m.id, content: body } as UIPart;
    });
}

// ── [vNEXT] Bestiary: minor-NPC archetype library ─────────────────────────────
// [vNEXT] Scene-grounded minor-NPC generator. Uses generateWithStory in
// 'background' mode (same path as generateCharacterSnapshot) so the model sees
// the live story + location and invents someone who fits the moment. Returns a
// {name, brief} for review/spawn; does NOT create anything itself.
async function generateSceneNpc(archetype?: NpcArchetypeDef | null): Promise<{ name: string; brief: string } | null> {
    try {
        let gsLocName = 'the current location';
        let gsLocDesc = '';
        let gsLocId = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
        if (gsLocId) {
            let gsLocEnt = await loadEntity(gsLocId);
            if (gsLocEnt) { gsLocName = gsLocEnt.name || gsLocName; gsLocDesc = gsLocEnt.description || ''; }
        }
        let gsCfg = await loadConfig();
        let gsSys: string[] = [
            gsCfg.generalStyle || '',
            '',
            'You invent ONE minor background character who would plausibly be present in the current scene.',
            'Base them on what is actually happening in the story right now and on the location.',
            'Output EXACTLY two lines and nothing else, no preamble:',
            'NAME: <a short name or label, e.g. Gate Guard, Mara, Hooded Vendor>',
            'DOING: <one present-tense sentence describing what they are doing here and why>'
        ];
        if (archetype) {
            gsSys.push('');
            gsSys.push('They should fit this archetype: ' + archetype.name + (archetype.briefTemplate ? ' \u2014 ' + aeExpandAlternations(archetype.briefTemplate) : '') + '.');
        }
        let gsUsr: string[] = [
            'Location: ' + gsLocName,
            gsLocDesc ? 'Setting: ' + gsLocDesc.slice(0, 160) : '',
            'Invent a fitting minor NPC now. Two lines only.'
        ].filter(Boolean);

        let gsResp = await api.v1.generateWithStory(
            [{ role: 'system', content: gsSys.join('\n') }, { role: 'user', content: gsUsr.join('\n') }],
            { model: 'glm-4-6', max_tokens: 120 },
            { suppressScriptHooks: 'self', contextLimitReduction: 450 },
            undefined,
            'background'
        );
        let gsTxt = (gsResp && gsResp.choices && gsResp.choices.length > 0) ? String(gsResp.choices[0].text || '') : '';
        if (!gsTxt.trim()) return null;

        let gsName = '';
        let gsBrief = '';
        gsTxt.split('\n').forEach(function(ln) {
            let t = ln.trim();
            let up = t.toUpperCase();
            if (up.indexOf('NAME:') === 0) gsName = t.substring(5).trim();
            else if (up.indexOf('DOING:') === 0) gsBrief = t.substring(6).trim();
        });
        if (!gsName || !gsBrief) {
            let gsLines = gsTxt.split('\n').map(function(s) { return s.trim(); }).filter(Boolean);
            if (!gsName && gsLines.length > 0) gsName = gsLines[0].replace(/^NAME:\s*/i, '');
            if (!gsBrief && gsLines.length > 1) gsBrief = gsLines.slice(1).join(' ').replace(/^DOING:\s*/i, '');
        }
        gsName = gsName.replace(/^["'\s\-]+/, '').replace(/["'\s]+$/, '').slice(0, 60);
        gsBrief = gsBrief.replace(/^["'\s\-]+/, '').slice(0, 240);
        if (!gsName) return null;
        return { name: gsName, brief: gsBrief };
    } catch (e) {
        api.v1.error('[AE] generateSceneNpc:', e);
        api.v1.ui.toast('Scene generation failed.', { type: 'error' });
        return null;
    }
}

var _aeBestiaryHandle: any = null;
var _aeBestiaryDelPending: string | null = null;
var _aeArchEditHandle: any = null;
var _aeArchEditId: string | null = null;

async function aeMutateArchetype(mut: (a: NpcArchetypeDef) => void): Promise<void> {
    const muCfg = await loadConfig();
    const muArch = (((muCfg as any).npcArchetypes || []) as NpcArchetypeDef[]).find(function(x) { return x.id === _aeArchEditId; });
    if (!muArch) return;
    try { mut(muArch); } catch (eMu) { api.v1.error('[AE:bestiary] mutate:', eMu); return; }
    await saveConfig(muCfg);
}

function aeArchTagFromName(nm: string): string {
    let tagTxt = String(nm || '').toLowerCase().replace(/[^a-z0-9]+/g, '');
    return '#' + (tagTxt || 'res');
}

async function buildArchetypeEditContent(): Promise<UIPart[]> {
    const eCfg = await loadConfig();
    const eArch = (((eCfg as any).npcArchetypes || []) as NpcArchetypeDef[]).find(function(x) { return x.id === _aeArchEditId; });
    let eParts: UIPart[] = [];
    if (!eArch) { eParts.push({ type: 'error', text: 'Archetype not found.' } as UIPart); return eParts; }

    eParts.push({ type: 'textInput', label: 'Name (supports {a|b|c})', placeholder: 'e.g. {Brittle|Rattling|Ancient} Skeleton', initialValue: eArch.name || '', onChange: async function(v: string) { await aeMutateArchetype(function(a) { a.name = v; }); } } as UIPart);
    eParts.push({ type: 'textInput', label: 'Icon (emoji, optional)', placeholder: 'e.g. skull emoji', initialValue: eArch.icon || '', onChange: async function(v: string) { await aeMutateArchetype(function(a) { a.icon = v.trim() || undefined; }); } } as UIPart);
    eParts.push({ type: 'multilineTextInput', label: 'What are they doing here? (supports {a|b|c})', placeholder: 'e.g. A skeleton lurching forward, {sword|axe|club} raised to strike.', initialValue: eArch.briefTemplate || '', style: { minHeight: '56px' }, onChange: async function(v: string) { await aeMutateArchetype(function(a) { a.briefTemplate = v; }); } } as UIPart);

    // ── Resources ──────────────────────────────────────────────────────────────
    eParts.push({ type: 'text', text: 'Resources', style: { fontSize: '12px', fontWeight: 'bold', marginTop: '10px', marginBottom: '4px' } } as UIPart);
    eParts.push({ type: 'text', text: 'Copied onto each spawned NPC. A def with the same tag as a seeded personal default (e.g. #health) replaces it. Track state labels read best when evocative — they surface directly in context ("looks close to death").', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } } as UIPart);
    const eDefs = eArch.charResourceDefs || [];
    for (let eRi = 0; eRi < eDefs.length; eRi++) {
        const eDef = eDefs[eRi];
        const eDefId = eDef.id;
        let eRowParts: UIPart[] = [
            { type: 'textInput', label: 'Name', initialValue: eDef.name || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await aeMutateArchetype(function(a) { let d = (a.charResourceDefs || []).find(function(x) { return x.id === eDefId; }); if (d) { d.name = v; d.tag = aeArchTagFromName(v); } }); } } as UIPart,
            { type: 'button', text: eDef.type === 'pool' ? 'Pool' : 'Track', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 8px', alignSelf: 'flex-end' }, callback: async function() { await aeMutateArchetype(function(a) { let d = (a.charResourceDefs || []).find(function(x) { return x.id === eDefId; }); if (d) d.type = (d.type === 'pool') ? 'track' : 'pool'; }); await refreshArchetypeEditModal(); } } as UIPart
        ];
        if (eDef.type === 'pool') {
            eRowParts.push({ type: 'textInput', label: 'Max', initialValue: (eDef.max !== undefined ? String(eDef.max) : '10'), style: { flex: '0 0 64px' }, onChange: async function(v: string) { await aeMutateArchetype(function(a) { let d = (a.charResourceDefs || []).find(function(x) { return x.id === eDefId; }); if (d) { let n = Number(v); d.max = isNaN(n) ? 10 : n; d.min = 0; d.hasBounds = true; } }); } } as UIPart);
        } else {
            eRowParts.push({ type: 'textInput', label: 'States (worst \u2192 best, comma-sep)', initialValue: (eDef.states || []).join(', '), style: { flex: '2 1 0' }, onChange: async function(v: string) { await aeMutateArchetype(function(a) { let d = (a.charResourceDefs || []).find(function(x) { return x.id === eDefId; }); if (d) d.states = v.split(',').map(function(s) { return s.trim(); }).filter(Boolean); }); } } as UIPart);
        }
        eRowParts.push({ type: 'button', text: '\u2715', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px', alignSelf: 'flex-end' }, callback: async function() { await aeMutateArchetype(function(a) { a.charResourceDefs = (a.charResourceDefs || []).filter(function(x) { return x.id !== eDefId; }); }); await refreshArchetypeEditModal(); } } as UIPart);
        eParts.push({ type: 'row', style: { gap: '4px', marginBottom: '4px', alignItems: 'flex-end' }, content: eRowParts } as UIPart);
    }
    eParts.push({ type: 'button', text: '+ Default Resources', style: { width: '100%', fontSize: '11px', marginBottom: '4px', backgroundColor: 'rgba(136,204,255,0.10)', color: '#88ccff' }, callback: async function() {
        const seedTpl = (eCfg.characterResourceDefs && eCfg.characterResourceDefs.length) ? eCfg.characterResourceDefs : DEFAULT_CHAR_RESOURCES;
        await aeMutateArchetype(function(a) {
            if (!a.charResourceDefs) a.charResourceDefs = [];
            const haveTags: string[] = a.charResourceDefs.map(function(d) { return d.tag; });
            for (const sd of seedTpl) {
                if (haveTags.indexOf(sd.tag) >= 0) continue;
                a.charResourceDefs.push({ id: generateId(), name: sd.name, tag: sd.tag, type: sd.type, hasBounds: sd.hasBounds, min: sd.min, max: sd.max, states: sd.states ? sd.states.slice() : undefined });
            }
        });
        await refreshArchetypeEditModal();
    } } as UIPart);
    eParts.push({ type: 'button', text: '+ Add Resource', style: { width: '100%', fontSize: '11px', marginBottom: '4px' }, callback: async function() {
        await aeMutateArchetype(function(a) {
            if (!a.charResourceDefs) a.charResourceDefs = [];
            a.charResourceDefs.push({ id: generateId(), name: 'Health', tag: '#health', type: 'track', hasBounds: true, states: ['looks close to death', 'looks badly hurt', 'looks roughed up', 'looks unharmed'] });
        });
        await refreshArchetypeEditModal();
    } } as UIPart);

    // ── Actions ────────────────────────────────────────────────────────────────
    eParts.push({ type: 'text', text: 'Actions', style: { fontSize: '12px', fontWeight: 'bold', marginTop: '10px', marginBottom: '4px' } } as UIPart);
    eParts.push({ type: 'text', text: 'Copied from the Action Library onto each spawned NPC\u2019s body. Edits to the library after copying do not flow through \u2014 re-add to refresh.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } } as UIPart);
    const eActs = eArch.actionInstances || [];
    for (let eAi = 0; eAi < eActs.length; eAi++) {
        const eAct = eActs[eAi];
        const eActId = eAct.id;
        eParts.push({ type: 'row', style: { gap: '4px', marginBottom: '3px', alignItems: 'center' }, content: [
            { type: 'text', text: '\u26a1 ' + (eAct.name || eActId), style: { flex: '1 1 0', fontSize: '11px' } },
            { type: 'button', text: '\u2715', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, callback: async function() { await aeMutateArchetype(function(a) { a.actionInstances = (a.actionInstances || []).filter(function(x) { return x.id !== eActId; }); }); await refreshArchetypeEditModal(); } }
        ] } as UIPart);
    }
    eParts.push({ type: 'button', text: '+ From Action Library', style: { width: '100%', fontSize: '11px', marginBottom: '4px' }, callback: async function() {
        const pkCfg = await loadConfig();
        const pkItems = ((pkCfg.actionTemplates || []) as ActionInstance[]).filter(function(tmp) { return (String(tmp.id || '')).indexOf('sys_') !== 0; });
        await openPickerModal({
            title: 'Copy Action to Archetype',
            items: pkItems,
            getId: function(it: any) { return it.id; },
            getLabel: function(it: any) { return it.name || it.id; },
            emptyText: 'No library actions yet \u2014 build one in the Action tab first.',
            onSelect: async function(it: any) {
                await aeMutateArchetype(function(a) {
                    if (!a.actionInstances) a.actionInstances = [];
                    if (!a.actionInstances.some(function(x) { return x.id === it.id; })) a.actionInstances.push(JSON.parse(JSON.stringify(it)));
                });
                await openArchetypeEditModal(String(_aeArchEditId));
            }
        });
    } } as UIPart);

    // ── Tag subscriptions (live library refs; shared across all spawned copies) ──
    const eTpls = ((eCfg.actionTemplates || []) as ActionInstance[]).filter(function(t) {
        if (t.appliesTo && t.appliesTo.length && t.appliesTo.indexOf('character') < 0) return false;
        return true;
    });
    const eAllTags: string[] = [];
    for (const eTpl of eTpls) {
        for (const eTag of (((eTpl as any).tags || []) as string[])) {
            if (typeof eTag === 'string' && eTag.charAt(0) !== '_' && eAllTags.indexOf(eTag) < 0) eAllTags.push(eTag);
        }
    }
    eAllTags.sort();
    const eSubs: string[] = eArch.tagSubscriptions || [];
    eParts.push({ type: 'text', text: 'Action Tags', style: { fontSize: '12px', fontWeight: 'bold', marginTop: '10px', marginBottom: '4px' } } as UIPart);
    if (eAllTags.length === 0) {
        eParts.push({ type: 'text', text: 'No tagged library actions yet \u2014 tag actions in the Action Library, then subscribe here. Tags resolve live, so editing the library updates every spawned NPC.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } } as UIPart);
    } else {
        eParts.push({ type: 'text', text: 'Checked tags live-include every matching library action on each spawned NPC. No copy is made \u2014 edit the library action once and all copies update.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } } as UIPart);
        for (const eTag of eAllTags) {
            const captTag = eTag;
            const eMatch = eTpls.filter(function(t) { return (((t as any).tags || []) as string[]).indexOf(captTag) >= 0; }).length;
            eParts.push({ type: 'checkboxInput', label: captTag + '  (' + eMatch + ' action' + (eMatch === 1 ? '' : 's') + ')', initialValue: eSubs.indexOf(captTag) >= 0, onChange: async function(v: boolean) {
                await aeMutateArchetype(function(a) {
                    let arr: string[] = (a.tagSubscriptions || []).slice();
                    if (v) { if (arr.indexOf(captTag) < 0) arr.push(captTag); }
                    else   { arr = arr.filter(function(x) { return x !== captTag; }); }
                    a.tagSubscriptions = arr;
                });
                await refreshArchetypeEditModal();
            } } as UIPart);
        }
    }

    eParts.push({ type: 'button', text: 'Done', style: { width: '100%', marginTop: '10px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, callback: async function() {
        try { if (_aeArchEditHandle && !_aeArchEditHandle.isClosed()) await _aeArchEditHandle.close(); } catch (eCl) {}
        await openBestiaryModal();
    } } as UIPart);
    return eParts;
}

async function refreshArchetypeEditModal(): Promise<void> {
    if (_aeArchEditHandle && typeof _aeArchEditHandle.isClosed === 'function' && !_aeArchEditHandle.isClosed()) {
        let recContent = await buildArchetypeEditContent();
        await _aeArchEditHandle.update({ content: recContent });
    }
}

async function openArchetypeEditModal(archId: string): Promise<void> {
    _aeArchEditId = archId;
    let aeContent = await buildArchetypeEditContent();
    _aeArchEditHandle = await openEngineModal({ id: 'ae-arch-edit', title: 'Edit Archetype', size: 'medium', content: aeContent });
}

async function buildBestiaryContent(): Promise<UIPart[]> {
    const bCfg = await loadConfig();
    const bArchs = (((bCfg as any).npcArchetypes || []) as NpcArchetypeDef[]);
    let bParts: UIPart[] = [];
    bParts.push({ type: 'text', text: 'Archetype templates for quick drop-in minor NPCs. Spawning deep-copies the template \u2014 editing an archetype never touches already-spawned NPCs. Use the Spawn Minor NPC effect in the Action studio to fire these from encounters (different counts on different resolution bands = encounter variety).', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } } as UIPart);
    bParts.push({ type: 'button', text: '+ New Archetype', iconId: 'plus', style: { width: '100%', marginBottom: '8px' }, disabledWhileCallbackRunning: true, callback: async function() {
        const nbCfg = await loadConfig();
        if (!(nbCfg as any).npcArchetypes) (nbCfg as any).npcArchetypes = [];
        const nbArch: NpcArchetypeDef = { id: generateId(), name: 'New Archetype', briefTemplate: '', charResourceDefs: [], actionInstances: [] };
        ((nbCfg as any).npcArchetypes as NpcArchetypeDef[]).push(nbArch);
        await saveConfig(nbCfg);
        try { if (_aeBestiaryHandle && !_aeBestiaryHandle.isClosed()) await _aeBestiaryHandle.close(); } catch (eNb) {}
        await openArchetypeEditModal(nbArch.id);
    } } as UIPart);
    if (bArchs.length === 0) bParts.push({ type: 'text', text: 'No archetypes yet.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic' } } as UIPart);
    for (const bA of bArchs) {
        const bId = bA.id;
        const bDelArm = _aeBestiaryDelPending === bId;
        bParts.push({ type: 'row', style: { gap: '4px', marginBottom: '4px', alignItems: 'center' }, content: [
            { type: 'text', text: aeIconPfx(bA.icon) + bA.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },
            { type: 'text', text: ((bA.charResourceDefs || []).length) + ' res \u00b7 ' + ((bA.actionInstances || []).length) + ' act', style: { flex: '0 0 auto', fontSize: '10px', opacity: '0.5' } },
            { type: 'button', text: 'Spawn', iconId: 'user-plus', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, disabledWhileCallbackRunning: true, callback: async function() {
                let spLoc = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
                await spawnMinorNpc('', '', spLoc, bA, false);
            } },
            { type: 'button', text: '\u2728', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, disabledWhileCallbackRunning: true, callback: async function() {
                api.v1.ui.toast('Generating ' + bA.name + ' for the scene\u2026', { id: 'ae-gen-b', autoClose: false });
                let gsGen = await generateSceneNpc(bA);
                if (gsGen) {
                    let gsLoc = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;
                    await spawnMinorNpc(gsGen.name, gsGen.brief, gsLoc, bA, false);
                    api.v1.ui.toast('\u2728 ' + gsGen.name + ' joins the scene.', { id: 'ae-gen-b', type: 'success', autoClose: 2500 });
                } else {
                    api.v1.ui.toast('Generation failed \u2014 try again.', { id: 'ae-gen-b', type: 'warning', autoClose: 3000 });
                }
            } },
            { type: 'button', text: 'Edit', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, callback: async function() {
                try { if (_aeBestiaryHandle && !_aeBestiaryHandle.isClosed()) await _aeBestiaryHandle.close(); } catch (eBe) {}
                await openArchetypeEditModal(bId);
            } },
            { type: 'button', text: bDelArm ? 'Sure?' : '\u2715', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px', color: bDelArm ? '#ff8888' : 'inherit' }, callback: async function() {
                if (_aeBestiaryDelPending !== bId) { _aeBestiaryDelPending = bId; await refreshBestiaryModal(); return; }
                _aeBestiaryDelPending = null;
                const dCfg = await loadConfig();
                (dCfg as any).npcArchetypes = (((dCfg as any).npcArchetypes || []) as NpcArchetypeDef[]).filter(function(x) { return x.id !== bId; });
                await saveConfig(dCfg);
                await refreshBestiaryModal();
            } }
        ] } as UIPart);
    }
    return bParts;
}

async function refreshBestiaryModal(): Promise<void> {
    if (_aeBestiaryHandle && typeof _aeBestiaryHandle.isClosed === 'function' && !_aeBestiaryHandle.isClosed()) {
        let rbContent = await buildBestiaryContent();
        await _aeBestiaryHandle.update({ content: rbContent });
    }
}

async function openBestiaryModal(): Promise<void> {
    _aeBestiaryDelPending = null;
    let bmContent = await buildBestiaryContent();
    _aeBestiaryHandle = await openEngineModal({ id: 'ae-bestiary', title: 'Bestiary', size: 'medium', content: bmContent });
}

// ── [vNEXT] Add-Minor-NPC modal (blank or from archetype) ─────────────────────
var _aeAddMinorHandle: any = null;
var _aeAddMinorName = '';
var _aeAddMinorBrief = '';
var _aeAddMinorArchId: string | null = null;
var _aeAddMinorLoc: string | null = null;
var _aeAddMinorRefresh: (() => Promise<void>) | null = null;

async function buildAddMinorContent(): Promise<UIPart[]> {
    const amCfg = await loadConfig();
    const amArchs = (((amCfg as any).npcArchetypes || []) as NpcArchetypeDef[]);
    const amSel = amArchs.find(function(x) { return x.id === _aeAddMinorArchId; });
    let amParts: UIPart[] = [];
    amParts.push({ type: 'text', text: 'A quick drop-in NPC at the current location. No lorebook, no dossier \u2014 just a name and what they are doing here. Promote later to flesh out.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } } as UIPart);
    amParts.push({ type: 'row', style: { gap: '4px', marginBottom: '6px', alignItems: 'center' }, content: [
        { type: 'text', text: 'Archetype:', style: { flex: '0 0 auto', fontSize: '11px', opacity: '0.7' } },
        { type: 'button', text: amSel ? (aeIconPfx(amSel.icon) + amSel.name) : 'None (blank)', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() {
            await openPickerModal({
                title: 'Pick Archetype',
                items: amArchs,
                getId: function(it: any) { return it.id; },
                getLabel: function(it: any) { return aeIconPfx(it.icon) + it.name; },
                pinnedOptions: [{ id: '__none__', label: 'None (blank)', onSelect: async function() { _aeAddMinorArchId = null; await refreshAddMinorModal(); } }],
                emptyText: 'No archetypes yet \u2014 build them in the Bestiary (Characters tab).',
                onSelect: async function(it: any) { _aeAddMinorArchId = it.id; await refreshAddMinorModal(); }
            });
        } }
    ] } as UIPart);
    amParts.push({ type: 'textInput', label: 'Name' + (amSel ? ' (blank = archetype name)' : ''), placeholder: amSel ? amSel.name : 'e.g. Skeleton, Gate Guard, Fruit Vendor', initialValue: _aeAddMinorName, onChange: function(v: string) { _aeAddMinorName = v; } } as UIPart);
    amParts.push({ type: 'multilineTextInput', label: 'What are they doing here?' + (amSel ? ' (blank = archetype description)' : ''), placeholder: amSel ? (amSel.briefTemplate || '') : 'e.g. A brittle skeleton lurching forward to attack.', initialValue: _aeAddMinorBrief, style: { minHeight: '50px' }, onChange: function(v: string) { _aeAddMinorBrief = v; } } as UIPart);
    amParts.push({ type: 'button', text: '\u2728 Generate from Scene', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
        api.v1.ui.toast('Generating an NPC that fits the scene\u2026', { id: 'ae-gen-am', autoClose: false });
        let amGen = await generateSceneNpc(amSel || null);
        if (amGen) {
            _aeAddMinorName = amGen.name;
            _aeAddMinorBrief = amGen.brief;
            api.v1.ui.toast('Filled in \u2014 tweak and Create, or generate again.', { id: 'ae-gen-am', type: 'success', autoClose: 2500 });
            await refreshAddMinorModal();
        } else {
            api.v1.ui.toast('Could not generate \u2014 type it in or try again.', { id: 'ae-gen-am', type: 'warning', autoClose: 3000 });
        }
    } } as UIPart);
    amParts.push({ type: 'button', text: 'Create NPC', iconId: 'user-plus', style: { width: '100%', marginTop: '6px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
        if (!_aeAddMinorName.trim() && !amSel) { api.v1.ui.toast('Name required (or pick an archetype).', { type: 'warning' }); return; }
        await spawnMinorNpc(_aeAddMinorName.trim(), _aeAddMinorBrief.trim(), _aeAddMinorLoc, amSel || null, false);
        try { if (_aeAddMinorHandle && !_aeAddMinorHandle.isClosed()) await _aeAddMinorHandle.close(); } catch (eAc) {}
        if (_aeAddMinorRefresh) await _aeAddMinorRefresh();
    } } as UIPart);
    return amParts;
}

async function refreshAddMinorModal(): Promise<void> {
    if (_aeAddMinorHandle && typeof _aeAddMinorHandle.isClosed === 'function' && !_aeAddMinorHandle.isClosed()) {
        let ramContent = await buildAddMinorContent();
        await _aeAddMinorHandle.update({ content: ramContent });
    }
}

async function openAddMinorNpcModal(locId: string | null, refreshFn: () => Promise<void>): Promise<void> {
    _aeAddMinorName = '';
    _aeAddMinorBrief = '';
    _aeAddMinorArchId = null;
    _aeAddMinorLoc = locId;
    _aeAddMinorRefresh = refreshFn;
    let oamContent = await buildAddMinorContent();
    _aeAddMinorHandle = await openEngineModal({ id: 'ae-add-minor', title: 'Add Minor NPC', size: 'small', content: oamContent });
}

async function killCharacter(charId: string): Promise<void> {
    try {
        let char = await loadCharacter(charId);
        if (!char) return;

        char.active = false;
        char.scenePresent = false;

        // --- INVENTORY DROP LOGIC ---
        if (char.entityId) {
            let allEnts = await loadEntityIndex();
            let charBody = await loadEntity(char.entityId);
            
            if (charBody) {
                // Determine where to drop the loot: the room they died in.
                // If they are in the void (null), fallback to the player's room.
                let dropRoomId = charBody.parentId; 
                if (!dropRoomId) {
                    dropRoomId = await loadPlayerLocation(); 
                }

                if (dropRoomId) {
                    // Find all items/entities currently attached to the dying character
                    let lootItems = allEnts.filter(function(e) { return e.parentId === char.entityId; });
                    for (let lootMeta of lootItems) {
                        let itemEnt = await loadEntity(lootMeta.id);
                        if (itemEnt) {
                            itemEnt.parentId = dropRoomId;
                            await saveEntity(itemEnt);
                        }
                    }
                }
                
                // Clear equipped items so they aren't still "wielding" things from the grave
                char.equippedItemIds = [];
            }
        }

        await saveCharacter(char);

        // Send entity body to Graveyard
        if (char.entityId) {
            let allEnts = await loadEntityIndex();
            let gyMeta = allEnts.find(function(e) { return e.name === 'Graveyard' && e.type === 'location'; });
            if (!gyMeta) {
                let gyEnt = makeDefaultEntity('Graveyard');
                gyEnt.type = 'location';
                gyEnt.parentId = null;
                await saveEntity(gyEnt);
                gyMeta = { id: gyEnt.id, name: 'Graveyard', type: 'location', parentId: null, childCount: 0, presentCharacterCount: 0, state: 'default' };
            }
            let gyBody = await loadEntity(char.entityId);
            if (gyBody) { gyBody.parentId = gyMeta.id; await saveEntity(gyBody); }
        }

        // Move to bottom of character index
        let idx = await loadIndex();
        let pos = idx.findIndex(function(m) { return m.id === charId; });
        if (pos >= 0 && pos < idx.length - 1) {
            let item = idx.splice(pos, 1)[0];
            idx.push(item);
            await saveIndex(idx);
        }

        api.v1.ui.toast('💀 ' + char.name + ' — deceased.', { type: 'warning' });
    } catch (e) { 
        api.v1.error('[AE] killCharacter:', e); 
    }
}


// ── Character Edit Modal ─────────────────────────────────────────────────────

async function openCharEditModal(charId: string): Promise<void> {
    if (charEditModalHandle && !charEditModalHandle.isClosed()) charEditModalHandle.close();
    editingCharId = charId;
    charEditModalHandle = await openEngineModal({ id: 'ce-char-edit', size: 'full', fillWidth: true, title: 'Edit Character', content: await buildCharEditContent(charId) });
}

async function refreshCharEditModal(): Promise<void> { 
    if (!charEditModalHandle || charEditModalHandle.isClosed() || !editingCharId) return; 
    await charEditModalHandle.update({ content: await buildCharEditContent(editingCharId) }); 
}


async function buildCharEditContent(charId: string): Promise<UIPart[]> {
    const char = await loadCharacter(charId); if (!char) return [{ type: 'text', text: 'Character not found.' }];
    
    // --- DATA SAFETY PATCH (Fixes "filter of undefined" on new characters) ---
    char.hooks = char.hooks || [];
    char.eventHistory = char.eventHistory || [];
    char.ephemeralHistory = char.ephemeralHistory || [];
    char.nicknames = char.nicknames || [];
    char.coreValues = char.coreValues || [];
    if (!char.primaryRelationship) {
        char.primaryRelationship = { targetName: '', enabled: false, archetype: '', howItStarted: '', threads: [], currentStatus: '', trajectory: '', summary: '', milestones: [] };
    }
    char.primaryRelationship.threads = char.primaryRelationship.threads || [];
    char.primaryRelationship.milestones = char.primaryRelationship.milestones || [];
    if (!char.customFieldValues) char.customFieldValues = {};
    if (!char.sheetValues) char.sheetValues = {};
    // ------------------------------------------------------------------------

    const cfg = await loadConfig(); const parts: UIPart[] = [];
    async function mut(fn: (c: CharacterRecord) => void): Promise<void> { const f = await loadCharacter(charId); if (!f) return; fn(f); await saveCharacter(f); await refreshSidebar(); }

    // --- CONSOLIDATED HEADER (2-ROW LAYOUT) ---
    const idx = await loadIndex();
    const myMeta = idx.find(m => m.id === charId);
    const currentLocationId = myMeta ? myMeta.currentLocationId : undefined;
    const entIdx = await loadEntityIndex();
    const locName = currentLocationId ? (entIdx.find(m => m.id === currentLocationId)?.name || 'Unknown') : 'No Location';

    parts.push({ type: 'column', style: { gap: '4px', marginBottom: '12px' }, content: [
        { type: 'textInput', placeholder: 'Character Name', initialValue: char.name, style: { fontSize: '15px', fontWeight: 'bold' }, onChange: async (v: string) => {
            await mut(c => { c.name = v; });
            const fresh = await loadCharacter(charId);
            if (fresh?.entityId) { let nameEnt = await loadEntity(fresh.entityId); if (nameEnt) { nameEnt.name = v; await saveEntity(nameEnt); } }
        }},
        { type: 'row', style: { gap: '4px' }, content: [
            { type: 'button', text: char.active ? '🌟 Active' : '⚰️ Inactive', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: char.active ? 'rgba(126,200,160,0.2)' : 'rgba(255,107,107,0.2)', color: char.active ? '#7ec8a0' : '#ff6b6b' }, callback: async () => { await mut(c => { c.active = !c.active; }); await refreshCharEditModal(); }},
            { type: 'button', text: char.scenePresent ? '🟢 Scene' : '⚫ Away', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: char.scenePresent ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: char.scenePresent ? '#7ec8a0' : '#888' }, callback: async () => { await mut(c => { c.scenePresent = !c.scenePresent; }); await refreshCharEditModal(); }},
            { type: 'button', text: (char as any).isStatic ? '▫️Static' : '⚡️Dynamic', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: (char as any).isStatic ? 'rgba(255,255,255,0.05)' : 'rgba(136,204,255,0.15)', color: (char as any).isStatic ? '#888' : '#88ccff' }, callback: async () => { await mut(c => { (c as any).isStatic = !(c as any).isStatic; c.charContextEnabled = !(c as any).isStatic; c.autoUpdateEnabled = !(c as any).isStatic; c.autoThoughtsEnabled = !(c as any).isStatic; c.hooksEnabled = !(c as any).isStatic; }); await refreshCharEditModal(); }}
        ]},
        // [vNEXT] Dynamic-priority rank row (non-protagonist, non-minor only). Under a
        // dynamic cap, lower rank = kept dynamic first. Assignment swaps to keep one
        // character per rank.
        ((char as any).isProtagonist || (char as any).npcClass === 'minor') ? { type: 'text', text: '', style: { height: '0px' } } : { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
            { type: 'text', text: 'Dynamic priority', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } },
            { type: 'button', text: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? ('Rank #' + (char as any).dynamicPriorityRank) : 'Unranked', style: { flex: '1 1 0', margin: 0, fontSize: '10px', textAlign: 'left', backgroundColor: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? 'rgba(232,168,124,0.15)' : 'rgba(255,255,255,0.05)', color: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? '#e8a87c' : '#888' }, callback: async function() {
                await openDynamicRankPicker(charId, async function() { await refreshCharEditModal(); await refreshSidebar(); });
            } }
        ]},
        { type: 'row', style: { gap: '4px' }, content: [
            { type: 'button', text: `📍 ${locName}`, style: { flex: '1 1 0', margin: 0, fontSize: '10px', textAlign: 'left', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }, callback: async function() {
                const freshEntIdx = await loadEntityIndex();
                const spatialNodes = freshEntIdx.filter(function(n: any) { return n.type !== 'character'; });
                
                const pickerContent = [
                    { type: 'button', text: '✕ No Location', style: { width: '100%', marginBottom: '8px' }, callback: async function() {
                        const f = await loadCharacter(char.id); if (!f) { pm.close(); return; }
                        if (f.entityId) { let locEnt = await loadEntity(f.entityId); if (locEnt) { locEnt.parentId = null; await saveEntity(locEnt); } }
                        await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshCharEditModal();
                    } }
                ];
                
                spatialNodes.filter(Boolean).forEach(function(l: any) {
                    pickerContent.push({ type: 'button', text: `📍 ${l.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: currentLocationId === l.id ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                        const f = await loadCharacter(char.id); if (!f) { pm.close(); return; }
                        if (f.entityId) { let locEnt2 = await loadEntity(f.entityId); if (locEnt2) { locEnt2.parentId = l.id; await saveEntity(locEnt2); } }
                        await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshCharEditModal();
                    } } as UIPart);
                });

                const pm = await openEngineModal({ title: 'Set Location', size: 'medium', content: pickerContent });
            } },
            { type: 'button', text: '💀 Kill', style: { flex: '0 1 auto', margin: 0, fontSize: '10px', color: '#ff6b6b' }, callback: async () => { await confirmDeleteChar(char.id, char.name); }},
            { type: 'button', text: '❓ Help', style: { flex: '0 1 auto', margin: 0, fontSize: '10px' }, callback: async () => {
                await openEngineModal({ title: 'Header Controls Help', size: 'medium', content: [
                    { type: 'text', text: 'Active:', style: { fontWeight: 'bold', fontSize: '12px' } },
                    { type: 'text', text: 'Removes the character from all context injections entirely, as if they don\'t exist.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                    { type: 'text', text: 'Scene:', style: { fontWeight: 'bold', fontSize: '12px' } },
                    { type: 'text', text: 'Manually overrides scene presence. This will be automatically reset to the correct value when you change locations.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                    { type: 'text', text: 'Dynamic:', style: { fontWeight: 'bold', fontSize: '12px' } },
                    { type: 'text', text: 'Toggles all background AI updates for this character (thoughts, goals, hooks).', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                    { type: 'text', text: 'Location:', style: { fontWeight: 'bold', fontSize: '12px' } },
                    { type: 'text', text: 'Changes where the character\'s physical body is located in the world graph.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },
                    { type: 'text', text: 'Kill:', style: { fontWeight: 'bold', fontSize: '12px' } },
                    { type: 'text', text: 'Sets the character to Inactive, drops their inventory at their last location, and moves their body to a "Graveyard" location. They can be restored by moving them out of the Graveyard and setting them back to Active.', style: { fontSize: '11px', opacity: '0.8' } }
                ]});
            }}
        ]}
    ]});

    // [v0.9.8.5] Preview now mirrors the new split: the collapsed identity line is
    // what the LOREBOOK entry leads with (static), e.g. "Gareth — human male, 34,
    // blacksmith"; the dynamic layer is assembled separately into the Author's Note.
    function getBiographicalPreviews(c: CharacterRecord) {
        const idLeader = [(c.species || '').trim(), (c.gender || '').trim()].filter(Boolean).join(' ');
        const idMid = [idLeader, (c.age || '').trim(), (c.occupationRole || '').trim()].filter(Boolean).join(', ');
        let loreLine = (c.name || 'Unnamed').trim();
        if (idMid) loreLine += ' \u2014 ' + idMid;
        return { anLine: loreLine };
    }

    // Fast non-flicker live preview update using api.v1.ui.updateParts()
    async function updateBiographicalPreviews() {
        const fresh = await loadCharacter(charId);
        if (!fresh) return;
        const previews = getBiographicalPreviews(fresh);
        await api.v1.ui.updateParts([
            { id: 'ae-an-preview', text: 'Lorebook: ' + previews.anLine }
        ]).catch(function() {});
    }

    const initialPreviews = getBiographicalPreviews(char);

    // Dramatis Personae
    parts.push({ type: 'collapsibleSection', title: '📋 Dramatis Personae', initialCollapsed: false, storageKey: `temp:ce_dp_${charId}`, content: [
        { type: 'text', text: char.name || '(Name not set)', style: { fontSize: '13px', fontWeight: 'bold', marginBottom: '6px' } },
        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
            { type: 'textInput', placeholder: 'Age', initialValue: char.age || '', style: { flex: '1 1 0' }, onChange: async function(v) { await mut(function(c){ c.age = v; }); await updateBiographicalPreviews(); } },
            { type: 'textInput', placeholder: 'Gender', initialValue: char.gender || '', style: { flex: '1 1 0' }, onChange: async function(v) { await mut(function(c){ c.gender = v; }); await updateBiographicalPreviews(); } },
            (cfg.species && cfg.species.length > 0) ? { type: 'button', text: char.species?.trim() || 'Species', style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: char.species?.trim() ? 'rgba(136,204,255,0.1)' : 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.12)', color: char.species?.trim() ? '#88ccff' : '#666' }, callback: async function() {
                const pm = await openEngineModal({ title: 'Set Species', size: 'small', content: [
                    { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() { await mut(function(c) { c.species = ''; }); pm.close(); await refreshCharEditModal(); } },
                    ...(cfg.species || []).map(function(sp) {
                        const isCur = char.species === sp.name;
                        return { type: 'button', text: sp.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: isCur ? 'rgba(136,204,255,0.15)' : undefined, color: isCur ? '#88ccff' : undefined }, callback: async function() { await mut(function(c) { c.species = sp.name; }); pm.close(); await refreshCharEditModal(); } } as UIPart;
                    })
                ]});
            } } as UIPart : { type: 'textInput', placeholder: 'Species', initialValue: char.species || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mut(function(c) { c.species = v; }); await updateBiographicalPreviews(); } } as UIPart,
            { type: 'textInput', placeholder: 'Role / occupation', initialValue: char.occupationRole || '', style: { flex: '2 1 0' }, onChange: async function(v) { await mut(function(c){ c.occupationRole = v; }); await updateBiographicalPreviews(); } }
        ] },
        { type: 'multilineTextInput', label: 'Brief Description', placeholder: 'One vivid sentence the generators must not contradict. Authoring anchor — not injected into context.', initialValue: char.briefDescription || '', style: { minHeight: '40px' }, onChange: async function(v) { await mut(function(c){ c.briefDescription = v; }); await updateBiographicalPreviews(); } },
        { type: 'text', text: 'Authoring anchor for field/intro generation. Not injected into context — static identity rides the lorebook entry.', style: { fontSize: '10px', opacity: '0.45', marginTop: '4px', marginBottom: '8px' } },
        
        // --- REAL-TIME CONTEXT INJECTION PREVIEW BOX ---
        { type: 'box', style: { backgroundColor: 'rgba(255,255,255,0.03)', border: '1px dashed rgba(255,255,255,0.1)', padding: '8px', borderRadius: '6px' }, content: [
            { type: 'text', text: '👁 Live Context Injection Preview', style: { fontSize: '10px', fontWeight: 'bold', color: 'var(--ae-accent)', marginBottom: '4px', textTransform: 'uppercase' } },
            { id: 'ae-an-preview', type: 'text', text: 'Lorebook: ' + initialPreviews.anLine, style: { fontSize: '11px', opacity: '0.9', marginBottom: '2px', fontFamily: 'monospace' } }
        ] }
    ] });
    
    // ── Static Fields ──────────────────────────────────────────────────────
    const staticContent: UIPart[] = [];

    // MOVED TO TOP: Concept Dump
    staticContent.push({
        type: 'multilineTextInput', 
        label: 'Concept Dump (Raw Notes)', 
        placeholder: 'Dump ideas, profiles, references — informs all static field generations. Not injected into live context.',
        initialValue: char.conceptDump || '', 
        style: { minHeight: '80px', marginBottom: '12px' }, 
        onChange: async function(v: string) { 
            await mut(function(c) { c.conceptDump = v; }); 
        } 
    } as UIPart);

    for (const fd of STATIC_FIELD_DEFS) {
        const label      = cfg.fieldLabels[fd.key] || fd.label;
        const promptKey  = `ce_prmt_${charId}_${fd.key}`;
        const capturedFd = fd;
        const capBudget  = cfg.fieldBudgets[fd.key] || fd.defaultBudget;
        const capInst    = cfg.fieldInstructions[fd.key] || fd.defaultInstructions;
        const currentHint = await api.v1.tempStorage.getOrDefault(promptKey, '') as string;

        const rawVal = (char as any)[capturedFd.key];
        const strVal = (rawVal !== null && rawVal !== undefined && !Array.isArray(rawVal))
            ? String(rawVal)
            : '';

        staticContent.push({
            type: 'multilineTextInput', label,
            initialValue: strVal,
            placeholder: '',
            style: { minHeight: '55px' },
            onChange: async function(v: string) {
                await mut(function(c) { (c as any)[capturedFd.key] = v; });
            }
        } as UIPart);

        staticContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '8px' }, content: [
            { type: 'textInput', placeholder: 'Optional hint…', initialValue: currentHint, style: { flex: '1 1 0' },
              onChange: async function(v: string) { await api.v1.tempStorage.set(promptKey, v); } },
            { type: 'button', iconId: 'zap',
              style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' },
              disabledWhileCallbackRunning: true,
              callback: async function() {
                  const hint = await api.v1.tempStorage.get(promptKey) as string || '';
                  api.v1.ui.toast(`Generating ${label}…`, { id: `gen-${capturedFd.key}`, autoClose: false, type: 'info' });
                  const result = await generateFieldContent(char, label, capInst, cfg.generalStyle, hint, capBudget);
                  if (result) {
                      await mut(function(c) { (c as any)[capturedFd.key] = result; });
                      await api.v1.tempStorage.remove(promptKey);
                      api.v1.ui.toast('Generated.', { id: `gen-${capturedFd.key}`, type: 'success', autoClose: 1500 });
                      await refreshCharEditModal();
                  } else {
                      api.v1.ui.toast('Failed.', { id: `gen-${capturedFd.key}`, type: 'error', autoClose: 2000 });
                  }
              }
            }
        ] } as UIPart);
    }

    // Core Values — stored as string[] on the record; edited here as semicolon-delimited text.
    const cvHintKey  = `ce_prmt_${charId}_coreValues`;
    const cvHint     = await api.v1.tempStorage.getOrDefault(cvHintKey, '') as string;
    const cvInitial  = (char.coreValues || []).filter(Boolean).join('; ');
    staticContent.push({
        type: 'multilineTextInput', label: 'Core Values',
        initialValue: cvInitial,
        placeholder: 'e.g. Loyalty; Honesty; Freedom  (semicolon-separated)',
        style: { minHeight: '45px' },
        onChange: async function(v: string) {
            await mut(function(c) {
                c.coreValues = v.split(';').map(function(s) { return s.trim(); }).filter(Boolean);
            });
        }
    } as UIPart);
    staticContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '8px' }, content: [
        { type: 'textInput', placeholder: 'Optional hint…', initialValue: cvHint, style: { flex: '1 1 0' },
          onChange: async function(v: string) { await api.v1.tempStorage.set(cvHintKey, v); } },
        { type: 'button', iconId: 'zap',
          style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' },
          disabledWhileCallbackRunning: true,
          callback: async function() {
              const hint = await api.v1.tempStorage.get(cvHintKey) as string || '';
              api.v1.ui.toast('Generating Core Values…', { id: 'gen-coreValues', autoClose: false, type: 'info' });
              const result = await generateFieldContent(char, 'Core Values',
                  'List 3–5 deeply held values that drive this character\'s decisions. Return them as a semicolon-separated list only.',
                  cfg.generalStyle, hint, 80);
              if (result) {
                  const vals = result.split(';').map(function(s) { return s.trim(); }).filter(Boolean);
                  await mut(function(c) { c.coreValues = vals; });
                  await api.v1.tempStorage.remove(cvHintKey);
                  api.v1.ui.toast('Generated.', { id: 'gen-coreValues', type: 'success', autoClose: 1500 });
                  await refreshCharEditModal();
              } else {
                  api.v1.ui.toast('Failed.', { id: 'gen-coreValues', type: 'error', autoClose: 2000 });
              }
          }
        }
    ] } as UIPart);

    // Custom fields
    for (const cf of cfg.customStaticFields.filter(Boolean)) {
        const capturedCf     = cf;
        const promptKeyCustom = `ce_prmt_${charId}_custom_${capturedCf.id}`;
        const currentHintCustom = await api.v1.tempStorage.getOrDefault(promptKeyCustom, '') as string;

        staticContent.push({ type: 'multilineTextInput', label: capturedCf.label,
            initialValue: char.customFieldValues[capturedCf.id] || '',
            placeholder: capturedCf.placeholder || '',
            style: { minHeight: '45px' },
            onChange: async function(v: string) { await mut(function(c) { c.customFieldValues[capturedCf.id] = v; }); }
        } as UIPart);
        staticContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '8px' }, content: [
            { type: 'textInput', placeholder: 'Optional hint…', initialValue: currentHintCustom, style: { flex: '1 1 0' },
              onChange: async function(v: string) { await api.v1.tempStorage.set(promptKeyCustom, v); } },
            { type: 'button', iconId: 'zap',
              style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' },
              disabledWhileCallbackRunning: true,
              callback: async function() {
                  const hint   = await api.v1.tempStorage.get(promptKeyCustom) as string || '';
                  const budget = cfg.fieldBudgets[capturedCf.id] || 150;
                  api.v1.ui.toast('Generating…', { id: `gen-cf-${capturedCf.id}`, autoClose: false, type: 'info' });
                  const result = await generateFieldContent(char, capturedCf.label, capturedCf.instructions, cfg.generalStyle, hint, budget);
                  if (result) {
                      await mut(function(c) { c.customFieldValues[capturedCf.id] = result; });
                      await api.v1.tempStorage.remove(promptKeyCustom);
                      api.v1.ui.toast('Generated.', { id: `gen-cf-${capturedCf.id}`, type: 'success', autoClose: 1500 });
                      await refreshCharEditModal();
                  } else {
                      api.v1.ui.toast('Failed.', { id: `gen-cf-${capturedCf.id}`, type: 'error', autoClose: 2000 });
                  }
              }
            }
        ] } as UIPart);
    }

    // Lorebook sync convenience — MOVED from its own section into static fields
    const tmpNickKey = `ce_tmp_nick_${char.id}`;
    const nickItems: UIPart[] = (char.nicknames || []).filter(Boolean).map(function(nick, i) { return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [{ type: 'text', text: nick, style: { flex: '1 1 0', fontSize: '12px' } }, { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.nicknames.splice(i, 1); await saveCharacter(f); await refreshCharEditModal(); } }] } as UIPart; });

    staticContent.push({ type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: (function() {
        const lbContent: UIPart[] = [];
        if (char.lorebookEntryId) {
            lbContent.push(
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },
                { type: 'text', text: `Keys: ${getLorebookKeys(char).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },
                { type: 'row', style: { gap: '6px' }, content: [
                    { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncLorebookEntry(char.id); } },
                    { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.lorebookEntryId = undefined; await saveCharacter(f); await refreshCharEditModal(); } }
                ] }
            );
        } else {
            lbContent.push(
                { type: 'text', text: "No lorebook entry. Creating one lets NAI natively inject this character's static profile when their name appears.", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
                { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { if (typeof createLinkedLorebookEntry === 'function') { await createLinkedLorebookEntry(char.id); await refreshCharEditModal(); } } }
            );
        }
        
        lbContent.push({ type: 'text', text: 'Nicknames / Aliases (added as lorebook keys):', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });
        
        nickItems.forEach(function(item) {
            lbContent.push(item);
        });
        
        lbContent.push({ type: 'row', style: { gap: '4px' }, content: [
            { type: 'textInput', placeholder: 'Add nickname or alias...', storageKey: `temp:${tmpNickKey}`, style: { flex: '1 1 0' } },
            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpNickKey) as string || ''; if (!v.trim()) return; const f = await loadCharacter(char.id); if (!f) return; if (!f.nicknames.includes(v.trim())) f.nicknames.push(v.trim()); await saveCharacter(f); await api.v1.tempStorage.remove(tmpNickKey); await refreshCharEditModal(); } }
        ] });
        
        return lbContent;
    })()});

    parts.push({ type: 'collapsibleSection', title: '✍ Static Fields', initialCollapsed: false,
        storageKey: `temp:ce_static_${charId}`, content: staticContent });

    parts.push(buildDynamicStateSection(char, cfg));

    // Inner Builders — Engine reference data (read-only runtime state)
    parts.push({ type: 'text', text: '── Engine Reference Only ──', style: { fontSize: '10px', opacity: '0.35', textAlign: 'center', letterSpacing: '1px', margin: '6px 0 2px' } });

    // Image Generation — character visual tags for image gen (engine + bridge)
    parts.push({ type: 'collapsibleSection', title: '🖼 Image Generation', initialCollapsed: true,
        storageKey: `temp:ce_imggen_${charId}`, content: [
        { type: 'text', text: 'Used for all character image generations. Tags like: hair color, eye color, clothing.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px' } },
        { type: 'multilineTextInput', label: 'Base Character Visuals', placeholder: '1girl, brown hair, blue eyes, red dress...', initialValue: char.visuals || '', style: { minHeight: '55px' }, onChange: async function(v: string) { await mut(function(c) { c.visuals = v; }); } } as UIPart,
        { type: 'text', text: 'Tags to suppress in all this character\'s images.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px', marginTop: '10px' } },
        { type: 'multilineTextInput', label: 'Character Unwanted Content', placeholder: 'lowres, bad anatomy, extra limbs...', initialValue: char.uc || '', style: { minHeight: '40px' }, onChange: async function(v: string) { await mut(function(c) { c.uc = v; }); } } as UIPart
    ] });

    // [v0.9.86] Tag Subscriptions — character-side shortcut to set tagSubscriptions on
    // the character's entity. Keeps the same live-resolve model; no copies are made.
    await (async function() {
        if (!(char as any).entityId) return;
        const _ctsCfg = await loadConfig();
        const _ctsTpls = ((_ctsCfg.actionTemplates || []) as ActionInstance[]);
        const _ctsAllTags: string[] = [];
        // Characters can have a 'character' type entity — filter appliesTo accordingly.
        const _ctsApplicable = _ctsTpls.filter(function(t) {
            if (t.appliesTo && t.appliesTo.length && t.appliesTo.indexOf('character') < 0) return false;
            return true;
        });
        for (const _ctsTpl of _ctsApplicable) {
            for (const _ctsTag of ((_ctsTpl as any).tags || [])) {
                if (typeof _ctsTag === 'string' && !_ctsTag.startsWith('_') && _ctsAllTags.indexOf(_ctsTag) < 0) {
                    _ctsAllTags.push(_ctsTag);
                }
            }
        }
        _ctsAllTags.sort();
        if (!_ctsAllTags.length) return;

        const _ctsEnt = await loadEntity((char as any).entityId);
        if (!_ctsEnt) return;
        const _ctsSubs: string[] = ((_ctsEnt as any).tagSubscriptions || []);
        const _ctsRows: UIPart[] = [
            { type: 'text', text: 'Checked tags auto-include all matching library actions on this character\'s entity. Applied live — no copy is made.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '6px' } }
        ];
        for (const _ctsTag of _ctsAllTags) {
            const captCTag = _ctsTag;
            const matchCount = _ctsApplicable.filter(function(t) { return ((t as any).tags || []).indexOf(captCTag) >= 0; }).length;
            const isSubbed = _ctsSubs.indexOf(captCTag) >= 0;
            _ctsRows.push({
                type: 'checkboxInput',
                label: captCTag + '  (' + matchCount + ' action' + (matchCount === 1 ? '' : 's') + ')',
                initialValue: isSubbed,
                onChange: async function(v: boolean) {
                    const f = await loadCharacter(charId); if (!f || !(f as any).entityId) return;
                    const _ctsEntFresh = await loadEntity((f as any).entityId); if (!_ctsEntFresh) return;
                    let _ctsArr: string[] = (((_ctsEntFresh as any).tagSubscriptions || []) as string[]).slice();
                    if (v) { if (_ctsArr.indexOf(captCTag) < 0) _ctsArr.push(captCTag); }
                    else   { _ctsArr = _ctsArr.filter(function(x) { return x !== captCTag; }); }
                    (_ctsEntFresh as any).tagSubscriptions = _ctsArr;
                    await saveEntity(_ctsEntFresh);
                    await refreshCharEditModal();
                }
            } as UIPart);
        }
        parts.push({ type: 'collapsibleSection', title: '\ud83c\udff7 Tag Subscriptions (' + _ctsSubs.filter(function(s) { return _ctsAllTags.indexOf(s) >= 0; }).length + ' active)', initialCollapsed: true, storageKey: `temp:ce_tagsubs_${charId}`, content: _ctsRows });
    })();
    parts.push(await buildKnowledgeSection(char));
    // ── EQUIPMENT ─────────────────────────────────────────────────────
    parts.push({ type: 'collapsibleSection', title: '🎒 Equipment', initialCollapsed: true, storageKey: `temp:ce_equip_${char.id}`, content: await (async function() {
        const equippedParts: UIPart[] = [];
        const entIdx = await loadEntityIndex();
        const invItems = entIdx.filter(function(e) { return e.type === 'item' && e.parentId === char.entityId; });

        if (invItems.length === 0) {
            equippedParts.push({ type: 'text', text: 'No items in inventory. Add item entities as children of this character\'s entity.', style: { fontSize: '11px', opacity: '0.5' } });
        } else {
            for (const item of invItems) {
                const isEquipped = (char.equippedItemIds || []).includes(item.id);
                equippedParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                    { type: 'text', text: item.name, style: { flex: '1 1 0', fontSize: '12px', color: isEquipped ? '#7ec8a0' : undefined } },
                    { type: 'button', text: isEquipped ? '✓ Equipped' : 'Equip', style: { margin: 0, fontSize: '11px', backgroundColor: isEquipped ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: isEquipped ? '#7ec8a0' : undefined }, callback: async function() {
                        const f = await loadCharacter(char.id); if (!f) return;
                        if (!f.equippedItemIds) f.equippedItemIds = [];
                        if (isEquipped) {
                            f.equippedItemIds = f.equippedItemIds.filter(function(id) { return id !== item.id; });
                        } else {
                            f.equippedItemIds.push(item.id);
                        }
                        await saveCharacter(f); await refreshCharEditModal();  // [v0.9.8.5] equipment rides ephemeral temp entry; no lorebook sync
                    } }
                ] });
            }
        }
        return equippedParts;
    })() });
    // [v0.9.9.2] Daily Schedule - hourly timetable for when the player is not present.
    parts.push({ type: 'collapsibleSection', title: '\ud83d\udd52 Daily Schedule', initialCollapsed: true, storageKey: `temp:ce_sched_${char.id}`, content: await (async function() {
        const schedParts: UIPart[] = [];
        char.schedule = char.schedule || [];
        const rows = char.schedule;
        const entIdxS = await loadEntityIndex();
        const locOptsS = entIdxS.filter(function(e) { return e.type === 'location'; });

        schedParts.push({ type: 'text', text: 'Places this character goes by hour of day, used only while the player is not present in their scene. Resolved on travel.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });

        schedParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [
            { type: 'text', text: char.scheduleEnabled ? '\u2705 Schedule Active' : '\u26ab Schedule Inactive', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: char.scheduleEnabled ? '#7ec8a0' : undefined } },
            { type: 'button', text: char.scheduleEnabled ? 'Disable' : 'Enable', style: { margin: 0, fontSize: '11px' }, callback: async function() {
                const f = await loadCharacter(charId); if (!f) return;
                f.scheduleEnabled = !f.scheduleEnabled;
                await saveCharacter(f); await refreshCharEditModal();
            } }
        ] });

        if (rows.length === 0) {
            schedParts.push({ type: 'text', text: 'No schedule rows yet. Add one below.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });
        } else {
            const sortedRows = rows.map(function(r, i) { return { r: r, i: i }; }).sort(function(a, b) { return a.r.startHour - b.r.startHour; });
            for (const entry of sortedRows) {
                const row = entry.r; const rowIdx = entry.i;
                const locMeta = locOptsS.find(function(l) { return l.id === row.locationId; });
                schedParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                    { type: 'numberInput', initialValue: row.startHour, style: { width: '56px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) {
                        const f = await loadCharacter(charId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;
                        let hv = Math.floor(Number(v) || 0); if (hv < 0) hv = 0; if (hv > 23) hv = 23;
                        f.schedule[rowIdx].startHour = hv;
                        await saveCharacter(f);
                    } },
                    { type: 'text', text: ':00 \u2192', style: { fontSize: '11px', opacity: '0.6' } },
                    { type: 'button', text: locMeta ? ('\ud83c\udf0d ' + locMeta.name) : '(pick location)', style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left' }, callback: async function() {
                        await openPickerModal({
                            title: 'Pick Schedule Location',
                            items: locOptsS,
                            getId: function(item) { return item.id; },
                            getLabel: function(item) { return item.name; },
                            getIcon: function() { return '\ud83c\udf0d'; },
                            searchable: true,
                            selectedId: row.locationId,
                            emptyText: 'No locations found. Create a location entity first.',
                            onSelect: async function(item) {
                                const f = await loadCharacter(charId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;
                                f.schedule[rowIdx].locationId = item.id;
                                await saveCharacter(f); await refreshCharEditModal();
                            }
                        });
                    } },
                    { type: 'button', text: '\u2715', style: { margin: 0, fontSize: '11px', width: '28px' }, callback: async function() {
                        const f = await loadCharacter(charId); if (!f || !f.schedule) return;
                        f.schedule = f.schedule.filter(function(_rr, ri2) { return ri2 !== rowIdx; });
                        await saveCharacter(f); await refreshCharEditModal();
                    } }
                ] });
            }
        }

        schedParts.push({ type: 'button', text: '+ Add Schedule Row', style: { width: '100%', marginTop: '4px', fontSize: '11px' }, callback: async function() {
            const f = await loadCharacter(charId); if (!f) return;
            f.schedule = f.schedule || [];
            f.schedule.push({ startHour: 8, locationId: (locOptsS[0] ? locOptsS[0].id : '') });
            await saveCharacter(f); await refreshCharEditModal();
        } });

        schedParts.push({ type: 'button', text: '\ud83d\udd04 Process Schedule Now', style: { width: '100%', marginTop: '8px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)' }, callback: async function() {
            try {
                await resolveSchedules();
                await refreshSidebar();
                await refreshCharEditModal();
            } catch (e) { api.v1.error('[AE:charEdit] manual schedule resolve error:', e); }
        } });

        return schedParts;
    })() });

    if (cfg.sheetCategories && cfg.sheetCategories.length > 0) parts.push(buildSheetSection(char, cfg));
    
// ── CHARACTER RESOURCES ────────────────────────────────────────────
    parts.push(await (async function(): Promise<UIPart> {
        const defs = char.charResourceDefs || [];
        const vals = char.charResourceValues || {};
        const resParts: UIPart[] = [];

        resParts.push({ type: 'text', text: 'Personal resources tracked on this character. Adjustable here and targetable by action rules.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });

        for (let ri = 0; ri < defs.length; ri++) {
            const res = defs[ri];
            const captRi = ri;
            const captId = res.id;
            const val = vals[res.id] || 0;
            const states = res.states || [];

            resParts.push({ type: 'box', style: { padding: '8px', marginBottom: '8px', backgroundColor: 'rgba(255,255,255,0.02)', borderRadius: '6px', borderLeft: res.type === 'pool' ? '3px solid #88ccff' : '3px solid #e8a87c' }, content: [
                // Definition row
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                    { type: 'textInput', initialValue: res.name, placeholder: 'Name', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].name = v; await saveCharacter(f); } },
                    { type: 'textInput', initialValue: res.tag, placeholder: '#tag', style: { width: '80px', fontSize: '11px' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].tag = v; await saveCharacter(f); } },
                    { type: 'button', text: res.type === 'pool' ? 'Pool' : 'Track', style: { margin: 0, fontSize: '10px', backgroundColor: res.type === 'pool' ? 'rgba(136,204,255,0.15)' : 'rgba(232,168,124,0.15)', color: res.type === 'pool' ? '#88ccff' : '#e8a87c', border: 'none' }, callback: async function() {
                        const f = await loadCharacter(charId); if (!f) return;
                        f.charResourceDefs[captRi].type = f.charResourceDefs[captRi].type === 'pool' ? 'track' : 'pool';
                        await saveCharacter(f); await refreshCharEditModal();
                    } },
                    { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() {
                        const f = await loadCharacter(charId); if (!f) return;
                        f.charResourceDefs.splice(captRi, 1);
                        delete f.charResourceValues[captId];
                        await saveCharacter(f); await refreshCharEditModal();
                    } }
                ] },
                // Bounds / states config
                res.type === 'pool' ? { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                    { type: 'checkboxInput', label: 'Bounded', initialValue: !!res.hasBounds, onChange: async function(v: boolean) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].hasBounds = v; await saveCharacter(f); await refreshCharEditModal(); } },
                    res.hasBounds ? { type: 'textInput', placeholder: 'Min', initialValue: res.min !== undefined ? res.min.toString() : '0', style: { width: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; const n = parseInt(v, 10); f.charResourceDefs[captRi].min = isNaN(n) ? 0 : n; await saveCharacter(f); } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart,
                    res.hasBounds ? { type: 'text', text: '–', style: { opacity: '0.5' } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart,
                    res.hasBounds ? { type: 'textInput', placeholder: 'Max', initialValue: res.max !== undefined ? res.max.toString() : '10', style: { width: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; const n = parseInt(v, 10); f.charResourceDefs[captRi].max = isNaN(n) ? 10 : n; await saveCharacter(f); } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart
                ] } as UIPart : aeRenderIndexedStatesEditor(states, async function(next) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].states = next; await saveCharacter(f); }, refreshCharEditModal, 'State'),
                // [vNEXT] Value editing restored — GM-adjustable here for corrections/manual
                // grants, in addition to changing through gameplay (resolution effects).
                res.type === 'pool'
                    ? { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                        { type: 'text', text: 'Current:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                        { type: 'button', text: '−', style: { margin: 0, padding: '2px 8px' }, callback: async function() {
                            const f = await loadCharacter(charId); if (!f) return;
                            const cur = f.charResourceValues[captId] || 0;
                            const lo = res.hasBounds && res.min !== undefined ? res.min : -999999;
                            f.charResourceValues[captId] = Math.max(lo, cur - 1);
                            await saveCharacter(f); await refreshCharEditModal();
                        } } as UIPart,
                        { type: 'numberInput', initialValue: val, style: { width: '64px', margin: 0, textAlign: 'center' } as any, onChange: async function(v: number) {
                            const f = await loadCharacter(charId); if (!f) return;
                            let nv = (v === null || v === undefined) ? 0 : v;
                            if (res.hasBounds) { nv = Math.max(res.min !== undefined ? res.min : 0, Math.min(res.max !== undefined ? res.max : 999999, nv)); }
                            f.charResourceValues[captId] = nv;
                            await saveCharacter(f);
                        } } as UIPart,
                        { type: 'button', text: '+', style: { margin: 0, padding: '2px 8px' }, callback: async function() {
                            const f = await loadCharacter(charId); if (!f) return;
                            const cur = f.charResourceValues[captId] || 0;
                            const hi = res.hasBounds && res.max !== undefined ? res.max : 999999;
                            f.charResourceValues[captId] = Math.min(hi, cur + 1);
                            await saveCharacter(f); await refreshCharEditModal();
                        } } as UIPart,
                        res.hasBounds && res.max !== undefined ? { type: 'text', text: '/ ' + res.max, style: { fontSize: '11px', opacity: '0.5' } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart
                    ] as UIPart[] }
                    : { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
                        { type: 'text', text: 'State:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                        { type: 'button', text: '‹', style: { margin: 0, padding: '2px 8px' }, callback: async function() {
                            const f = await loadCharacter(charId); if (!f) return;
                            const cur = f.charResourceValues[captId] || 0;
                            f.charResourceValues[captId] = Math.max(0, cur - 1);
                            await saveCharacter(f); await refreshCharEditModal();
                        } } as UIPart,
                        { type: 'text', text: states[val] || '?', style: { fontSize: '13px', fontWeight: 'bold', flex: '1 1 0', textAlign: 'center', color: '#e8a87c' } as any } as UIPart,
                        { type: 'button', text: '›', style: { margin: 0, padding: '2px 8px' }, callback: async function() {
                            const f = await loadCharacter(charId); if (!f) return;
                            const cur = f.charResourceValues[captId] || 0;
                            f.charResourceValues[captId] = Math.min(states.length - 1, cur + 1);
                            await saveCharacter(f); await refreshCharEditModal();
                        } } as UIPart
                    ] as UIPart[] }
            ] });
        }

        if (defs.length === 0) {
            resParts.push({ type: 'text', text: 'No character resources defined.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '6px' } });
        }

        resParts.push({ type: 'button', text: '+ New Resource', style: { width: '100%', margin: '2px 0 0 0', fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {
            const f = await loadCharacter(charId); if (!f) return;
            if (!f.charResourceDefs) f.charResourceDefs = [];
            const newId = generateId();
            f.charResourceDefs.push({ id: newId, name: 'New Resource', tag: '#res_' + newId.slice(-4), type: 'pool', hasBounds: true, min: 0, max: 10 });
            if (!f.charResourceValues) f.charResourceValues = {};
            f.charResourceValues[newId] = 0;
            await saveCharacter(f); await refreshCharEditModal();
        } });

        return { type: 'collapsibleSection', title: '💠 Character Resources (' + defs.length + ')', initialCollapsed: defs.length === 0, storageKey: 'temp:ce_cres_' + charId, content: resParts };
    })());
// ── CHARACTER FACTION RELATIONSHIPS ────────────────────────────────
    const trackedFactions = cfg.factions ? cfg.factions.filter(function(f) { return char.charFactionRelationships && char.charFactionRelationships[f.id] !== undefined; }) : [];
    const untrackedFactions = cfg.factions ? cfg.factions.filter(function(f) { return !char.charFactionRelationships || char.charFactionRelationships[f.id] === undefined; }) : [];

    if (cfg.factions && cfg.factions.length > 0) {
        const facRelParts: UIPart[] = [];
        facRelParts.push({ type: 'text', text: 'Track faction relationships for this character independently of the player\'s standing.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });

        for (let fi = 0; fi < trackedFactions.length; fi++) {
            let fac = trackedFactions[fi];
            let captFacId = fac.id;
            let relIdx = char.charFactionRelationships[fac.id] || 0;
            let relState = (fac.relationshipStates || [])[relIdx] || 'Unknown';
            facRelParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                { type: 'text', text: fac.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },
                { type: 'button', text: relState, style: { margin: 0, fontSize: '11px', minWidth: '90px', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
                    let states = fac.relationshipStates || [];
                    let pm = await openEngineModal({ title: fac.name + ' — Relationship', size: 'small', content: states.map(function(s, idx) {
                        return { type: 'button', text: s, style: { width: '100%', marginBottom: '4px', backgroundColor: relIdx === idx ? 'rgba(126,200,160,0.2)' : undefined, color: relIdx === idx ? '#7ec8a0' : undefined }, callback: async function() {
                            const f2 = await loadCharacter(charId); if (!f2) return;
                            if (!f2.charFactionRelationships) f2.charFactionRelationships = {};
                            f2.charFactionRelationships[captFacId] = idx; await saveCharacter(f2); pm.close(); await refreshCharEditModal();
                        } } as UIPart;
                    })});
                } },
                { type: 'button', text: '✕', style: { margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() {
                    const f2 = await loadCharacter(charId); if (!f2) return;
                    delete f2.charFactionRelationships[captFacId]; await saveCharacter(f2); await refreshCharEditModal();
                } }
            ] });
        }

        if (untrackedFactions.length > 0) {
            facRelParts.push({ type: 'button', text: '+ Track Faction', style: { fontSize: '11px', width: '100%', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {
                let pm = await openEngineModal({ title: 'Track Faction Relationship', size: 'small', content: untrackedFactions.map(function(f) {
                    return { type: 'button', text: f.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() {
                        const f2 = await loadCharacter(charId); if (!f2) return;
                        if (!f2.charFactionRelationships) f2.charFactionRelationships = {};
                        f2.charFactionRelationships[f.id] = 0; await saveCharacter(f2); pm.close(); await refreshCharEditModal();
                    } } as UIPart;
                })});
            } });
        }

        if (trackedFactions.length === 0) facRelParts.push({ type: 'text', text: 'No factions tracked. Use "+ Track Faction" to add.', style: { fontSize: '11px', opacity: '0.4' } });
        parts.push({ type: 'collapsibleSection', title: '⚔️ Faction Relationships (' + trackedFactions.length + ')', initialCollapsed: true, storageKey: 'temp:ce_facrel_' + charId, content: facRelParts });
    }

    // --- EVENT HISTORY ---
    if (typeof buildEventHistorySection === 'function') {
        const eventPart = buildEventHistorySection(char, cfg); 
        if (eventPart) {
            parts.push(eventPart); 
        }
    }

    // --- SYSTEM ACTIONS (Export, Repair, Delete) ---
    
    // Check if the physical body is missing or the ID is a dead link
    let charBodyIsMissing = true;
    if (char.entityId) {
        let checkEnt = await loadEntity(char.entityId);
        if (checkEnt) charBodyIsMissing = false;
    }

    const systemActionsContent: UIPart[] = [
        { type: 'text', text: 'Manage character database links and lorebook sync.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } }
    ];

    // Inject the Repair tool only if the body is actually missing
    if (charBodyIsMissing) {
        systemActionsContent.push(
            { type: 'button', text: '🔧 Generate Missing Physical Body', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', border: '1px solid rgba(255,180,50,0.3)', color: '#ffb432' }, callback: async function() { 
                if (typeof makeDefaultEntity === 'function') {
                    let repairEnt = makeDefaultEntity(char.name);
                    repairEnt.type = 'character';
                    repairEnt.parentId = null;
                    await saveEntity(repairEnt);
                    
                    const f = await loadCharacter(char.id);
                    if (f) { 
                        f.entityId = repairEnt.id; 
                        await saveCharacter(f); 
                        await refreshCharEditModal(); 
                        if (typeof refreshSidebar === 'function') await refreshSidebar();
                    }
                }
            } }
        );
    }

    systemActionsContent.push(
        { type: 'button', text: '🗑️ Delete Character', style: { width: '100%', color: '#ff6b6b', backgroundColor: 'rgba(255,107,107,0.1)', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { 
            if (typeof confirmDeleteChar === 'function') await confirmDeleteChar(char.id, char.name); 
        } }
    );

    parts.push({ 
        type: 'collapsibleSection', 
        title: '⚙️ System Actions', 
        initialCollapsed: true, 
        storageKey: `temp:ce_system_${char.id}`, 
        content: systemActionsContent
    });

    // Padding for smooth scrolling at the bottom
    parts.push({ type: 'text', text: ' ', style: { marginBottom: '48px' } });
    
    return parts.filter(Boolean) as UIPart[];
}

// ============================================================================
// CHARACTER KNOWLEDGE SECTION BUILDER
// ============================================================================
async function buildKnowledgeSection(char: CharacterRecord): Promise<UIPart> {
    const knownEntities = char.knownEntities || [];
    const knowParts: UIPart[] = [];

    // Search filter
    const ksSearchKey = 'temp:ce_ks_char_' + char.id;
    const ksTerm = ((await api.v1.tempStorage.getOrDefault(ksSearchKey, '')) as string).toLowerCase();

    if (knownEntities.length > 0) {
        knowParts.push({ type: 'textInput', placeholder: '🔍 Filter knowledge entries...', initialValue: ksTerm, onChange: async function(v: string) { await api.v1.tempStorage.set(ksSearchKey, v); await refreshCharEditModal(); } });
    }

    const filtered = knownEntities.filter(function(e) {
        if (!ksTerm) return true;
        return e.entityName.toLowerCase().includes(ksTerm) || e.snapshot.toLowerCase().includes(ksTerm);
    });

    if (filtered.length === 0 && knownEntities.length === 0) {
        knowParts.push({ type: 'text', text: 'No knowledge entries yet. Add via the entity picker below or from an entity\'s Characters & Knowledge panel.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });
    }

    for (let ki = 0; ki < filtered.length; ki++) {
        const ke = filtered[ki];
        const captKe = ke;
        const captKi = ki;
        const origIdx = knownEntities.findIndex(function(e) { return e.id === ke.id; });
        knowParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: ke.isManual ? 'rgba(255,180,50,0.05)' : 'rgba(255,255,255,0.03)', borderRadius: '4px', border: '1px solid ' + (ke.isManual ? 'rgba(255,180,50,0.15)' : 'rgba(255,255,255,0.08)') }, content: [
            { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
                { type: 'text', text: (ke.isManual ? '📝 ' : '🔗 ') + ke.entityName, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: ke.isManual ? '#ffb432' : '#88ccff' } },
                ...(ke.entityId ? [{ type: 'button', text: '↺', style: { margin: 0, padding: '2px 6px', fontSize: '11px', backgroundColor: 'transparent', opacity: '0.6' }, disabledWhileCallbackRunning: true, callback: async function() {
                    // Re-sync from entity
                    const f = await loadCharacter(char.id); if (!f) return;
                    if (!f.knownEntities) return;
                    const entry = f.knownEntities.find(function(e) { return e.id === captKe.id; });
                    if (!entry || !entry.entityId) return;
                    const freshEnt = await loadEntity(entry.entityId);
                    if (freshEnt?.knowledgeString) { entry.snapshot = freshEnt.knowledgeString; entry.entityName = freshEnt.name; }
                    else { entry.snapshot = await buildEntityKnowledgeString(entry.entityId); }
                    await saveCharacter(f); await refreshCharEditModal();
                    api.v1.ui.toast('Entry refreshed.', { type: 'success', autoClose: 1500 });
                } } as UIPart] : []),
                { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() {
                    const f = await loadCharacter(char.id); if (!f || !f.knownEntities) return;
                    f.knownEntities = f.knownEntities.filter(function(e) { return e.id !== captKe.id; });
                    await saveCharacter(f); await refreshCharEditModal();
                } }
            ] },
            { type: 'text', text: ke.snapshot || '(no snapshot)', style: { fontSize: '11px', opacity: '0.7', lineHeight: '1.4' } }
        ] });
    }

    // Add from entity picker
    knowParts.push({ type: 'button', text: '+ Link Entity Knowledge', style: { width: '100%', fontSize: '11px', marginTop: '4px', backgroundColor: 'rgba(136,204,255,0.06)', color: '#88ccff' }, callback: async function() {
        await api.v1.tempStorage.set('temp:ce_klink_search', '');
        async function drawKlinkPicker(pm4: any) {
            const term4 = ((await api.v1.tempStorage.getOrDefault('temp:ce_klink_search', '')) as string).toLowerCase();
            const allEnts4 = await loadEntityIndex();
            const existing4 = (char.knownEntities || []).map(function(e) { return e.entityId; }).filter(Boolean);
            const pickable4 = allEnts4.filter(function(m) {
                if (existing4.includes(m.id)) return false;
                if (!term4) return true;
                return m.name.toLowerCase().includes(term4);
            });
            const content4: UIPart[] = [
                { type: 'textInput', placeholder: '🔍 Search entities...', initialValue: term4, onChange: async function(v: string) { await api.v1.tempStorage.set('temp:ce_klink_search', v); await drawKlinkPicker(pm4); } } as UIPart,
                ...pickable4.map(function(m) { return { type: 'button', text: (ENTITY_TYPE_ICONS[m.type] || '●') + ' ' + m.name, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() {
                    pm4.close();
                    const f4 = await loadCharacter(char.id); if (!f4) return;
                    if (!f4.knownEntities) f4.knownEntities = [];
                    // Get or build snapshot from entity
                    const targetEnt4 = await loadEntity(m.id);
                    let snap4 = targetEnt4?.knowledgeString || '';
                    if (!snap4.trim()) snap4 = await buildEntityKnowledgeString(m.id);
                    // Also update entity's knowledgeString and awareCharacterIds
                    if (targetEnt4) {
                        if (!targetEnt4.knowledgeString || !targetEnt4.knowledgeString.trim()) targetEnt4.knowledgeString = snap4;
                        if (!targetEnt4.awareCharacterIds.includes(f4.id)) targetEnt4.awareCharacterIds.push(f4.id);
                        await saveEntity(targetEnt4);
                    }
                    f4.knownEntities.push({ id: generateId(), entityId: m.id, entityName: m.name, snapshot: snap4, addedAt: Date.now() });
                    await saveCharacter(f4); await refreshCharEditModal();
                } } as UIPart; })
            ];
            if (pm4 && !pm4.isClosed()) { await pm4.update({ content: content4 }); }
            else { pm4 = await openEngineModal({ id: 'ce-klink-picker', title: 'Link Entity Knowledge', size: 'medium', content: content4 }); }
        }
        let pm4: any = null;
        await drawKlinkPicker(pm4);
    } });

    // Manual entry
    knowParts.push({ type: 'button', text: '+ Manual Entry', style: { width: '100%', fontSize: '11px', marginTop: '4px', backgroundColor: 'rgba(255,180,50,0.06)', color: '#ffb432' }, callback: async function() {
        let manualSubject = '';
        let manualDesc = '';
        const manualPm = await openEngineModal({ title: 'Add Manual Knowledge Entry', size: 'medium', content: [
            { type: 'text', text: 'Subject', style: { fontSize: '11px', opacity: '0.7', marginBottom: '2px' } },
            { type: 'textInput', placeholder: 'e.g. "the old smuggler\'s tunnel"', initialValue: '', onChange: function(v: string) { manualSubject = v; } },
            { type: 'text', text: 'Description', style: { fontSize: '11px', opacity: '0.7', marginTop: '8px', marginBottom: '2px' } },
            { type: 'multilineTextInput', placeholder: 'What does this character know about it?', initialValue: '', onChange: function(v: string) { manualDesc = v; } },
            { type: 'button', text: '✓ Add Entry', style: { width: '100%', marginTop: '10px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432' }, callback: async function() {
                if (!manualSubject.trim()) { api.v1.ui.toast('Subject required.', { type: 'warning' }); return; }
                manualPm.close();
                const f5 = await loadCharacter(char.id); if (!f5) return;
                if (!f5.knownEntities) f5.knownEntities = [];
                f5.knownEntities.push({ id: generateId(), entityName: manualSubject.trim(), snapshot: manualDesc.trim(), isManual: true, addedAt: Date.now() });
                await saveCharacter(f5); await refreshCharEditModal();
            } }
        ] });
    } });

    return { type: 'collapsibleSection', title: '💬 Knowledge Base (' + knownEntities.length + ')', initialCollapsed: true, storageKey: `temp:ce_know_${char.id}`, content: knowParts };
}

function buildDynamicStateSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {
    const eph = char.ephemeral; const mid = char.midRange;
    const ephContent: UIPart[] = [];
    if (eph) {
        ephContent.push(
            { type: 'box', style: { backgroundColor: 'bg1', padding: '8px', borderRadius: '4px', marginBottom: '8px' }, content: [
                { type: 'text', text: `Event: "${eph.eventAnchor}"`, style: { fontSize: '11px', marginBottom: '2px' } },
                { type: 'text', text: `Feeling: "${eph.emotionalResponse}"`, style: { fontSize: '11px', marginBottom: '2px' } },
                { type: 'text', text: `Drive: "${eph.immediateDesire}"`, style: { fontSize: '11px', marginBottom: '6px' } },
                { type: 'text', text: 'Override thought (replaces AI fallback line):', style: { fontSize: '9px', opacity: '0.55', marginTop: '6px', marginBottom: '2px' } },
                { type: 'multilineTextInput', label: 'Override', placeholder: 'Leave blank to use AI-generated line. Type here to manually set.', initialValue: eph.compressedLine, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.ephemeral) { f.ephemeral.compressedLine = v; await saveCharacter(f); } } }
            ] },
            { type: 'row', style: { gap: '4px' }, content: [
                { type: 'button', text: '↺ Regenerate', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-eph', autoClose: false, type: 'info' }); const ok = await generateEphemeral(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-eph', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } },
                { type: 'button', text: 'Clear', style: { margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.ephemeral = null; f.ephemeralHistory = []; f.lastEphemeralGen = 0; await saveCharacter(f); await refreshCharEditModal(); } }
            ] }
        );
        if (char.ephemeralHistory.filter(Boolean).length > 0) {
            ephContent.push({ type: 'text', text: 'History:', style: { fontSize: '10px', opacity: '0.5', marginTop: '8px' } });
            for (const h of char.ephemeralHistory.filter(Boolean)) { ephContent.push({ type: 'text', text: `  ${h.compressedLine}`, style: { fontSize: '10px', opacity: '0.4' } }); }
        }
    } else {
        ephContent.push({ type: 'text', text: 'No snapshot yet. Generates automatically on generation end.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });
        ephContent.push({ type: 'button', text: '⚡ Force Generate', style: { fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-eph', autoClose: false, type: 'info' }); const ok = await generateEphemeral(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-eph', type: ok ? 'success' : 'error', autoClose: ok ? 2000 : 3000 }); if (ok) await refreshCharEditModal(); } });
    }
    const midContent: UIPart[] = [];
if (mid) {
        midContent.push(
            { type: 'multilineTextInput', label: 'Current Goal', initialValue: mid.currentDesire, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.currentDesire = v; await saveCharacter(f); } } },
            { type: 'multilineTextInput', label: 'Social Mask (performing vs. interior)', initialValue: mid.socialMask, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.socialMask = v; await saveCharacter(f); } } },
            { type: 'multilineTextInput', label: 'Shifted View (what they now believe that changed)', initialValue: mid.shiftedView, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.shiftedView = v; await saveCharacter(f); } } },
            { type: 'button', text: '↺ Regenerate', style: { fontSize: '11px', marginTop: '4px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-mid', autoClose: false, type: 'info' }); const ok = await generateMidRange(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-mid', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } }
        );
    } else {
        midContent.push({ type: 'text', text: 'No mid-range state yet.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });
        midContent.push({ type: 'button', text: '⚡ Force Generate', style: { fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-mid', autoClose: false, type: 'info' }); const ok = await generateMidRange(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-mid', type: ok ? 'success' : 'error', autoClose: ok ? 2000 : 3000 }); if (ok) await refreshCharEditModal(); } });
    }
    return { type: 'collapsibleSection', title: '⚡ Dynamic State', initialCollapsed: false, storageKey: `temp:ce_dyn_${char.id}`, content: [
        // ── Individual Switches ────────────────────────────────────────────
        { type: 'text', text: 'Master toggle is the ⚡️Dynamic/▫️Static button on the character card. Individual switches below can be adjusted after.', style: { fontSize: '10px', opacity: '0.45', marginBottom: '8px', fontStyle: 'italic' } },
        { type: 'row', style: { gap: '8px', marginBottom: '10px', flexWrap: 'wrap' }, content: [
            { type: 'checkboxInput', label: 'Ephemeral Thoughts (injected)', initialValue: !!char.autoThoughtsEnabled, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (!f) return; f.autoThoughtsEnabled = v; await saveCharacter(f); } },
            { type: 'checkboxInput', label: 'Goal/Mask/View updates (engine reference)', initialValue: !!char.autoUpdateEnabled, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (!f) return; f.autoUpdateEnabled = v; await saveCharacter(f); } }
        ] },
        // ── Ephemeral Thoughts ─────────────────────────────────────────────
        { type: 'collapsibleSection', title: 'Ephemeral Thoughts (injected)', initialCollapsed: false, storageKey: `temp:ce_eph_${char.id}`, content: ephContent },
        // ── Mid-range State ────────────────────────────────────────────────
        { type: 'collapsibleSection', title: 'Mid-range State (engine reference)', initialCollapsed: true, storageKey: `temp:ce_mid_${char.id}`, content: midContent },
        // ── Primary Relationship ───────────────────────────────────────────
        buildRelationshipSection(char, cfg),
        // ── Hooks ─────────────────────────────────────────────────────────
        buildHooksSection(char, cfg)
    ] };
}

// [CHANGE] buildArcSection removed — arc UI retired. Data fields kept for backward compat.

function buildRelationshipSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {
    const rel = char.primaryRelationship;
    
    const threadItems: UIPart[] = rel.threads.filter(Boolean).map(function(thread, i) {
        const ti = i; return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
            { type: 'textInput', initialValue: thread, style: { flex: '1 1 0', fontSize: '12px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads[ti] = v; await saveCharacter(f); } } },
            { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads.splice(ti, 1); await saveCharacter(f); await refreshCharEditModal(); } } }
        ] } as UIPart;
    });
    const tkTh = `ce_tmp_rth_${char.id}`;
    
    return { type: 'collapsibleSection', title: '🔗 Primary Relationship', initialCollapsed: true, storageKey: `temp:ce_prel_${char.id}`, content: [
        { type: 'button', text: rel.targetName === '__player__' ? '👑 Player Character' : (rel.targetName ? `👤 ${rel.targetName}` : 'Select Character...'), style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
            const others = await loadCharacterListForPicker(char.id);
            const pm = await openEngineModal({ title: 'Relationship Target', size: 'small', content: [
                { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.targetName = ''; await saveCharacter(f); } pm.close(); await refreshCharEditModal(); } },
                { type: 'button', text: '👑 Player Character (protagonist)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.2)' }, callback: async function() {
                    const f = await loadCharacter(char.id); if (!f) return;
                    f.primaryRelationship.targetName = '__player__';
                    if (!f.primaryRelationship.enabled) f.primaryRelationship.enabled = true;
                    await saveCharacter(f); pm.close(); await refreshCharEditModal();
                } },
                ...others.map(function(m) {
                    return { type: 'button', text: m.name, style: { width: '100%', marginBottom: '4px', backgroundColor: rel.targetName === m.name ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {
                        const f = await loadCharacter(char.id); if (!f) return;
                        f.primaryRelationship.targetName = m.name; await saveCharacter(f); pm.close(); await refreshCharEditModal();
                    } } as UIPart;
                })
            ]});
        } },
        
        // NEW: The Enable/Disable Checkbox (Defaults to false/off)
        { type: 'row', alignment: 'center', style: { gap: '8px', marginTop: '6px', marginBottom: '4px' }, content: [
            { type: 'checkboxInput', initialValue: !!rel.enabled, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.enabled = v; await saveCharacter(f); await refreshCharEditModal(); } } },
            { type: 'text', text: 'Enable in AI Context', style: { fontSize: '12px', fontWeight: 'bold', color: rel.enabled ? '#7ec8a0' : '#888' } }
        ] },

        { type: 'column', style: { gap: '2px', marginTop: '8px', marginBottom: '8px' }, content: (function() {
            let archDef = findArchetypeDef(cfg, rel);
            let stageName = resolveArchetypeStage(cfg, rel);
            let hasStages = !!(archDef && archDef.stages && archDef.stages.length);
            let curStageIdx = (typeof rel.stageIndex === 'number') ? rel.stageIndex : 0;
            let archCol: UIPart[] = [
                { type: 'text', text: 'Archetype', style: { fontSize: '11px', opacity: '0.6' } },
                { type: 'button', text: rel.archetype || '(Select Archetype)', style: { margin: 0, textAlign: 'left', fontSize: '12px' }, callback: async function() {
                    let items: PickItem[] = (cfg.relationshipArchetypes || []).map(function(d) { return { id: d.id, label: d.name + (d.stages && d.stages.length ? '  (' + d.stages.length + ' stages)' : ''), selected: rel.archetypeId === d.id || rel.archetype === d.name }; });
                    await openSearchPicker('Archetype', items, async function(id) {
                        const f = await loadCharacter(char.id); if (!f) return;
                        let picked = (cfg.relationshipArchetypes || []).find(function(d) { return d.id === id; });
                        if (picked) { f.primaryRelationship.archetypeId = picked.id; f.primaryRelationship.archetype = picked.name; f.primaryRelationship.stageIndex = 0; await saveCharacter(f); }
                        await refreshCharEditModal();
                    });
                } }
            ];
            if (hasStages) {
                archCol.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginTop: '4px' }, content: [
                    { type: 'text', text: 'Stage:', style: { fontSize: '11px', width: '44px', opacity: '0.7' } },
                    { type: 'button', text: '\u25c0', style: { margin: 0, width: '32px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { let m = Math.max(0, Math.min((archDef!.stages.length - 1), curStageIdx - 1)); f.primaryRelationship.stageIndex = m; await saveCharacter(f); await refreshCharEditModal(); } } },
                    { type: 'text', text: (curStageIdx + 1) + '/' + archDef!.stages.length + ' \u2014 ' + (stageName || ''), style: { flex: '1', fontSize: '11px', textAlign: 'center', color: '#7ec8a0' } },
                    { type: 'button', text: '\u25b6', style: { margin: 0, width: '32px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { let m = Math.max(0, Math.min((archDef!.stages.length - 1), curStageIdx + 1)); f.primaryRelationship.stageIndex = m; await saveCharacter(f); await refreshCharEditModal(); } } }
                ] } as UIPart);
            }
            return archCol;
        })() },
        { type: 'textInput', label: 'How It Started', initialValue: rel.howItStarted, placeholder: 'Origin of the dynamic...', onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.howItStarted = v; await saveCharacter(f); } } },
        { type: 'text', text: 'Threads', style: { fontSize: '11px', opacity: '0.6', marginTop: '8px', marginBottom: '2px' } },
        ...threadItems,
        { type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [
            { type: 'textInput', placeholder: 'Add thread...', storageKey: `temp:${tkTh}`, style: { flex: '1 1 0' } },
            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tkTh) as string || ''; if (!v.trim()) return; const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads.push(v.trim()); await saveCharacter(f); await api.v1.tempStorage.remove(tkTh); await refreshCharEditModal(); } } }
        ] },
        { type: 'multilineTextInput', label: 'Current Status', initialValue: rel.currentStatus, placeholder: 'Observable surface behavior — how do they act toward each other right now?', style: { minHeight: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.currentStatus = v; await saveCharacter(f); } } },
        { type: 'multilineTextInput', label: 'Trajectory', initialValue: rel.trajectory, placeholder: 'The force pushing it — what event or tension is driving change?', style: { minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.trajectory = v; await saveCharacter(f); } } },
        { type: 'multilineTextInput', label: 'Summary', initialValue: rel.summary, placeholder: 'The core knot — what do they each need that the other cannot give?', style: { minHeight: '60px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.summary = v; await saveCharacter(f); } } },
        { type: 'button', text: '↺ Regen Relationship', style: { width: '100%', marginTop: '8px', fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-rel', autoClose: false, type: 'info' }); const ok = await generateRelationshipUpdate(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-rel', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } }
    ] };
}

// ============================================================================
// CHARACTER EDIT — HOOKS SECTION
// ============================================================================

function npcPressureLabel(p: number): string {
    if (p < 25) return 'Latent';
    if (p < 60) return 'Building';
    if (p < 85) return 'Urgent';
    return 'Critical';
}

function buildHooksSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {
    const hookItems: UIPart[] = char.hooks.filter(Boolean).map(function(hk, i) {
        const hi = i; const imperative = npcPressureLabel(hk.pressureLevel);
        const captHi = hi; const captHk = hk;
        let hkDisplayTarget = hk.targetName === '__player__' ? '👑 Player' : (hk.targetName || 'Unknown');
        return { type: 'collapsibleSection', title: (hk.pressureLevel >= 85 ? '🔥 ' : '') + hkDisplayTarget + ' — ' + imperative + ' (' + hk.pressureLevel + ')', initialCollapsed: true, storageKey: `temp:ce_hk_${char.id}_${hk.id}`, content: [
            
            // --- SEARCHABLE TARGET PICKER ---
            { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Target:', style: { fontSize: '11px', width: '50px', opacity: '0.7' } },
                { type: 'button', text: hk.targetName === '__player__' ? '👑 Player' : (hk.targetName || '(Select Target)'), style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
                    await api.v1.tempStorage.set('ce_hk_target_search', '');
                    
                    async function drawSearchablePicker() {
                        const term = await api.v1.tempStorage.getOrDefault('ce_hk_target_search', '') as string;
                        const chars = typeof loadIndex === 'function' ? await loadIndex() : [];
                        const pickable = chars.filter(function(m) { 
                            return m.id !== char.id && m.name.toLowerCase().includes(term.toLowerCase()); 
                        });
                        
                        const contentParts: UIPart[] = [];
                        contentParts.push({ type: 'textInput', placeholder: '🔍 Search characters...', initialValue: term, onChange: async function(v: string) { await api.v1.tempStorage.set('ce_hk_target_search', v); await drawSearchablePicker(); } });
                        contentParts.push({ type: 'button', text: '✕ Clear Target', style: { width: '100%', marginBottom: '4px', marginTop: '8px', color: '#ff6b6b' }, callback: async function() { 
                            const f = await loadCharacter(char.id); 
                            if (f) { f.hooks[hi].targetName = ''; await saveCharacter(f); pm.close(); await refreshCharEditModal(); } 
                        } });
                        contentParts.push({ type: 'button', text: '👑 Player Character (protagonist)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.2)' }, callback: async function() { 
                            const f = await loadCharacter(char.id); 
                            if (f) { f.hooks[hi].targetName = '__player__'; await saveCharacter(f); pm.close(); await refreshCharEditModal(); } 
                        } });
                        
                        pickable.forEach(function(m) {
                            contentParts.push({ type: 'button', text: `👤 ${m.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: hk.targetName === m.name ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() { 
                                const f = await loadCharacter(char.id); 
                                if (f) { f.hooks[hi].targetName = m.name; await saveCharacter(f); pm.close(); await refreshCharEditModal(); } 
                            } } as UIPart);
                        });

                        if (pm && typeof pm.isClosed === 'function' && !pm.isClosed()) {
                            await pm.update({ content: contentParts });
                        } else {
                            pm = await openEngineModal({ id: 'ce-hk-target-picker', title: 'Select Hook Target', size: 'medium', content: contentParts });
                        }
                    }
                    let pm: any;
                    await drawSearchablePicker();
                }}
            ]},

            { type: 'multilineTextInput', label: 'Hook Description (the core tension)', initialValue: hk.description, style: { minHeight: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].description = v; await saveCharacter(f); } } },
            { type: 'sliderInput', label: `Pressure Level — ${imperative}`, min: 0, max: 100, step: 5, initialValue: hk.pressureLevel, onChange: async function(v: number) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].pressureLevel = v; await saveCharacter(f); } } },
            { type: 'text', text: 'Pressure 60+: injects as Active Tension (global cap: 2). Pressure 85+: injects as Critical (global cap: 1).', style: { fontSize: '10px', opacity: '0.45', marginBottom: '6px' } },
            hk.developmentNotes.filter(Boolean).length > 0 ? { type: 'box', style: { backgroundColor: 'bg1', padding: '6px', borderRadius: '4px', marginBottom: '4px' }, content: hk.developmentNotes.filter(Boolean).map(function(n) { return { type: 'text', text: `• ${n}`, style: { fontSize: '10px', opacity: '0.6' } } as UIPart; }) } as UIPart : null,
            { type: 'checkboxInput', label: 'Resolved', initialValue: hk.resolved, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].resolved = v; await saveCharacter(f); await refreshCharEditModal(); } } },
            { type: 'button', text: '🗑 Remove Hook', style: { fontSize: '11px', marginTop: '6px', color: '#ff6b6b' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.hooks.splice(hi, 1); await saveCharacter(f); await refreshCharEditModal(); } } }
        ].filter(Boolean) as UIPart[] } as UIPart;
    });
    return { type: 'collapsibleSection', title: (function() {
        const activeHooks = char.hooks.filter(function(h){ return !h.resolved; });
        const critCount = activeHooks.filter(function(h){ return h.pressureLevel >= 85; }).length;
        return '🎣 Hooks' + (activeHooks.length > 0 ? ' (' + (critCount > 0 ? '🔥 ' : '') + activeHooks.length + ' active)' : '');
    })(), initialCollapsed: true, storageKey: `temp:ce_hooks_${char.id}`, content: [
        { type: 'text', text: 'Dramatic tensions between this character and another. Tracked by pressure level and injected into context when high enough.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
        ...hookItems,
        { type: 'row', style: { gap: '4px', marginTop: '8px' }, content: [
            { type: 'button', text: '+ Add Blank Hook', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.hooks.push({ id: api.v1.uuid(), targetName: '', description: '', pressureLevel: 30, developmentNotes: [], resolved: false }); await saveCharacter(f); await refreshCharEditModal(); } } },
            { type: 'button', text: '↺ Scan Hooks', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() {
                const f = await loadCharacter(char.id); if (!f) return;
                const cfg2 = await loadConfig(); const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
                api.v1.ui.toast('Scanning…', { id: 'ce-hk', autoClose: false, type: 'info' });
                const ok = await generateHookUpdates(f, cfg2, tc);
                api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-hk', type: ok ? 'success' : 'error', autoClose: 2000 });
                if (ok) await refreshCharEditModal();
            } },
            { type: 'button', text: '✓ Resolve Hook', style: { margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.08)', color: '#7ec8a0', border: '1px solid rgba(126,200,160,0.3)' }, disabled: char.hooks.length === 0, callback: async function() {
                const f = await loadCharacter(char.id); if (!f || f.hooks.length === 0) return;
                const hDesc = f.hooks[0].description.substring(0, 50);
                f.hooks = []; await saveCharacter(f);
                api.v1.ui.toast('✓ Hook resolved: ' + hDesc, { type: 'success', autoClose: 3000 });
                await refreshCharEditModal();
            } }
        ] }
    ] };
}

// ============================================================================
// CHARACTER EDIT — WARDROBE / EQUIPMENT SECTION
// ============================================================================

async function buildInventorySection(char: CharacterRecord): Promise<UIPart> {
    if (!char.entityId) {
        return { type: 'collapsibleSection', title: '🎒 Inventory', initialCollapsed: true, storageKey: `temp:ce_inv_${char.id}`, content: [
            { type: 'text', text: 'Character must be linked to an Entity to hold items.', style: { fontSize: '11px', opacity: '0.5' } }
        ] };
    }

    const entIdx = await loadEntityIndex();
    const items = entIdx.filter(m => m.type === 'item' && m.parentId === char.entityId);
    
    const rows: UIPart[] = items.map(function(item) {
        const isEq = char.equippedItemId === item.id;
        return { type: 'box', style: { marginBottom: '4px', backgroundColor: 'bg1', padding: '6px', borderRadius: '4px', borderLeft: `3px solid ${isEq ? '#7ec8a0' : 'transparent'}` }, content: [
            { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
                { type: 'text', text: isEq ? '●' : '○', style: { fontSize: '12px', color: isEq ? '#7ec8a0' : '#555', flexShrink: '0' } },
                { type: 'text', text: item.name, style: { flex: '1 1 0', fontWeight: 'bold', fontSize: '12px' } },
                { type: 'button', text: isEq ? 'Unequip' : 'Equip', style: { margin: 0, fontSize: '11px', color: isEq ? '#888' : '#7ec8a0' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.equippedItemId = isEq ? undefined : item.id; await saveCharacter(f); await refreshCharEditModal(); } },
                { type: 'button', iconId: 'edit', style: { margin: 0 }, callback: async function() { await openEntityEditModal(item.id); } }
            ] }
        ] } as UIPart;
    });

    return { type: 'collapsibleSection', title: `🎒 Inventory (${items.length})`, initialCollapsed: true, storageKey: `temp:ce_inv_${char.id}`, content: [
        { type: 'text', text: 'Items physically parented to this character.', style: { fontSize: '10px', opacity: '0.6', marginBottom: '8px' } },
        ...(rows.length > 0 ? rows : [{ type: 'text', text: 'Inventory is empty.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '6px' } } as UIPart]),
        { type: 'button', text: '+ Create Item', iconId: 'plus', style: { marginTop: '8px' }, callback: async function() { 
            const newItem = makeDefaultEntity('New Item');
            newItem.type = 'item';
            newItem.parentId = char.entityId || null;
            await saveEntity(newItem);
            await openEntityEditModal(newItem.id); // Drops them straight into the new item!
        } }
    ] };
}

// ============================================================================
// CHARACTER EDIT — CHARACTER SHEET SECTION
// ============================================================================

function buildSheetSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {
    if (cfg.sheetCategories.filter(Boolean).length === 0) {
        return { type: 'collapsibleSection', title: '📊 Character Sheet', initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}`, content: [{ type: 'text', text: 'No categories defined. Add them in ⚙ Settings.', style: { fontSize: '11px', opacity: '0.5' } }] };
    }
    const cats: UIPart[] = cfg.sheetCategories.filter(Boolean).map(function(cat) {
        const fields: UIPart[] = cat.fields.filter(Boolean).map(function(field) {
            const key = `${cat.id}.${field.id}`; const cur = char.sheetValues[key] || '';
            if (cat.fieldType === 'enum' && cat.enumValues.filter(Boolean).length > 0) {
                return { type: 'column', style: { marginBottom: '8px' }, content: [
                    { type: 'text', text: field.name, style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },
                    { type: 'button', text: cur || '(Select…)', style: { margin: 0, textAlign: 'left', fontSize: '12px' }, callback: async function() {
                        const p = await openEngineModal({ title: field.name, size: 'small', content: cat.enumValues.filter(Boolean).map(function(v) {
                            return { type: 'button', text: v, style: { margin: '2px', width: '100%', backgroundColor: v === cur ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } p.close(); await refreshCharEditModal(); } } as UIPart;
                        }) });
                    } }
                ] } as UIPart;
            } else if (cat.fieldType === 'number') {
                return { type: 'numberInput', label: field.name, initialValue: Number(cur) || 0, style: { marginBottom: '8px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } } } as UIPart;
            } else {
                return { type: 'textInput', label: field.name, initialValue: cur, style: { marginBottom: '8px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } } } as UIPart;
            }
        });
        return { type: 'collapsibleSection', title: cat.name, initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}_${cat.id}`, content: fields.filter(Boolean) as UIPart[] } as UIPart;
    });
    return { type: 'collapsibleSection', title: '📊 Character Sheet', initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}`, content: cats };
}

// ============================================================================
// CHARACTER EDIT — EVENT HISTORY SECTION
// ============================================================================

function buildEventHistorySection(char: CharacterRecord, cfg: GlobalConfig): UIPart {
    const events: UIPart[] = char.eventHistory.filter(Boolean).map(function(ev, i) {
        const ei = i;
        return { type: 'row', style: { marginBottom: '6px', gap: '4px' }, content: [
            { type: 'multilineTextInput', initialValue: ev.summary, style: { flex: '1 1 0', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.eventHistory[ei].summary = v; await saveCharacter(f); } } },
            { type: 'button', iconId: 'trash', style: { margin: 0 }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.eventHistory.splice(ei, 1); await saveCharacter(f); await refreshCharEditModal(); } } }
        ] } as UIPart;
    });
    return { type: 'collapsibleSection', title: `📜 Event History (${char.eventHistory.length})`, initialCollapsed: true, storageKey: `temp:ce_evts_${char.id}`, content: [
        { type: 'text', text: 'Major character-shaping events. Used as background context by the engine.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
        ...events,
        { type: 'row', style: { gap: '4px', marginTop: '8px' }, content: [
            { type: 'button', text: '+ Add Blank', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.eventHistory.push({ id: api.v1.uuid(), summary: '', timestamp: Date.now() }); await saveCharacter(f); await refreshCharEditModal(); } } },
            { type: 'button', text: '⚡ Generate from Context', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() {
                api.v1.ui.toast('Generating summary…', { id: 'ce-ev', autoClose: false, type: 'info' });
                const cfg2 = await loadConfig(); const summ = await generateEventSummary(char, cfg2);
                if (summ) { const f = await loadCharacter(char.id); if (f) { f.eventHistory.push({ id: api.v1.uuid(), summary: summ, timestamp: Date.now() }); await saveCharacter(f); api.v1.ui.toast('Added.', { id: 'ce-ev', type: 'success', autoClose: 1000 }); await refreshCharEditModal(); } }
                else api.v1.ui.toast('Failed to generate.', { id: 'ce-ev', type: 'error', autoClose: 2000 });
            } }
        ] }
    ] };
}


// ============================================================================
// TEMPLATE BUILDER UI SYSTEM
// ============================================================================

const MACRO_DICTIONARIES = {
    trackedNarrative: ['name', 'description', 'storyState', 'pathNames'],
    location: ['playerName', 'name', 'description', 'atmosphere', 'state'],
    player: ['playerName', 'presentNames', 'name', 'res.<tag>'],
    npc: ['name', 'primaryRelationship.targetName', 'primaryRelationship.currentStatus', 'relArchetype', 'relStage', 'conditionStates', 'res.<tag>', 'midRange.currentDesire', 'midRange.socialMask', 'midRange.shiftedView', 'ephemeral.eventAnchor', 'ephemeral.emotionalResponse', 'ephemeral.immediateDesire', 'ephemeral.compressedLine', 'hookDescription'],
    npcWeb: ['charA_name', 'charB_name', 'dynamic'],
    activeNarrative: ['name', 'description']            // [v0.9.24] deprecated; preview only
};

// [v0.9.26 DRM1] Preview-only sample data. res is a wildcard (res.<tag>), so the
// sample res objects carry the common tags an author might reference (condition,
// health, mood, luck, stamina, mana, drunk). _resProxyForPreview() below also
// supplies a generic fallback for any res tag not listed here, so EVERY res.<x>
// macro renders something in the live preview.
function _resPreview(base: Record<string, string>): any {
    // Returns base merged with a fallback so unknown res tags still preview.
    let out: Record<string, string> = {};
    let common = { condition: 'Steady', health: 'Healthy', mood: 'Calm', luck: '3', stamina: 'Rested', mana: 'Full', drunk: 'Sober', hunger: 'Fed', morale: 'High' };
    for (let k in common) { out[k] = (common as any)[k]; }
    for (let k2 in base) { out[k2] = base[k2]; }
    return out;
}
const DUMMY_DATA: Record<string, any> = {
    trackedNarrative: { name: 'The Stolen Relic', description: 'Recover the amulet from the thieves guild.', storyState: 'active', pathNames: 'Tavern → Alley → Docks' },
    location: { playerName: 'Aria', name: 'The Rusty Anchor', description: 'A dimly lit tavern smelling of stale ale.', atmosphere: 'Tense and quiet.', state: 'Crowded' },
    player: { playerName: 'Aria', presentNames: 'Barkeeper, Sel', name: 'Aria', res: _resPreview({ health: 'Steady', luck: '3' }) },
    npc: {
        name: 'Barkeeper',
        primaryRelationship: { targetName: 'Aria', currentStatus: 'suspicious' },
        relArchetype: 'Enemies to Lovers', relStage: 'Uneasy Trust',
        conditionStates: 'Tipsy, Wary',
        res: _resPreview({ mood: 'Grumpy', drunk: 'Tipsy', condition: 'Wary' }),
        midRange: { currentDesire: 'get paid before the night ends', socialMask: 'Friendly smile', shiftedView: 'Starting to respect you' },
        ephemeral: { eventAnchor: 'You slammed coins on the bar', emotionalResponse: 'Surprised, then pleased', immediateDesire: 'Hear your offer', compressedLine: 'this stranger knows too much' },
        hookDescription: 'Needs someone to clear the cellar rats.'
    },
    npcWeb: { charA_name: 'Barkeeper', charB_name: 'Thief', dynamic: 'Owes money to the other.' },
    activeNarrative: { name: 'A Brewing Storm', description: 'Tensions rise between the guilds.' }
};

async function copyMacroToClipboard(macroName: string) {
    try {
        await api.v1.permissions.request(['clipboardWrite']);
        const templateStr = `[ |${macroName}| ]`;
        await api.v1.clipboard.writeText(templateStr);
        api.v1.ui.toast('Copied: ' + templateStr, { type: 'success', autoClose: 2000 });
    } catch (e) {
        api.v1.ui.toast('Clipboard permission denied. Type it manually.', { type: 'error' });
    }
}

function buildMacroButtons(type: keyof typeof MACRO_DICTIONARIES): any {
    return {
        type: 'row',
        wrap: true,
        style: { gap: '4px', marginBottom: '4px' },
        content: MACRO_DICTIONARIES[type].map(m => ({
            type: 'button',
            text: m,
            style: { padding: '2px 6px', fontSize: '9px', margin: 0, backgroundColor: 'rgba(255,255,255,0.05)' },
            callback: () => copyMacroToClipboard(m)
        }))
    };
}

function buildTemplateEditor(
    label: string, 
    type: keyof typeof MACRO_DICTIONARIES, 
    currentValue: string, 
    onSave: (val: string) => void
): any[] {
    const previewText = parseMacroTemplate(currentValue, DUMMY_DATA[type]);
    
    return [
        { type: 'text', text: `${label}`, style: { marginTop: '12px', fontSize: '11px', color: '#88ccff' } },
        buildMacroButtons(type),
        {
            type: 'multilineTextInput',
            initialValue: currentValue,
            placeholder: 'Enter macro template...',
            style: { fontFamily: 'monospace', fontSize: '11px', minHeight: '50px' },
            onChange: onSave
        },
        { type: 'text', text: `Preview: ${previewText || '(Blank)'}`, style: { fontSize: '11px', opacity: 0.7, marginBottom: '8px', fontStyle: 'italic' } }
    ];
}

async function getGlobalTemplateUIParts(refreshUI: () => void): Promise<UIPart[]> {
    const cfg = await loadConfig();
    const parts: any[] = [
        { type: 'text', text: 'Click a macro to copy its Tripartite Bracket format `[ Prefix | macro.path | Suffix ]` to your clipboard.', style: { fontSize: '10px', opacity: 0.6, marginBottom: '8px' } }
    ];

    // [v0.9.8.4] Editors ordered to match the injection / scene flow:
    // quest -> location -> roster -> character dynamics -> background webs.
    parts.push(...buildTemplateEditor('Tracked Narrative (Quest)', 'trackedNarrative', cfg.contextTemplates.trackedNarrative, async (v) => {
        cfg.contextTemplates.trackedNarrative = v; await saveConfig(cfg); refreshUI();
    }));
    parts.push(...buildTemplateEditor('Location & Scene', 'location', cfg.contextTemplates.location, async (v) => {
        cfg.contextTemplates.location = v; await saveConfig(cfg); refreshUI();
    }));
    parts.push(...buildTemplateEditor('Scene Roster (Present With)', 'player', cfg.contextTemplates.player, async (v) => {
        cfg.contextTemplates.player = v; await saveConfig(cfg); refreshUI();
    }));
    parts.push(...buildTemplateEditor('Character Dynamics', 'npc', cfg.contextTemplates.npc, async (v) => {
        cfg.contextTemplates.npc = v; await saveConfig(cfg); refreshUI();
    }));
    parts.push(...buildTemplateEditor('NPC Web (Background)', 'npcWeb', cfg.contextTemplates.npcWeb, async (v) => {
        cfg.contextTemplates.npcWeb = v; await saveConfig(cfg); refreshUI();
    }));
    // [v0.9.26 DRM2] Active Narrative editor removed — Tracked Narrative covers it; activeNarrative macro dict retained for preview only.

    return parts;
}

// ============================================================================
// SECTION 21 — SIDEBAR: DRAMA TAB
// buildDramaTabContent: NPC hooks, narrative arcs, web links.
// ============================================================================

async function buildDramaTabContent(): Promise<UIPart[]> {
    const allChars = await loadAllCharacters();
    let parts: UIPart[] = [];

    // [v0.9.17] Resolve the player's display name so __player__ targets show a real name.
    const _dramaCfg = await loadConfig();
    const _dramaProtag = allChars.find(function(c) { return (c as any).isProtagonist; });
    const _playerDisplayName = _dramaProtag ? _dramaProtag.name : ((_dramaCfg as any).protagonistName || 'Player');

    // --- 1. THE HOOK QUEUE (COLLAPSIBLE) ---
    let hookParts: UIPart[] = [
        { type: 'text', text: 'Hooks are active dramatic tensions involving characters. Pressure 60+ (Urgent) injects into the Scene Drama block at the bottom of the AI context. Pressure 85+ (Critical) injects as a high-priority Imperative at the top of context.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }
    ];
    let allHooks: { charId: string, charName: string, hook: UnresolvedHook }[] = [];
    
    for (const c of allChars) {
        if (!c.active || !c.hooks) continue;
        for (const h of c.hooks) {
            // Under the new rules, this will realistically only find 1 active hook per character
            if (!h.resolved) allHooks.push({ charId: c.id, charName: c.name, hook: h });
        }
    }

    allHooks.sort(function(a, b) { return b.hook.pressureLevel - a.hook.pressureLevel; });

    if (allHooks.length === 0) {
        hookParts.push({ type: 'text', text: 'No active hooks. The tea is cold.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '8px', textAlign: 'center' } });
    } else {
        for (const item of allHooks) {
            const h = item.hook;
            
            // Color Logic & Glow
            let pColor = '#f1c40f'; // Yellow (< 60)
            let shadow = 'none';
            if (h.pressureLevel >= 85) {
                pColor = '#ff6b6b'; // Red (Critical)
                shadow = '0 0 10px rgba(255, 107, 107, 0.3)';
            } else if (h.pressureLevel >= 60) {
                pColor = '#ffb432'; // Orange (Urgent)
                shadow = '0 0 6px rgba(255, 180, 50, 0.15)';
            }

            hookParts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.3)', padding: '8px', marginBottom: '8px', borderLeft: `3px solid ${pColor}`, borderRadius: '4px', boxShadow: shadow }, content: [
                
                // ROW 1: Title, %, Edit, Delete
                { type: 'row', alignment: 'center', style: { marginBottom: '4px', gap: '4px' }, content: [
                    { type: 'text', text: `${item.charName} ➝ ${h.targetName === '__player__' ? _playerDisplayName : (h.targetName || 'Unknown')}`, style: { fontWeight: 'bold', fontSize: '13px', flex: '1 1 0', color: '#e8a87c', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } },
                    { type: 'text', text: `${h.pressureLevel}%`, style: { fontSize: '11px', color: pColor, fontWeight: 'bold', backgroundColor: 'rgba(0,0,0,0.5)', padding: '2px 6px', borderRadius: '4px' } },
                    { type: 'button', iconId: 'edit-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent' }, callback: async function() { await openCharEditModal(item.charId); } },
                    { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async function() {
                        const f = await loadCharacter(item.charId);
                        if (f && f.hooks) {
                            f.hooks = f.hooks.filter(function(x) { return x.id !== h.id; });
                            await saveCharacter(f);
                            await refreshSidebar(); 
                        }
                    }}
                ]},
                
                // ROW 2: Description
                { type: 'text', text: h.description, style: { fontSize: '12px', opacity: '0.85', lineHeight: '1.4', marginBottom: '8px' } },
                
                // ROW 3: Slider & Manual Force-Update Button
                { type: 'row', alignment: 'center', style: { gap: '8px' }, content: [
                    { type: 'sliderInput', min: 0, max: 100, step: 5, initialValue: h.pressureLevel, style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: number) {
                        const f = await loadCharacter(item.charId);
                        if (f && f.hooks) {
                            const targetHook = f.hooks.find(function(x) { return x.id === h.id; });
                            if (targetHook) {
                                targetHook.pressureLevel = v;
                                await saveCharacter(f);
                                // Note: Slider saves backend state silently to avoid UI crash. 
                                // User clicks 🔄 to actually trigger the color/text refresh.
                            }
                        }
                    }},
                    { type: 'button', text: '🔄 Update', style: { margin: 0, padding: '4px 8px', fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.05)', border: '1px solid rgba(255,255,255,0.1)' }, disabledWhileCallbackRunning: true, callback: async function() {
                        const f = await loadCharacter(item.charId);
                        if (!f) return;
                        const cfg = await loadConfig();
                        const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
                        
                        api.v1.ui.toast(`Scanning scene for ${f.name}...`, { id: 'hk-upd', autoClose: false, type: 'info' });
                        const ok = await generateHookUpdates(f, cfg, tc); // Calls the background engine manually
                        api.v1.ui.toast(ok ? 'Tension Updated.' : 'No changes detected.', { id: 'hk-upd', type: ok ? 'success' : 'warning', autoClose: 2000 });
                        
                        // Redraws the sidebar to apply the new colors/text
                        await refreshSidebar();
                    }}
                ]}
            ]});
        }
    }

    parts.push({ type: 'collapsibleSection', title: `🔥 The Hook Queue (${allHooks.length})`, initialCollapsed: false, storageKey: 'temp:drama_hooks', content: hookParts });

// --- 2. THE NPC WEB (COLLAPSIBLE) ---
    const npcWeb = await loadNpcWeb();
    let webParts: UIPart[] = [
        { type: 'text', text: 'Bilateral dynamics between characters. When both characters are present in the scene, priority 70+ injects as an Imperative (top of context), while lower priorities inject as Background Drama.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }
    ];

    // Helper to fetch character names for the UI buttons
    function getCharName(id: string) {
        const c = allChars.find(function(x) { return x.id === id; });
        return c ? c.name : 'Select...';
    }

    for (let i = 0; i < npcWeb.length; i++) {
        const link = npcWeb[i];
        
        // NEW: Check if both characters are currently in the scene!
        const cA = allChars.find(function(x) { return x.id === link.charA_id; });
        const cB = allChars.find(function(x) { return x.id === link.charB_id; });
        const bothPresent = !!(cA && cA.scenePresent && cB && cB.scenePresent);
        
        // Green if active in scene, Blue if background
        const webBorderColor = bothPresent ? '#7ec8a0' : '#88ccff'; 
        const webShadow = bothPresent ? '0 0 8px rgba(126,200,160,0.2)' : 'none';

        // Modal helper to select a character
        async function selectChar(isCharA: boolean) {
            const pm = await openEngineModal({
                title: 'Select Character',
                size: 'small',
                content: allChars.map(function(c) {
                    return { type: 'button', text: c.name, style: { margin: '2px', width: '100%', backgroundColor: 'rgba(255,255,255,0.02)' }, callback: async function() {
                        const web = await loadNpcWeb();
                        if (isCharA) web[i].charA_id = c.id;
                        else web[i].charB_id = c.id;
                        await saveNpcWeb(web);
                        pm.close();
                        await refreshSidebar();
                    } } as UIPart;
                })
            });
        }

        webParts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.3)', padding: '8px', marginBottom: '8px', borderLeft: `3px solid ${webBorderColor}`, boxShadow: webShadow, borderRadius: '4px' }, content: [
            
            // ROW 1: Character A ⇄ Character B + Delete
            { type: 'row', alignment: 'center', style: { marginBottom: '6px', gap: '4px' }, content: [
                { type: 'button', text: getCharName(link.charA_id), style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '4px', color: (cA && cA.scenePresent) ? '#7ec8a0' : undefined }, callback: async function() { await selectChar(true); } },
                { type: 'text', text: '⇄', style: { fontSize: '14px', opacity: '0.6', margin: '0 2px' } },
                { type: 'button', text: getCharName(link.charB_id), style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '4px', color: (cB && cB.scenePresent) ? '#7ec8a0' : undefined }, callback: async function() { await selectChar(false); } },
                { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async function() {
                    const web = await loadNpcWeb();
                    web.splice(i, 1);
                    await saveNpcWeb(web);
                    await refreshSidebar();
                }}
            ]},
            
            // ROW 2: The Dynamic Input
            { type: 'textInput', placeholder: 'Describe their dynamic (e.g., Bitter rivals...)', initialValue: link.dynamic, style: { fontSize: '12px', marginBottom: '6px' }, onChange: async function(v: string) {
                const web = await loadNpcWeb();
                web[i].dynamic = v;
                await saveNpcWeb(web);
            }},
            
            // ROW 3: The Priority Slider
            { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
                { type: 'text', text: 'Priority', style: { fontSize: '10px', opacity: '0.6' } },
                { type: 'sliderInput', min: 0, max: 100, step: 10, initialValue: link.priority, showValue: false, style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: number) {
                    const web = await loadNpcWeb();
                    web[i].priority = v;
                    await saveNpcWeb(web);
                }},
                { type: 'text', text: `${link.priority}`, style: { fontSize: '10px', fontWeight: 'bold', width: '24px', textAlign: 'right', color: webBorderColor } }
            ]}
        ]});
    }

    // Add New Link Button
    webParts.push({ type: 'button', text: '+ Add Web Link', iconId: 'plus', style: { width: '100%', fontSize: '11px', marginTop: '4px', backgroundColor: 'rgba(136,204,255,0.1)' }, callback: async function() {
        const web = await loadNpcWeb();
        web.push({ id: api.v1.uuid(), charA_id: '', charB_id: '', dynamic: '', priority: 30 });
        await saveNpcWeb(web);
        await refreshSidebar();
    }});

    parts.push({ type: 'collapsibleSection', title: `🕸️ The NPC Web (${npcWeb.length})`, initialCollapsed: true, storageKey: 'temp:drama_npcweb', content: webParts });
    // --- 3. NARRATIVE THREADS (QUEST TREE) ---
    const entIdx = await loadEntityIndex();
    const narratives = entIdx.filter(function(n) { return n.type === 'narrative'; });
    let storyParts: UIPart[] = [
        { type: 'text', text: 'Active story threads. Their descriptions inject into the Scene Drama block (bottom of context) to remind the AI of ongoing plots when they are active.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }
    ];

    // Recursive Tree Builder
    async function renderNarrativeTree(narrativeParentId: string | null, depth: number) {
        const children = narratives.filter(function(n) { return (n.narrativeParentId || null) === narrativeParentId; });
        for (const child of children) {
            const hasChildren = narratives.some(function(n) { return n.narrativeParentId === child.id; });
            
            // Emoji logic based on storyState
            let stateEmoji = '🔒';
            let nameColor = '#888';
            if (child.storyState === 'active') { stateEmoji = '🔥'; nameColor = '#ffb432'; }
            else if (child.storyState === 'completed') { stateEmoji = '✅'; nameColor = '#7ec8a0'; }

            storyParts.push({
                type: 'row', alignment: 'center', style: { paddingLeft: `${depth * 14}px`, marginBottom: '4px' }, content: [
                    { type: 'text', text: stateEmoji, style: { marginRight: '6px', fontSize: '12px' } },
                    { type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', color: nameColor, fontWeight: depth === 0 ? 'bold' : 'normal' } },
                    { type: 'button', iconId: 'edit', style: { margin: 0, padding: '2px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } }
                ]
            });

            if (hasChildren) await renderNarrativeTree(child.id, depth + 1);
        }
    }

    await renderNarrativeTree(null, 0);

    if (narratives.length === 0) {
        storyParts.push({ type: 'text', text: 'No narrative threads created yet.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', textAlign: 'center', marginBottom: '8px' } });
    }

    storyParts.push({ type: 'button', text: '+ New Narrative Thread', iconId: 'plus', style: { marginTop: '8px', fontSize: '11px', backgroundColor: 'rgba(232, 168, 124, 0.1)' }, callback: async function() {
        const ent = makeDefaultEntity('New Thread');
        ent.type = 'narrative';
        ent.storyState = 'locked';
        await saveEntity(ent);
        await openEntityEditModal(ent.id);
        await refreshSidebar();
    }});

    parts.push({ type: 'collapsibleSection', title: `📜 Narrative Threads (${narratives.length})`, initialCollapsed: false, storageKey: 'temp:drama_narratives', content: storyParts });
    
    // --- 4. GLOBAL CONTEXT TEMPLATE BUILDER ---
    const templateParts = await getGlobalTemplateUIParts(async () => await refreshSidebar());
    parts.push({ type: 'collapsibleSection', title: '⚙️ Context Templates', initialCollapsed: true, storageKey: 'temp:drama_templates', content: templateParts });
    
    return parts;
}

// ============================================================================
// SECTION 22 — SIDEBAR: WORLD / ENTITIES TAB
// [CHANGE] renderSceneHUD() -> queueSceneStateBroadcast() in travel callbacks.
// ============================================================================

async function buildEntitiesTab(): Promise<UIPart[]> {
    const parts: UIPart[] = [];
    
    // 1. Fetch the active search query for entities from temporary storage
    const searchQuery = await api.v1.tempStorage.getOrDefault('temp:ae_entity_search', '') as string;
    
    // Top Row: Create Node Button
    parts.push({ 
        type: 'button', 
        text: '➕ Create Node', 
        primary: true, 
        style: { marginBottom: '8px' }, 
        callback: async function() { 
            const ent = makeDefaultEntity('New Node');
            await saveEntity(ent);
            await openEntityEditModal(ent.id);
            await refreshSidebar();
        } 
    });

    // 2. Add the Search Bar component
    parts.push({
        type: 'textInput', 
        placeholder: '🔍 Search entities...', 
        initialValue: searchQuery,
        style: { marginBottom: '12px' }, 
        onChange: async function(v: string) {
            // Save the query and re-render the UI
            await api.v1.tempStorage.set('temp:ae_entity_search', v);
            await refreshSidebar();
        }
    });

    // Load the master entity index
    const entIdx = await loadEntityIndex();
    
    // 3. Filter the index based on the search query
    let displayEntIdx = entIdx;
    if (searchQuery) {
        const sq = searchQuery.toLowerCase();
        displayEntIdx = displayEntIdx.filter(m => (m.name || '').toLowerCase().includes(sq));
    }
    
    // Empty state message (Optional but recommended)
    if (displayEntIdx.length === 0) {
        parts.push({ 
            type: 'text', 
            text: searchQuery ? 'No entities match your search.' : 'No entities yet.', 
            style: { fontSize: '12px', opacity: '0.6', marginBottom: '8px' } 
        });
    }
    
    // Helper to swap order in the index array
    async function moveEntity(id: string, direction: -1 | 1) {
        const currentIndex = await loadEntityIndex();
        const childMeta = currentIndex.find(function(m) { return m.id === id; });
        if (!childMeta) return;

        // Get siblings in their current exact order
        const siblings = currentIndex.filter(function(m) { return m.parentId === childMeta.parentId; });
        const sibIdx = siblings.findIndex(function(m) { return m.id === id; });

        if (direction === -1 && sibIdx > 0) {
            // Move Up (Swap with previous sibling)
            const targetId = siblings[sibIdx - 1].id;
            const pos1 = currentIndex.findIndex(function(m) { return m.id === id; });
            const pos2 = currentIndex.findIndex(function(m) { return m.id === targetId; });
            const temp = currentIndex[pos1]; currentIndex[pos1] = currentIndex[pos2]; currentIndex[pos2] = temp;
            await saveEntityIndex(currentIndex);
            await refreshSidebar();
        } else if (direction === 1 && sibIdx < siblings.length - 1) {
            // Move Down (Swap with next sibling)
            const targetId = siblings[sibIdx + 1].id;
            const pos1 = currentIndex.findIndex(function(m) { return m.id === id; });
            const pos2 = currentIndex.findIndex(function(m) { return m.id === targetId; });
            const temp = currentIndex[pos1]; currentIndex[pos1] = currentIndex[pos2]; currentIndex[pos2] = temp;
            await saveEntityIndex(currentIndex);
            await refreshSidebar();
        }
    }

    if (searchQuery) {
        // Render a flat list when searching, since tree hierarchy parents might not match the search
        for (const child of displayEntIdx) {
            const icon = (child as any).icon || ENTITY_TYPE_ICONS[child.type] || '●';
            parts.push({
                type: 'row', alignment: 'center',
                style: { marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: '4px' },
                content: [
                    { type: 'text', text: icon, style: { marginRight: '6px', fontSize: '14px' } },
                    { type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', opacity: child.type === 'item' ? '0.7' : '1' } },
                    { type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } }
                ]
            });
        }
    } else {
        // Async Recursive Tree Builder with Collapse Memory
        async function renderEntityTree(parentId: string | null, depth: number) {
            const children = entIdx.filter(function(m) { return m.parentId === parentId; });
            
            for (let i = 0; i < children.length; i++) {
                const child = children[i];
                const hasChildren = entIdx.some(function(m) { return m.parentId === child.id; });
                const isCollapsed = await api.v1.tempStorage.getOrDefault(`ce_col_${child.id}`, false);

                const icon = (child as any).icon || ENTITY_TYPE_ICONS[child.type] || '●';
                
                const rowContent: UIPart[] = [];
                
                // 1. The Collapse Toggle Chevron
                if (hasChildren) {
                    rowContent.push({
                        type: 'button', iconId: isCollapsed ? 'chevron-right' : 'chevron-down',
                        style: { margin: '0 4px 0 0', padding: '2px', backgroundColor: 'transparent' },
                        callback: async function() {
                            await api.v1.tempStorage.set(`ce_col_${child.id}`, !isCollapsed);
                            await refreshSidebar();
                        }
                    });
                } else {
                    rowContent.push({ type: 'text', text: '', style: { minWidth: '24px', marginRight: '4px' } });
                }
                
                // 2. The Icon & Name
                rowContent.push({ type: 'text', text: icon, style: { marginRight: '6px', fontSize: '14px' } });
                rowContent.push({ type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: depth === 0 ? 'bold' : 'normal', opacity: child.type === 'item' ? '0.7' : '1' } });
                
                // 3. Sorting Chevrons (Up / Down)
                const isFirst = i === 0;
                const isLast = i === children.length - 1;
                
                rowContent.push({
                    type: 'button', iconId: 'chevron-up', disabled: isFirst,
                    style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: isFirst ? '0.1' : '0.5' },
                    callback: async function() { await moveEntity(child.id, -1); }
                });
                
                rowContent.push({
                    type: 'button', iconId: 'chevron-down', disabled: isLast,
                    style: { margin: '0 4px 0 0', padding: '2px', backgroundColor: 'transparent', opacity: isLast ? '0.1' : '0.5' },
                    callback: async function() { await moveEntity(child.id, 1); }
                });

                // 4. The Edit Button
                rowContent.push({ type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } });

                // Push the assembled row
                parts.push({
                    type: 'row', alignment: 'center',
                    style: { paddingLeft: `${depth * 14}px`, marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: '4px' },
                    content: rowContent
                });
                
                // 5. Recurse!
                if (hasChildren && !isCollapsed) {
                    await renderEntityTree(child.id, depth + 1);
                }
            }
        }
        
        // Kick off the recursion starting at the Root level (null)
        await renderEntityTree(null, 0);
    }

    if (entIdx.length === 0) {
        parts.push({ type: 'text', text: 'No nodes created yet.', style: { fontSize: '12px', opacity: '0.6' } });
    }

    // ── LOST & FOUND: entities with broken parent references ────────────
    let orphanEnts = entIdx.filter(function(m) {
        return m.parentId !== null && !entIdx.find(function(p) { return p.id === m.parentId; });
    });
    if (orphanEnts.length > 0) {
        let lostParts: UIPart[] = [
            { type: 'text', text: 'These entities have a parent that no longer exists. Move to Root or edit to reparent.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } }
        ];
        for (let orphan of orphanEnts) {
            let captOrphanId = orphan.id;
            let oIcon = ENTITY_TYPE_ICONS[orphan.type] || '❓';
            lostParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px', padding: '6px 8px', backgroundColor: 'rgba(255,180,50,0.07)', borderRadius: '4px', border: '1px solid rgba(255,180,50,0.2)' }, content: [
                { type: 'text', text: oIcon, style: { fontSize: '13px', flexShrink: '0' } },
                { type: 'text', text: orphan.name, style: { flex: '1 1 0', fontSize: '12px', color: '#ffb432' } },
                { type: 'button', text: 'Root', style: { margin: 0, fontSize: '10px', padding: '2px 8px', backgroundColor: 'rgba(255,255,255,0.06)' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let fe = await loadEntity(captOrphanId); if (!fe) return;
                    fe.parentId = null; await saveEntity(fe); await refreshSidebar();
                } },
                { type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(captOrphanId); } }
            ] });
        }
        parts.push({ type: 'collapsibleSection', title: '⚠️ Lost Entities (' + orphanEnts.length + ')', initialCollapsed: false, storageKey: 'temp:ce_lost_ents', content: lostParts });
    }

    return parts;
}

// ============================================================================
// ENTITY EDIT MODAL
// ============================================================================

async function openEntityEditModal(id: string): Promise<void> {
    const ent = await loadEntity(id);
    if (!ent) return;

    const allNodes = await loadEntityIndex();
    const cfg = await loadConfig(); 
    let parts: UIPart[] = [];

    // --- PRE-CALCULATE COMBINED SKILL OPTIONS ---
    const skillOptions: { tag: string, name: string }[] = [];
    (cfg.resources || []).forEach(function(r: any) { skillOptions.push({ tag: r.tag, name: `[Resource] ${r.name}` }); });
    (cfg.sheetCategories || []).forEach(function(cat: any) {
        (cat.fields || []).forEach(function(f: any) {
            const tag = `#${f.name.toLowerCase().replace(/[^a-z0-9]/g, '')}`;
            skillOptions.push({ tag: tag, name: `[Skill] ${f.name}` });
        });
    });

    // --- ALWAYS VISIBLE (Top Level) ---
    parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
        { type: 'textInput', label: 'Entity Name', initialValue: ent.name, style: { flex: '1 1 0' }, onChange: async function(val: string) { ent.name = val; await saveEntity(ent); await refreshSidebar(); } },
        { type: 'textInput', label: 'Icon', placeholder: '🌍', initialValue: ent.icon || '', style: { width: '52px', flexShrink: '0', textAlign: 'center' }, onChange: async function(val: string) { ent.icon = val.trim() || undefined; await saveEntity(ent); await refreshSidebar(); queueSceneStateBroadcast(); } },
        { type: 'button', text: '⧉ Copy', style: { margin: 0, fontSize: '11px', flexShrink: '0', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
            await copyEntity(ent.id, false);
        } },
        { type: 'button', text: '⧉+ Deep', style: { margin: 0, fontSize: '11px', flexShrink: '0', backgroundColor: 'rgba(232,168,124,0.1)', border: '1px solid rgba(232,168,124,0.3)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {
            await copyEntity(ent.id, true);
        } }
    ] });

    const typeOpts = [
        { id: 'location', icon: '🌍', label: 'Location' },
        { id: 'item', icon: '🎒', label: 'Item' },
        { id: 'narrative', icon: '📜', label: 'Narrative' },
        { id: 'character', icon: '👤', label: 'Character' }
    ];
    
    parts.push({ type: 'text', text: 'Entity Type', style: { fontSize: '12px', fontWeight: 'bold', marginBottom: '4px', marginTop: '8px' } });
    parts.push({ type: 'row', style: { gap: '4px', marginBottom: '12px' }, content: typeOpts.map(function(opt) { 
        const isActive = ent.type === opt.id; 
        return { 
            type: 'button', text: `${opt.icon} ${opt.label}`, 
            style: { 
                flex: '1 1 0', margin: 0, fontSize: '11px', 
                backgroundColor: isActive ? 'rgba(126,200,160,0.22)' : 'transparent', 
                border: isActive ? '1px solid rgba(126,200,160,0.55)' : '1px solid rgba(255,255,255,0.1)', 
                fontWeight: isActive ? 'bold' : 'normal' 
            }, 
            callback: async function() { ent.type = opt.id as any; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } 
        } as UIPart; 
    }) });

    // --- NARRATIVE SPECIFIC CONTROLS ---
    if (ent.type === 'narrative') {
        parts.push({ type: 'text', text: 'Story State', style: { fontSize: '12px', fontWeight: 'bold', marginBottom: '4px', marginTop: '8px', color: '#e8a87c' } });
        parts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [
            { type: 'button', text: '🔒 Locked', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'locked' ? 'rgba(136,136,136,0.2)' : 'transparent', border: ent.storyState === 'locked' ? '1px solid #888' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'locked'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } },
            { type: 'button', text: '🔥 Active', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'active' ? 'rgba(255,180,50,0.2)' : 'transparent', border: ent.storyState === 'active' ? '1px solid #ffb432' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'active'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } },
            { type: 'button', text: '✅ Done', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'completed' ? 'rgba(126,200,160,0.2)' : 'transparent', border: ent.storyState === 'completed' ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'completed'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } }
        ]});

        const narrativeNodes = allNodes.filter(function(n) { return n.type === 'narrative' && n.id !== ent.id; });
        const narrParentName = ent.narrativeParentId ? (narrativeNodes.find(function(n) { return n.id === ent.narrativeParentId; })?.name || 'Unknown') : 'None (Root Plot)';
        
        parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '12px', backgroundColor: 'rgba(232, 168, 124, 0.05)', padding: '8px', borderRadius: '4px' }, content: [
            { type: 'text', text: `Plot Parent: ${narrParentName}`, style: { fontSize: '11px', flex: '1 1 0', color: '#e8a87c', fontWeight: 'bold' } },
            { type: 'button', text: 'Set Parent', style: { margin: 0, fontSize: '11px' }, callback: async function() {
                const pm = await openEngineModal({ id: 'ce-nparent-picker', title: 'Nest Under Plotline', size: 'medium', content: [
                    { type: 'button', text: '✕ None (Make Root Plot)', style: { width: '100%', marginBottom: '8px' }, callback: async function() { ent.narrativeParentId = null; await saveEntity(ent); pm.close(); await openEntityEditModal(ent.id); await refreshSidebar(); } },
                    ...narrativeNodes.map(function(m) { return { type: 'button', text: `📜 ${m.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() { ent.narrativeParentId = m.id; await saveEntity(ent); pm.close(); await openEntityEditModal(ent.id); await refreshSidebar(); } } as UIPart; })
                ]});
            }}
        ]});

        // --- QUEST TARGET ---
        const allEntForTarget = await loadEntityIndex();
        const qtMeta = ent.questTarget ? allEntForTarget.find(function(m) { return m.id === ent.questTarget; }) : null;
        const qtDisplay = qtMeta ? (ENTITY_TYPE_ICONS[qtMeta.type] || '●') + ' ' + qtMeta.name : 'None set';
        parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px', padding: '8px', backgroundColor: 'rgba(136,204,255,0.05)', borderRadius: '4px', border: '1px solid rgba(136,204,255,0.1)' }, content: [
            { type: 'text', text: '🎯 Quest Target:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
            { type: 'text', text: qtDisplay, style: { flex: '1 1 0', fontSize: '12px', color: qtMeta ? '#88ccff' : '#888' } },
            ...(ent.questTarget ? [{ type: 'button', text: '✕', style: { margin: 0, padding: '2px 8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() {
                const fe = await loadEntity(ent.id); if (!fe) return;
                fe.questTarget = ''; await saveEntity(fe); await openEntityEditModal(ent.id);
            } } as UIPart] : []),
            { type: 'button', text: 'Set', style: { margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.08)', color: '#88ccff' }, callback: async function() {
                await api.v1.tempStorage.set('temp:ce_qt_search', '');
                async function drawQtPicker(pm3: any) {
                    const term3 = ((await api.v1.tempStorage.getOrDefault('temp:ce_qt_search', '')) as string).toLowerCase();
                    const pickable3 = allEntForTarget.filter(function(m) { return m.id !== ent.id && (!term3 || m.name.toLowerCase().includes(term3)); });
                    const content3: UIPart[] = [
                        { type: 'textInput', placeholder: '🔍 Search all entities...', initialValue: term3, onChange: async function(v: string) { await api.v1.tempStorage.set('temp:ce_qt_search', v); await drawQtPicker(pm3); } } as UIPart,
                        ...pickable3.map(function(m) { return { type: 'button', text: (ENTITY_TYPE_ICONS[m.type] || '●') + ' ' + m.name, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() {
                            pm3.close();
                            const fe3 = await loadEntity(ent.id); if (!fe3) return;
                            fe3.questTarget = m.id; await saveEntity(fe3); await openEntityEditModal(ent.id);
                        } } as UIPart; })
                    ];
                    if (pm3 && !pm3.isClosed()) { await pm3.update({ content: content3 }); }
                    else { pm3 = await openEngineModal({ id: 'ce-qt-picker', title: 'Set Quest Target', size: 'medium', content: content3 }); }
                }
                let pm3: any = null;
                await drawQtPicker(pm3);
            } }
        ] });
    }

    // --- 1. CORE DESCRIPTION ---
    let coreParts: UIPart[] = [];
    const parentName = ent.parentId ? (allNodes.find(function(m){ return m.id === ent.parentId; })?.name || 'Unknown') : 'None (Root Level)';
    
    coreParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '12px', backgroundColor: 'rgba(255,255,255,0.05)', padding: '8px', borderRadius: '4px' }, content: [
        { type: 'text', text: 'Parent:', style: { fontSize: '12px', fontWeight: 'bold' } },
        { type: 'button', text: '❓', style: { margin: 0, padding: '2px 8px', fontSize: '11px', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.2)', opacity: '0.7' }, callback: async function() {
            await api.v1.ui.modal.open({ 
                title: 'About Parents & Children', size: 'small', 
                content: [ { type: 'text', markdown: true, text: 'The Engine uses a strict parent/child hierarchy.\n\n- **Locations**: If a Room is parented to a Building, entering the Room automatically moves the player down the tree.\n- **Items/Characters**: Assigning a location as a parent places them inside that location.' } ] 
            });
        } },
        { type: 'button', text: parentName, style: { margin: 0, fontSize: '11px', flex: '1 1 0' }, callback: async function() {
            await openPickerModal({
                title: 'Nest Under Entity',
                items: allNodes.filter(function(m) { return m.id !== ent.id; }),
                getId: function(m) { return m.id; },
                getLabel: function(m) { return m.name; },
                getIcon: function(m) { return m.icon || '\ud83d\udccd'; },
                getSublabel: function(m) { return m.type; },
                selectedId: ent.parentId || undefined,
                searchable: true,
                pinnedOptions: [
                    { id: '__none__', label: 'None (Make Root Level)', icon: '\u2715', onSelect: async function() { ent.parentId = null; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } }
                ],
                onSelect: async function(m) { ent.parentId = m.id; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); }
            });
        } }
    ] });

    if (ent.type === 'item') {
        coreParts.push({ 
            type: 'checkboxInput', 
            label: '🎒 Equipped to Parent (Targetable State)', 
            initialValue: !!(ent as any).isEquipped, 
            onChange: async function(val: boolean) { 
                const fe = await loadEntity(ent.id);
                if (!fe) return;
                
                (fe as any).isEquipped = val;
                (fe as any).equippedToCharId = (val && fe.parentId) ? fe.parentId : null;
                await saveEntity(fe); 
                
                // Cross-sync equippedItemIds to the parent
                if (fe.parentId) {
                    let parentChar = await loadCharacter(fe.parentId).catch(() => null);
                    if (parentChar) {
                        if (!parentChar.equippedItemIds) parentChar.equippedItemIds = [];
                        if (val && !parentChar.equippedItemIds.includes(fe.id)) parentChar.equippedItemIds.push(fe.id);
                        if (!val) parentChar.equippedItemIds = parentChar.equippedItemIds.filter(function(i: string) { return i !== fe.id; });
                        await saveCharacter(parentChar);
                    } else {
                        // Fallback in case items are parented to non-character entities
                        let parentEnt = await loadEntity(fe.parentId).catch(() => null);
                        if (parentEnt) {
                            if (!(parentEnt as any).equippedItemIds) (parentEnt as any).equippedItemIds = [];
                            if (val && !(parentEnt as any).equippedItemIds.includes(fe.id)) (parentEnt as any).equippedItemIds.push(fe.id);
                            if (!val) (parentEnt as any).equippedItemIds = (parentEnt as any).equippedItemIds.filter(function(i: string) { return i !== fe.id; });
                            await saveEntity(parentEnt);
                        }
                    }
                }
            } 
        });
    }

    // --- SILENT TOGGLE (top-level, no header) ---
    parts.push({ type: 'checkboxInput', label: '🔕 Silent Interaction (does not trigger AI)', initialValue: !!(ent as any).isSilent, onChange: async function(val: boolean) { (ent as any).isSilent = val; await saveEntity(ent); } });
    if (ent.type === 'location') {
        parts.push({ type: 'checkboxInput', label: '🚀 Vehicle — Can be piloted, moving all children with it', initialValue: !!(ent as any).isVehicle, onChange: async function(val: boolean) { (ent as any).isVehicle = val; await saveEntity(ent); } });
    }

    coreParts.push({ type: 'multilineTextInput', label: 'Description', initialValue: ent.description, style: { minHeight: '80px' }, onChange: async function(val) { ent.description = val; await saveEntity(ent); } });
    if (ent.type === 'location') {
        coreParts.push({ type: 'text', text: 'Brief description that exists in AN if present.', style: { fontSize: '10px', opacity: '0.6', marginTop: '2px', marginBottom: '8px' } });
        coreParts.push({ type: 'multilineTextInput', label: '🎨 Location Visuals', placeholder: 'Image tags for how this place looks (e.g. "stone tavern interior, fireplace, wooden beams"). Used by image generations specific to this location.', initialValue: (ent as any).locationVisuals || '', style: { minHeight: '50px' }, onChange: async function(val: string) { (ent as any).locationVisuals = val; await saveEntity(ent); } });
    } else if (ent.type === 'item') {
        coreParts.push({ type: 'text', text: 'Item names are listed under Equipped character in AN. Item descriptions are added to Equipped character lorebooks. Unequipping removes from lorebook.', style: { fontSize: '10px', opacity: '0.6', marginTop: '2px', marginBottom: '8px' } });
    }

    parts.push({ type: 'collapsibleSection', title: '📝 Core Details', initialCollapsed: false, storageKey: `temp:ce_core_${ent.id}`, content: coreParts });

    // [WP-1] ENTITY LOREBOOK
    if (ent.type !== 'character') {
        const loreParts: UIPart[] = [];
        const loreLinked = !!ent.lorebookEntryId;
        loreParts.push({ type: 'multilineTextInput', label: '📖 Lorebook Entry', placeholder: 'Extended info NOT already in the description — history, secrets, rules, reputation. Injected only when the name or an added key is mentioned (Sync after editing).', initialValue: ent.lorebookText || '', style: { minHeight: '70px' }, onChange: async function(val: string) { ent.lorebookText = val; await saveEntity(ent); } });
        loreParts.push({ type: 'text', text: loreLinked ? '✅ Linked — injects when a key below appears in the story.' : 'Not linked. Create an entry to inject this entity into context when its name (or a key) appears.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '6px' } });
        loreParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
            { type: 'button', text: loreLinked ? '🔄 Sync' : '➕ Create Lorebook', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { if (ent.lorebookEntryId) { await syncEntityLorebookEntry(ent.id); } else { await createLinkedEntityLorebookEntry(ent.id); } await openEntityEditModal(ent.id); } }
        ].concat(loreLinked ? [{ type: 'button', text: '🔗 Unlink', style: { margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() { await unlinkEntityLorebookEntry(ent.id); await openEntityEditModal(ent.id); } } as UIPart] : []) });
        loreParts.push({ type: 'text', text: '🔑 Keys: ' + [ent.name].concat(ent.lorebookTags || []).join(', '), style: { fontSize: '11px', opacity: '0.8', marginBottom: '4px' } });
        (ent.lorebookTags || []).forEach(function(tg, ti) {
            const captTi = ti;
            loreParts.push({ type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                { type: 'text', text: '• ' + tg, style: { fontSize: '11px', flex: '1 1 0' } },
                { type: 'button', text: '✕', style: { margin: 0, padding: '2px 6px', fontSize: '10px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() { let fe = await loadEntity(ent.id); if (!fe) return; fe.lorebookTags = (fe.lorebookTags || []).filter(function(_t, i) { return i !== captTi; }); await saveEntity(fe); if (fe.lorebookEntryId) await syncEntityLorebookEntry(fe.id, true); await openEntityEditModal(fe.id); } }
            ] });
        });
        loreParts.push({ type: 'button', text: '+ Add Key', style: { margin: '4px 0 0 0', fontSize: '11px', width: '100%' }, callback: async function() {
            let addModal: any; let pending = '';
            addModal = await openEngineModal({ id: 'ae-lore-key-add', title: 'Add Lorebook Key', size: 'small', content: [
                { type: 'text', text: 'Extra trigger word or phrase. The entity name is always a key.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '6px' } },
                { type: 'textInput', placeholder: 'e.g. the old mill', initialValue: '', onChange: function(v: string) { pending = v; } },
                { type: 'button', text: 'Add', style: { width: '100%', marginTop: '6px' }, callback: async function() { let t = (pending || '').trim(); if (t) { let fe = await loadEntity(ent.id); if (fe) { if (!fe.lorebookTags) fe.lorebookTags = []; if (fe.lorebookTags.indexOf(t) < 0) fe.lorebookTags.push(t); await saveEntity(fe); if (fe.lorebookEntryId) await syncEntityLorebookEntry(fe.id, true); } } await addModal.close(); await openEntityEditModal(ent.id); } }
            ] });
        } });
        parts.push({ type: 'collapsibleSection', title: '📖 Lorebook', initialCollapsed: true, storageKey: `temp:ce_lore_${ent.id}`, content: loreParts });
    }
    
    // --- MERGED DYNAMIC DETAILS & STATE OVERRIDES ---
    const attrParts: UIPart[] = [];
    if (ent.type === 'location' || ent.type === 'narrative' || ent.type === 'item') {
        attrParts.push({ type: 'textInput', label: 'Default State', placeholder: 'Baseline condition shown in context — changes on triggers (flooded, broken, sold) or just sets the mood', initialValue: ent.atmosphere || '', onChange: async function(val: string) { ent.atmosphere = val; await saveEntity(ent); } });
        attrParts.push({ type: 'text', text: 'This text is added below the description and can be switched out with other text by actions, such as flooding or changing ownership.', style: { fontSize: '10px', opacity: '0.6', marginTop: '2px', marginBottom: '12px' } });

        const overrideKeys = Object.keys(ent.stateDescriptions || {}).filter(function(k) { return k !== 'default'; });
        const isDefaultActive = !ent.state || ent.state === 'default';

        attrParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '10px', padding: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '6px' }, content: [
            { type: 'text', text: 'Active:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
            { type: 'button', 
              text: isDefaultActive ? '⬜ Default State' : ent.state, 
              style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: isDefaultActive ? 'rgba(255,255,255,0.05)' : 'rgba(232,168,124,0.15)', color: isDefaultActive ? undefined : '#e8a87c', border: isDefaultActive ? '1px solid rgba(255,255,255,0.1)' : '1px solid rgba(232,168,124,0.4)' }, 
              callback: async function() {
                const freshEnt = await loadEntity(ent.id); if (!freshEnt) return;
                const freshKeys = Object.keys(freshEnt.stateDescriptions || {}).filter(function(k) { return k !== 'default'; });
                const pm = await openEngineModal({ title: 'Set Active State', size: 'small', content: [
                    { type: 'button', text: '⬜ Default State', style: { width: '100%', marginBottom: '6px', textAlign: 'left', backgroundColor: (!freshEnt.state || freshEnt.state === 'default') ? 'rgba(126,200,160,0.15)' : undefined, color: (!freshEnt.state || freshEnt.state === 'default') ? '#7ec8a0' : undefined }, callback: async function() { freshEnt.state = 'default'; await saveEntity(freshEnt); pm.close(); await openEntityEditModal(ent.id); } },
                    ...freshKeys.map(function(sk) {
                        const isActive = freshEnt.state === sk;
                        return { type: 'button', text: sk, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: isActive ? 'rgba(232,168,124,0.15)' : undefined, color: isActive ? '#e8a87c' : undefined }, callback: async function() { freshEnt.state = sk; await saveEntity(freshEnt); pm.close(); await openEntityEditModal(ent.id); } } as UIPart;
                    })
                ]});
            } }
        ] });

        if (overrideKeys.length === 0) {
            attrParts.push({ type: 'text', text: 'No overrides defined. Default State is always active.', style: { fontSize: '11px', opacity: '0.45', marginBottom: '6px' } });
        }

        for (let oi = 0; oi < overrideKeys.length; oi++) {
            const sk = overrideKeys[oi];
            const sd = ent.stateDescriptions[sk] || '';
            const isActive = ent.state === sk;
            const captKey = sk;

            attrParts.push({ type: 'box', style: { padding: '8px', marginBottom: '8px', backgroundColor: isActive ? 'rgba(232,168,124,0.06)' : 'rgba(255,255,255,0.02)', borderRadius: '6px', borderLeft: isActive ? '3px solid #e8a87c' : '3px solid rgba(255,255,255,0.08)' }, content: [
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                    { type: 'textInput', 
                      placeholder: 'State name (e.g. flooded, night, ruined)...', 
                      initialValue: sk, 
                      style: { flex: '1 1 0', fontSize: '12px', fontWeight: isActive ? 'bold' : 'normal' }, 
                      onChange: async function(v: string) {
                        const newKey = v.trim();
                        if (!newKey || newKey === captKey) return;
                        const txt = ent.stateDescriptions[captKey];
                        delete ent.stateDescriptions[captKey];
                        ent.stateDescriptions[newKey] = txt || '';
                        if (ent.state === captKey) ent.state = newKey;
                        await saveEntity(ent); await openEntityEditModal(ent.id);
                      } },
                    isActive
                        ? { type: 'text', text: '● Active', style: { fontSize: '10px', color: '#e8a87c', flexShrink: '0', opacity: '0.8' } } as UIPart
                        : { type: 'button', text: 'Set Active', style: { margin: 0, fontSize: '10px', flexShrink: '0' }, callback: async function() { ent.state = captKey; await saveEntity(ent); await openEntityEditModal(ent.id); } } as UIPart,
                    { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() {
                        delete ent.stateDescriptions[captKey];
                        if (ent.state === captKey) ent.state = 'default';
                        await saveEntity(ent); await openEntityEditModal(ent.id);
                    } }
                ] },
                { type: 'multilineTextInput', 
                  placeholder: 'Atmosphere text when this state is active...', 
                  initialValue: sd, 
                  style: { minHeight: '44px', fontSize: '11px' }, 
                  onChange: async function(v: string) { ent.stateDescriptions[captKey] = v; await saveEntity(ent); } }
            ] });
        }

        attrParts.push({ type: 'button', text: '+ State Override', style: { marginTop: '2px', fontSize: '11px', width: '100%', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {
            const freshEnt = await loadEntity(ent.id); if (!freshEnt) return;
            let newKey = 'override';
            let n = 1;
            while (freshEnt.stateDescriptions[newKey]) { newKey = 'override-' + n; n++; }
            freshEnt.stateDescriptions[newKey] = '';
            await saveEntity(freshEnt); await openEntityEditModal(ent.id);
        } });
    }

    if (attrParts.length > 0) {
        parts.push({ type: 'collapsibleSection', title: '✨ Dynamic Details', initialCollapsed: true, storageKey: `temp:ce_attr_${ent.id}`, content: attrParts });
    }

    // [WP-5] 🎬 Action Studio
    const aeInsts = (((ent as any).actionInstances || []) as ActionInstance[]);
    const aeInstParts: UIPart[] = [];
    // [v0.9.17] Preload one-shot latch states so the list can show used/ready + Reset.
    let aeOneShotUsed: Record<string, boolean> = {};
    for (const _osInst of aeInsts) {
        if (_osInst.oneShot) aeOneShotUsed[_osInst.id] = await api.v1.historyStorage.getOrDefault('ae_inst_1shot_' + ent.id + '_' + _osInst.id, false) as boolean;
    }
    aeInsts.forEach(function(inst) {
        let osIsUsed = !!aeOneShotUsed[inst.id];
        let aeRowKids: UIPart[] = [
            { type: 'text', text: (inst.name || 'Action') + (inst.resolution ? ' \ud83c\udfb2' : '') + (inst.targetMode === 'player_pick' ? ' \ud83c\udfaf' : '') + (inst.oneShot ? (osIsUsed ? ' \u2014 \u2713 used' : ' \u2014 \u26ab one-shot') : ''), style: { flex: '1', fontSize: '12px', fontWeight: 'bold', opacity: (inst.oneShot && osIsUsed) ? '0.55' : '1' } },
            { type: 'button', text: '\u25b6 Test', style: { margin: 0, padding: '2px 6px', fontSize: '10px', backgroundColor: 'rgba(126,200,160,0.2)' }, callback: async function() {
                let feR = await loadEntity(ent.id); let fcR = await loadConfig(); if (!feR) return;
                let fiR = (((feR as any).actionInstances || []) as ActionInstance[]).find(function(x) { return x.id === inst.id; });
                if (!fiR) return;
                await runActionInstance(fiR, feR, fcR, {});
            } }
        ];
        if (inst.oneShot) {
            aeRowKids.push({ type: 'button', text: osIsUsed ? '\u21ba Reset' : 'ready', style: { margin: 0, padding: '2px 6px', fontSize: '10px', backgroundColor: osIsUsed ? 'rgba(232,168,124,0.22)' : 'rgba(255,255,255,0.05)', opacity: osIsUsed ? '1' : '0.55' }, callback: async function() {
                if (!osIsUsed) { api.v1.ui.toast('One-shot hasn\u2019t fired yet.', { type: 'info', autoClose: 1400 }); return; }
                await api.v1.historyStorage.set('ae_inst_1shot_' + ent.id + '_' + inst.id, false);
                api.v1.ui.toast('\u21ba Reset: ' + (inst.name || 'Action'), { type: 'success', autoClose: 1500 });
                await openEntityEditModal(ent.id);
            } });
        }
        aeRowKids.push({ type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px', color: '#ff6b6b' }, callback: async function() {
            let feD = await loadEntity(ent.id); if (!feD) return;
            (feD as any).actionInstances = (((feD as any).actionInstances || []) as ActionInstance[]).filter(function(x) { return x.id !== inst.id; });
            await saveEntity(feD); await openEntityEditModal(ent.id);
        } });
        aeInstParts.push({ type: 'row', spacing: 'space-between', alignment: 'center', style: { gap: '6px', marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.08)', paddingBottom: '4px' }, content: aeRowKids });
    });
    if (aeInsts.length === 0) aeInstParts.push({ type: 'text', text: 'No actions yet. Add from Library or create a new one.', style: { fontSize: '11px', opacity: '0.45' } });
    
    aeInstParts.push({ type: 'row', style: { gap: '6px', marginTop: '6px' }, content: [
        { type: 'button', text: '\ud83d\udcda + Action Library', style: { flex: '1 1 0', fontSize: '11px', margin: 0, backgroundColor: 'rgba(136,204,255,0.12)' }, callback: async function() {
            let lc = await loadConfig();
            let templates = (((lc as any).actionTemplates || []) as ActionInstance[]);
            let applicable = templates.filter(function(t) { return !t.appliesTo || !t.appliesTo.length || t.appliesTo.indexOf(ent.type) >= 0; });
            if (!applicable.length) { api.v1.ui.toast('No library actions yet — create one in the Actions tab.', { type: 'info' }); return; }
            let pickItems: PickItem[] = applicable.map(function(t) { return { id: t.id, label: (t.name || 'Action') + (((t as any).tags && (t as any).tags.length) ? '  🏷 ' + (t as any).tags.join(', ') : '') }; });
            await openSearchPicker('Copy from Action Library', pickItems, async function(tid) {
                let t = applicable.find(function(x) { return x.id === tid; }); if (!t) return;
                let feC = await loadEntity(ent.id); if (!feC) return;
                let copy = JSON.parse(JSON.stringify(t)) as ActionInstance;
                copy.id = generateId();
                copy.templateId = t.id;
                (copy.conditions || []).forEach(function(r) { r.id = generateId(); });
                (copy.successEffects || []).forEach(function(r) { r.id = generateId(); });
                (copy.failureEffects || []).forEach(function(r) { r.id = generateId(); });
                ((copy as any).alwaysEffects || []).forEach(function(r: AERule) { r.id = generateId(); });
                if (!(feC as any).actionInstances) (feC as any).actionInstances = [];
                (feC as any).actionInstances.push(copy);
                await saveEntity(feC); await openEntityEditModal(ent.id);
            });
        } }
    ] });

    // [v0.9.86] Tag Subscriptions — live-resolved from library; no copies made.
    // Hides _system / _travel tags (internal plumbing the user shouldn't touch).
    const _tsAllTags: string[] = [];
    const _tsCfg = cfg;
    const _tsTplsAll = ((_tsCfg.actionTemplates || []) as ActionInstance[]);
    const _tsApplicable = _tsTplsAll.filter(function(t) {
        if (t.appliesTo && t.appliesTo.length && t.appliesTo.indexOf(ent.type) < 0) return false;
        return true;
    });
    for (const _tsTpl of _tsApplicable) {
        for (const _tsTag of ((_tsTpl as any).tags || [])) {
            if (typeof _tsTag === 'string' && !_tsTag.startsWith('_') && _tsAllTags.indexOf(_tsTag) < 0) {
                _tsAllTags.push(_tsTag);
            }
        }
    }
    _tsAllTags.sort();

    if (_tsAllTags.length > 0) {
        const _tsSubs: string[] = (ent as any).tagSubscriptions || [];
        const _tsRows: UIPart[] = [
            { type: 'text', text: 'Check a tag to auto-include all matching library actions on this entity. Actions are resolved live — no copy is made.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '6px' } }
        ];
        for (const _tsTag of _tsAllTags) {
            const captTag = _tsTag;
            const matchCount = _tsApplicable.filter(function(t) { return ((t as any).tags || []).indexOf(captTag) >= 0; }).length;
            const isSubbed = _tsSubs.indexOf(captTag) >= 0;
            _tsRows.push({
                type: 'checkboxInput',
                label: captTag + '  (' + matchCount + ' action' + (matchCount === 1 ? '' : 's') + ')',
                initialValue: isSubbed,
                onChange: async function(v: boolean) {
                    let _tsFreshEnt = await loadEntity(ent.id); if (!_tsFreshEnt) return;
                    let _tsArr: string[] = ((_tsFreshEnt as any).tagSubscriptions || []).slice();
                    if (v) { if (_tsArr.indexOf(captTag) < 0) _tsArr.push(captTag); }
                    else   { _tsArr = _tsArr.filter(function(x) { return x !== captTag; }); }
                    (_tsFreshEnt as any).tagSubscriptions = _tsArr;
                    await saveEntity(_tsFreshEnt);
                    await openEntityEditModal(ent.id);
                }
            } as UIPart);
        }
        aeInstParts.push({ type: 'collapsibleSection', title: '\ud83c\udff7 Tag Subscriptions (' + _tsSubs.filter(function(s) { return _tsAllTags.indexOf(s) >= 0; }).length + ' active)', initialCollapsed: true, storageKey: 'temp:ce_tagsubs_' + ent.id, content: _tsRows });
    }
    
    parts.push({ type: 'collapsibleSection', title: '\ud83c\udfac Action Studio (' + aeInsts.length + ')', initialCollapsed: true, storageKey: 'temp:ce_actinst_' + ent.id, content: aeInstParts });

    // --- 4. CONNECTIONS ---
    const implicitRows: UIPart[] = [];
    if (ent.parentId) { 
        const pMeta = allNodes.find(function(m) { return m.id === ent.parentId; }); 
        if (pMeta) implicitRows.push({ type: 'text', text: `↑ Go back to ${pMeta.name} (Parent)`, style: { fontSize: '11px', opacity: '0.6', marginLeft: '8px', marginBottom: '2px' } }); 
    }
    const children = allNodes.filter(function(m) { return m.parentId === ent.id; });
    for (const child of children) {
        const captChild = child;
        const childEntForGate = await loadEntity(child.id);
        const childIsGated = !!(childEntForGate as any)?.gated;
        // [v1.6.3 LOCK-SELF] The lock control now lives on each location's OWN modal
        // (self-lock toggle at the top of this section). Here we keep only a read-only
        // indicator so the parent view still flags which children are currently locked.
        implicitRows.push({ type: 'text', text: (childIsGated ? '🔒 ' : '↓ ') + 'Enter ' + captChild.name + ' (Child)' + (childIsGated ? ' — locked' : ''), style: { fontSize: '11px', opacity: '0.7', marginLeft: '8px', marginBottom: '2px' } });
    }
    
    let connParts: UIPart[] = [
        // [v1.6.3 LOCK-SELF] Self-lock lives on the location itself and gates travel in
        // BOTH directions (the entity_locked guard checks the target's own .gated, so a
        // locked location can't be entered from a parent, child, or sibling).
        ...(ent.type === 'location' ? [{ type: 'row', alignment: 'center', style: { gap: '8px', marginTop: '2px', marginBottom: '8px', padding: '6px 8px', borderRadius: '6px', backgroundColor: (ent as any).gated ? 'rgba(255,85,85,0.10)' : 'rgba(255,255,255,0.03)', border: '1px solid ' + ((ent as any).gated ? 'rgba(255,85,85,0.35)' : 'rgba(255,255,255,0.12)') }, content: [
            { type: 'text', text: ((ent as any).gated ? '🔒' : '🔓') + ' Lock this location', style: { fontSize: '12px', fontWeight: 'bold', flex: '1 1 0' } },
            { type: 'checkboxInput', label: 'Locked (blocks travel in & out)', initialValue: !!(ent as any).gated, onChange: async function(v: boolean) {
                const slfEnt = await loadEntity(ent.id); if (!slfEnt) return;
                (slfEnt as any).gated = v; await saveEntity(slfEnt); queueSceneStateBroadcast(); await openEntityEditModal(ent.id);
            } }
        ] } as UIPart] : []),
        { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '4px', marginBottom: '2px' }, content: [
            { type: 'button', text: ent.entryActionId ? '⚙ Entry Action' : '+ Entry Action', style: { flex: '1 1 0', margin: 0, fontSize: '10px', padding: '3px 6px', backgroundColor: ent.entryActionId ? 'rgba(136,204,255,0.1)' : 'transparent', border: '1px solid rgba(255,255,255,0.18)' }, callback: async function() {
                let eaCEnt = await loadEntity(ent.id); if (!eaCEnt) return;
                let eaCfg  = await loadConfig();
                let eaId = (eaCEnt as any).entryActionId as string | undefined;
                if (!eaId || !(eaCfg.actionTemplates || []).find(function(t: any) { return t.id === eaId; })) {
                    eaId = generateId();
                    let sysDef = (eaCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                    const eaNew: any = sysDef ? JSON.parse(JSON.stringify(sysDef)) : { id: eaId, name: 'Enter: ' + ent.name, tags: ['_travel'], conditions: [], successEffects: [], failureEffects: [], alwaysEffects: [], hidden: true };
                    eaNew.id = eaId;
                    eaNew.name = 'Enter: ' + ent.name;
                    eaNew.tags = ['_travel'];
                    eaNew.hidden = true;
                    if (!eaCfg.actionTemplates) eaCfg.actionTemplates = [];
                    eaCfg.actionTemplates.push(eaNew);
                    await saveConfig(eaCfg);
                    (eaCEnt as any).entryActionId = eaId;
                    await saveEntity(eaCEnt);
                }
                await openActionBuilderModal(eaId);
            } },
            ...(ent.entryActionId ? [{ type: 'button', iconId: 'trash', style: { margin: 0, padding: '3px 6px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.2)' }, callback: async function() {
                let rEnt = await loadEntity(ent.id); if (!rEnt) return;
                let oldId = (rEnt as any).entryActionId;
                (rEnt as any).entryActionId = undefined;
                await saveEntity(rEnt);
                if (oldId) {
                    let ecfg = await loadConfig();
                    if (ecfg.actionTemplates) {
                        ecfg.actionTemplates = ecfg.actionTemplates.filter(function(t: any) { return t.id !== oldId; });
                        await saveConfig(ecfg);
                    }
                }
                await openEntityEditModal(ent.id);
            } } as UIPart] : [])
        ] },
        { type: 'text', text: 'Resource required to travel downward in map to location', style: { fontSize: '10px', opacity: '0.6', marginLeft: '6px', marginBottom: '10px' } },
        { type: 'box', style: { marginBottom: '12px', padding: '6px', backgroundColor: 'rgba(255,255,255,0.02)', borderRadius: '4px' }, content: [
            { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Implicit Tree Connections:', style: { fontSize: '11px', fontWeight: 'bold' } },
                { type: 'button', text: '❓', style: { margin: 0, padding: '2px 6px', fontSize: '10px', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.2)', opacity: '0.7' }, callback: async function() {
                    await api.v1.ui.modal.open({ title: 'Implicit vs Explicit Connections', size: 'medium', content: [ { type: 'text', markdown: true, text: 'The engine automatically creates **Implicit** "Up" and "Down" connections based on parents and children (e.g., moving from the House down to the Bedroom).\n\n**Explicit** Connections are custom travel routes to entities that aren\'t strictly parents/children (e.g., a teleporter or road).' } ] });
                } }
            ] },
            ...(implicitRows.length > 0 ? implicitRows : [{ type: 'text', text: 'No parent or children.', style: { fontSize: '11px', opacity: '0.4', marginLeft: '8px', marginBottom: '2px' } } as UIPart])
        ]}
    ];

    ent.connectedEntityIds.filter(Boolean).forEach(function(conn, i) {
        const targetMeta = allNodes.find(function(m) { return m.id === conn.targetId; });
        const targetName = targetMeta?.name || `Unknown (${conn.targetId.substring(0, 8)})`; 
        
        connParts.push({ type: 'box', style: { padding: '8px', backgroundColor: 'rgba(255,255,255,0.05)', marginBottom: '4px' }, content: [
            { type: 'textInput', label: `→ ${targetName} Label`, initialValue: conn.label, placeholder: 'e.g. "Head to the market"', onChange: async function(v: string) { ent.connectedEntityIds[i].label = v; await saveEntity(ent); } },
            { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '4px', marginBottom: '4px' }, content: [
                { type: 'checkboxInput', label: 'Requires Vehicle', initialValue: !!conn.requiresVehicle, onChange: async function(val: boolean) { let fe = await loadEntity(ent.id); if (!fe) return; fe.connectedEntityIds[i].requiresVehicle = val; await saveEntity(fe); } }
            ] },
            
            { type: 'checkboxInput', label: '🔕 Silent Travel (No text/AI gen)', initialValue: !!conn.isSilent, onChange: async function(val) { ent.connectedEntityIds[i].isSilent = val; await saveEntity(ent); } },

            { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '6px' }, content: [
                { type: 'button', text: conn.travelActionId ? '⚙ Travel Action' : '+ Travel Action', style: { flex: '1 1 0', margin: 0, fontSize: '10px', padding: '3px 6px', backgroundColor: conn.travelActionId ? 'rgba(136,204,255,0.1)' : 'transparent', border: '1px solid rgba(255,255,255,0.18)' }, callback: async function() {
                    let taCEnt = await loadEntity(ent.id); if (!taCEnt) return;
                    let taCfg  = await loadConfig();
                    let taConnIdx = taCEnt.connectedEntityIds.findIndex(function(c) { return c.targetId === conn.targetId; });
                    if (taConnIdx < 0) return;
                    let taId = (taCEnt.connectedEntityIds[taConnIdx] as any).travelActionId as string | undefined;
                    if (!taId || !(taCfg.actionTemplates || []).find(function(t: any) { return t.id === taId; })) {
                        taId = generateId();
                        let sysDef = (taCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });
                        const taNew: any = sysDef ? JSON.parse(JSON.stringify(sysDef)) : { id: taId, name: 'Travel: ' + targetName, tags: ['_travel'], conditions: [], successEffects: [], failureEffects: [], alwaysEffects: [], hidden: true };
                        taNew.id = taId;
                        taNew.name = 'Travel: ' + targetName;
                        taNew.tags = ['_travel'];
                        taNew.hidden = true;
                        if (!taCfg.actionTemplates) taCfg.actionTemplates = [];
                        taCfg.actionTemplates.push(taNew);
                        await saveConfig(taCfg);
                        (taCEnt.connectedEntityIds[taConnIdx] as any).travelActionId = taId;
                        await saveEntity(taCEnt);
                    }
                    await openActionBuilderModal(taId);
                } },
                ...(conn.travelActionId ? [{ type: 'button', iconId: 'trash', style: { margin: 0, padding: '3px 6px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.2)' }, callback: async function() {
                    let rCEnt = await loadEntity(ent.id); if (!rCEnt) return;
                    let rConnIdx = rCEnt.connectedEntityIds.findIndex(function(c) { return c.targetId === conn.targetId; });
                    if (rConnIdx >= 0) {
                        let oldId = (rCEnt.connectedEntityIds[rConnIdx] as any).travelActionId;
                        (rCEnt.connectedEntityIds[rConnIdx] as any).travelActionId = undefined;
                        await saveEntity(rCEnt);
                        if (oldId) {
                            let ecfg2 = await loadConfig();
                            if (ecfg2.actionTemplates) {
                                ecfg2.actionTemplates = ecfg2.actionTemplates.filter(function(t: any) { return t.id !== oldId; });
                                await saveConfig(ecfg2);
                            }
                        }
                    }
                    await openEntityEditModal(ent.id);
                } } as UIPart] : []),
                { type: 'button', text: !!(targetMeta as any)?.gated ? '🔒 Locked' : '🔓 Open', style: { margin: 0, fontSize: '10px', padding: '3px 8px', backgroundColor: !!(targetMeta as any)?.gated ? 'rgba(255,85,85,0.12)' : 'transparent', border: '1px solid rgba(255,255,255,0.18)' }, callback: async function() {
                    let glEnt = await loadEntity(conn.targetId); if (!glEnt) return;
                    (glEnt as any).gated = !(glEnt as any).gated; await saveEntity(glEnt); await openEntityEditModal(ent.id);
                } }
            ] },

            { type: 'button', text: 'Remove', style: { color: '#ff6b6b', marginTop: '4px' }, callback: async function() { ent.connectedEntityIds.splice(i, 1); await saveEntity(ent); await openEntityEditModal(ent.id); } }
        ] });
    });

    const existingTargetIds = new Set(ent.connectedEntityIds.map(function(c) { return c.targetId; }));
    const pickableConns = allNodes.filter(function(m) { return m.id !== ent.id && !existingTargetIds.has(m.id); });
    if (pickableConns.length > 0) {
        connParts.push({ type: 'button', text: '+ Add Explicit Connection', style: { marginTop: '6px', fontSize: '11px' }, callback: async function() {
            const pickerModal = await openEngineModal({ id: 'ce-conn-picker', size: 'medium', title: 'Pick Destination', content: [
                ...pickableConns.map(function(m) { return { type: 'button', text: `📍 ${m.name}`, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() { pickerModal.close(); ent.connectedEntityIds.push({ targetId: m.id, label: `Go to ${m.name}`, resourceCost: 0 }); await saveEntity(ent); await openEntityEditModal(ent.id); } } as UIPart; })
            ] });
        } });
    }
    parts.push({ type: 'collapsibleSection', title: `🔗 Connections (${ent.connectedEntityIds.length})`, initialCollapsed: true, storageKey: `temp:ce_conn_${ent.id}`, content: connParts });
    
    // --- 5b. SKILL BONUSES (items only) ---
    if (ent.type === 'item') {
        const bonuses = ent.skillBonuses || [];
        const bonusParts: UIPart[] = [];

        bonusParts.push({ type: 'text', text: 'When equipped, adds these modifiers to matching skill rolls.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });

        if (bonuses.length === 0) {
            bonusParts.push({ type: 'text', text: 'No bonuses defined.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '6px' } });
        }

        for (let bi = 0; bi < bonuses.length; bi++) {
            const bonus = bonuses[bi];
            const captBi = bi;
            const matchedSkill = skillOptions.find(function(s) { return s.tag === bonus.skillTag; });
            const skillLabel = matchedSkill ? matchedSkill.name : (bonus.skillTag || 'Pick Skill...');

            bonusParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                { type: 'button', text: skillLabel, style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {
                    const pm = await openEngineModal({ title: 'Select Skill', size: 'small', content: [
                        { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() {
                            const fe = await loadEntity(ent.id); if (!fe) return;
                            fe.skillBonuses[captBi].skillTag = ''; await saveEntity(fe); pm.close(); await openEntityEditModal(ent.id);
                        } },
                        ...skillOptions.map(function(opt) {
                            return { type: 'button', text: opt.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: bonus.skillTag === opt.tag ? 'rgba(136,204,255,0.15)' : undefined, color: bonus.skillTag === opt.tag ? '#88ccff' : undefined }, callback: async function() {
                                const fe = await loadEntity(ent.id); if (!fe) return;
                                fe.skillBonuses[captBi].skillTag = opt.tag; await saveEntity(fe); pm.close(); await openEntityEditModal(ent.id);
                            } } as UIPart;
                        })
                    ]});
                } },
                { type: 'text', text: 'Mod:', style: { fontSize: '11px', opacity: '0.6', flexShrink: '0' } },
                { type: 'textInput', initialValue: bonus.modifier.toString(), placeholder: '±0', style: { width: '50px', textAlign: 'center' }, onChange: async function(v: string) {
                    const fe = await loadEntity(ent.id); if (!fe) return;
                    const num = parseInt(v, 10);
                    fe.skillBonuses[captBi].modifier = isNaN(num) ? 0 : num;
                    await saveEntity(fe);
                } },
                { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() {
                    const fe = await loadEntity(ent.id); if (!fe) return;
                    fe.skillBonuses.splice(captBi, 1); await saveEntity(fe); await openEntityEditModal(ent.id);
                } }
            ] });
        }

        bonusParts.push({ type: 'button', text: '+ Add Skill Bonus', style: { marginTop: '2px', fontSize: '11px', width: '100%', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {
            const fe = await loadEntity(ent.id); if (!fe) return;
            if (!fe.skillBonuses) fe.skillBonuses = [];
            fe.skillBonuses.push({ skillTag: '', modifier: 1 });
            await saveEntity(fe); await openEntityEditModal(ent.id);
        } });

        parts.push({ type: 'collapsibleSection', title: '⚔️ Skill Bonuses (' + bonuses.length + ')', initialCollapsed: bonuses.length === 0, storageKey: 'temp:ce_bonus_' + ent.id, content: bonusParts });
    }
    // --- 6. ENCOUNTERS --- [v0.9.25 E4] Removed — replaced by action system
    // --- 6. CHARACTERS ---
    const charIdx = await loadIndex();
    const chars = await loadAllCharacters();
    const presentChars = chars.filter(function(c) { return c.currentLocationId === ent.id; });
    let charParts: UIPart[] = [];
    // --- Present characters (read-only, auto-synced) ---
    charParts.push({ type: 'text', text: 'Present (auto-synced from entity tree)', style: { fontWeight: 'bold', fontSize: '11px', opacity: '0.6', marginBottom: '4px' } });
    if (presentChars.length === 0) {
        charParts.push({ type: 'text', text: 'None currently.', style: { fontSize: '11px', opacity: '0.4' } });
    } else {
        presentChars.forEach(function(c) { charParts.push({ type: 'text', text: '• ' + c.name, style: { fontSize: '12px', marginLeft: '8px', marginBottom: '2px' } }); });
    }

    // --- Knowledge string (canonical truth for this entity) ---
    charParts.push({ type: 'text', text: 'Knowledge String', style: { fontWeight: 'bold', fontSize: '12px', marginTop: '12px', marginBottom: '4px' } });
    charParts.push({ type: 'text', text: 'This is the master knowledge text synced to any aware characters. Edit freely, then re-sync.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });
    charParts.push({ type: 'multilineTextInput', storageKey: 'temp:ce_ks_' + ent.id,
        initialValue: ent.knowledgeString || '',
        onChange: async function(v: string) { const fe = await loadEntity(ent.id); if (fe) { fe.knowledgeString = v; await saveEntity(fe); } }
    });
    charParts.push({ type: 'row', style: { gap: '6px', marginTop: '6px' }, content: [
        { type: 'button', text: '⟳ Build from Entity', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.05)' }, disabledWhileCallbackRunning: true, callback: async function() {
            const built = await buildEntityKnowledgeString(ent.id);
            const fe = await loadEntity(ent.id); if (!fe) return;
            fe.knowledgeString = built; await saveEntity(fe);
            api.v1.ui.toast('Knowledge string built.', { type: 'success', autoClose: 2000 });
            await openEntityEditModal(ent.id);
        } },
        { type: 'button', text: '↺ Sync to All Aware', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.06)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
            const fe = await loadEntity(ent.id); if (!fe) return;
            await syncEntityKnowledgeToAwareChars(fe);
            api.v1.ui.toast('Synced to ' + (fe.awareCharacterIds || []).length + ' character(s).', { type: 'success', autoClose: 2500 });
        } }
    ] });

    // --- Aware characters (knowledge recipients) ---
    charParts.push({ type: 'text', text: 'Aware Characters (receive synced knowledge)', style: { fontWeight: 'bold', fontSize: '12px', marginTop: '12px', marginBottom: '4px' } });
    // Search filter
    const awareSearchKey = 'temp:ce_aware_search_' + ent.id;
    const awareTerm = ((await api.v1.tempStorage.getOrDefault(awareSearchKey, '')) as string).toLowerCase();
    if (ent.awareCharacterIds.length > 0) {
        charParts.push({ type: 'textInput', placeholder: '🔍 Filter aware characters...', initialValue: awareTerm, onChange: async function(v: string) { await api.v1.tempStorage.set(awareSearchKey, v); await openEntityEditModal(ent.id); } });
    }
    const filteredAware = ent.awareCharacterIds.filter(Boolean).filter(function(charId) {
        if (!awareTerm) return true;
        const cMeta = charIdx.find(function(m) { return m.id === charId; });
        return (cMeta?.name || '').toLowerCase().includes(awareTerm);
    });
    if (filteredAware.length === 0 && ent.awareCharacterIds.length === 0) {
        charParts.push({ type: 'text', text: 'No aware characters yet.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '4px' } });
    }
    filteredAware.forEach(function(charId) {
        const cMeta = charIdx.find(function(m) { return m.id === charId; });
        charParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
            { type: 'text', text: cMeta?.name || 'Unknown', style: { flex: '1 1 0', fontSize: '12px' } },
            { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() {
                const fe = await loadEntity(ent.id); if (!fe) return;
                fe.awareCharacterIds = fe.awareCharacterIds.filter(function(id) { return id !== charId; });
                await saveEntity(fe); await openEntityEditModal(ent.id);
            } }
        ] });
    });
    // Add aware character — searchable picker
    charParts.push({ type: 'button', text: '+ Add Aware Character', style: { fontSize: '11px', marginTop: '4px', width: '100%' }, callback: async function() {
        await api.v1.tempStorage.set('temp:ce_aap_search', '');
        async function drawAwareAddPicker(pm2: any) {
            const term2 = ((await api.v1.tempStorage.getOrDefault('temp:ce_aap_search', '')) as string).toLowerCase();
            const pickable2 = charIdx.filter(function(m) { return !ent.awareCharacterIds.includes(m.id) && (!term2 || m.name.toLowerCase().includes(term2)); });
            const content2: UIPart[] = [
                { type: 'textInput', placeholder: '🔍 Search characters...', initialValue: term2, onChange: async function(v: string) { await api.v1.tempStorage.set('temp:ce_aap_search', v); await drawAwareAddPicker(pm2); } } as UIPart,
                ...pickable2.map(function(m) { return { type: 'button', text: m.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() {
                    pm2.close();
                    const fe2 = await loadEntity(ent.id); if (!fe2) return;
                    if (!fe2.awareCharacterIds.includes(m.id)) fe2.awareCharacterIds.push(m.id);
                    // Auto-build string if empty
                    if (!fe2.knowledgeString || !fe2.knowledgeString.trim()) {
                        fe2.knowledgeString = await buildEntityKnowledgeString(fe2.id);
                    }
                    await saveEntity(fe2);
                    // Push snapshot to the character
                    const char2 = await loadCharacter(m.id); if (!char2) return;
                    if (!char2.knownEntities) char2.knownEntities = [];
                    const existing2 = char2.knownEntities.find(function(e) { return e.entityId === fe2.id; });
                    if (!existing2) {
                        char2.knownEntities.push({ id: generateId(), entityId: fe2.id, entityName: fe2.name, snapshot: fe2.knowledgeString, addedAt: Date.now() });
                    }
                    await saveCharacter(char2);
                    await openEntityEditModal(ent.id);
                } } as UIPart; })
            ];
            if (pm2 && !pm2.isClosed()) { await pm2.update({ content: content2 }); }
            else { pm2 = await openEngineModal({ id: 'ce-aware-add-picker', title: 'Add Aware Character', size: 'medium', content: content2 }); }
        }
        let pm2: any = null;
        await drawAwareAddPicker(pm2);
    } });

    parts.push({ type: 'collapsibleSection', title: '👥 Characters & Knowledge', initialCollapsed: true, storageKey: `temp:ce_chars_${ent.id}`, content: charParts });
    
    // --- 7. EXPORT / DELETE ---
    parts.push({ type: 'row', style: { gap: '8px', marginTop: '16px' }, content: [
        { type: 'button', text: 'Delete Node', style: { flex: '1 1 0', margin: 0, fontSize: '11px', color: '#ff6b6b' }, callback: async function() { if (typeof confirmDeleteEntity === 'function') { await confirmDeleteEntity(ent.id, ent.name); } editingEntityId = null; } }
    ] });

    await openEngineModal({ id: 'entity-edit-modal', title: `Edit: ${ent.name}`, size: 'large', content: parts });
}

// ============================================================================
// ENTITY DELETION & GRAVEYARD PROTECTION
// ============================================================================


async function confirmDeleteEntity(id: string, name: string): Promise<void> {
    const pm = await openEngineModal({
        title: 'Confirm Deletion',
        size: 'small',
        content: [
            { type: 'text', text: `Are you sure you want to remove ${name}?`, style: { marginBottom: '12px' } },
            
            // THE GRAVEYARD SHUNT
            { type: 'button', text: '⚰️ Send to Graveyard (Keep data, hide from play)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,136,136,0.2)' }, callback: async function() {
                const allEnts = await loadEntityIndex();
                let gyMeta = allEnts.find(function(e) { return e.name === 'Graveyard' && e.type === 'location'; });
                
                // Forge the Graveyard if it doesn't exist
                if (!gyMeta) {
                    const gy = typeof makeDefaultEntity === 'function' ? makeDefaultEntity('Graveyard') : { id: generateId(), name: 'Graveyard' };
                    gy.type = 'location';
                    gy.parentId = null;
                    await saveEntity(gy);
                    gyMeta = { id: gy.id, name: gy.name, type: gy.type, parentId: null };
                }
                
                const ent = await loadEntity(id);
                if (ent) {
                    ent.parentId = gyMeta.id;
                    await saveEntity(ent);
                }
                
                pm.close();
                if (typeof editingEntityId !== 'undefined' && editingEntityId === id) await openEntityEditModal(id);
                await refreshSidebar();
            }},
            
            // THE ORPHAN PROTECTOR
            { type: 'button', text: '🗑️ Permanently Delete', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b', backgroundColor: 'rgba(255,107,107,0.1)' }, callback: async function() {
                const allEnts = await loadEntityIndex();
                const children = allEnts.filter(function(e) { return e.parentId === id; });
                
                // Failsafe: Shunt all internal items/characters back to Root
                for (const childMeta of children) {
                    const child = await loadEntity(childMeta.id);
                    if (child) {
                        child.parentId = null; 
                        await saveEntity(child);
                    }
                }
                
                // Now permanently delete the target node
                if (typeof deleteEntity === 'function') await deleteEntity(id);
                pm.close();
                
                // Close modal if deleting the one we are actively editing
                if (typeof editingEntityId !== 'undefined' && editingEntityId === id) {
                    const em = await openEngineModal({id: 'entity-edit-modal', title: 'Closed', content: []});
                    em.close();
                }
                await refreshSidebar();
            }},
            { type: 'button', text: 'Cancel', style: { width: '100%' }, callback: async function() { pm.close(); } }
        ]
    });
}

// ============================================================================
// SECTION 23 — WORLDBUILDING MODAL (New Setup Hub)
// ============================================================================

var worldbuildingModalHandle: any = null;

async function refreshWorldbuildingModal(): Promise<void> {
    if (!worldbuildingModalHandle || worldbuildingModalHandle.isClosed()) return;
    await worldbuildingModalHandle.update({ content: await buildWorldbuildingContent() });
}

// ── World-Build Wizard: engine-native interface ──────────────────────────
// [vNEXT] Engine-only interface for the wizard (the bridge HUD will mirror every
// function later). Tabbed so future groups (Characters, Factions, Species, ...)
// slot in without the modal growing unmanageable. Data lives in storyStorage
// (chats) and config (sections/project fields); the modal reloads fresh data on
// every redraw rather than holding a snapshot.
// [v0.9.8.2] iconId replaces emoji labels; tab order: setup, chats, memory,
// species, factions, locations, characters, intro, drama.
var WIZARD_TABS: { id: string; label: string; iconId: string }[] = [
    { id: 'setup',      label: 'Setup',      iconId: 'settings'        },
    { id: 'chats',      label: 'Chats',      iconId: 'message-square'  },
    { id: 'memory',     label: 'Memory',     iconId: 'file-text'       },
    { id: 'species',    label: 'Species',    iconId: 'activity'        },
    { id: 'factions',   label: 'Factions',   iconId: 'shield'          },
    { id: 'bestiary',   label: 'Bestiary',   iconId: 'target'          },
    { id: 'locations',  label: 'Locations',  iconId: 'map-pin'         },
    { id: 'characters', label: 'Characters', iconId: 'user'            },
    { id: 'intro',      label: 'Intro',      iconId: 'film'            },
    { id: 'drama',      label: 'Drama',      iconId: 'zap'             },
    { id: 'help',       label: 'Help',       iconId: 'help'            }
];

// [v1.6.1] All-Schedules modal — every character's daily timetable in one place,
// now read/write. Was read-only (see prior comment below); this reuses the exact
// same row mechanics as each character's own Daily Schedule section (same
// loadCharacter/saveCharacter/openPickerModal calls) so both surfaces stay on one
// source of truth — nothing here is a separate copy of the schedule data.
// One pass over the character index + one location-index load per render; nothing
// here runs unless the user opens it, so it adds zero runtime scan cost.
async function openAllSchedulesModal(): Promise<void> {
    let asHandle: any = null;

    async function renderAll() {
        let asParts: UIPart[] = [];
        try {
            let asChars = await loadAllCharacters();
            let asEntIdx = await loadEntityIndex();
            let asLocOpts = asEntIdx.filter(function(e) { return e.type === 'location'; });
            let asLocName: Record<string, string> = {};
            asLocOpts.forEach(function(e) { asLocName[e.id] = e.name; });

            asParts.push({ type: 'text', text: 'Every character\u2019s daily timetable. Schedules position offstage NPCs by hour of day while the player is elsewhere. Edit directly here or from a character\u2019s own card (Daily Schedule) \u2014 both read and write the same data.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px', lineHeight: '1.4' } } as UIPart);

            asParts.push({ type: 'button', text: '\ud83d\udd04 Process All Schedules Now', style: { width: '100%', marginBottom: '10px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)' }, callback: async function() {
                try { await resolveSchedules(); await refreshSidebar(); await renderAll(); }
                catch (e) { api.v1.error('[AE:schedules] manual resolve error:', e); }
            } } as UIPart);

            if (asChars.length === 0) {
                asParts.push({ type: 'text', text: 'No characters yet.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic' } } as UIPart);
            } else {
                // Sort: enabled schedules first, then has-rows-but-disabled, then empty, then by name.
                let asSorted = asChars.slice().sort(function(a, b) {
                    let aRank = a.scheduleEnabled ? 0 : ((a.schedule && a.schedule.length) ? 1 : 2);
                    let bRank = b.scheduleEnabled ? 0 : ((b.schedule && b.schedule.length) ? 1 : 2);
                    if (aRank !== bRank) return aRank - bRank;
                    return String(a.name || '').localeCompare(String(b.name || ''));
                });

                for (let c of asSorted) {
                    let cCharId = c.id;
                    let statusDot = c.scheduleEnabled ? '\u2705' : '\u26ab';
                    let rowCount = (c.schedule || []).length;
                    let sectionTitle = statusDot + ' ' + (c.name || 'Unnamed') + (rowCount ? ' (' + rowCount + ')' : '');

                    asParts.push({ type: 'collapsibleSection', title: sectionTitle, initialCollapsed: true, storageKey: `temp:as_sched_${cCharId}`, content: await (async function() {
                        let secParts: UIPart[] = [];
                        let secRows = (c.schedule || []);

                        secParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [
                            { type: 'text', text: c.scheduleEnabled ? '\u2705 Schedule Active' : '\u26ab Schedule Inactive', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: c.scheduleEnabled ? '#7ec8a0' : undefined } },
                            { type: 'button', text: c.scheduleEnabled ? 'Disable' : 'Enable', style: { margin: 0, fontSize: '11px' }, callback: async function() {
                                let f = await loadCharacter(cCharId); if (!f) return;
                                f.scheduleEnabled = !f.scheduleEnabled;
                                await saveCharacter(f); await renderAll();
                            } }
                        ] } as UIPart);

                        if (secRows.length === 0) {
                            secParts.push({ type: 'text', text: 'No schedule rows yet. Add one below.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } } as UIPart);
                        } else {
                            let sortedRows = secRows.map(function(r, i) { return { r: r, i: i }; }).sort(function(a, b) { return a.r.startHour - b.r.startHour; });
                            for (let entry of sortedRows) {
                                let row = entry.r; let rowIdx = entry.i;
                                let locMeta = asLocOpts.find(function(l) { return l.id === row.locationId; });
                                secParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                                    { type: 'numberInput', initialValue: row.startHour, style: { width: '56px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) {
                                        let f = await loadCharacter(cCharId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;
                                        let hv = Math.floor(Number(v) || 0); if (hv < 0) hv = 0; if (hv > 23) hv = 23;
                                        f.schedule[rowIdx].startHour = hv;
                                        await saveCharacter(f);
                                    } },
                                    { type: 'text', text: ':00 \u2192', style: { fontSize: '11px', opacity: '0.6' } },
                                    { type: 'button', text: locMeta ? ('\ud83c\udf0d ' + locMeta.name) : (asLocName[row.locationId] || '(pick location)'), style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left' }, callback: async function() {
                                        await openPickerModal({
                                            title: 'Pick Schedule Location',
                                            items: asLocOpts,
                                            getId: function(item) { return item.id; },
                                            getLabel: function(item) { return item.name; },
                                            getIcon: function() { return '\ud83c\udf0d'; },
                                            searchable: true,
                                            selectedId: row.locationId,
                                            emptyText: 'No locations found. Create a location entity first.',
                                            onSelect: async function(item) {
                                                let f = await loadCharacter(cCharId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;
                                                f.schedule[rowIdx].locationId = item.id;
                                                await saveCharacter(f); await renderAll();
                                            }
                                        });
                                    } },
                                    { type: 'button', text: '\u2715', style: { margin: 0, fontSize: '11px', width: '28px' }, callback: async function() {
                                        let f = await loadCharacter(cCharId); if (!f || !f.schedule) return;
                                        f.schedule = f.schedule.filter(function(_rr, ri2) { return ri2 !== rowIdx; });
                                        await saveCharacter(f); await renderAll();
                                    } }
                                ] } as UIPart);
                            }
                        }

                        secParts.push({ type: 'button', text: '+ Add Schedule Row', style: { width: '100%', marginTop: '4px', fontSize: '11px' }, callback: async function() {
                            let f = await loadCharacter(cCharId); if (!f) return;
                            f.schedule = f.schedule || [];
                            f.schedule.push({ startHour: 8, locationId: (asLocOpts[0] ? asLocOpts[0].id : '') });
                            await saveCharacter(f); await renderAll();
                        } } as UIPart);

                        return secParts;
                    })() } as UIPart);
                }
            }
        } catch (e) {
            api.v1.error('[AE:schedules] build error:', e);
            asParts.push({ type: 'text', text: 'Could not load schedules.', style: { fontSize: '11px', opacity: '0.5' } } as UIPart);
        }

        asParts.push(_aeHudClose(function() { return asHandle; }));
        try { if (asHandle && !asHandle.isClosed()) { await asHandle.update({ content: asParts }); return; } } catch (e) {}
        asHandle = await openEngineModal({ id: 'ae-all-schedules', title: 'All Character Schedules', size: 'medium', content: asParts });
    }

    try {
        await renderAll();
    } catch (e) {
        api.v1.error('[AE:schedules] open error:', e);
    }
}

async function openWizardModal(): Promise<void> {
    let pm: any;

    async function redraw(): Promise<void> {
        if (pm && typeof pm.isClosed === 'function' && pm.isClosed()) return;
        let content = await buildWizardContent();
        if (pm && !pm.isClosed()) { await pm.update({ content: content }); }
    }

    function tabBar(activeTab: string): UIPart {
        return { type: 'row', style: { gap: '3px', flexWrap: 'wrap', marginBottom: '10px', borderBottom: '1px solid rgba(255,255,255,0.08)', paddingBottom: '4px' }, content: WIZARD_TABS.map(function(t) {
            let on = activeTab === t.id;
            // [v0.9.8.2] iconId on each tab button; text provides the accessible label.
        return { type: 'button', iconId: t.iconId as any, text: t.label, style: { flex: '1 1 auto', minWidth: '76px', margin: 0, padding: '4px 3px', fontSize: '10px', fontWeight: on ? 'bold' : 'normal', borderBottom: on ? '2px solid #88ccff' : '2px solid transparent', borderRadius: '4px 4px 0 0', backgroundColor: on ? 'rgba(136,204,255,0.12)' : 'transparent', opacity: on ? '1' : '0.65' }, callback: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_TAB, t.id); await redraw(); } } as UIPart;
        }) };
    }

    async function buildWizardContent(): Promise<UIPart[]> {
        let cfg = await loadConfig();
        let chats = await loadWizardChats();
        let activeId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_ACTIVE_CHAT, '') as string;
        let active = chats.find(function(c) { return c.id === activeId; }) || null;
        let topics = ((cfg as any).wizardTopics && (cfg as any).wizardTopics.length) ? (cfg as any).wizardTopics : DEFAULT_WIZARD_TOPICS;
        let activeTab = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_TAB, 'setup') as string;
        if (activeTab === 'story') { activeTab = 'setup'; } // [v0.9.8.2] legacy redirect
        let parts: UIPart[] = [];
        parts.push(tabBar(activeTab));

        if (activeTab === 'setup') {
            // ── SETUP: project fields + helper text ──────────────────────────────────
            parts.push({ type: 'text', text: 'Name your project and jot the initial concept. These seed every wizard chat and all world generation when no chat is selected.', style: { fontSize: '12px', opacity: '0.7', lineHeight: '1.5', marginBottom: '12px' } });
            parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [
                { type: 'textInput', label: 'Project Name', initialValue: cfg.projectName || '', placeholder: 'Untitled Project', style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: string) { await mutConfig(function(c) { c.projectName = v; }); } },
                { type: 'textInput', label: 'Genre', initialValue: cfg.projectGenre || '', placeholder: 'e.g. dark fantasy, cyberpunk noir…', style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: string) { await mutConfig(function(c) { c.projectGenre = v; }); } }
            ] });
            parts.push({ type: 'multilineTextInput', label: 'Initial Concept', initialValue: cfg.projectConcept || '', placeholder: 'The working idea your wizard chats start from…', style: { minHeight: '80px', marginBottom: '10px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.projectConcept = v; }); } } as UIPart);

        } else if (activeTab === 'chats') {
            // ── CHATS [v0.9.8.3]: two collapsible panels + bare transcript ──────────
            // Panel 1 — Select Chat: topic picker modal, new-chat, existing-chat modal.
            // Panel 2 — active chat config: name edit + context sources.
            // Below: transcript + send input (no extra wrapping).
            let topicPickId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_TOPIC_PICK, topics[0] ? topics[0].id : '') as string;
            let pickedTopic = topics.find(function(tp0: WizardTopic) { return tp0.id === topicPickId; }) || topics[0] || null;

            // ─── Panel 1: Select Chat ──────────────────────────────────────────────
            let selParts: UIPart[] = [];

            // ─ Topic picker ──────────────────────────────────────────────────────────────
            selParts.push({ type: 'button', text: 'Select Topic' + (pickedTopic ? ': ' + pickedTopic.label : '…'), iconId: 'tag' as any, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: 'rgba(136,204,255,0.08)', border: '1px solid rgba(136,204,255,0.2)' }, callback: async function() {
                await openSearchPicker('Select Topic', topics.map(function(tp1: WizardTopic) { return { id: tp1.id, label: tp1.label, selected: tp1.id === topicPickId }; }), async function(id: string) {
                    await api.v1.tempStorage.set(STORAGE_WIZ_TOPIC_PICK, id); await redraw();
                });
            } });

            // ─ New chat button ──────────────────────────────────────────────────────────
            selParts.push({ type: 'button', text: '+ New ' + (pickedTopic ? '"' + pickedTopic.label + '" Chat' : 'Chat'), iconId: 'plus', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, callback: async function() {
                let tid = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_TOPIC_PICK, topics[0] ? topics[0].id : '') as string;
                let tp2 = topics.find(function(tp3: WizardTopic) { return tp3.id === tid; }) || topics[0];
                if (!tp2) { api.v1.ui.toast('Select a topic first.', { type: 'error', autoClose: 2000 }); return; }
                let nc = await createWizardChat(tp2.id, tp2.label);
                await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, nc.id); await redraw();
            } });

            // ─ Existing-chat picker ────────────────────────────────────────────────────
            if (chats.length > 0) {
                selParts.push({ type: 'button', text: 'Open Chat' + (active ? ': ' + active.title : '…'), iconId: 'message-square' as any, style: { width: '100%', textAlign: 'left', backgroundColor: active ? 'rgba(126,200,160,0.08)' : 'transparent', border: '1px solid rgba(255,255,255,0.15)' }, callback: async function() {
                    let chatItems = chats.map(function(c) { return { id: c.id, label: c.title, selected: !!(active && c.id === active.id) }; });
                    await openSearchPicker('Open Chat', chatItems, async function(id: string) {
                        await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, id); await redraw();
                    });
                } });
            } else {
                selParts.push({ type: 'text', text: 'No chats yet — select a topic and create one above.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });
            }

            // [vNEXT] Export every wizard chat transcript to a JSON file.
            if (chats.length > 0) {
                selParts.push({ type: 'button', text: '⬇ Export All Chats (JSON)', iconId: 'download' as any, style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.08)' }, disabledWhileCallbackRunning: true, callback: async function() {
                    await exportWizardChats('all');
                } } as UIPart);
            }

            parts.push({ type: 'collapsibleSection', title: 'Select Chat', iconId: 'list' as any, initialCollapsed: !!active, storageKey: 'temp:wiz_sel', content: selParts } as UIPart);

            // ─── Panel 2: active chat config ─────────────────────────────────────────
            if (active) {
                let activeTopic2 = topics.find(function(t: WizardTopic) { return t.id === active.topicId; });
                let cfgTitle = (activeTopic2 ? activeTopic2.label + ' · ' : '') + active.title;
                let cfgParts: UIPart[] = [];

                cfgParts.push({ type: 'textInput', label: 'Chat Name', initialValue: active.title, style: { margin: '0 0 6px 0' }, onChange: async function(v: string) { let f = await loadWizardChat(active.id); if (!f) return; f.title = v; await saveWizardChat(f); } } as UIPart);
                cfgParts.push({ type: 'checkboxInput', label: 'Include recent story text as context', initialValue: !!active.includeStory, onChange: async function(val: boolean) { let f = await loadWizardChat(active.id); if (!f) return; f.includeStory = val; await saveWizardChat(f); } } as UIPart);
                let otherChs = chats.filter(function(oc) { return oc.id !== active.id; });
                if (otherChs.length > 0) {
                    cfgParts.push({ type: 'text', text: 'Also pull context from:', style: { fontSize: '10px', opacity: '0.6', marginTop: '4px', marginBottom: '2px' } });
                    otherChs.forEach(function(oc) {
                        let onOc = (active.contextChatIds || []).indexOf(oc.id) >= 0;
                        cfgParts.push({ type: 'checkboxInput', label: oc.title, initialValue: onOc, onChange: async function(val: boolean) {
                            let f = await loadWizardChat(active.id); if (!f) return;
                            let ids = f.contextChatIds || [];
                            if (val && ids.indexOf(oc.id) < 0) ids.push(oc.id);
                            else if (!val) ids = ids.filter(function(x) { return x !== oc.id; });
                            f.contextChatIds = ids; await saveWizardChat(f);
                        } } as UIPart);
                    });
                }
                cfgParts.push({ type: 'row', style: { gap: '6px', marginTop: '8px' }, content: [
                    { type: 'button', text: 'Export this chat', iconId: 'download' as any, style: { flex: '1 1 0', margin: 0, fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
                        await exportWizardChats('one', active.id);
                    } },
                    { type: 'button', text: 'Delete this chat', iconId: 'trash', style: { flex: '1 1 0', margin: 0, fontSize: '11px', opacity: '0.7' }, callback: async function() {
                        await deleteWizardChat(active.id);
                        await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, ''); await redraw();
                    } }
                ] } as UIPart);

                parts.push({ type: 'collapsibleSection', title: cfgTitle, iconId: 'message-square' as any, initialCollapsed: false, storageKey: 'temp:wiz_cfg', content: cfgParts } as UIPart);

                // ─── Transcript + input (no collapsible wrapper) ───────────────────────────────
                if (!active.messages || active.messages.length === 0) {
                    parts.push({ type: 'text', text: '(empty — send a message to begin)', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '4px' } });
                } else {
                    let editTgt = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_EDIT_MSG, '') as string;
                    active.messages.forEach(function(m, mi) {
                        let isUser = m.role === 'user';
                        let thisKey = active.id + ':' + mi;
                        let isEditing = editTgt === thisKey;
                        let editBtnPart: UIPart = isEditing
                            ? { type: 'button', text: 'Done', style: { margin: 0, padding: '1px 6px', fontSize: '10px', backgroundColor: 'rgba(126,200,160,0.18)', color: '#7ec8a0' }, callback: async function() {
                                let draftMsg = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_MSG_DRAFT, null) as any;
                                if (draftMsg !== null) { let f = await loadWizardChat(active.id); if (f && f.messages[mi]) { f.messages[mi].content = String(draftMsg); await saveWizardChat(f); } }
                                await api.v1.tempStorage.set(STORAGE_WIZ_EDIT_MSG, ''); await redraw();
                            } }
                            : { type: 'button', iconId: 'edit', style: { margin: 0, padding: '1px 4px' }, callback: async function() {
                                await api.v1.tempStorage.set(STORAGE_WIZ_EDIT_MSG, thisKey);
                                await api.v1.tempStorage.set(STORAGE_WIZ_MSG_DRAFT, m.content); await redraw();
                            } };
                        let msgRow: UIPart[] = [
                            { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                                { type: 'text', text: (isUser ? 'You' : 'Wiz'), style: { fontSize: '9px', opacity: '0.55', fontWeight: 'bold', flex: '1 1 0' } },
                                editBtnPart,
                                { type: 'button', iconId: 'trash', style: { margin: 0, padding: '1px 4px' }, callback: async function() {
                                    let f = await loadWizardChat(active.id); if (!f) return;
                                    f.messages.splice(mi, 1); await saveWizardChat(f);
                                    if (editTgt === thisKey) await api.v1.tempStorage.set(STORAGE_WIZ_EDIT_MSG, '');
                                    await redraw();
                                } }
                            ] }
                        ];
                        if (isEditing) {
                            msgRow.push({ type: 'multilineTextInput', initialValue: m.content, style: { minHeight: '60px', fontSize: '12px' } as any, onChange: async function(v: string) { await api.v1.tempStorage.set(STORAGE_WIZ_MSG_DRAFT, v); } } as UIPart);
                        } else {
                            msgRow.push({ type: 'text', text: m.content, style: { fontSize: '12px', whiteSpace: 'pre-wrap' } as any });
                        }
                        parts.push({ type: 'box', style: { backgroundColor: isUser ? 'rgba(136,204,255,0.08)' : 'rgba(126,200,160,0.08)', padding: '5px 7px', borderRadius: '5px', marginBottom: '3px' }, content: msgRow });
                    });
                }

                parts.push({ type: 'multilineTextInput', placeholder: 'Message the Wiz…', initialValue: '', style: { minHeight: '44px', marginTop: '6px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(STORAGE_WIZ_INPUT, v); } } as UIPart);
                parts.push({ type: 'row', style: { gap: '6px', marginTop: '4px' }, content: [
                    { type: 'button', text: 'Send', iconId: 'send', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                        let draftSend = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INPUT, '') as string;
                        if (!draftSend || !draftSend.trim()) { api.v1.ui.toast('Type a message first.', { type: 'info', autoClose: 1500 }); return; }
                        api.v1.ui.toast('Thinking…', { id: 'wiz-turn', autoClose: false, type: 'info' });
                        let reply = await runWizardChatTurn(active.id, draftSend);
                        await api.v1.tempStorage.set(STORAGE_WIZ_INPUT, '');
                        api.v1.ui.toast(reply ? 'Replied.' : 'Generation failed.', { id: 'wiz-turn', type: reply ? 'success' : 'error', autoClose: 1500 });
                        await redraw();
                    } }
                ] });

                let activeTopic3 = topics.find(function(t: WizardTopic) { return t.id === active.topicId; });
                if (activeTopic3 && activeTopic3.commitKind === 'memoryFanout') {
                    parts.push({ type: 'button', text: 'Commit → generate enabled Memory sections', iconId: 'check', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
                        api.v1.ui.toast('Generating sections…', { id: 'wiz-commit', autoClose: false, type: 'info' });
                        let nFan = await runWizardMemoryFanout(active.id);
                        api.v1.ui.toast(nFan >= 0 ? ('Committed ' + nFan + ' section(s).') : 'Commit failed.', { id: 'wiz-commit', type: nFan >= 0 ? 'success' : 'error', autoClose: 2500 });
                        await redraw();
                    } });
                }
            }

        } else if (activeTab === 'memory') {
            // ── MEMORY SECTIONS ──
            let activeChatId = active ? active.id : '';
            parts.push({ type: 'text', text: 'Enabled sections are generated on commit and assembled into the static Memory block (Style → Author’s Note). Regenerate or edit any section individually below. Regeneration uses the active chat (' + (active ? active.title : 'none selected') + ') plus the hint.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });
            (cfg.wizardSections || []).forEach(function(s: WizardMemorySection, si: number) {
                let hintKey = STORAGE_WIZ_SEC_HINT + s.id;
                parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: [
                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                        { type: 'checkboxInput', label: '', initialValue: !!s.enabled, onChange: async function(val: boolean) { await mutConfig(function(c) { c.wizardSections[si].enabled = val; }); } } as UIPart,
                        { type: 'textInput', initialValue: s.label, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].label = v; }); } },
                        { type: 'text', text: s.target === 'an' ? 'AN' : 'MEM', style: { fontSize: '9px', opacity: '0.5', flexShrink: '0' } },
                        { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() { await mutConfig(function(c) { c.wizardSections.splice(si, 1); }); await redraw(); } }
                    ] },
                    { type: 'multilineTextInput', initialValue: s.content || '', placeholder: '(generated on commit; editable)', style: { minHeight: '40px', marginBottom: '3px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].content = v; }); } } as UIPart,
                    { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '3px' }, content: [
                        { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(hintKey, v); } },
                        { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                            let hint = await api.v1.tempStorage.getOrDefault(hintKey, '') as string;
                            api.v1.ui.toast('Regenerating “' + s.label + '”…', { id: 'wiz-regen', autoClose: false, type: 'info' });
                            let r = await regenerateWizardSection(s.id, activeChatId, hint);
                            api.v1.ui.toast(r ? ('Regenerated “' + s.label + '”.') : 'Regeneration failed.', { id: 'wiz-regen', type: r ? 'success' : 'error', autoClose: 2000 });
                            await redraw();
                        } }
                    ] },
                    { type: 'textInput', initialValue: s.instructions || '', placeholder: 'Scope instructions', style: { margin: 0, fontSize: '10px', opacity: '0.8' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].instructions = v; }); } }
                ] });
            });
            parts.push({ type: 'button', text: '+ Add Section', style: { marginTop: '2px', fontSize: '11px' }, callback: async function() {
                await mutConfig(function(c) { if (!c.wizardSections) c.wizardSections = []; c.wizardSections.push({ id: 'wsec_' + generateId(), label: 'New Section', enabled: false, content: '', instructions: 'Describe ONLY this section’s scope.', target: 'memory' }); });
                await redraw();
            } });
            parts.push({ type: 'button', text: '✅ Commit to Memory + Author’s Note', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
                let fresh = await loadConfig();
                let ok = await commitWizardMemory(fresh);
                api.v1.ui.toast(ok ? 'Committed to Memory and Author’s Note.' : 'Commit failed.', { type: ok ? 'success' : 'error', autoClose: 2000 });
            } });
            // [vNEXT] Sync every world lorebook (characters, locations, species, factions)
            // in one pass. Creates entries that are missing OR whose stored link was
            // deleted in NAI; syncs the rest. One lorebook read for the whole run.
            parts.push({ type: 'text', text: 'Lorebook: create any missing entries and refresh existing ones for all characters, locations, species, and factions.', style: { fontSize: '10px', opacity: '0.55', marginTop: '10px', marginBottom: '4px' } });
            parts.push({ type: 'button', text: '📚 Sync All Lorebooks', iconId: 'book-open' as any, style: { width: '100%', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.10)' }, disabledWhileCallbackRunning: true, callback: async function() {
                api.v1.ui.toast('Syncing all lorebooks…', { id: 'wiz-lore-all', autoClose: false, type: 'info' });
                try {
                    let t = await syncAllLorebooks();
                    let totCreated = t.characters.created + t.locations.created + t.species.created + t.factions.created;
                    let totSynced  = t.characters.synced  + t.locations.synced  + t.species.synced  + t.factions.synced;
                    api.v1.ui.toast(totCreated + ' created, ' + totSynced + ' synced (chars ' + t.characters.created + '+' + t.characters.synced + ', locs ' + t.locations.created + '+' + t.locations.synced + ', species ' + t.species.created + '+' + t.species.synced + ', factions ' + t.factions.created + '+' + t.factions.synced + ').', { id: 'wiz-lore-all', type: 'success', autoClose: 4000 });
                } catch (e) {
                    api.v1.error('[AE:lore] Sync All button:', e);
                    api.v1.ui.toast('Sync All failed.', { id: 'wiz-lore-all', type: 'error', autoClose: 2500 });
                }
            } });
        } else if (activeTab === 'species' || activeTab === 'factions') {
            // ── SPECIES / FACTIONS (batch yoink generation + per-item regen) ──
            let kind = (activeTab === 'factions') ? 'faction' : 'species';
            let list: any[] = (kind === 'faction') ? (cfg.factions || []) : (cfg.species || []);
            // [v0.9.81] Per-tab context sources: MULTI-select (checkboxes, mirroring the
            // per-chat context model). Stored as a JSON id array per kind. Empty selection
            // falls back to the active chat; no active chat falls back to project concept only.
            let srcKey = STORAGE_WIZ_TAB_SRC + kind;
            let storedSrcRaw = await api.v1.tempStorage.getOrDefault(srcKey, '') as string;
            let storedSrcIds: string[] = [];
            try { let parsedSrc = JSON.parse(storedSrcRaw || '[]'); if (Array.isArray(parsedSrc)) storedSrcIds = parsedSrc.filter(Boolean); } catch (eSrcParse) { storedSrcIds = []; }
            storedSrcIds = storedSrcIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });
            let effSrcIds = storedSrcIds.length ? storedSrcIds : (active ? [active.id] : []);
            let countKey = STORAGE_WIZ_GEN_COUNT + kind;
            let countDraft = await api.v1.tempStorage.getOrDefault(countKey, 3) as number;

            parts.push({ type: 'text', text: 'Generate ' + (kind === 'faction' ? 'factions' : 'species') + ' from the chosen context source plus project context. Existing entries are fed in so new ones won\'t duplicate them. Each becomes a record with a linked lorebook entry — regenerate or edit any individually below.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            // Context sources (multi-select checkboxes, mirroring the per-chat context model).
            parts.push({ type: 'text', text: 'Context sources' + (storedSrcIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, using project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onSrc = storedSrcIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(srcKey, '') as string;
                        let curIds: string[] = [];
                        try { let pj = JSON.parse(curRaw || '[]'); if (Array.isArray(pj)) curIds = pj.filter(Boolean); } catch (eSrcSet) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(srcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }

            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: countDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(countKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let n = await api.v1.tempStorage.getOrDefault(countKey, 3) as number;
                    api.v1.ui.toast('Generating ' + n + ' ' + kind + '(s)…', { id: 'wiz-batch', autoClose: false, type: 'info' });
                    let made = (kind === 'faction') ? await runWizardFactionsBatch(n, effSrcIds) : await runWizardSpeciesBatch(n, effSrcIds);
                    api.v1.ui.toast(made > 0 ? ('Created ' + made + ' ' + kind + '(s).') : 'Generation failed.', { id: 'wiz-batch', type: made > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            parts.push({ type: 'button', text: '+ Add blank ' + (kind === 'faction' ? 'faction' : 'species'), style: { width: '100%', marginBottom: '10px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
                await addBlankWizardEntity(kind);
                await redraw();
            } });

            if (list.length === 0) {
                parts.push({ type: 'text', text: 'None yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });
            } else {
                list.forEach(function(item: any, ii: number) {
                    let hintKey = STORAGE_WIZ_ITEM_HINT + item.id;
                    let boxContent: UIPart[] = [
                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                            { type: 'textInput', initialValue: item.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].name = v; }); } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {
                                let capId = item.id;
                                if (kind === 'faction') { await unlinkFactionLorebookEntry(capId).catch(function() {}); }
                                else { await unlinkSpeciesLorebookEntry(capId).catch(function() {}); }
                                await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; let idx = arr.findIndex(function(x: any) { return x.id === capId; }); if (idx >= 0) arr.splice(idx, 1); });
                                await redraw();
                            } }
                        ] },
                        { type: 'multilineTextInput', initialValue: item.description || '', placeholder: '(lore description)', style: { minHeight: '44px', marginBottom: '3px' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].description = v; }); } } as UIPart,
                        { type: 'textInput', initialValue: (item.lorebookTags || []).join(', '), placeholder: 'Lorebook tags (comma-separated)', style: { margin: '0 0 3px 0', fontSize: '10px' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].lorebookTags = v.split(',').map(function(s2: string) { return s2.trim(); }).filter(Boolean); }); } },
                        { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(hintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let hint = await api.v1.tempStorage.getOrDefault(hintKey, '') as string;
                                api.v1.ui.toast('Regenerating “' + item.name + '”…', { id: 'wiz-ireg', autoClose: false, type: 'info' });
                                let r = await regenerateWizardEntity(kind, item.id, effSrcIds, hint);
                                api.v1.ui.toast(r ? ('Regenerated “' + item.name + '”.') : 'Regeneration failed.', { id: 'wiz-ireg', type: r ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } },
                            { type: 'button', text: '🔗 Sync Lore', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                if (kind === 'faction') await syncFactionLorebookEntry(item.id); else await syncSpeciesLorebookEntry(item.id);
                            } }
                        ] }
                    ];
                    if (kind === 'faction') {
                        boxContent.push({ type: 'textInput', initialValue: (item.relationshipStates || []).join(' → '), placeholder: 'Standing track (lowest → highest)', style: { margin: 0, fontSize: '10px', opacity: '0.8' }, onChange: async function(v: string) { await mutConfig(function(c) { if (c.factions[ii]) c.factions[ii].relationshipStates = v.split('→').map(function(s2: string) { return s2.trim(); }).filter(Boolean); }); } });
                    }
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: boxContent });
                });
            }
        } else if (activeTab === 'bestiary') {
            let bwCfg = await loadConfig();
            let bwArchs = (((bwCfg as any).npcArchetypes || []) as NpcArchetypeDef[]);
            let bwSrcKey = STORAGE_WIZ_TAB_SRC + 'bestiary';
            let bwStoredRaw = await api.v1.tempStorage.getOrDefault(bwSrcKey, '') as string;
            let bwStoredIds: string[] = [];
            try { let bwParsed = JSON.parse(bwStoredRaw || '[]'); if (Array.isArray(bwParsed)) bwStoredIds = bwParsed.filter(Boolean); } catch (eBwParse) { bwStoredIds = []; }
            bwStoredIds = bwStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });
            let bwEffSrcIds = bwStoredIds.length ? bwStoredIds : (active ? [active.id] : []);
            let bwCountKey = STORAGE_WIZ_GEN_COUNT + 'bestiary';
            let bwCountDraft = await api.v1.tempStorage.getOrDefault(bwCountKey, 3) as number;

            parts.push({ type: 'text', text: 'Generate minor-NPC archetypes \u2014 drop-in creatures and background figures \u2014 from the chosen context source plus project context. Existing archetypes are fed in so new ones won\u2019t duplicate them. Each becomes a spawn template with an empty resources/tags to fill in below or in the Bestiary.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            parts.push({ type: 'text', text: 'Context sources' + (bwStoredIds.length ? '' : (active ? ' \u2014 none checked, using active chat \u201c' + active.title + '\u201d' : ' \u2014 none, using project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet \u2014 generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(bwc) {
                    let bwOn = bwStoredIds.indexOf(bwc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: bwc.title, initialValue: bwOn, onChange: async function(val: boolean) {
                        let bwCurRaw = await api.v1.tempStorage.getOrDefault(bwSrcKey, '') as string;
                        let bwCurIds: string[] = [];
                        try { let bwPj = JSON.parse(bwCurRaw || '[]'); if (Array.isArray(bwPj)) bwCurIds = bwPj.filter(Boolean); } catch (eBwSet) { bwCurIds = []; }
                        if (val && bwCurIds.indexOf(bwc.id) < 0) bwCurIds.push(bwc.id);
                        else if (!val) bwCurIds = bwCurIds.filter(function(x) { return x !== bwc.id; });
                        await api.v1.tempStorage.set(bwSrcKey, JSON.stringify(bwCurIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }

            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: bwCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(bwCountKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '\u26a1 Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let bwN = await api.v1.tempStorage.getOrDefault(bwCountKey, 3) as number;
                    api.v1.ui.toast('Generating ' + bwN + ' archetype(s)\u2026', { id: 'wiz-batch', autoClose: false, type: 'info' });
                    let bwMade = await runWizardArchetypesBatch(bwN, bwEffSrcIds);
                    api.v1.ui.toast(bwMade > 0 ? ('Created ' + bwMade + ' archetype(s).') : 'Generation failed.', { id: 'wiz-batch', type: bwMade > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            parts.push({ type: 'button', text: '\ud83d\udc3e Open Bestiary (spawn, edit resources & tags)', style: { width: '100%', marginBottom: '10px', fontSize: '11px' }, callback: async function() { await openBestiaryModal(); } } as UIPart);

            if (bwArchs.length === 0) {
                parts.push({ type: 'text', text: 'None yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });
            } else {
                bwArchs.forEach(function(bwA) {
                    parts.push({ type: 'row', style: { gap: '4px', marginBottom: '4px', alignItems: 'center' }, content: [
                        { type: 'text', text: aeIconPfx(bwA.icon) + bwA.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },
                        { type: 'text', text: (bwA.briefTemplate || '').slice(0, 46) + ((bwA.briefTemplate || '').length > 46 ? '\u2026' : ''), style: { flex: '2 1 0', fontSize: '10px', opacity: '0.6' } },
                        { type: 'button', text: 'Edit', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, callback: async function() { await openArchetypeEditModal(bwA.id); } }
                    ] } as UIPart);
                });
            }
        } else if (activeTab === 'locations') {
            // ── LOCATIONS (two-pass tree: scope top-level, then step into any node) ──
            let lkind = 'locations';
            // Context sources (multi-select, same model as species/factions).
            let lSrcKey = STORAGE_WIZ_TAB_SRC + lkind;
            let lStoredRaw = await api.v1.tempStorage.getOrDefault(lSrcKey, '') as string;
            let lStoredIds: string[] = [];
            try { let lpj = JSON.parse(lStoredRaw || '[]'); if (Array.isArray(lpj)) lStoredIds = lpj.filter(Boolean); } catch (eLSrc) { lStoredIds = []; }
            lStoredIds = lStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });
            let lEffIds = lStoredIds.length ? lStoredIds : (active ? [active.id] : []);

            // Current parent navigation (Pass 2 step-into).
            let lParentId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;
            let lParentEnt = lParentId ? await loadEntity(lParentId) : null;
            if (lParentId && !lParentEnt) { lParentId = ''; await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, ''); }
            let lChildDepth = lParentId ? ((await computeEntityTier(lParentId)) + 1) : 0;
            let lBandIdx = tierBandIndexForDepth(lChildDepth);
            let lBand = (cfg.tierTravelDefaults || DEFAULT_TIER_TRAVEL)[lBandIdx];

            // Breadcrumb / step-up.
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [
                { type: 'text', text: lParentEnt ? ('📍 Inside: ' + lParentEnt.name) : '🌍 World root (top-level)', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: '#88ccff' } }
            ].concat(lParentEnt ? [{ type: 'button', text: '↑ Up', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, callback: async function() {
                let up = (lParentEnt && lParentEnt.parentId) ? lParentEnt.parentId : '';
                await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, up);
                await redraw();
            } } as UIPart] : []) });
            parts.push({ type: 'text', text: lParentEnt ? ('Generating sub-locations of “' + lParentEnt.name + '” (' + lBand.label + ' tier).') : ('Generating top-level locations (' + lBand.label + ' tier). Step into any location below to build its sub-locations.'), style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            // Tier travel rule for the tier being created (shared across that depth).
            let lCostBtns: UIPart[] = [{ type: 'text', text: 'Cost:', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } } as UIPart];
            // [v0.9.9.6] Offer both global resources AND per-character personal resources
            // (Health/Wealth/Luck, etc). adjustResource/checkResource fall back to the
            // protagonist's personal pool for any tag that is not a global resource.
            let lResGlobals = (cfg.resources || []).map(function(r) { return { tag: r.tag, name: r.name }; });
            let lGlobTags = lResGlobals.map(function(x) { return x.tag; });
            let lResChars = (cfg.characterResourceDefs || []).filter(function(r) { return lGlobTags.indexOf(r.tag) < 0; }).map(function(r) { return { tag: r.tag, name: r.name }; });
            let lResList = [{ tag: '', name: 'None' }].concat(lResGlobals).concat(lResChars);
            lResList.forEach(function(rr) {
                let onCost = (lBand.costTag || '') === rr.tag;
                lCostBtns.push({ type: 'button', text: rr.name, style: { margin: 0, fontSize: '10px', padding: '2px 6px', backgroundColor: onCost ? 'rgba(136,204,255,0.25)' : 'transparent', border: '1px solid ' + (onCost ? '#88ccff' : 'rgba(255,255,255,0.18)'), color: onCost ? '#88ccff' : 'inherit' }, callback: async function() {
                    await mutConfig(function(c) { if (!c.tierTravelDefaults) c.tierTravelDefaults = JSON.parse(JSON.stringify(DEFAULT_TIER_TRAVEL)); c.tierTravelDefaults[lBandIdx].costTag = rr.tag; if (!rr.tag) c.tierTravelDefaults[lBandIdx].costAmount = 0; syncTierTemplate(c, lBandIdx); });
                    await redraw();
                } } as UIPart);
            });
            let lRuleBox: UIPart[] = [
                { type: 'text', text: '🧭 Travel rule for the ' + lBand.label + ' tier', style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '4px' } },
                { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px', flexWrap: 'wrap' }, content: lCostBtns }
            ];
            if (lBand.costTag) {
                lRuleBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                    { type: 'text', text: 'Amount:', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } },
                    { type: 'numberInput', initialValue: lBand.costAmount || 0, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await mutConfig(function(c) { c.tierTravelDefaults[lBandIdx].costAmount = Math.max(0, v || 0); syncTierTemplate(c, lBandIdx); }); } }
                ] } as UIPart);
            }
            lRuleBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'text', text: 'Time (hours):', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: lBand.timeCostHours || 0, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await mutConfig(function(c) { if (!c.tierTravelDefaults) c.tierTravelDefaults = JSON.parse(JSON.stringify(DEFAULT_TIER_TRAVEL)); c.tierTravelDefaults[lBandIdx].timeCostHours = Math.max(0, Math.floor(v || 0)); syncTierTemplate(c, lBandIdx); }); } }
            ] } as UIPart);
            lRuleBox.push({ type: 'checkboxInput', label: 'Narrate travel (uncheck = silent, no text/AI)', initialValue: !!lBand.narrated, onChange: async function(val: boolean) { await mutConfig(function(c) { c.tierTravelDefaults[lBandIdx].narrated = val; syncTierTemplate(c, lBandIdx); }); } } as UIPart);
            parts.push({ type: 'box', style: { backgroundColor: 'rgba(136,204,255,0.06)', padding: '7px', borderRadius: '5px', marginBottom: '8px' }, content: lRuleBox });

            // Context sources (multi-select checkboxes).
            parts.push({ type: 'text', text: 'Context sources' + (lStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onSrc = lStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(lSrcKey, '') as string;
                        let curIds: string[] = [];
                        try { let lpj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(lpj2)) curIds = lpj2.filter(Boolean); } catch (eLSrc2) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(lSrcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }

            // Generate + add-blank.
            let lCountKey = STORAGE_WIZ_GEN_COUNT + lkind;
            let lCountDraft = await api.v1.tempStorage.getOrDefault(lCountKey, 3) as number;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: lCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(lCountKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let n = await api.v1.tempStorage.getOrDefault(lCountKey, 3) as number;
                    let pId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;
                    api.v1.ui.toast('Generating ' + n + ' location(s)…', { id: 'wiz-loc', autoClose: false, type: 'info' });
                    let made = await runWizardLocationsBatch(n, pId || null, lEffIds);
                    api.v1.ui.toast(made > 0 ? ('Created ' + made + ' location(s).') : 'Generation failed.', { id: 'wiz-loc', type: made > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });
            parts.push({ type: 'button', text: '+ Add blank location', style: { width: '100%', marginBottom: '10px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
                let pId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;
                await addBlankWizardLocation(pId || null);
                await redraw();
            } });

            // Children list (locations under the current parent).
            let lIdx = await loadEntityIndex();
            let lKids = lIdx.filter(function(m) { return m.type === 'location' && m.parentId === (lParentId || null); });
            if (lKids.length === 0) {
                parts.push({ type: 'text', text: 'No locations here yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });
            } else {
                for (let lk = 0; lk < lKids.length; lk++) {
                    let kidMeta = lKids[lk];
                    let kidEnt = await loadEntity(kidMeta.id);
                    if (!kidEnt) continue;
                    let kidId = kidMeta.id;
                    let kidName = kidEnt.name;
                    let lHintKey = STORAGE_WIZ_ITEM_HINT + kidId;
                    let grandCount = lIdx.filter(function(m) { return m.type === 'location' && m.parentId === kidId; }).length;
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: [
                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                            { type: 'textInput', initialValue: kidEnt.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; fe.name = v; await saveEntity(fe); } },
                            { type: 'button', text: '↳ Into' + (grandCount ? (' (' + grandCount + ')') : ''), style: { margin: 0, fontSize: '10px', padding: '3px 8px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, callback: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, kidId); await redraw(); } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() { await deleteEntity(kidId); await redraw(); } }
                        ] },
                        { type: 'multilineTextInput', initialValue: kidEnt.description || '', placeholder: 'Scene description (AN — short, what you sense on arrival)', style: { minHeight: '38px', marginBottom: '3px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; fe.description = v; await saveEntity(fe); } } as UIPart,
                        { type: 'multilineTextInput', initialValue: (kidEnt as any).lorebookText || '', placeholder: '📖 Lorebook (comprehensive — history, significance, secrets)', style: { minHeight: '52px', marginBottom: '3px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; (fe as any).lorebookText = v; await saveEntity(fe); } } as UIPart,
                        { type: 'button', text: (kidEnt as any).lorebookEntryId ? '🔗 Sync lorebook entry' : '+ Create lorebook entry', style: { width: '100%', margin: '0 0 3px 0', fontSize: '10px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() { let fe = await loadEntity(kidId); if (!fe) return; if ((fe as any).lorebookEntryId) await syncEntityLorebookEntry(kidId, false).catch(function() {}); else await createLinkedEntityLorebookEntry(kidId).catch(function() {}); await redraw(); } } as UIPart,
                        { type: 'textInput', initialValue: (kidEnt as any).locationVisuals || '', placeholder: '🎨 Image tags (booru + plain language) — for the image pipeline', style: { margin: '0 0 3px 0', fontSize: '10px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; (fe as any).locationVisuals = v; await saveEntity(fe); } },
                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(lHintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let hint = await api.v1.tempStorage.getOrDefault(lHintKey, '') as string;
                                api.v1.ui.toast('Regenerating “' + kidName + '”…', { id: 'wiz-lreg', autoClose: false, type: 'info' });
                                let r = await regenerateWizardLocation(kidId, lEffIds, hint);
                                api.v1.ui.toast(r ? ('Regenerated “' + kidName + '”.') : 'Regeneration failed.', { id: 'wiz-lreg', type: r ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } }
                        ] }
                    ] });
                }
            }
        } else if (activeTab === 'characters') {
            // ── CHARACTERS (seed-and-go: name + comprehensive dump -> fields -> create) ──
            let ckind = 'characters';
            let cSrcKey = STORAGE_WIZ_TAB_SRC + ckind;
            let cStoredRaw = await api.v1.tempStorage.getOrDefault(cSrcKey, '') as string;
            let cStoredIds: string[] = [];
            try { let cpj = JSON.parse(cStoredRaw || '[]'); if (Array.isArray(cpj)) cStoredIds = cpj.filter(Boolean); } catch (eCSrc) { cStoredIds = []; }
            cStoredIds = cStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });
            let cEffIds = cStoredIds.length ? cStoredIds : (active ? [active.id] : []);

            parts.push({ type: 'text', text: 'Generate characters from the selected context. Each gets a comprehensive concept dump organising everything the chat establishes about them; their dramatis-personae and static fields are then derived from that dump. New characters appear in the Characters tab — edit and regenerate individual fields there.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            // Context sources (multi-select checkboxes).
            parts.push({ type: 'text', text: 'Context sources' + (cStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onSrc = cStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(cSrcKey, '') as string;
                        let curIds: string[] = [];
                        try { let cpj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(cpj2)) curIds = cpj2.filter(Boolean); } catch (eCSrc2) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(cSrcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });
            }

            // Generate N (each character runs several budget-free passes).
            let cCountKey = STORAGE_WIZ_GEN_COUNT + ckind;
            let cCountDraft = await api.v1.tempStorage.getOrDefault(cCountKey, 2) as number;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: cCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(cCountKey, Math.max(1, Math.min(8, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let n = await api.v1.tempStorage.getOrDefault(cCountKey, 2) as number;
                    api.v1.ui.toast('Generating ' + n + ' character(s) — a few passes each, please wait…', { id: 'wiz-char', autoClose: false, type: 'info' });
                    let made = await runWizardCharactersBatch(n, cEffIds);
                    api.v1.ui.toast(made > 0 ? ('Created ' + made + ' character(s).') : 'Generation failed.', { id: 'wiz-char', type: made > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            // Manual add by name (ensures a specific character is generated).
            let cNameKey = 'ae_wiz_char_addname';
            let cNameDraft = await api.v1.tempStorage.getOrDefault(cNameKey, '') as string;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [
                { type: 'textInput', initialValue: cNameDraft, placeholder: 'Add a specific character by name…', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(cNameKey, v); } },
                { type: 'button', text: '+ Generate', style: { margin: 0, fontSize: '11px', padding: '4px 10px' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let nm = ((await api.v1.tempStorage.getOrDefault(cNameKey, '') as string) || '').trim();
                    if (!nm) { api.v1.ui.toast('Enter a name first.', { type: 'error', autoClose: 2000 }); return; }
                    api.v1.ui.toast('Generating “' + nm + '”…', { id: 'wiz-char1', autoClose: false, type: 'info' });
                    let ok = await runWizardCharacterSingle(nm, cEffIds);
                    api.v1.ui.toast(ok ? ('Created “' + nm + '”.') : 'Generation failed.', { id: 'wiz-char1', type: ok ? 'success' : 'error', autoClose: 2500 });
                    if (ok) await api.v1.tempStorage.set(cNameKey, '');
                    await redraw();
                } }
            ] });

            // Existing character names (dedup visibility; managed in the Characters tab).
            let cCharIdx = await loadIndex();
            if (cCharIdx.length === 0) {
                parts.push({ type: 'text', text: 'No characters yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });
            } else {
                parts.push({ type: 'text', text: 'Characters (' + cCharIdx.length + ') — generation avoids repeating these:', style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px' } });
                cCharIdx.forEach(function(cm) {
                    parts.push({ type: 'text', text: (cm.isProtagonist ? '★ ' : '• ') + cm.name + (cm.occupationRole ? (' — ' + cm.occupationRole) : ''), style: { fontSize: '11px', opacity: '0.85', marginBottom: '2px' } });
                });
            }
            // [vNEXT] Overview of every character's daily schedule in one modal.
            parts.push({ type: 'button', text: '\ud83d\udd52 View All Schedules', iconId: 'clock' as any, style: { width: '100%', marginTop: '10px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.10)' }, callback: async function() { await openAllSchedulesModal(); } } as UIPart);
        } else if (activeTab === 'drama') {
            // ── DRAMA (seed hooks, NPC web, narrative threads) ──
            // [vNEXT] Seeds the three drama primitives the sidebar Drama tab + dynamic
            // engine maintain. ONE shared context-source select feeds all three generators.
            let dkind = 'drama';
            let dSrcKey = STORAGE_WIZ_TAB_SRC + dkind;
            let dStoredRaw = await api.v1.tempStorage.getOrDefault(dSrcKey, '') as string;
            let dStoredIds: string[] = [];
            try { let dpj = JSON.parse(dStoredRaw || '[]'); if (Array.isArray(dpj)) dStoredIds = dpj.filter(Boolean); } catch (eDSrc) { dStoredIds = []; }
            dStoredIds = dStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });
            let dEffIds = dStoredIds.length ? dStoredIds : (active ? [active.id] : []);
            let dramaChars = await loadAllCharacters();

            parts.push({ type: 'text', text: 'Seed the dramatic engine across the cast: directed hooks, bilateral web dynamics, and narrative threads. Generators read the cast plus the chosen context. Full editing of each lives in the sidebar Drama tab — this establishes the opening state.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });

            if (dramaChars.length === 0) {
                parts.push({ type: 'text', text: 'No characters yet — create the cast in the Characters tab before seeding hooks or web dynamics.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '8px' } });
            }

            // Shared context sources (multi-select).
            parts.push({ type: 'text', text: 'Context sources' + (dStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length === 0) {
                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });
            } else {
                chats.forEach(function(pc) {
                    let onDSrc = dStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onDSrc, onChange: async function(val: boolean) {
                        let dCurRaw = await api.v1.tempStorage.getOrDefault(dSrcKey, '') as string;
                        let dCurIds: string[] = [];
                        try { let dpj2 = JSON.parse(dCurRaw || '[]'); if (Array.isArray(dpj2)) dCurIds = dpj2.filter(Boolean); } catch (eDSrc2) { dCurIds = []; }
                        if (val && dCurIds.indexOf(pc.id) < 0) dCurIds.push(pc.id);
                        else if (!val) dCurIds = dCurIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(dSrcKey, JSON.stringify(dCurIds));
                        await redraw();
                    } } as UIPart);
                });
                parts.push({ type: 'text', text: '(Shared by all three generators below. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '10px' } });
            }

            // ===== 1. HOOKS =====
            parts.push({ type: 'text', text: '🔥 Hooks', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#e8a87c' } });
            parts.push({ type: 'text', text: 'One directed opening tension per character (pressure 20–50, matching what the engine spawns mid-play). Check who to seed, then generate.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });

            let hookSelRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;
            let hookSelIds: string[] = [];
            try { let hsp = JSON.parse(hookSelRaw || '[]'); if (Array.isArray(hsp)) hookSelIds = hsp.filter(Boolean); } catch (eHookSel) { hookSelIds = []; }
            hookSelIds = hookSelIds.filter(function(id) { return dramaChars.some(function(c) { return c.id === id; }); });
            let hookCandidates = dramaChars.filter(function(c) { return c.active; });

            hookCandidates.forEach(function(hc) {
                let curHook = (hc.hooks && hc.hooks.length) ? hc.hooks[0] : null;
                let onHook = hookSelIds.indexOf(hc.id) >= 0;
                let hookSubtitle = curHook ? ('▸ ' + (curHook.targetName === '__player__' ? 'the player' : (curHook.targetName || '?')) + ' · ' + curHook.pressureLevel + '% — ' + curHook.description) : '(no hook yet)';
                let hookBox: UIPart[] = [
                    { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [
                        { type: 'checkboxInput', label: '', initialValue: onHook, onChange: async function(val: boolean) {
                            let hCurRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;
                            let hCurIds: string[] = [];
                            try { let hsp2 = JSON.parse(hCurRaw || '[]'); if (Array.isArray(hsp2)) hCurIds = hsp2.filter(Boolean); } catch (eHookSel2) { hCurIds = []; }
                            if (val && hCurIds.indexOf(hc.id) < 0) hCurIds.push(hc.id);
                            else if (!val) hCurIds = hCurIds.filter(function(x) { return x !== hc.id; });
                            await api.v1.tempStorage.set(STORAGE_WIZ_HOOK_CHARS, JSON.stringify(hCurIds));
                            await redraw();
                        } } as UIPart,
                        { type: 'text', text: (hc.isProtagonist ? '★ ' : '') + hc.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },
                        { type: 'button', text: '⚡ Reseed', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                            api.v1.ui.toast('Seeding hook for ' + hc.name + '…', { id: 'wiz-hook1', autoClose: false, type: 'info' });
                            let hOk = await runWizardHookSingle(hc.id, dEffIds, '');
                            api.v1.ui.toast(hOk ? ('Hook seeded for ' + hc.name + '.') : 'No clean tension found.', { id: 'wiz-hook1', type: hOk ? 'success' : 'warning', autoClose: 2500 });
                            await redraw();
                        } }
                    ] },
                    { type: 'text', text: hookSubtitle, style: { fontSize: '10px', opacity: curHook ? '0.8' : '0.4', fontStyle: curHook ? 'normal' : 'italic', marginTop: '2px', lineHeight: '1.3' } }
                ];
                if (curHook) {
                    hookBox.push({ type: 'button', text: '✕ Clear hook', style: { margin: '3px 0 0 0', fontSize: '9px', padding: '2px 6px', backgroundColor: 'transparent', color: '#ff6b6b', opacity: '0.85' }, callback: async function() {
                        let fh = await loadCharacter(hc.id);
                        if (fh) { fh.hooks = []; await saveCharacter(fh); }
                        await redraw();
                    } });
                }
                parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: hookBox });
            });

            if (hookCandidates.length > 0) {
                parts.push({ type: 'button', text: '⚡ Seed hooks for checked characters', style: { width: '100%', margin: '2px 0 16px 0', fontSize: '11px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let hbRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;
                    let hbIds: string[] = [];
                    try { let hsp3 = JSON.parse(hbRaw || '[]'); if (Array.isArray(hsp3)) hbIds = hsp3.filter(Boolean); } catch (eHookSel3) { hbIds = []; }
                    if (hbIds.length === 0) { api.v1.ui.toast('Check at least one character first.', { type: 'info', autoClose: 2000 }); return; }
                    api.v1.ui.toast('Seeding ' + hbIds.length + ' hook(s)…', { id: 'wiz-hooks', autoClose: false, type: 'info' });
                    let hbMade = await runWizardHooksBatch(hbIds, dEffIds);
                    api.v1.ui.toast(hbMade > 0 ? ('Seeded ' + hbMade + ' hook(s).') : 'No clean tensions found.', { id: 'wiz-hooks', type: hbMade > 0 ? 'success' : 'warning', autoClose: 2500 });
                    await redraw();
                } });
            }

            // ===== 2. NPC WEB =====
            parts.push({ type: 'text', text: '🕸 NPC Web', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#88ccff' } });
            parts.push({ type: 'text', text: 'Bilateral dynamics between cast members. Generated pairs are mapped to real characters; self-pairs and duplicates are skipped.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });

            let webCountKey = STORAGE_WIZ_GEN_COUNT + 'web';
            let webCountDraft = await api.v1.tempStorage.getOrDefault(webCountKey, 3) as number;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: webCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(webCountKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                    if (dramaChars.length < 2) { api.v1.ui.toast('Need at least two characters.', { type: 'error', autoClose: 2000 }); return; }
                    let wn = await api.v1.tempStorage.getOrDefault(webCountKey, 3) as number;
                    api.v1.ui.toast('Generating ' + wn + ' web dynamic(s)…', { id: 'wiz-web', autoClose: false, type: 'info' });
                    let wMade = await runWizardWebBatch(wn, dEffIds);
                    api.v1.ui.toast(wMade > 0 ? ('Added ' + wMade + ' web link(s).') : 'No new links resolved.', { id: 'wiz-web', type: wMade > 0 ? 'success' : 'warning', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            let dramaWeb = await loadNpcWeb();
            if (dramaWeb.length === 0) {
                parts.push({ type: 'text', text: 'No web links yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '14px' } });
            } else {
                dramaWeb.forEach(function(wl) {
                    let wlA = dramaChars.find(function(c) { return c.id === wl.charA_id; });
                    let wlB = dramaChars.find(function(c) { return c.id === wl.charB_id; });
                    let wlHintKey = STORAGE_WIZ_ITEM_HINT + wl.id;
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: [
                        { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '3px' }, content: [
                            { type: 'text', text: (wlA ? wlA.name : '?') + ' ⇄ ' + (wlB ? wlB.name : '?'), style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: '#88ccff' } },
                            { type: 'text', text: wl.priority + '%', style: { fontSize: '10px', opacity: '0.6' } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {
                                let wFresh = await loadNpcWeb();
                                let wIdx = wFresh.findIndex(function(x) { return x.id === wl.id; });
                                if (wIdx >= 0) { wFresh.splice(wIdx, 1); await saveNpcWeb(wFresh); }
                                await redraw();
                            } }
                        ] },
                        { type: 'text', text: wl.dynamic || '(no dynamic yet)', style: { fontSize: '11px', opacity: wl.dynamic ? '0.85' : '0.4', fontStyle: wl.dynamic ? 'normal' : 'italic', lineHeight: '1.3', marginBottom: '4px' } },
                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(wlHintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let wHint = await api.v1.tempStorage.getOrDefault(wlHintKey, '') as string;
                                api.v1.ui.toast('Regenerating dynamic…', { id: 'wiz-webreg', autoClose: false, type: 'info' });
                                let wr = await regenerateWebLink(wl.id, dEffIds, wHint);
                                api.v1.ui.toast(wr ? 'Dynamic updated.' : 'Regeneration failed.', { id: 'wiz-webreg', type: wr ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } }
                        ] }
                    ] });
                });
                parts.push({ type: 'box', style: { marginBottom: '14px' }, content: [] });
            }

            // ===== 3. NARRATIVE THREADS =====
            parts.push({ type: 'text', text: '📜 Narrative Threads', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#ffb432' } });
            parts.push({ type: 'text', text: 'Opening plot threads (quests, mysteries, obligations). Created at the top level — nest and re-state them in the sidebar Drama tab afterward.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });

            let narrCountKey = STORAGE_WIZ_GEN_COUNT + 'narrative';
            let narrCountDraft = await api.v1.tempStorage.getOrDefault(narrCountKey, 3) as number;
            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [
                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'numberInput', initialValue: narrCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(narrCountKey, Math.max(1, Math.min(12, v || 1))); } },
                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432' }, disabledWhileCallbackRunning: true, callback: async function() {
                    let nn = await api.v1.tempStorage.getOrDefault(narrCountKey, 3) as number;
                    api.v1.ui.toast('Generating ' + nn + ' thread(s)…', { id: 'wiz-narr', autoClose: false, type: 'info' });
                    let nMade = await runWizardNarrativesBatch(nn, dEffIds);
                    api.v1.ui.toast(nMade > 0 ? ('Created ' + nMade + ' thread(s).') : 'Generation failed.', { id: 'wiz-narr', type: nMade > 0 ? 'success' : 'error', autoClose: 2500 });
                    await redraw();
                } }
            ] });

            parts.push({ type: 'button', text: '+ Add blank thread', style: { width: '100%', marginBottom: '8px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {
                await addBlankWizardNarrative();
                await redraw();
            } });

            let dramaNarrIdx = await loadEntityIndex();
            let dramaNarratives = dramaNarrIdx.filter(function(n) { return n.type === 'narrative' && (n.narrativeParentId || null) === null; });
            if (dramaNarratives.length === 0) {
                parts.push({ type: 'text', text: 'No top-level threads yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });
            } else {
                dramaNarratives.forEach(function(nm) {
                    let nStateEmoji = nm.storyState === 'active' ? '🔥' : (nm.storyState === 'completed' ? '✅' : '🔒');
                    let nHintKey = STORAGE_WIZ_ITEM_HINT + nm.id;
                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: [
                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [
                            { type: 'text', text: nStateEmoji, style: { fontSize: '12px' } },
                            { type: 'textInput', initialValue: nm.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { let nf = await loadEntity(nm.id); if (nf) { nf.name = v; await saveEntity(nf); } } },
                            { type: 'button', iconId: 'edit', style: { margin: 0, padding: '2px' }, callback: async function() { await openEntityEditModal(nm.id); } },
                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {
                                await deleteEntity(nm.id);
                                await redraw();
                            } }
                        ] },
                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [
                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(nHintKey, v); } },
                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {
                                let nHint = await api.v1.tempStorage.getOrDefault(nHintKey, '') as string;
                                api.v1.ui.toast('Regenerating “' + nm.name + '”…', { id: 'wiz-narrreg', autoClose: false, type: 'info' });
                                let nr = await regenerateNarrativeThread(nm.id, dEffIds, nHint);
                                api.v1.ui.toast(nr ? ('Updated “' + nm.name + '”.') : 'Regeneration failed.', { id: 'wiz-narrreg', type: nr ? 'success' : 'error', autoClose: 2000 });
                                await redraw();
                            } }
                        ] }
                    ] });
                });
            }

        } else if (activeTab === 'intro') {
            // ── INTRO / OPENING (unified location picker, generate & insert) ──
            // [v0.9.86] Cast presence removed — set character locations in their character cards.
            let ikind = 'intro';
            let introLocId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;
            let introLocEnt = introLocId ? await loadEntity(introLocId) : null;
            if (introLocId && !introLocEnt) { introLocId = ''; await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, ''); }

            parts.push({ type: 'text', text: '🎬 Opening scene', style: { fontWeight: 'bold', fontSize: '13px', marginBottom: '2px' } });
            parts.push({ type: 'text', text: 'Choose the opening location and brainstorming context, then generate a draft opening. Review, edit, or regenerate it below before committing it into the story. Set which characters are present via their character cards.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '10px' } });

            // Location: unified picker button.
            parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '10px' }, content: [
                { type: 'text', text: '📍 Location:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },
                { type: 'button',
                  text: introLocEnt ? introLocEnt.name : 'Pick location…',
                  style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left',
                           backgroundColor: introLocEnt ? 'rgba(136,204,255,0.15)' : 'transparent',
                           color: introLocEnt ? '#88ccff' : 'rgba(255,255,255,0.5)',
                           border: '1px solid ' + (introLocEnt ? '#88ccff' : 'rgba(255,255,255,0.2)') },
                  callback: async function() {
                    let iLocIdx = (await loadEntityIndex()).filter(function(m) { return m.type === 'location'; });
                    let curILocId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;
                    await openPickerModal({
                        title: 'Intro location',
                        items: iLocIdx,
                        getId:       function(m) { return m.id; },
                        getLabel:    function(m) { return m.name; },
                        getIcon:     function(m) { return m.icon || '📍'; },
                        getSublabel: function(m) {
                            if (!m.parentId) return 'top-level';
                            let par = iLocIdx.find(function(x) { return x.id === m.parentId; });
                            return par ? ('in ' + par.name) : '';
                        },
                        selectedId:    curILocId || undefined,
                        emptyText:     'No locations yet — build some in the Locations tab first.',
                        pinnedOptions: curILocId ? [{ id: '__clear__', label: 'Clear selection', icon: '✕', onSelect: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, ''); await redraw(); } }] : [],
                        onSelect: async function(lm) { await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, lm.id); await redraw(); }
                    });
                  } } as UIPart
            ] });

            // Context sources (multi-select checkboxes).
            let iSrcKey = STORAGE_WIZ_TAB_SRC + ikind;
            let iStoredRaw = await api.v1.tempStorage.getOrDefault(iSrcKey, '') as string;
            let iStoredIds: string[] = [];
            try { let ipj = JSON.parse(iStoredRaw || '[]'); if (Array.isArray(ipj)) iStoredIds = ipj.filter(Boolean); } catch (eISrc) { iStoredIds = []; }
            iStoredIds = iStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });
            let iEffIds = iStoredIds.length ? iStoredIds : (active ? [active.id] : []);
            parts.push({ type: 'text', text: 'Context sources' + (iStoredIds.length ? '' : (active ? ' — using “' + active.title + '”' : ' — project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });
            if (chats.length > 0) {
                chats.forEach(function(pc) {
                    let onSrc = iStoredIds.indexOf(pc.id) >= 0;
                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {
                        let curRaw = await api.v1.tempStorage.getOrDefault(iSrcKey, '') as string;
                        let curIds: string[] = [];
                        try { let ipj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(ipj2)) curIds = ipj2.filter(Boolean); } catch (eISrc2) { curIds = []; }
                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);
                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });
                        await api.v1.tempStorage.set(iSrcKey, JSON.stringify(curIds));
                        await redraw();
                    } } as UIPart);
                });
            }

            // [v1.6.3 INTRO-STAGE] Staged workflow: generate a draft, review / edit / regenerate
            // it in-tab, then commit into the story — matching the other wizard tabs.
            let introDraft = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_DRAFT, null) as any;
            let introHasDraft = !!(introDraft && ((introDraft.prose || '') as string).trim());

            parts.push({ type: 'button', text: introHasDraft ? '🔄 Regenerate opening draft' : '🎬 Generate opening draft', style: { width: '100%', margin: '10px 0 0 0', fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.18)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
                let locPick = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;
                if (!locPick) { api.v1.ui.toast('Pick an intro location first.', { type: 'error', autoClose: 2500 }); return; }
                api.v1.ui.toast('Writing the opening…', { id: 'wiz-intro', autoClose: false, type: 'info' });
                let okGen = await generateIntroDraft(locPick, iEffIds);
                api.v1.ui.toast(okGen ? 'Draft ready — review and edit below.' : 'Intro generation failed.', { id: 'wiz-intro', type: okGen ? 'success' : 'error', autoClose: 3000 });
                await redraw();
            } });

            if (introHasDraft) {
                parts.push({ type: 'text', text: '📝 Draft opening — edit freely, then commit:', style: { fontSize: '11px', fontWeight: 'bold', marginTop: '12px', marginBottom: '4px', color: '#88ccff' } });
                parts.push({ type: 'multilineTextInput', initialValue: String(introDraft.prose || ''), placeholder: 'The opening prose\u2026', style: { minHeight: '160px', fontSize: '12px', lineHeight: '1.5' }, onChange: async function(v: string) {
                    let cur = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_DRAFT, null) as any;
                    if (!cur || typeof cur !== 'object') cur = { locationId: '', prose: '' };
                    cur.prose = v;
                    await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_DRAFT, cur).catch(function() {});
                } } as UIPart);
                parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginTop: '8px' }, content: [
                    { type: 'button', text: '\u2705 Commit to story', style: { flex: '2 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.22)', color: '#7ec8a0', border: '1px solid rgba(126,200,160,0.5)' }, disabledWhileCallbackRunning: true, callback: async function() {
                        api.v1.ui.toast('Inserting the opening\u2026', { id: 'wiz-intro-commit', autoClose: false, type: 'info' });
                        let okC = await commitIntroDraft();
                        api.v1.ui.toast(okC ? 'Opening inserted into the story.' : 'Commit failed.', { id: 'wiz-intro-commit', type: okC ? 'success' : 'error', autoClose: 3000 });
                        await redraw();
                    } },
                    { type: 'button', text: '\ud83d\uddd1 Discard', style: { flex: '1 1 0', margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() {
                        await api.v1.tempStorage.remove(STORAGE_WIZ_INTRO_DRAFT).catch(function() {});
                        api.v1.ui.toast('Draft discarded.', { type: 'info', autoClose: 1800 });
                        await redraw();
                    } }
                ] });
            }
        } else if (activeTab === 'help') {
            // ── HELP & RULES [v0.9.8.3] ──────────────────────────────────────────────────────────────
            parts.push({ type: 'text', text: 'Risky actions are resolved by rolling 2d6 and adding the modifier from whichever of the Four Fs the action calls on. The result lands in one of three bands that quietly tell the AI how the scene turns out.', style: { fontSize: '12px', opacity: '0.75', lineHeight: '1.5', marginBottom: '10px' } });

            // — Four Fs —
            parts.push({ type: 'collapsibleSection', title: 'The Four Fs', iconId: 'user', initialCollapsed: false, storageKey: 'temp:wiz_help_fourfs', content: [
                { type: 'text', text: 'Every action leans on one attribute. The character\'s rating in that attribute is the modifier added to the 2d6 roll.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } },
                { type: 'row', style: { flexWrap: 'wrap', gap: '6px' }, content: [
                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(136,204,255,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(136,204,255,0.4)' }, content: [
                        { type: 'text', text: 'Force', style: { fontWeight: 'bold', color: '#88ccff', marginBottom: '3px' } },
                        { type: 'text', text: 'Raw power and direct pressure — breaking, lifting, intimidating, overpowering, enduring.', style: { fontSize: '10px', opacity: '0.8' } }
                    ] } as UIPart,
                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(126,200,160,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(126,200,160,0.4)' }, content: [
                        { type: 'text', text: 'Finesse', style: { fontWeight: 'bold', color: '#7ec8a0', marginBottom: '3px' } },
                        { type: 'text', text: 'Precision and control — sleight of hand, stealth, agility, aim, delicate work.', style: { fontSize: '10px', opacity: '0.8' } }
                    ] } as UIPart,
                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(232,168,124,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(232,168,124,0.4)' }, content: [
                        { type: 'text', text: 'Focus', style: { fontWeight: 'bold', color: '#e8a87c', marginBottom: '3px' } },
                        { type: 'text', text: 'Mind and will — perception, recall, analysis, concentration, resolve.', style: { fontSize: '10px', opacity: '0.8' } }
                    ] } as UIPart,
                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(200,126,200,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(200,126,200,0.4)' }, content: [
                        { type: 'text', text: 'Flair', style: { fontWeight: 'bold', color: '#c87ec8', marginBottom: '3px' } },
                        { type: 'text', text: 'Presence and charm — persuasion, performance, deception, style, improvisation.', style: { fontSize: '10px', opacity: '0.8' } }
                    ] } as UIPart
                ] }
            ] as any });

            // — Stakes —
            parts.push({ type: 'collapsibleSection', title: '2d6 + Modifier (Stakes)', iconId: 'activity', initialCollapsed: false, storageKey: 'temp:wiz_help_stakes', content: [
                { type: 'text', text: 'Roll 2d6 and add the relevant F. Higher is better. Even a failure pushes the story forward. A staked resource shifts on partial or strong results.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } },
                { type: 'box', style: { padding: '7px', marginBottom: '4px', backgroundColor: 'rgba(0,0,0,0.25)', borderRadius: '6px', borderLeft: '3px solid #e74c4c' }, content: [
                    { type: 'text', text: '2–6  Failure', style: { fontWeight: 'bold', color: '#e74c4c', marginBottom: '3px' } },
                    { type: 'text', text: 'The attempt fails. Describe the setback honestly — let it create a complication.', style: { fontSize: '11px', opacity: '0.8' } }
                ] } as UIPart,
                { type: 'box', style: { padding: '7px', marginBottom: '4px', backgroundColor: 'rgba(0,0,0,0.25)', borderRadius: '6px', borderLeft: '3px solid #e0b341' }, content: [
                    { type: 'text', text: '7–9  Partial Success', style: { fontWeight: 'bold', color: '#e0b341', marginBottom: '3px' } },
                    { type: 'text', text: 'Success at a cost. Describe what the protagonist must risk, pay, or sacrifice.', style: { fontSize: '11px', opacity: '0.8' } }
                ] } as UIPart,
                { type: 'box', style: { padding: '7px', backgroundColor: 'rgba(0,0,0,0.25)', borderRadius: '6px', borderLeft: '3px solid #7ec8a0' }, content: [
                    { type: 'text', text: '10+  Strong Hit', style: { fontWeight: 'bold', color: '#7ec8a0', marginBottom: '3px' } },
                    { type: 'text', text: 'Clean success — no cost, no complication.', style: { fontSize: '11px', opacity: '0.8' } }
                ] } as UIPart
            ] as any });

            // — Test Roller (state via tempStorage so it survives redraws) —
            let rollMod = await api.v1.tempStorage.getOrDefault('temp:wiz_help_mod', 0) as number;
            let rollD1  = await api.v1.tempStorage.getOrDefault('temp:wiz_help_d1',  0) as number;
            let rollD2  = await api.v1.tempStorage.getOrDefault('temp:wiz_help_d2',  0) as number;
            let hasRolled = rollD1 > 0 && rollD2 > 0;
            let rollTotal = rollD1 + rollD2 + rollMod;
            let rDist: number[] = [0, 0, 1, 2, 3, 4, 5, 6, 5, 4, 3, 2, 1];
            let rFail = 0, rPart = 0, rStrong = 0;
            for (let rs = 2; rs <= 12; rs++) { let rt = rs + rollMod; let rc = rDist[rs]; if (rt <= 6) rFail += rc; else if (rt <= 9) rPart += rc; else rStrong += rc; }
            let rPct = function(n: number) { return (Math.round(n * 1000 / 36) / 10).toFixed(1); };
            let rBandLabel = rollTotal <= 6 ? 'Failure' : rollTotal <= 9 ? 'Partial Success' : 'Strong Hit';
            let rBandColor = rollTotal <= 6 ? '#e74c4c' : rollTotal <= 9 ? '#e0b341' : '#7ec8a0';
            let modDisp = rollMod === 0 ? '±0' : (rollMod > 0 ? '+' + rollMod : String(rollMod));
            let modStr3 = rollMod === 0 ? '' : (rollMod > 0 ? ' +' + rollMod : ' ' + rollMod);
            let rollerParts: UIPart[] = [
                { type: 'text', text: 'Sandbox — changes nothing in your story. Adjust the modifier and roll to see the outcome band.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } },
                { type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '4px' }, content: [
                    { type: 'button', text: '−', style: { margin: 0, padding: '2px 12px', fontSize: '16px', fontWeight: 'bold' }, callback: async function() { await api.v1.tempStorage.set('temp:wiz_help_mod', Math.max(-6, rollMod - 1)); await redraw(); } },
                    { type: 'text', text: 'Modifier ' + modDisp, style: { fontSize: '14px', fontWeight: 'bold', minWidth: '90px', textAlign: 'center' } },
                    { type: 'button', text: '+', style: { margin: 0, padding: '2px 12px', fontSize: '16px', fontWeight: 'bold' }, callback: async function() { await api.v1.tempStorage.set('temp:wiz_help_mod', Math.min(6, rollMod + 1)); await redraw(); } }
                ] },
                { type: 'text', text: 'fail ' + rPct(rFail) + '% · partial ' + rPct(rPart) + '% · strong ' + rPct(rStrong) + '%', style: { fontSize: '10px', opacity: '0.55', textAlign: 'center', marginBottom: '8px' } },
                { type: 'button', text: 'Roll 2d6', iconId: 'zap', style: { width: '100%', fontSize: '13px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.18)', color: '#88ccff', marginBottom: '6px' }, callback: async function() {
                    let d1r = Math.floor(Math.random() * 6) + 1;
                    let d2r = Math.floor(Math.random() * 6) + 1;
                    await api.v1.tempStorage.set('temp:wiz_help_d1', d1r);
                    await api.v1.tempStorage.set('temp:wiz_help_d2', d2r);
                    await redraw();
                } },
                hasRolled
                    ? ({ type: 'text', text: rollD1 + ' + ' + rollD2 + modStr3 + ' = ' + rollTotal + '  →  ' + rBandLabel, style: { fontSize: '15px', fontWeight: 'bold', textAlign: 'center', color: rBandColor } } as UIPart)
                    : ({ type: 'text', text: 'Roll to see the result.', style: { fontSize: '12px', opacity: '0.35', textAlign: 'center', fontStyle: 'italic' } } as UIPart)
            ];
            parts.push({ type: 'collapsibleSection', title: 'Test Roller', iconId: 'zap', initialCollapsed: false, storageKey: 'temp:wiz_help_roller', content: rollerParts } as any);

            // — Icon Library —
            let iconIds: string[] = ['play','pause','save','download','upload','edit','delete','trash','add','plus','settings','info','warning','error','alert','success','check','home','user','search','refresh','reload','copy','eye','eye-off','hide','show','lock','unlock','mail','email','file','folder','image','code','send','close','x','chevron-right','chevron-left','chevron-up','chevron-down','right','left','up','down','list','grid','star','heart','favorite','filter','calendar','clock','time','zap','lightning','square','hexagon','help','trending-up','trending-down','file-minus','file-plus','file-text','folder-plus','folder-minus','activity','alertOctagon','alertTriangle','align-center','align-justify','align-left','align-right','anchor','archive','arrow-down','arrow-down-circle','arrow-down-left','arrow-down-right','arrow-left','arrow-left-circle','arrow-right','arrow-right-circle','arrow-up','arrow-up-circle','arrow-up-left','arrow-up-right','at-sign','award','bar-chart','bar-chart-2','battery','batteryCharging','bell','bell-off','bold','book','bookOpen','bookmark','box','breifcase','camera','cameraOff','check-circle','check-square','chevrons-down','chevrons-left','chevrons-right','chevrons-up','circle','clipboard','cloud','cloud-drizzle','cloud-lightning','cloud-off','cloud-rain','cloud-snow','coffee','columns','command','compass','corner-down-left','corner-down-right','corner-left-down','corner-left-up','corner-right-down','corner-right-up','corner-up-left','corner-up-right','cpu','crop','crosshair','database','disc','divide','divide-circle','divide-square','dollar-sign','download-cloud','droplet','edit-2','edit-3','external-link','fast-forward','feather','film','flag','frown','gift','globe','hard-drive','hash','headphones','help-circle','inbox','italic','key','layers','layout','life-buoy','link','link-2','loader','login','logout','map','map-pin','maximize','maximize-2','meh','menu','message-circle','message-square','mic','mic-off','minimize','minimize-2','minus','minus-circle','minus-square','monitor','moon','more-horizontal','more-vertical','mouse-pointer','move','music','navigation-2','navigation','octagon','package','paperclip','pause-circle','pen-tool','percent','phone','pie-chart','play-circle','plus-circle','plus-square','pocket','power','printer','radio','refresh-cw','refresh-ccw','repeat','rewind','rotate-ccw','rotate-cw','rss','scissors','server','share','share-2','shield','shield-off','shopping-bag','shopping-cart','shuffle','sidebar','skip-back','skip-forward','slash','sliders','smartphone','smile','speaker','stop-circle','sun','sunrise','sunset','tablet','tag','target','terminal','thermometer','thumbs-down','thumbs-up','toggle-left','toggle-right','tool','trash-2','triangle','truck','tv','type','x-square','x-octagon','zap-off','zoom-in','zoom-out'];
            let iconBtns: UIPart[] = iconIds.map(function(ic) {
                return { type: 'button', iconId: ic as any, text: ic, style: { margin: '2px', fontSize: '10px', padding: '3px 7px', textAlign: 'left', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '4px', opacity: '0.8' }, callback: async function() {} } as UIPart;
            });
            parts.push({ type: 'collapsibleSection', title: 'Icon Library (' + iconIds.length + ' icons)', iconId: 'grid', initialCollapsed: true, storageKey: 'temp:wiz_help_icons', content: [
                { type: 'text', text: 'All Feather icons available via the NAI iconId enum. Use these string values for iconId on tabs, buttons, and collapsible sections.', style: { fontSize: '10px', opacity: '0.6', marginBottom: '8px' } },
                { type: 'row', style: { flexWrap: 'wrap', gap: '2px' }, content: iconBtns }
            ] as any });
        }
        return parts;
    }

    let initialContent = await buildWizardContent();
    pm = await openEngineModal({ id: 'ae-wizard', title: 'World-Build Wizard', size: 'large', content: initialContent });
}

async function openWorldbuildingModal(): Promise<void> {
    if (worldbuildingModalHandle && !worldbuildingModalHandle.isClosed()) worldbuildingModalHandle.close();
    worldbuildingModalHandle = await openEngineModal({ id: 'ae-worldbuilding', size: 'full', fillWidth: true, title: '🌍 Adventure Engine: Worldbuilding', content: await buildWorldbuildingContent() });
}

async function buildWorldbuildingContent(): Promise<UIPart[]> {
    const cfg = await loadConfig(); const parts: UIPart[] = [];

    // 1. Introduction
    parts.push({ type: 'collapsibleSection', title: '📖 Introduction & Setup', initialCollapsed: false, storageKey: 'temp:wb_intro', content: [
        { type: 'text', text: 'Welcome to Adventure Engine!', style: { fontWeight: 'bold', fontSize: '14px', marginBottom: '8px', color: '#88ccff' } },
        { type: 'text', text: '1. A toast should have popped up saying the bridge connected, and a 🗺️AE widget should appear to open the HUD. If it doesn\'t after refreshing the browser, notify AmbiProp on the NovelAI Discord for troubleshooting.', style: { fontSize: '12px', marginBottom: '6px' } },
        { type: 'text', text: '2. The settings below let you define the rules, species, factions, and sheet categories of your world.', style: { fontSize: '12px', marginBottom: '6px' } },
        { type: 'text', text: '3. Character data is recorded in the Characters tab, but their physical "body" is automatically created in the Worlds tab. The player interacts via the HUD and also has a body in the world graph.', style: { fontSize: '12px', marginBottom: '6px' } },
        { type: 'text', text: '4. Check the ⚙️ Settings menu for configurable generation and timing behaviors.', style: { fontSize: '12px', marginBottom: '6px' } },
        { type: 'text', text: '5. The Worlds tab uses a nested, nodular hierarchy. Locations can contain items, narratives, and characters. You navigate this tree to build your map.', style: { fontSize: '12px', marginBottom: '6px' } },
        { type: 'text', text: '6. The Actions tab provides interactive mechanics that roll dice against stats and execute outcomes.', style: { fontSize: '12px', marginBottom: '6px' } },
        { type: 'text', text: '7. All player interfaces, player character info, and images exist inside the Bridge HUD.', style: { fontSize: '12px', marginBottom: '6px' } },
        { type: 'text', text: '💡 Suggestion: Start by creating a character, then go to the Worlds tab to see where they (and you) are located. Explore the HUD to see how it reflects the character and worlds tabs!', style: { fontSize: '12px', fontStyle: 'italic', marginTop: '8px', color: '#e8a87c' } }
    ]});

    // 2. Species
    parts.push({ type: 'collapsibleSection', title: `🧬 Species (${(cfg.species || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_species', content: await (async function() {
        const spParts: UIPart[] = [];
        spParts.push({ type: 'text', text: 'Define species available as a selector on character cards. Create lorebook entries to give the AI detailed knowledge of each.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        for (var si = 0; si < (cfg.species || []).length; si++) {
            var sp = cfg.species[si];
            var captSi = si; var captSpId = sp.id;
            
            const tmpSpKey = `wb_tmp_sp_${captSpId}`;
            const spLbContent: UIPart[] = [];
            if (sp.lorebookEntryId) {
                spLbContent.push(
                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },
                    { type: 'text', text: `Keys: ${getSpeciesLorebookKeys(sp).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },
                    { type: 'row', style: { gap: '6px' }, content: [
                        { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncSpeciesLorebookEntry(captSpId); } },
                        { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { await unlinkSpeciesLorebookEntry(captSpId); await refreshWorldbuildingModal(); } }
                    ] }
                );
            } else {
                spLbContent.push(
                    { type: 'text', text: "No lorebook entry. Create one to inject this species' profile.", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
                    { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await createLinkedSpeciesLorebookEntry(captSpId); await refreshWorldbuildingModal(); } }
                );
            }
            spLbContent.push({ type: 'text', text: 'Trigger Keys:', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });
            (sp.lorebookTags || []).forEach(function(tg, ti) {
                spLbContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                    { type: 'text', text: '• ' + tg, style: { flex: '1 1 0', fontSize: '12px' } },
                    { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { await mutConfig(function(c) { c.species[captSi].lorebookTags!.splice(ti, 1); }); await refreshWorldbuildingModal(); } }
                ] } as UIPart);
            });
            spLbContent.push({ type: 'row', style: { gap: '4px' }, content: [
                { type: 'textInput', placeholder: 'Add key...', storageKey: `temp:${tmpSpKey}`, style: { flex: '1 1 0' } },
                { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpSpKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c) { if (!c.species[captSi].lorebookTags) c.species[captSi].lorebookTags = []; if (!c.species[captSi].lorebookTags!.includes(v.trim())) c.species[captSi].lorebookTags!.push(v.trim()); }); await api.v1.tempStorage.remove(tmpSpKey); await refreshWorldbuildingModal(); } }
            ] });

            spParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #88ccff' }, content: [
                { type: 'textInput', label: 'Name', initialValue: sp.name || '', onChange: async function(v: string) { await mutConfig(function(c) { c.species[captSi].name = v; }); } },
                { type: 'multilineTextInput', label: 'Description', initialValue: sp.description || '', style: { minHeight: '40px', marginTop: '4px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.species[captSi].description = v; }); } },
                { type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: spLbContent },
                { type: 'button', text: 'Delete Species', style: { marginTop: '8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { await mutConfig(function(c) { c.species.splice(captSi, 1); }); await refreshWorldbuildingModal(); } }
            ] } as UIPart);
        }
        if ((cfg.species || []).length === 0) spParts.push({ type: 'text', text: 'No species defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });
        spParts.push({ type: 'button', text: '+ Add Species', style: { marginTop: '4px', width: '100%', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.species) c.species = []; c.species.push({ id: 'sp_' + Date.now(), name: 'New Species', description: '', lorebookTags: [] }); }); await refreshWorldbuildingModal(); } });
        return spParts;
    })() });

    // 3. Factions
    parts.push({ type: 'collapsibleSection', title: `⚔️ Factions (${(cfg.factions || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_factions', content: await (async function() {
        const facParts: UIPart[] = [];
        facParts.push({ type: 'text', text: 'Define factions and their relationship tracks. The player\'s standing with each faction is set on the Player tab.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        for (var fci = 0; fci < (cfg.factions || []).length; fci++) {
            var fac = cfg.factions[fci];
            var captFci = fci; var captFacId = fac.id;
            
            const tmpFacKey = `wb_tmp_fac_${captFacId}`;
            const facLbContent: UIPart[] = [];
            if (fac.lorebookEntryId) {
                facLbContent.push(
                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },
                    { type: 'text', text: `Keys: ${getFactionLorebookKeys(fac).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },
                    { type: 'row', style: { gap: '6px' }, content: [
                        { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncFactionLorebookEntry(captFacId); } },
                        { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { await unlinkFactionLorebookEntry(captFacId); await refreshWorldbuildingModal(); } }
                    ] }
                );
            } else {
                facLbContent.push(
                    { type: 'text', text: "No lorebook entry. Create one to inject this faction's profile.", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
                    { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await createLinkedFactionLorebookEntry(captFacId); await refreshWorldbuildingModal(); } }
                );
            }
            facLbContent.push({ type: 'text', text: 'Trigger Keys:', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });
            (fac.lorebookTags || []).forEach(function(tg, ti) {
                facLbContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                    { type: 'text', text: '• ' + tg, style: { flex: '1 1 0', fontSize: '12px' } },
                    { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { await mutConfig(function(c) { c.factions[captFci].lorebookTags!.splice(ti, 1); }); await refreshWorldbuildingModal(); } }
                ] } as UIPart);
            });
            facLbContent.push({ type: 'row', style: { gap: '4px' }, content: [
                { type: 'textInput', placeholder: 'Add key...', storageKey: `temp:${tmpFacKey}`, style: { flex: '1 1 0' } },
                { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpFacKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c) { if (!c.factions[captFci].lorebookTags) c.factions[captFci].lorebookTags = []; if (!c.factions[captFci].lorebookTags!.includes(v.trim())) c.factions[captFci].lorebookTags!.push(v.trim()); }); await api.v1.tempStorage.remove(tmpFacKey); await refreshWorldbuildingModal(); } }
            ] });

            facParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #e8a87c' }, content: [
                { type: 'textInput', label: 'Name', initialValue: fac.name || '', onChange: async function(v: string) { await mutConfig(function(c) { c.factions[captFci].name = v; }); } },
                { type: 'multilineTextInput', label: 'Description', initialValue: fac.description || '', style: { minHeight: '40px', marginTop: '4px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.factions[captFci].description = v; }); } },
                { type: 'text', text: 'Relationship States (cold \u2192 warm):', style: { fontSize: '11px', opacity: '0.6', marginTop: '4px', marginBottom: '2px' } },
                aeRenderIndexedStatesEditor(fac.relationshipStates || [], async function(next) { await mutConfig(function(c) { c.factions[captFci].relationshipStates = next; }); }, refreshWorldbuildingModal, 'Standing'),
                { type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: facLbContent },
                { type: 'button', text: 'Delete Faction', style: { marginTop: '8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { await mutConfig(function(c) { c.factions.splice(captFci, 1); }); await refreshWorldbuildingModal(); } }
            ] } as UIPart);
        }
        if ((cfg.factions || []).length === 0) facParts.push({ type: 'text', text: 'No factions defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });
        facParts.push({ type: 'button', text: '+ Add Faction', style: { marginTop: '4px', width: '100%', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.factions) c.factions = []; c.factions.push({ id: 'fac_' + Date.now(), name: 'New Faction', description: '', relationshipStates: ['Hostile', 'Wary', 'Neutral', 'Friendly', 'Allied'], lorebookTags: [] }); }); await refreshWorldbuildingModal(); } });
        return facParts;
    })() });

    // 4. Relationship Archetypes
    function buildPresetSection(title: string, items: string[], skBase: string, addKey: string, onAdd: (v: string, c: GlobalConfig) => void, onRemove: (i: number, c: GlobalConfig) => void): UIPart {
        const rows: UIPart[] = items.filter(Boolean).map(function(item, i) {
            const pi = i;
            return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                { type: 'text', text: item, style: { flex: '1 1 0', fontSize: '12px' } },
                { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { await mutConfig(function(c){ onRemove(pi, c); }); await refreshWorldbuildingModal(); } }
            ] } as UIPart;
        });
        rows.push({ type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [
            { type: 'textInput', placeholder: `Add ${title}…`, storageKey: `temp:${addKey}`, style: { flex: '1 1 0' } },
            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(addKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c){ onAdd(v.trim(), c); }); await api.v1.tempStorage.remove(addKey); await refreshWorldbuildingModal(); } }
        ] } as UIPart);
        return { type: 'collapsibleSection', title, initialCollapsed: true, storageKey: `temp:${skBase}`, content: rows };
    }
    parts.push({ type: 'collapsibleSection', title: `💞 Relationship Archetypes (${(cfg.relationshipArchetypes || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_rels', content: (function() {
        const archParts: UIPart[] = [];
        archParts.push({ type: 'text', text: 'Each archetype has an ordered stage progression (cold → warm). Actions can set the archetype and advance/retreat the stage. Leave stages blank for a label-only archetype.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        (cfg.relationshipArchetypes || []).forEach(function(def, i) {
            const ai = i;
            archParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #d88fc0' }, content: [
                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                    { type: 'textInput', initialValue: def.name, placeholder: 'Archetype name', style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.relationshipArchetypes[ai].name = v; }); } },
                    { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.relationshipArchetypes.splice(ai, 1); }); await refreshWorldbuildingModal(); } }
                ] },
                { type: 'text', text: 'Stages (cold \u2192 warm):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },
                aeRenderIndexedStatesEditor(def.stages || [], async function(next) { await mutConfig(function(c) { c.relationshipArchetypes[ai].stages = next; }); }, refreshWorldbuildingModal, 'Stage')
            ] } as UIPart);
        });
        if (!(cfg.relationshipArchetypes || []).length) archParts.push({ type: 'text', text: 'No archetypes defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });
        archParts.push({ type: 'button', text: '+ Add Archetype', style: { width: '100%', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.relationshipArchetypes.push({ id: 'arch_' + Date.now(), name: 'New Archetype', stages: ['Stage 1', 'Stage 2', 'Stage 3'] }); }); await refreshWorldbuildingModal(); } });
        return archParts;
    })() });

    // 5. Global Resources
    parts.push({ type: 'collapsibleSection', title: `📦 Global Resources (${(cfg.resources || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_res', content: await (async function() {
        const resParts: UIPart[] = [];
        resParts.push({ type: 'text', text: 'Configure resource bounds and tracks.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });

        for (let i = 0; i < (cfg.resources || []).length; i++) {
            const res = cfg.resources[i];
            const editorParts: UIPart[] = [];

            editorParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'textInput', label: 'Name', initialValue: res.name || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].name = v; }); } },
                { type: 'textInput', label: 'Tag', initialValue: res.tag || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].tag = v; }); } },
                { type: 'textInput', label: 'Icon', placeholder: '💎', initialValue: res.icon || '', style: { width: '52px', flexShrink: '0', textAlign: 'center' }, onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].icon = v.trim() || undefined; }); } }
            ] });
            editorParts.push({ type: 'button', text: 'Delete Resource', style: { margin: '0 0 8px 0', backgroundColor: 'transparent', color: '#ff6b6b', border: '1px solid #ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.resources.splice(i, 1); }); await refreshWorldbuildingModal(); } });

            if (res.type === 'pool') {
                editorParts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [
                    { type: 'textInput', label: 'Minimum', initialValue: res.min !== undefined ? res.min.toString() : '0', onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].min = parseInt(v, 10) || 0; }); } },
                    { type: 'textInput', label: 'Maximum', initialValue: res.max !== undefined ? res.max.toString() : '100', onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].max = parseInt(v, 10) || 100; }); } }
                ] });
            } else if (res.type === 'track') {
                // [PATCH v0998] indexed editor replaces the comma-separated field —
                // the index is always visible, so authors (and conditions/effects
                // referencing this track by index) never have to count commas.
                editorParts.push({ type: 'text', text: 'States (low \u2192 high):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });
                editorParts.push(aeRenderIndexedStatesEditor(res.states || [], async function(next) { await mutConfig(function(c) { c.resources[i].states = next; }); }, refreshWorldbuildingModal, 'State'));
                editorParts.push({ type: 'text', text: 'Example: Rested, Tired, Exhausted', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });
            } else if (res.type === 'discrete') {
                editorParts.push({ type: 'text', text: 'Conditions:', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });
                editorParts.push(aeRenderIndexedStatesEditor(res.states || [], async function(next) { await mutConfig(function(c) { c.resources[i].states = next; }); }, refreshWorldbuildingModal, 'Condition'));
                editorParts.push({ type: 'text', text: 'First entry (index 0) = clear/none (bridge hides when index 0). Example: None, Poisoned, Cursed, Blessed', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });
            }
            let resBorderCol = res.type === 'pool' ? '3px solid #88ccff' : res.type === 'track' ? '3px solid #e8a87c' : '3px solid #b388ff';
            resParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: resBorderCol }, content: editorParts } as UIPart);
        }

        if (cfg.resources.length === 0) resParts.push({ type: 'text', text: 'No resources defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });

        resParts.push({ type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [
            { type: 'button', text: '+ Add Pool', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.resources.push({ id: 'res_' + Date.now(), name: 'New Pool', type: 'pool', tag: '#new_pool', hasBounds: true, min: 0, max: 100 }); }); await refreshWorldbuildingModal(); } },
            { type: 'button', text: '+ Add Track', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.resources.push({ id: 'res_' + Date.now(), name: 'New Track', type: 'track', tag: '#new_track', hasBounds: false, states: ['State 1', 'State 2', 'State 3'] }); }); await refreshWorldbuildingModal(); } },
            { type: 'button', text: '+ Add Condition', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.resources.push({ id: 'res_' + Date.now(), name: 'New Condition', type: 'discrete', tag: '#condition', hasBounds: false, states: ['None', 'State 1', 'State 2'] }); }); await refreshWorldbuildingModal(); } }
        ] });
        return resParts;
    })() });

    // 5a2. [v0.9.9.2] Time & Calendar
    parts.push({ type: 'collapsibleSection', title: '\ud83d\udd52 Time & Calendar', initialCollapsed: true, storageKey: 'temp:wb_cfg_time', content: await (async function() {
        const tParts: UIPart[] = [];
        tParts.push({ type: 'text', text: 'A 28-day cycle (4 weeks x 7 days) over a 24-hour clock. The clock tracks whole hours; bands are named views layered on top.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });

        let _tShow = (cfg.timeShowInAN !== false);
        tParts.push({ type: 'button', text: (_tShow ? 'Show date in story context: ON' : 'Show date in story context: OFF'), style: { width: '100%', marginBottom: '4px', fontSize: '11px', backgroundColor: (_tShow ? 'rgba(136,204,255,0.12)' : 'rgba(255,255,255,0.04)'), color: (_tShow ? '#88ccff' : '#a8a8b8') }, callback: async function() { await mutConfig(function(c) { c.timeShowInAN = (c.timeShowInAN === false); }); await refreshWorldbuildingModal(); } });

        tParts.push({ type: 'textInput', label: 'Fresh-story start hour (0-23)', initialValue: String(cfg.timeStartHours !== undefined ? cfg.timeStartHours : 8), onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); c.timeStartHours = isNaN(n) ? 8 : Math.max(0, Math.min(23, n)); }); } });

        let _tAuto = (cfg.timeAutoAdvanceEnabled === true);
        tParts.push({ type: 'button', text: (_tAuto ? 'Auto-advance each turn: ON' : 'Auto-advance each turn: OFF'), style: { width: '100%', margin: '6px 0 4px 0', fontSize: '11px', backgroundColor: (_tAuto ? 'rgba(166,227,161,0.14)' : 'rgba(255,255,255,0.04)'), color: (_tAuto ? '#a6e3a1' : '#a8a8b8') }, callback: async function() { await mutConfig(function(c) { c.timeAutoAdvanceEnabled = !(c.timeAutoAdvanceEnabled === true); }); await refreshWorldbuildingModal(); } });
        tParts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [
            { type: 'textInput', label: 'Hours per tick', initialValue: String(cfg.timeAdvanceHours !== undefined ? cfg.timeAdvanceHours : 1), onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); c.timeAdvanceHours = (isNaN(n) || n < 1) ? 1 : n; }); } },
            { type: 'textInput', label: 'Every N generations', initialValue: String(cfg.timeAdvanceEveryGens !== undefined ? cfg.timeAdvanceEveryGens : 3), onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); c.timeAdvanceEveryGens = (isNaN(n) || n < 1) ? 3 : n; }); } }
        ] });

        tParts.push({ type: 'text', text: 'Time bands (named hour ranges; a band whose start is later than its end wraps past midnight, e.g. 22 to 6):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '4px' } });
        if (!cfg.timeBands) cfg.timeBands = [];
        for (let bi = 0; bi < cfg.timeBands.length; bi++) {
            const bnd = cfg.timeBands[bi];
            tParts.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [
                { type: 'textInput', label: 'Band', initialValue: bnd.label || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { if (c.timeBands && c.timeBands[bi]) c.timeBands[bi].label = v; }); } },
                { type: 'textInput', label: 'From', initialValue: String(bnd.startHour), style: { width: '54px', flexShrink: '0' }, onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); if (c.timeBands && c.timeBands[bi]) c.timeBands[bi].startHour = isNaN(n) ? 0 : ((n % 24 + 24) % 24); }); } },
                { type: 'textInput', label: 'To', initialValue: String(bnd.endHour), style: { width: '54px', flexShrink: '0' }, onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); if (c.timeBands && c.timeBands[bi]) c.timeBands[bi].endHour = isNaN(n) ? 0 : ((n % 24 + 24) % 24); }); } },
                { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() { await mutConfig(function(c) { if (c.timeBands) c.timeBands.splice(bi, 1); }); await refreshWorldbuildingModal(); } }
            ] });
        }
        tParts.push({ type: 'button', text: '+ Add Band', style: { width: '100%', marginBottom: '8px', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.timeBands) c.timeBands = []; c.timeBands.push({ label: 'New Band', startHour: 0, endHour: 6 }); }); await refreshWorldbuildingModal(); } });

        tParts.push({ type: 'textInput', label: 'Weekday names (7, comma-separated; blank = Day N)', initialValue: (cfg.timeDayNames || []).join(', '), onChange: async function(v: string) { await mutConfig(function(c) { c.timeDayNames = v.split(',').map(function(s) { return s.trim(); }).filter(Boolean).slice(0, 7); }); } });
        tParts.push({ type: 'textInput', label: 'Week names (4, comma-separated; blank = Week N)', initialValue: (cfg.timeWeekNames || []).join(', '), style: { marginBottom: '8px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.timeWeekNames = v.split(',').map(function(s) { return s.trim(); }).filter(Boolean).slice(0, 4); }); } });

        if (cfg.tierTravelDefaults && cfg.tierTravelDefaults.length) {
            tParts.push({ type: 'text', text: 'Travel time cost per tier (hours added to the clock on entering a location at that tier):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '4px' } });
            for (let ti = 0; ti < cfg.tierTravelDefaults.length; ti++) {
                const tier = cfg.tierTravelDefaults[ti];
                tParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                    { type: 'text', text: tier.label || ('Tier ' + ti), style: { flex: '1 1 0', fontSize: '11px' } },
                    { type: 'textInput', label: 'Hours', initialValue: String(tier.timeCostHours || 0), style: { width: '72px', flexShrink: '0' }, onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); if (c.tierTravelDefaults && c.tierTravelDefaults[ti]) { c.tierTravelDefaults[ti].timeCostHours = (isNaN(n) || n < 0) ? 0 : n; syncTierTemplate(c, ti); } }); } }
                ] });
            }
        }

        return tParts;
    })() });

    // 5b. [v0.9.69] Character Resources — configurable template for personal (per-character)
    // resources. New characters are seeded from this automatically; Sync adds any missing
    // template resources to characters that predate a template change.
    parts.push({ type: 'collapsibleSection', title: `\ud83e\uddec Character Resources (${(cfg.characterResourceDefs || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_cres', content: await (async function() {
        const cresParts: UIPart[] = [];
        cresParts.push({ type: 'text', text: 'Personal resources every new character starts with (e.g. Health, Wealth, Luck). Edit freely \u2014 a resource here is skipped for a character if a Global Resource already uses the same tag.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });
        if (!cfg.characterResourceDefs) cfg.characterResourceDefs = [];

        for (let ci = 0; ci < cfg.characterResourceDefs.length; ci++) {
            const cres = cfg.characterResourceDefs[ci];
            const cEditorParts: UIPart[] = [];

            cEditorParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [
                { type: 'textInput', label: 'Name', initialValue: cres.name || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].name = v; }); } },
                { type: 'textInput', label: 'Tag', initialValue: cres.tag || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].tag = v; }); } }
            ] });
            cEditorParts.push({ type: 'button', text: 'Delete Resource', style: { margin: '0 0 8px 0', backgroundColor: 'transparent', color: '#ff6b6b', border: '1px solid #ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.splice(ci, 1); }); await refreshWorldbuildingModal(); } });

            if (cres.type === 'pool') {
                cEditorParts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [
                    { type: 'textInput', label: 'Minimum', initialValue: cres.min !== undefined ? cres.min.toString() : '0', onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].min = parseInt(v, 10) || 0; }); } },
                    { type: 'textInput', label: 'Maximum', initialValue: cres.max !== undefined ? cres.max.toString() : '100', onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].max = parseInt(v, 10) || 100; }); } }
                ] });
            } else if (cres.type === 'track') {
                cEditorParts.push({ type: 'text', text: 'States (low \u2192 high):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });
                cEditorParts.push(aeRenderIndexedStatesEditor(cres.states || [], async function(next) { await mutConfig(function(c) { c.characterResourceDefs[ci].states = next; }); }, refreshWorldbuildingModal, 'State'));
            } else if (cres.type === 'discrete') {
                cEditorParts.push({ type: 'text', text: 'Conditions:', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });
                cEditorParts.push(aeRenderIndexedStatesEditor(cres.states || [], async function(next) { await mutConfig(function(c) { c.characterResourceDefs[ci].states = next; }); }, refreshWorldbuildingModal, 'Condition'));
            }
            let cresBorderCol = cres.type === 'pool' ? '3px solid #88ccff' : cres.type === 'track' ? '3px solid #e8a87c' : '3px solid #b388ff';
            cresParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: cresBorderCol }, content: cEditorParts } as UIPart);
        }

        if (cfg.characterResourceDefs.length === 0) cresParts.push({ type: 'text', text: 'No character resources defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });

        cresParts.push({ type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [
            { type: 'button', text: '+ Add Pool', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.push({ id: 'cres_' + Date.now(), name: 'New Pool', type: 'pool', tag: '#new_pool', hasBounds: true, min: 0, max: 100 }); }); await refreshWorldbuildingModal(); } },
            { type: 'button', text: '+ Add Track', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.push({ id: 'cres_' + Date.now(), name: 'New Track', type: 'track', tag: '#new_track', hasBounds: true, states: ['State 1', 'State 2', 'State 3'] }); }); await refreshWorldbuildingModal(); } },
            { type: 'button', text: '+ Add Condition', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.push({ id: 'cres_' + Date.now(), name: 'New Condition', type: 'discrete', tag: '#condition', hasBounds: false, states: ['None', 'State 1', 'State 2'] }); }); await refreshWorldbuildingModal(); } }
        ] });
        cresParts.push({ type: 'button', text: '\ud83d\udd04 Sync to All Characters', style: { width: '100%', marginTop: '8px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
            api.v1.ui.toast('Syncing character resources...', { id: 'cres-sync', autoClose: false });
            const currentCfg = await loadConfig(); const allCharacters = await loadAllCharacters(); let updatedCount = 0;
            for (const char of allCharacters) {
                const initialDefCount = (char.charResourceDefs || []).length;
                const updatedChar = seedPersonalResourcesToCharacter(char, currentCfg);
                if (updatedChar.charResourceDefs.length > initialDefCount) { await saveCharacter(updatedChar); updatedCount++; }
            }
            api.v1.ui.toast(`Synced character resources to ${updatedCount} character(s).`, { id: 'cres-sync', type: 'success', autoClose: 3000 });
        }});

        return cresParts;
    })() });

    // 6. Character Sheet Categories
    const catItems: UIPart[] = cfg.sheetCategories.filter(Boolean).map(function(cat, ci) {
        const fieldRows: UIPart[] = cat.fields.filter(Boolean).map(function(field, fi) {
            return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [
                { type: 'textInput', initialValue: field.name, placeholder: 'Field name', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c){ c.sheetCategories[ci].fields[fi].name = v; }); } },
                { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fields.splice(fi, 1); }); await refreshWorldbuildingModal(); } }
            ] } as UIPart;
        });
        const addFk = `wb_cfg_cat_af_${cat.id}`;
        const catContent: UIPart[] = [
            { type: 'textInput', label: 'Category Name', initialValue: cat.name, onChange: async function(v: string) { await mutConfig(function(c){ c.sheetCategories[ci].name = v; }); } },
            { type: 'row', style: { gap: '4px', marginTop: '6px', marginBottom: '4px' }, content: [
                { type: 'button', text: 'Text', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: cat.fieldType === 'text' ? 'rgba(126,200,160,0.22)' : undefined }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fieldType = 'text'; }); await refreshWorldbuildingModal(); } },
                { type: 'button', text: 'Number', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: cat.fieldType === 'number' ? 'rgba(126,200,160,0.22)' : undefined }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fieldType = 'number'; }); await refreshWorldbuildingModal(); } },
                { type: 'button', text: 'Enum', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: cat.fieldType === 'enum' ? 'rgba(126,200,160,0.22)' : undefined }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fieldType = 'enum'; }); await refreshWorldbuildingModal(); } }
            ] },
            { type: 'text', text: 'Fields:', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },
            ...fieldRows,
            { type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [
                { type: 'textInput', placeholder: 'Add field…', storageKey: `temp:${addFk}`, style: { flex: '1 1 0' } },
                { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(addFk) as string || ''; if (!v.trim()) return; await mutConfig(function(c){ c.sheetCategories[ci].fields.push({ id: api.v1.uuid(), name: v.trim() }); }); await api.v1.tempStorage.remove(addFk); await refreshWorldbuildingModal(); } }
            ] }
        ].filter(Boolean) as UIPart[];
        if (cat.fieldType === 'enum') {
            // [PATCH v0998] indexed rung editor — index 0 is always the lowest rung,
            // matches how char_skill.amount now compares against this array by index.
            catContent.push({ type: 'text', text: 'Ladder Rungs (0 = lowest):', style: { fontSize: '11px', opacity: '0.6', marginTop: '8px', marginBottom: '2px' } });
            catContent.push(aeRenderIndexedStatesEditor(cat.enumValues || [], async function(next) { await mutConfig(function(c) { c.sheetCategories[ci].enumValues = next; }); }, refreshWorldbuildingModal, 'Rung'));
        }
        catContent.push({ type: 'button', text: '🗑 Remove Category', style: { fontSize: '11px', marginTop: '10px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c){ c.sheetCategories.splice(ci, 1); }); await refreshWorldbuildingModal(); } } as UIPart);
        return { type: 'collapsibleSection', title: cat.name || 'Category', initialCollapsed: true, storageKey: `temp:wb_cfg_cat_${cat.id}`, content: catContent } as UIPart;
    });
    catItems.push({ type: 'button', text: '+ Add Category', iconId: 'plus', style: { marginTop: '8px' }, callback: async function() { await mutConfig(function(c){ c.sheetCategories.push({ id: api.v1.uuid(), name: 'New Category', fieldType: 'text', enumValues: [], fields: [] }); }); await refreshWorldbuildingModal(); } } as UIPart);
    parts.push({ type: 'collapsibleSection', title: '📊 Character Sheet Categories', initialCollapsed: true, storageKey: 'temp:wb_cfg_sheet', content: catItems });

    // 7. Adventure Module Management [v0.9.7.11: lorebook-only; v0.98: +JSON]
    parts.push({ type: 'text', text: '📦 Adventure Module Management', style: { fontSize: '14px', fontWeight: 'bold', marginTop: '16px', marginBottom: '8px', color: '#7ec8a0' } });
    parts.push({ type: 'text', text: 'Pack the full world into a hidden lorebook entry that travels with your .scenario export. Use the picker to import any AE pack found in the lorebook.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } });
    parts.push({ type: 'row', style: { gap: '8px', marginBottom: '10px' }, content: [
        { type: 'button', text: '📦 Pack to Lorebook', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(126,200,160,0.12)', border: '1px solid rgba(126,200,160,0.35)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {
            await packConfigToLorebook();
        } },
        { type: 'button', text: '📥 Import from Lorebook', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(136,204,255,0.12)', border: '1px solid rgba(136,204,255,0.35)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {
            await pickAndImportFromLorebook();
        } }
    ] });
    parts.push({ type: 'text', text: 'Export to a plain JSON file for backups or external tools. Import a previously exported JSON file.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } });
    parts.push({ type: 'row', style: { gap: '8px', marginBottom: '24px' }, content: [
        { type: 'button', text: '⬇ Export JSON', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(232,168,124,0.12)', border: '1px solid rgba(232,168,124,0.35)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {
            await exportAll();
        } },
        { type: 'button', text: '⬆ Import JSON', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(232,168,124,0.12)', border: '1px solid rgba(232,168,124,0.35)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {
            await importData();
        } }
    ] });

        return parts.filter(Boolean) as UIPart[];
}

// ============================================================================
// SECTION 24 — CONFIG MODAL (Engine Tweaks Only)
// ============================================================================

async function mutConfig(fn: (c: GlobalConfig) => void): Promise<void> {
    const c = await loadConfig(); fn(c); await saveConfig(c);
}
async function refreshConfigModal(): Promise<void> {
    if (!configModalHandle || configModalHandle.isClosed()) return;
    await configModalHandle.update({ content: await buildConfigContent() });
}
async function openConfigModal(): Promise<void> {
    if (configModalHandle && !configModalHandle.isClosed()) configModalHandle.close();
    configModalHandle = await openEngineModal({ id: 'ae-config', size: 'full', fillWidth: true, title: '⚙ Adventure Engine Settings', content: await buildConfigContent() });
}

async function buildConfigContent(): Promise<UIPart[]> {
    const cfg = await loadConfig(); const parts: UIPart[] = [];

    // 1. Engine Timing
    parts.push({ type: 'collapsibleSection', title: '⚡️Dynamic Updates Timing', initialCollapsed: true, storageKey: 'temp:ce_cfg_timing', content: [
        { type: 'text', text: 'How many context tokens must pass before each update type fires.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '10px' } },
        { type: 'sliderInput', label: 'Ephemeral (Thoughts) Interval', min: 1, max: 20, step: 1, initialValue: cfg.thoughtIntervalGens, suffix: ' gens', defaultValue: 2, onChange: async function(v: number) { await mutConfig(function(c){ c.thoughtIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Mid-Range State Interval', min: 1, max: 40, step: 1, initialValue: cfg.dynamicIntervalGens, suffix: ' gens', defaultValue: 4, onChange: async function(v: number) { await mutConfig(function(c){ c.dynamicIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Primary Relationship Interval', min: 2, max: 50, step: 1, initialValue: cfg.arcIntervalGens, suffix: ' gens', defaultValue: 10, onChange: async function(v: number) { await mutConfig(function(c){ c.arcIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Hook Scan Interval', min: 1, max: 30, step: 1, initialValue: cfg.hookIntervalGens, suffix: ' gens', defaultValue: 6, onChange: async function(v: number) { await mutConfig(function(c){ c.hookIntervalGens = v; }); } },
        { type: 'sliderInput', label: 'Max Ephemeral Injections per Generation', min: 1, max: 6, step: 1, initialValue: cfg.ephemeralCap, defaultValue: 3, onChange: async function(v: number) { await mutConfig(function(c){ c.ephemeralCap = v; }); } },
        { type: 'text', text: 'Dynamic character cap: how many present characters stay dynamic at once (0 = no cap). Ranked characters fill slots first by rank, then unranked present characters. Set each character\u2019s rank from their card or edit panel.', style: { fontSize: '11px', opacity: '0.6', marginTop: '10px', marginBottom: '4px' } },
        { type: 'sliderInput', label: 'Max Dynamic Characters', min: 0, max: 20, step: 1, initialValue: Number(cfg.maxDynamicCharacters) || 0, suffix: ' (0 = off)', defaultValue: 0, onChange: async function(v: number) { await mutConfig(function(c){ (c as any).maxDynamicCharacters = Math.max(0, Math.floor(v || 0)); }); } },
    ] });

    // 2. Generation Style
    parts.push({ type: 'collapsibleSection', title: '✍ Generation Style', initialCollapsed: true, storageKey: 'temp:ce_cfg_style', content: [
        { type: 'text', text: 'Injected at the top of every generation prompt. Controls overall tone and register. Tip: add "Ignore any game mechanic formatting in the story text — numbered choice lists, > action markers, ## headers, {} or () notes, LOREBOOK: references. Treat only prose narrative as story content."', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },
        { type: 'multilineTextInput', initialValue: cfg.generalStyle, style: { minHeight: '100px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.generalStyle = v; }); } },
        { type: 'button', text: 'Reset to Default', style: { fontSize: '11px', marginTop: '6px' }, callback: async function() { await mutConfig(function(c){ c.generalStyle = DEFAULT_GENERAL_STYLE; }); await refreshConfigModal(); } }
    ] });

    // 3. Static Field Settings
    const fieldSections: UIPart[] = [
        { type: 'checkboxInput', label: 'Show field headers in context injection', initialValue: cfg.showFieldHeaders, onChange: async function(v: boolean) { await mutConfig(function(c){ c.showFieldHeaders = v; }); } } as UIPart
    ];
    STATIC_FIELD_DEFS.forEach(function(def) {
        fieldSections.push({ type: 'collapsibleSection', title: cfg.fieldLabels[def.key] || def.label, initialCollapsed: true, storageKey: `temp:ce_cfg_f_${def.key}`, content: [
            { type: 'textInput', label: 'Display Label', initialValue: cfg.fieldLabels[def.key] || def.label, onChange: async function(v: string) { await mutConfig(function(c){ c.fieldLabels[def.key] = v; }); } },
            { type: 'multilineTextInput', label: 'Generation Instructions', initialValue: cfg.fieldInstructions[def.key] || def.defaultInstructions, style: { minHeight: '80px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.fieldInstructions[def.key] = v; }); } },
            { type: 'sliderInput', label: 'Generation Token Budget', min: 50, max: 500, step: 25, initialValue: cfg.fieldBudgets[def.key] || def.defaultBudget, suffix: ' tokens', defaultValue: def.defaultBudget, onChange: async function(v: number) { await mutConfig(function(c){ c.fieldBudgets[def.key] = v; }); } },
            { type: 'button', text: 'Reset Instructions', style: { fontSize: '11px', marginTop: '4px' }, callback: async function() { await mutConfig(function(c){ c.fieldInstructions[def.key] = def.defaultInstructions; c.fieldBudgets[def.key] = def.defaultBudget; }); await refreshConfigModal(); } }
        ] } as UIPart);
    });
    parts.push({ type: 'collapsibleSection', title: '📝 Static Field Settings', initialCollapsed: true, storageKey: 'temp:ce_cfg_fields', content: fieldSections });

    // 4. Custom Static Fields
    const customFieldRows: UIPart[] = cfg.customStaticFields.filter(Boolean).map(function(cf, i) {
        const ci = i;
        return { type: 'collapsibleSection', title: cf.label || `Custom Field ${ci + 1}`, initialCollapsed: true, storageKey: `temp:ce_cfg_cuf_${cf.id}`, content: [
            { type: 'textInput', label: 'Label', initialValue: cf.label, onChange: async function(v: string) { await mutConfig(function(c){ c.customStaticFields[ci].label = v; }); } },
            { type: 'textInput', label: 'Placeholder', initialValue: cf.placeholder || '', onChange: async function(v: string) { await mutConfig(function(c){ c.customStaticFields[ci].placeholder = v; }); } },
            { type: 'multilineTextInput', label: 'Generation Instructions', initialValue: cf.instructions, style: { minHeight: '70px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.customStaticFields[ci].instructions = v; }); } },
            { type: 'sliderInput', label: 'Generation Token Budget', min: 50, max: 500, step: 25, initialValue: cfg.fieldBudgets[cf.id] || 150, suffix: ' tokens', defaultValue: 150, onChange: async function(v: number) { await mutConfig(function(c){ c.fieldBudgets[cf.id] = v; }); } },
            { type: 'button', text: '🗑 Remove Field', style: { fontSize: '11px', marginTop: '6px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c){ c.customStaticFields.splice(ci, 1); }); await refreshConfigModal(); } }
        ] } as UIPart;
    });
    customFieldRows.push({ type: 'button', text: '+ Add Custom Field', iconId: 'plus', style: { marginTop: '8px' }, callback: async function() { await mutConfig(function(c){ c.customStaticFields.push({ id: api.v1.uuid(), label: 'Custom Field', placeholder: '', instructions: 'Provide relevant information for this field.' }); }); await refreshConfigModal(); } });
    parts.push({ type: 'collapsibleSection', title: '🔧 Custom Static Fields', initialCollapsed: true, storageKey: 'temp:ce_cfg_custom', content: customFieldRows });

    // 5. Scene Default Background
    parts.push({ type: 'collapsibleSection', title: '🖼 Scene Default Background', initialCollapsed: true, storageKey: 'temp:ce_cfg_bg', content: [
        { type: 'text', text: 'URL of the fallback image shown in the scene banner when a location has no portrait. Stored in the module config — anyone who loads this story sees the same background. Leave blank for the CSS gradient fallback.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px', lineHeight: '1.5' } },
        { type: 'textInput', label: 'Image URL', initialValue: (cfg as any).defaultBackgroundUrl || '', onChange: async function(v: string) { await mutConfig(function(c) { (c as any).defaultBackgroundUrl = v.trim(); }); } },
        { type: 'button', text: '✕ Clear', style: { fontSize: '11px', marginTop: '4px', color: 'var(--ae-color-danger)' }, callback: async function() { await mutConfig(function(c) { (c as any).defaultBackgroundUrl = ''; }); await refreshConfigModal(); api.v1.ui.toast('Scene background cleared.', { type: 'success', autoClose: 2000 }); } }
    ] } as any);

    parts.push({ type: 'text', text: ' ', style: { marginBottom: '48px' } });
    return parts.filter(Boolean) as UIPart[];
}

async function confirmDeleteChar(id: string, name: string): Promise<void> {
    const m = await openEngineModal({ title: 'Confirm Delete', size: 'small', content: [
        { type: 'text', text: `Delete "${name}"? This cannot be undone.`, style: { marginBottom: '16px' } },
        { type: 'row', style: { gap: '8px' }, content: [
            { type: 'button', text: 'Delete', style: { flex: '1 1 0', margin: 0, color: '#ff6b6b' }, callback: async function() { await deleteCharacter(id); m.close(); await refreshSidebar(); } },
            { type: 'button', text: 'Cancel', style: { flex: '1 1 0', margin: 0 }, callback: function() { m.close(); } }
        ] }
    ] });
}



// ============================================================================
// SMART IMPORTER
// ============================================================================
// importPayload(data) — accepts a parsed JSON object and imports whatever
// recognizable blocks it finds. Returns a summary of what was imported.
// All import entry-points (module button, config modal, new-story prompt)
// funnel through this single function so behaviour is always identical.
//
// Recognised top-level blocks (any combination, all optional):
//   config          — GlobalConfig object  → replaces current settings
//   characters      — CharacterRecord[]    → merged into character index
//   character       — CharacterRecord      → single character (not bundle)
//   entities        — EntityRecord[]       → merged into entity index
//   locations       — EntityRecord[]       → backwards-compat alias for entities
//   entity          — EntityRecord         → single entity node
//   npcWeb          — NpcWebEntry[]        → replaces NPC drama web
//   partyState      — PartyState           → replaces party resources
//
// Special typed wrappers (detected first, return early):
//   { type: 'character_bundle', character, entity? }
//
// Bare root-level records (no top-level array key):
//   { id, name, ...CharacterRecord }  — no `type` field  → single character
//   { id, name, type, ... }           — has `type` field → single entity
// ============================================================================

// ImportResult interface defined in Section 1 (types block).


// ── Import Payload (full module importer) ────────────────────────────────────
async function importPayload(data: any): Promise<ImportResult> {
    const result: ImportResult = {
        charCount: 0, entityCount: 0,
        configImported: false, npcWebImported: false, partyStateImported: false
    };

    // 1. Config block — merge over defaults so missing new fields get defaults
    if (data.config && typeof data.config === 'object' && !Array.isArray(data.config)) {
        const newCfg = migrateConfig({ ...makeDefaultConfig(), ...data.config });
        await saveConfig(newCfg);
        result.configImported = true;
    }

    const activeCfg = await loadConfig();

    // 2. Character bundle — typed single-export format (char + optional entity)
    //    Detected first and returns early so its keys don't fall through to the
    //    generic `character` / `entity` checks below.
    if (data.type === 'character_bundle' && data.character) {
        await saveCharacter(migrateCharacter(data.character, activeCfg));
        result.charCount = 1;
        if (data.entity && typeof data.entity === 'object') {
            await saveEntity(migrateEntity(data.entity));
            result.entityCount = 1;
        }
        return result;
    }

    // 3. Characters — array, singular block, or bare root record
    if (data.characters && Array.isArray(data.characters)) {
        for (const c of data.characters.filter(Boolean)) {
            await saveCharacter(migrateCharacter(c, activeCfg));
            result.charCount++;
        }
    } else if (data.character && typeof data.character === 'object' && !Array.isArray(data.character)) {
        await saveCharacter(migrateCharacter(data.character, activeCfg));
        result.charCount = 1;
    } else if (data.id && data.name && !data.type && !data.entities && !data.locations && !data.characters) {
        // Bare root-level CharacterRecord — no `type` field distinguishes it from entity
        await saveCharacter(migrateCharacter(data, activeCfg));
        result.charCount = 1;
    }

    // 4. Entities — array (with backwards-compat alias), singular block, or bare root record
    const rawNodes: any[] = Array.isArray(data.entities) ? data.entities
                          : Array.isArray(data.locations) ? data.locations   // pre-v0.9 exports
                          : [];
    if (rawNodes.length > 0) {
        for (const n of rawNodes.filter(Boolean)) {
            await saveEntity(migrateEntity(n));
            result.entityCount++;
        }
    } else if (data.entity && typeof data.entity === 'object' && !Array.isArray(data.entity)) {
        await saveEntity(migrateEntity(data.entity));
        result.entityCount = 1;
    } else if (data.id && data.name && data.type && !data.characters && !data.entities && !data.locations) {
        // Bare root-level EntityRecord — presence of `type` (entity kind) is the signal
        await saveEntity(migrateEntity(data));
        result.entityCount = 1;
    }

    // 5. NPC Web
    if (data.npcWeb && Array.isArray(data.npcWeb)) {
        if (typeof saveNpcWeb === 'function') await saveNpcWeb(data.npcWeb);
        result.npcWebImported = true;
    }

    // 6. Party State
    if (data.partyState && typeof data.partyState === 'object' && !Array.isArray(data.partyState)) {
        if (typeof savePartyState === 'function') await savePartyState(data.partyState);
        result.partyStateImported = true;
    }

    return result;
}

// ── Image / Architect Settings helpers ───────────────────────────────────────
// [NEW] Merged from auto-illustrator-sb engine. These functions were previously
//       in the AI engine's standalone modal. Now part of the AE config modal.

async function injectNote(type: string, isAdding: boolean): Promise<void> {
    // Inserts or removes the image System Note from Memory or Author's Note.
    try {
        const note = (globalSettings.systemNote || DEFAULT_NOTE).trim();
        if (!note) { api.v1.ui.toast('No System Note defined in Image Settings.'); return; }
        if (type === 'memory') {
            const text = (await api.v1.memory.get()) || '';
            if (isAdding && !text.includes(note)) {
                await api.v1.memory.set(text ? text + '\n\n' + note : note);
                api.v1.ui.toast('✅ Image note inserted into Memory.');
            } else if (!isAdding && text.includes(note)) {
                await api.v1.memory.set(text.replace('\n\n' + note, '').replace('\n' + note, '').replace(note, '').trim());
                api.v1.ui.toast('🗑 Image note removed from Memory.');
            } else {
                api.v1.ui.toast(isAdding ? 'Note already in Memory.' : 'Note not found in Memory.');
            }
        } else if (type === 'an') {
            const text = (await api.v1.an.get()) || '';
            if (isAdding && !text.includes(note)) {
                await api.v1.an.set(text ? text + '\n\n' + note : note);
                api.v1.ui.toast('✅ Image note inserted into Author\'s Note.');
            } else if (!isAdding && text.includes(note)) {
                await api.v1.an.set(text.replace('\n\n' + note, '').replace('\n' + note, '').replace(note, '').trim());
                api.v1.ui.toast('🗑 Image note removed from Author\'s Note.');
            } else {
                api.v1.ui.toast(isAdding ? 'Note already in Author\'s Note.' : 'Note not found.');
            }
        }
    } catch (e) {
        api.v1.ui.toast('Injection failed — ensure storyEdit permission is granted.');
    }
}

// ============================================================================
// SECTION 26 — HOOK REGISTRATIONS
// All api.v1.hooks.register() calls.
//
//    ADVENTURE ENGINE PIPELINE:
//    onBeforeContextBuild  → world-state AN injection (AE context builder S13)
//    onLorebookEntrySelected → lore ID tracking
//    onContextBuilt        → imperative block + background drama + probability
//    onGenerationEnd       → token count + runDynamicEngine (S15)
//    onHistoryNavigated    → retry/undo skip flag
//
// ============================================================================

const AE_AN_SENTINEL = '[ Scene State ]';
// [v0.9.7.3 AN-FIX] Sentinel bracketing the wizard-owned region of the persisted AN.
// Final layout of the AN slot at generation time:
//   [user manual content, if any]
//   \n\n[ World Style ]          <- AE_WIZ_AN_SENTINEL (persisted by commitWizardMemory)
//   [wizard style/tone AN sections]
//   \n\n[ Scene State ]          <- AE_AN_SENTINEL (ephemeral, appended per-generation)
//   [quest line + world state + drama]
// Style first so the model frames itself before reading the immediate scene.
// Scene last so it carries the highest recency weight inside the AN slot.
const AE_WIZ_AN_SENTINEL = '[ World Style ]';

api.v1.hooks.register('onBeforeContextBuild', async function(params: any) {

    // [vNEXT] Yoink hijack active — leave the context alone; our prompt is swapped
    // in at onContextBuilt. Returning nothing means no world-state AN injection.
    if (_aeYoink.active) return;

    // ── AE path: Authors Note world-state injection ──────────────────────────
    if (params.dryRun) return;
    await api.v1.tempStorage.set(STORAGE_LORE_IDS, '[]').catch(function() {});

    // [v0.9.8.5] Scene lorebook activation (static identity + ephemeral equipment).
    // Returned regardless of whether an AN block is produced below.
    let aeResult: any = {};
    try {
        const sceneAct = await buildSceneLorebookActivation();
        if (sceneAct.lorebookEntries.length > 0) aeResult.lorebookEntries = sceneAct.lorebookEntries;
        if (sceneAct.temporaryLorebookEntries.length > 0) aeResult.temporaryLorebookEntries = sceneAct.temporaryLorebookEntries;
    } catch (eAct) { api.v1.error('[AE] scene activation:', eAct); }

    try {
        const anIdx = await loadIndex();
        const anProtagMeta = anIdx.find(function(m: any) { return m.isProtagonist; });
        const anProtag = anProtagMeta ? await loadCharacter(anProtagMeta.id) : null;
        const worldStateBlock = await buildWorldStateBlock(anProtag);

        // [v0.9.28 INJ1] Tracked narrative now renders via the trackedNarrative
        // context template (buildTrackedNarrativeBlock) — the old hardcoded
        // [Current objective: …] string is removed to stop double-injection.
        let questLine = '';
        try {
            const trackedNarrId2 = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;
            if (trackedNarrId2) {
                const anCfgForTracked = await loadConfig();
                questLine = await buildTrackedNarrativeBlock(trackedNarrId2, anCfgForTracked);
            }
        } catch (e) { api.v1.error('[AE] Quest AN injection:', e); }

        let dramaBlock = '';
        try { dramaBlock = await buildDramaContextBlock(); } catch (e) { api.v1.error('[AE] Drama AN injection:', e); }

        // [v0.9.30 NARR-ORDER] Tracked narrative (questLine) now leads the block, above
        // the location/world-state, so the current objective sits at the top of the
        // injected Author's Note rather than below the scene description.
        const fullBlock = [questLine, worldStateBlock.trim(), dramaBlock.trim()].filter(Boolean).join('\n');
        if (fullBlock) {
            // [v0.9.38 AN-IDEMPOTENT] Strip any prior AE region before re-appending.
            // We always append our block LAST, sentinel-prefixed, so the sentinel (or
            // the '\n\n'+sentinel join that precedes it) marks the trailing AE region.
            // Removing it first means N hook passes / N engine copies converge on one copy.
            let existingANraw = (params.authorsNote && params.authorsNote.content) ? params.authorsNote.content : '';
            let anMarker = '\n\n' + AE_AN_SENTINEL;
            let anMarkerIdx = existingANraw.lastIndexOf(anMarker);
            let baseAN = (anMarkerIdx >= 0)
                ? existingANraw.substring(0, anMarkerIdx)
                : ((existingANraw.indexOf(AE_AN_SENTINEL) === 0) ? '' : existingANraw);
            baseAN = baseAN.replace(/\s+$/, '');
            let wrappedBlock = AE_AN_SENTINEL + '\n' + fullBlock;
            aeResult.authorsNote = {
                active: true,
                content: baseAN ? (baseAN + '\n\n' + wrappedBlock) : wrappedBlock
            };
        }
    } catch (e) { api.v1.error('[AE] Author\'s Note injection error:', e); }

    return Object.keys(aeResult).length > 0 ? aeResult : undefined;
});

api.v1.hooks.register('onLorebookEntrySelected', async function(params: any) {
    try {
        if (!params.entryId) return;
        const raw = await api.v1.tempStorage.getOrDefault(STORAGE_LORE_IDS, '[]') as string;
        const ids: string[] = JSON.parse(raw);
        if (!ids.includes(params.entryId)) {
            ids.push(params.entryId);
            await api.v1.tempStorage.set(STORAGE_LORE_IDS, JSON.stringify(ids));
        }
    } catch (e) { api.v1.error('[AE] LoreTracking error:', e); }
});


api.v1.hooks.register('onResponse', async function(params: any) {
    // [vNEXT] While a yoink generation is active, buffer the streamed chunks and
    // swallow them so nothing reaches the user's document. Inert otherwise.
    if (_aeYoink.active) {
        if (params && params.text && Array.isArray(params.text)) {
            _aeYoink.responseText += params.text.join('');
        }
        return { text: [''] };
    }
});

api.v1.hooks.register('onContextBuilt', async function(params: any) {

    // [vNEXT] Yoink hijack — replace the whole context with our prompt. Runs before
    // the dryRun gate and all normal injection so the wizard gen is fully isolated.
    if (_aeYoink.active) {
        return { messages: _aeYoink.messages };
    }

    // ── AE normal path: gate on dryRun ────────────────────────────────────────
    if (params.dryRun) return;
    const { messages } = params;
    if (!messages || messages.length === 0) return;

    // ── IMPERATIVE BLOCK ─────────────────────────────────────────────────────
    try {
        const impIdx = await loadIndex();
        const impLines: string[] = [];
        // [v0.9.25 E4] pendingEncounter injection removed — STORAGE_PENDING_ENCOUNTER is now a tombstone
        const pendingKnowledge = await api.v1.tempStorage.get(STORAGE_PENDING_KNOWLEDGE) as any;
        if (pendingKnowledge && pendingKnowledge.charName && pendingKnowledge.snapshot) {
            await api.v1.tempStorage.remove(STORAGE_PENDING_KNOWLEDGE);
            impLines.push('[' + pendingKnowledge.charName + '\'s established knowledge of ' + pendingKnowledge.entityName + ': ' + pendingKnowledge.snapshot + ']');
        }
        const pendingInject = await api.v1.tempStorage.get(STORAGE_PENDING_INJECT) as string | undefined;
        if (pendingInject && pendingInject.trim()) {
            await api.v1.tempStorage.remove(STORAGE_PENDING_INJECT);
            impLines.push('[GM: ' + pendingInject.trim() + ']');
        }
        for (const meta of impIdx.filter(Boolean)) {
            if (!meta.active || !meta.scenePresent) continue;
            if ((meta as any).npcClass === 'minor') continue;
            const impChar = await loadCharacter(meta.id);
            if (!impChar || !impChar.hooks || impChar.hooks.length === 0) continue;
            const h = impChar.hooks[0];
            if (!h.resolved && h.pressureLevel >= 85 && h.description && h.description.trim()) {
                impLines.push('[' + impChar.name + ': ' + h.description.trim() + ']');
            }
        }
        const impWeb = await loadNpcWeb();
        const impAllChars = await loadAllCharacters();
        const impPresentIds = new Set(impIdx.filter(function(m) { return m.scenePresent; }).map(function(m) { return m.id; }));
        const impHighLinks = impWeb.filter(function(link) { return link.priority >= 70 && impPresentIds.has(link.charA_id) && impPresentIds.has(link.charB_id) && link.dynamic.trim() !== ''; }).sort(function(a, b) { return b.priority - a.priority; });
        for (const link of impHighLinks) {
            const cA = impAllChars.find(function(c) { return c.id === link.charA_id; });
            const cB = impAllChars.find(function(c) { return c.id === link.charB_id; });
            if (cA && cB) impLines.push('[' + cA.name + ' and ' + cB.name + ': ' + link.dynamic.trim() + ']');
        }
        if (impLines.length > 0) {
            const impBlock = impLines.join('\n');
            const lastUserForImp = messages.map(function(m: any) { return m.role; }).lastIndexOf('user');
            const insertAtImp = lastUserForImp >= 0 ? lastUserForImp : messages.length;
            messages.splice(insertAtImp, 0, { role: 'user', content: impBlock });
        }
    } catch (e) { api.v1.error('[AE] Imperative injection error:', e); }

    // ── BACKGROUND DRAMA ─────────────────────────────────────────────────────
    // [WP-0] Background drama moved to the Author's Note block in

    // ── EQUIPMENT DESCRIPTIONS ────────────────────────────────────────────────
    // [WP-0] Removed. Full equipped-item descriptions now live on each character's
    // lorebook entry (buildLorebookContent "Wearing/Carrying" section), activating
    // with the character's keys instead of loading on every generation.

    // [RETIRED vNEXT] Legacy freeform #tag 1d6 probability engine removed — all skill
    // checks now run through the Quick Action composer (2d6 fail-forward + Stakes).
    return { messages };
});

// ── onGenerationEnd ───────────────────────────────────────────────────────────
api.v1.hooks.register('onGenerationEnd', async function(params: any) {
    try {
        // [vNEXT] Yoink generation finished — hand the captured text back to the
        // awaiting caller and STOP. Must return before the gen counter, auto-triggers,
        // and dynamic engine so a wizard gen never advances story state.
        if (_aeYoink.active) {
            ae_genInFlight = false;
            if (_aeYoink.resolve) _aeYoink.resolve(_aeYoink.responseText);
            _aeYoink.active = false;
            _aeYoink.resolve = null;
            _aeYoink.reject = null;
            return;
        }

        ae_genInFlight = false; // [v0.9.36] generation finished — release the generate guard
        // Skip on inline generations (tooltips, etc.) and retry/undo flagged turns
        if (params?.inlineGeneration) return;
        const skipFlag = await api.v1.tempStorage.get(STORAGE_ENGINE_SKIP) as string | undefined;
        if (skipFlag === 'true') {
            await api.v1.tempStorage.remove(STORAGE_ENGINE_SKIP);
            api.v1.log('[AE] Engine skipped this turn (retry/undo).');
            return;
        }

        // [v0.9.24 E1] Increment persistent generation count (replaces token estimation).
        try {
            let _genC = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;
            _genC = (Number(_genC) || 0) + 1;
            await api.v1.storyStorage.set(STORAGE_GEN_COUNT, _genC);
            api.v1.log('[AE] Generation count: ' + _genC);
        } catch (e) { api.v1.error('[AE] Gen count increment error:', e); }

        // [v0.9.9.2] Time auto-advance. OFF by default. Clock + cadence counter both
        // live in HISTORY storage, so an undo rewinds them together and replaying
        // forward reproduces the identical clock. Runs AFTER the skip/yoink guards
        // above (undo navigations and wizard yoinks never tick) and BEFORE auto-
        // triggers (so time-gated actions evaluate against the new hour).
        try {
            let taCfg = await loadConfig();
            if (taCfg.timeAutoAdvanceEnabled) {
                let taEvery = (Number(taCfg.timeAdvanceEveryGens) > 0) ? Math.floor(Number(taCfg.timeAdvanceEveryGens)) : 3;
                let taHours = (Number(taCfg.timeAdvanceHours) > 0) ? Math.floor(Number(taCfg.timeAdvanceHours)) : 1;
                let taClk = await loadClock(taCfg);
                taClk.gensSinceTick = (Number(taClk.gensSinceTick) || 0) + 1;
                if (taClk.gensSinceTick >= taEvery) {
                    taClk.hours = Math.max(0, taClk.hours + taHours);
                    taClk.gensSinceTick = 0;
                    api.v1.log('[AE] Time auto-advanced to: ' + clockFormatStamp(taClk.hours, taCfg));
                }
                await saveClock(taClk);
                queueSceneStateBroadcast();
            }
        } catch (e) { api.v1.error('[AE] Time auto-advance error:', e); }

        api.v1.log('[AE] Generation complete — running auto-triggers...');
        await runAutoTriggers();
        api.v1.log('[AE] Generation complete — engaging dynamic engine...');
        await runDynamicEngine();
    } catch (e) {
        api.v1.error('[AE] onGenerationEnd error:', e);
        // [vNEXT] Failsafe — never leave the yoink lock stuck on error.
        if (_aeYoink.active) {
            if (_aeYoink.reject) _aeYoink.reject(e);
            _aeYoink.active = false;
            _aeYoink.resolve = null;
            _aeYoink.reject = null;
        }
    }
});

// Skip engine on retry and undo — token stamps shouldn't update when story reverts
api.v1.hooks.register('onHistoryNavigated', async function(params: any) {
    ae_genInFlight = false; // [v0.9.36] safety release if a generation was aborted/navigated
    if (params?.cause === 'retry' || params?.cause === 'undo') {
        await api.v1.tempStorage.set(STORAGE_ENGINE_SKIP, 'true');
    }
});


// ============================================================================
// SECTION 27 — STARTUP
// showNewStoryPrompt, ensureProtagonistExists, and the onScriptsLoaded hook.
//
// [CHANGE] onScriptsLoaded startup sequence:
//   1. Register sidebarPanel only (no ae-scene-hud scriptPanel — bridge owns HUD)
//   2. Request permissions
//   3. loadImageSettings() — seeds profiles[], globalSettings from storage
//   4. buildCharacterDataPayload() — seeds cachedCharVisuals before bridge connects
//   5. initMessaging() — sends HANDSHAKE_REQUEST; bridge ACK triggers state push
//   6. isFreshStory path → showNewStoryPrompt() | returning story → normal init
// ============================================================================

async function showNewStoryPrompt(): Promise<void> {
    // [v0.9.7.11] Scan lorebook for AE packs to offer inline import buttons.
    let nspPacks: { entry: any; data: any }[] = [];
    try {
        const nspAll = await api.v1.lorebook.entries();
        for (const nspE of nspAll) {
            if (!nspE.text) continue;
            try { const nspD = JSON.parse(nspE.text); if (nspD && nspD.aeVersion) nspPacks.push({ entry: nspE, data: nspD }); }
            catch (eNspP) {}
        }
    } catch (eNspL) { api.v1.log('[AE] new-story lorebook scan error:', eNspL); }

    const nspContent: any[] = [
        { type: 'text', text: nspPacks.length > 0
            ? 'A world pack was found in this lorebook. Select it to restore the full world, or start fresh.'
            : 'This looks like a new story. Start fresh, or import from a lorebook pack if one is available.',
          style: { marginBottom: '14px', lineHeight: '1.5', fontSize: '12px' } }
    ];
    for (let nspI = 0; nspI < nspPacks.length; nspI++) {
        (function(nspEnt: any, nspDat: any) {
            const nspCC = Object.keys(nspDat.charRecords || {}).length;
            const nspEC = Object.keys(nspDat.entRecords  || {}).length;
            const nspLbl = (nspEnt.displayName || '[AE World]') + ' — ' + nspCC + ' chars, ' + nspEC + ' locations';
            nspContent.push({ type: 'button', text: '📥 Import: ' + nspLbl,
              style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.15)', border: '1px solid rgba(136,204,255,0.4)', color: '#88ccff', fontWeight: 'bold' },
              disabledWhileCallbackRunning: true,
              callback: async function() {
                  try { await importFromLorebookPack(nspDat); } catch (eNspImp) { api.v1.error('[AE] new-story import failed:', eNspImp); }
                  pm.close(); await ensureProtagonistExists(); await refreshSidebar(); queueSceneStateBroadcast();
              }
            });
        })(nspPacks[nspI].entry, nspPacks[nspI].data);
    }
    nspContent.push({ type: 'button', text: '✨ Start Fresh', style: { width: '100%' },
        callback: async function() { pm.close(); await ensureProtagonistExists(); await refreshSidebar(); queueSceneStateBroadcast(); }
    });
    nspContent.push({ type: 'text', text: 'Pack or import a world anytime via ⚙ Settings → Adventure Module Management.',
        style: { fontSize: '10px', opacity: '0.45', marginTop: '10px', textAlign: 'center' } });
    const pm = await openEngineModal({ id: 'ae-new-story-prompt', title: '🗺 Adventure Engine', size: 'small', content: nspContent });
}

// ============================================================================
// INITIALIZATION
// ============================================================================


async function ensureProtagonistExists(): Promise<void> {
    try {
        const idx = await loadIndex();
        if (idx.some(function(m) { return !!m.isProtagonist; })) return;

        const cfg = await loadConfig();

        // 1. Create a default starting location node so the story begins in a valid room
        const startLoc = makeDefaultEntity('Starting Area');
        startLoc.type = 'location';
        startLoc.parentId = null;
        startLoc.description = 'Where your adventure begins... Customize this location in the Worlds tab.';
        startLoc.atmosphere = 'The air is still, ripe with the potential of a new story.';
        await saveEntity(startLoc);

        // 2. Create the player's physical body entity and nest it inside the starting area
        const playerBody = makeDefaultEntity('Player');
        playerBody.type = 'character';
        playerBody.parentId = startLoc.id;
        playerBody.storyState = 'active';
        await saveEntity(playerBody);

        // 3. Create the protagonist character record, link it, and focus the HUD camera
        const char = makeDefaultCharacter('Player', cfg);
        char.isProtagonist = true;
        char.active = true;
        char.scenePresent = true;
        char.entityId = playerBody.id;
        char.currentLocationId = startLoc.id; // Sets active HUD camera focus to the starting area
        await saveCharacter(char);

        try { await createLinkedLorebookEntry(char.id); } catch (lbErr) { /* non-fatal */ }

        api.v1.log('[AE] Protagonist and Starting Area auto-created.');
    } catch (e) {
        api.v1.error('[AE] ensureProtagonistExists failed:', e);
    }
}

// [v0.9.22 E5] Intercepts direct player TA-box input and composes any pending
// player flavor into inputText before it is written to the story document.
// Only fires for actual player key-submissions; not triggered by generate().
api.v1.hooks.register('onTextAdventureInput', async function(params: any) {
    try {
        let taFlavor = await api.v1.tempStorage.get(STORAGE_PENDING_FLAVOR) as string | undefined;
        if (taFlavor && taFlavor.trim()) {
            await api.v1.tempStorage.remove(STORAGE_PENDING_FLAVOR);
            let taInput = String((params && params.inputText) || '');
            return { inputText: composeActionPrompt(taInput, taFlavor.trim()) };
        }
    } catch (_e) {}
});

// ============================================================================
// SECTION 27 — NATIVE TOOLBAR HUD (bridge-less interface)
// A toolbar tray whose five buttons each open a native modal rendering the same
// SceneStatePayload the bridge consumes. Gated by cfg.interfaceMode. Renderer-only:
// every verb is shared with the bridge. NAI has no dropdown UIPart, so the bridge's
// three side-by-side <select>s become full-width picker-buttons via openPickerModal.
// ============================================================================

// Persistent Goal & Approach composer state — mirrors the bridge _composer* vars
// so picks survive a modal reopen within a session.
var _aeNavGoal: string = '';
var _aeNavAttr: string | null = null;
var _aeNavStake: string | null = null;
var _aeNavStakeAuto: boolean = true;
var _aeNavTarget: string = 'none';
var _aeNavLuck: number = 0;
var _aeMapInspectId: string = '';   // [v0.9.9.5] native map "Looking at" inspected location id
var _aeNavInit: boolean = false;    // [v0.9.9.6] action composer defaults applied once (so 'No check' persists)

function _aeHudHeader(text: string): UIPart {
    return { type: 'text', text: text, style: { fontSize: '12px', fontWeight: 'bold', color: '#7ec8a0', marginTop: '10px', marginBottom: '4px' } } as UIPart;
}
function _aeHudInfo(text: string): UIPart {
    return { type: 'text', text: text, style: { fontSize: '11px', opacity: '0.65', marginBottom: '6px', lineHeight: '1.4' } } as UIPart;
}
function _aeHudSub(text: string): UIPart {
    return { type: 'text', text: text, style: { fontSize: '11px', fontWeight: 'bold', opacity: '0.7', marginTop: '6px', marginBottom: '2px', color: '#a9d4f5' } } as UIPart;
}
function _aeHudRow(content: UIPart[]): UIPart {
    return { type: 'row', style: { gap: '5px', marginBottom: '4px', alignItems: 'stretch' }, content: content } as UIPart;
}
function _aeHudClose(handleGetter: () => any): UIPart {
    return { type: 'button', text: 'Close', style: { marginTop: '12px' }, callback: async function() {
        let h = handleGetter(); try { if (h && !h.isClosed()) await h.close(); } catch (e) {}
    } } as UIPart;
}

// Smart Stakes default: the StakeDef whose defaultForAttrs includes the attr tag
// (# normalized on both sides). Mirrors the bridge composer exactly.
function _aeDefaultStakeFor(state: any, attrTag: string | null): string {
    let tag = String(attrTag || '').replace(/^#/, '').toLowerCase();
    if (!tag) return '';
    let match = (state.stakeDefs || []).filter(function(sd: any) {
        return (sd.defaultForAttrs || []).some(function(a: string) { return String(a).replace(/^#/, '').toLowerCase() === tag; });
    })[0];
    return match ? match.id : '';
}

// ── SHARED INSPECT / ITEM / NARRATIVE HELPERS ──────────────────────────────
// [v0.9.9.7] Used by the character inspection view, the top-level Inspect modal,
// and the Player modal's Inventory/Quests tabs -- one render path for "a list of
// items" or "a list of narratives" everywhere they appear in the native HUD.

function _aePressureLabel(p: number): string {
    if (p < 25) return 'Latent';
    if (p < 60) return 'Building';
    if (p < 85) return 'Urgent';
    return 'Critical';
}

// One-line dramatis persona for a single character: "Name (species, age, role) — brief".
function _aeCharDramatis(char: any): string {
    let idParts = [char.species, char.age, char.occupationRole].filter(function(x: any) { return x && String(x).trim(); });
    let header = idParts.length ? (char.name + ' (' + idParts.join(', ') + ')') : char.name;
    let brief = (char.briefDescription && String(char.briefDescription).trim()) ? '  \u2014  ' + String(char.briefDescription).trim() : '';
    return header + brief;
}

// [v0.9.9.7] Shared action-instance executor for any entity-attached action button
// (Action tab, item rows, narrative rows). Resolves the live instance, detects
// whether it needs a target picker, and runs it -- same resolve path RUN_ACTION_INSTANCE
// uses. closeFn (if given) is called right before the action actually runs, matching
// the close-then-act pattern used elsewhere in the native HUD.
async function aeRunEntityAction(entityId: string, instId: string, closeFn?: () => (void | Promise<void>)): Promise<void> {
    try {
        let ent = await loadEntity(entityId);
        if (!ent) { api.v1.ui.toast('Action source missing.', { type: 'warning' }); return; }
        let cfg2 = await loadConfig();
        let found = (((ent as any).actionInstances || []) as any[]).find(function(x: any) { return x.id === instId; })
                  || ((cfg2.actionTemplates || []) as any[]).find(function(x: any) { return x.id === instId; });
        if (!found) { api.v1.ui.toast('Action not found.', { type: 'warning' }); return; }
        let requiresTarget = (found as any).targetMode === 'player_pick';
        if (requiresTarget) {
            let state: any = await getSceneState();
            let cands: any[] = [];
            ((state && state.presentCharacters) || []).forEach(function(c: any) { if (!c.isProtagonist && c.entityId) cands.push({ tid: c.entityId, label: c.name }); });
            ((state && state.presentItems) || []).forEach(function(it: any) { cands.push({ tid: it.id, label: it.name }); });
            ((state && state.presentMinorNpcs) || []).forEach(function(n: any) { if (n.id) cands.push({ tid: n.id, label: n.name }); });
            if (cands.length === 0) { api.v1.ui.toast('No valid targets present.', { type: 'warning' }); return; }
            await openPickerModal({
                title: 'Choose Target', items: cands, size: 'small',
                getId: function(t: any) { return t.tid; }, getLabel: function(t: any) { return t.label; },
                onSelect: async function(t: any) {
                    let tEnt = await loadEntity(t.tid);
                    if (closeFn) { try { await closeFn(); } catch (e0) {} }
                    try { await runActionInstance(found, ent, cfg2, { target: tEnt || null }); } catch (eRun) { api.v1.error('[AE:hud] avail action:', eRun); }
                }
            });
            return;
        }
        if (closeFn) { try { await closeFn(); } catch (e0) {} }
        try { await runActionInstance(found, ent, cfg2, { target: null }); } catch (eRun2) { api.v1.error('[AE:hud] avail action:', eRun2); }
    } catch (e) { api.v1.error('[AE:hud] aeRunEntityAction:', e); }
}

// Active-hooks list content (caller wraps in one 'Active Hooks (N)' collapsibleSection).
function _aeHookRows(hooks: any[], charId: string, refreshFn: () => Promise<void>): UIPart[] {
    if (!hooks || hooks.length === 0) return [_aeHudInfo('No active hooks.')];
    return hooks.map(function(h: any) {
        let targetLabel = h.targetName === '__player__' ? 'Player' : (h.targetName || 'Unknown');
        return { type: 'box', style: { padding: '8px 10px', marginBottom: '6px', backgroundColor: 'rgba(217,138,138,0.08)', border: '1px solid rgba(217,138,138,0.25)', borderRadius: '6px' }, content: [
            { type: 'text', text: '\ud83e\ude9d ' + targetLabel, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '2px' } } as UIPart,
            { type: 'text', text: h.description || '', style: { fontSize: '11px', opacity: '0.85', lineHeight: '1.4', marginBottom: '4px' } } as UIPart,
            { type: 'text', text: _aePressureLabel(h.pressureLevel) + '  (' + h.pressureLevel + ')', style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px' } } as UIPart,
            { type: 'button', text: 'Resolve Hook', iconId: 'check', style: { width: '100%', fontSize: '11px', margin: 0 }, callback: async function() { await resolveCharHook(charId, h.id); await refreshFn(); } } as UIPart
        ] } as UIPart;
    });
}

// One collapsibleSection per item, always defaults closed. Equip toggle only ever
// targets the item's own owner/parent -- ownerCharId is resolved by the caller
// (the character whose inventory this is, or undefined for ownerless location items,
// which hides the toggle since there is no parent entity to toggle to).
function _aeItemSection(items: any[], ownerCharId: string | undefined, refreshFn: () => Promise<void>): UIPart[] {
    return (items || []).map(function(item: any) {
        let body: UIPart[] = [];
        body.push({ type: 'text', text: item.description || 'No description.', style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);
        let equipTarget = item.isEquipped ? (item.equippedToCharId || ownerCharId) : ownerCharId;
        if (equipTarget) {
            body.push({ type: 'button', text: item.isEquipped ? 'Equipped' : 'Equip', iconId: item.isEquipped ? 'check-circle' : 'package', style: { width: '100%', fontSize: '11px', marginBottom: '4px', backgroundColor: item.isEquipped ? 'rgba(126,200,160,0.15)' : undefined, color: item.isEquipped ? '#7ec8a0' : undefined }, callback: async function() { await setItemEquip(equipTarget, item.id, !item.isEquipped); await refreshFn(); } } as UIPart);
        }
        (item.actionInstances || []).forEach(function(inst: any) {
            body.push({ type: 'button', text: inst.name, iconId: 'zap', style: { width: '100%', fontSize: '11px', marginBottom: '3px' }, callback: async function() { await aeRunEntityAction(item.id, inst.id); await refreshFn(); } } as UIPart);
        });
        body.push({ type: 'button', text: 'Edit Entity', iconId: 'tool', style: { width: '100%', fontSize: '11px', marginTop: '2px', opacity: '0.75' }, callback: async function() { try { await openEntityEditModal(item.id); } catch (e) {} } } as UIPart);
        return { type: 'collapsibleSection', title: aeIconPfx(item.icon) + item.name, initialCollapsed: true, storageKey: 'temp:ae_item_' + item.id, content: body } as UIPart;
    });
}

// One collapsibleSection per narrative, always defaults closed. storyState, tracked
// toggle (same STORAGE_TRACKED_NARRATIVE flag the bridge uses), target destination
// and a due-date countdown (from eventDayTarget), entity-attached actions, and an
// edit-modal button. curAbsDay is the clock's current absolute day (loaded once by
// the caller so a long list doesn't reload the clock per row).
function _aeNarrativeSection(narrs: any[], curAbsDay: number, refreshFn: () => Promise<void>): UIPart[] {
    return (narrs || []).map(function(n: any) {
        let body: UIPart[] = [];
        let stateLabel = n.storyState === 'active' ? '\ud83d\udd25 Active' : n.storyState === 'completed' ? '\u2705 Completed' : '\ud83d\udd12 Locked';
        if (n.isTracked) stateLabel = '\ud83c\udfaf Tracked  \u00b7  ' + stateLabel;
        body.push({ type: 'text', text: stateLabel, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '4px', color: n.isTracked ? '#7ec8a0' : '#a8a8b8' } } as UIPart);
        if (n.description) body.push({ type: 'text', text: n.description, style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);
        if (n.questTargetName) body.push({ type: 'text', text: 'Target:  ' + n.questTargetName, style: { fontSize: '11px', opacity: '0.7', marginBottom: '2px' } } as UIPart);
        if (typeof n.eventDayTarget === 'number') {
            let due = Math.floor(n.eventDayTarget) - curAbsDay;
            let dueStr = due > 1 ? (due + ' days remaining') : due === 1 ? '1 day remaining' : due === 0 ? 'due today' : ('overdue by ' + (-due) + (due === -1 ? ' day' : ' days'));
            body.push({ type: 'text', text: 'Due:  ' + dueStr, style: { fontSize: '11px', marginBottom: '6px', color: due < 0 ? '#d98a8a' : '#e8c07d' } } as UIPart);
        }
        body.push({ type: 'button', text: n.isTracked ? 'Stop Tracking' : 'Track Quest', iconId: 'navigation', style: { width: '100%', fontSize: '11px', marginBottom: '4px', backgroundColor: n.isTracked ? undefined : 'rgba(126,200,160,0.15)', color: n.isTracked ? undefined : '#7ec8a0' }, callback: async function() { await toggleNarrativeTracking(n.id); await refreshFn(); } } as UIPart);
        (n.actionInstances || []).forEach(function(inst: any) {
            body.push({ type: 'button', text: inst.name, iconId: 'zap', style: { width: '100%', fontSize: '11px', marginBottom: '3px' }, callback: async function() { await aeRunEntityAction(n.id, inst.id); await refreshFn(); } } as UIPart);
        });
        body.push({ type: 'button', text: 'Edit Entity', iconId: 'tool', style: { width: '100%', fontSize: '11px', marginTop: '2px', opacity: '0.75' }, callback: async function() { try { await openEntityEditModal(n.id); } catch (e) {} } } as UIPart);
        return { type: 'collapsibleSection', title: aeIconPfx(n.icon) + n.name, initialCollapsed: true, storageKey: 'temp:ae_narr_' + n.id, content: body } as UIPart;
    });
}

// Personal (per-character) resource rows with inline +/- steppers -- adjustCharResource
// runs directly in-worker, so there is no round-trip latency native has an edge here.
function _aeResourceRows(charId: string, resources: any[], refreshFn: () => Promise<void>): UIPart[] {
    if (!resources || resources.length === 0) return [_aeHudInfo('No personal resources.')];
    return resources.map(function(r: any) {
        let valLabel: string;
        if (r.type === 'pool') valLabel = String(r.value) + (typeof r.max === 'number' ? ' / ' + r.max : '');
        else valLabel = (r.states && r.states[r.value]) ? r.states[r.value] : String(r.value);
        return _aeHudRow([
            { type: 'text', text: r.name, style: { flex: '1 1 0', fontSize: '12px', alignSelf: 'center' } } as UIPart,
            { type: 'button', text: '\u2212', style: { width: '30px', margin: 0 }, callback: async function() { await adjustCharResource(charId, r.tag, -1); await broadcastSceneState(); await refreshFn(); } } as UIPart,
            { type: 'text', text: valLabel, style: { width: '70px', fontSize: '11px', textAlign: 'center', alignSelf: 'center' } } as UIPart,
            { type: 'button', text: '+', style: { width: '30px', margin: 0 }, callback: async function() { await adjustCharResource(charId, r.tag, 1); await broadcastSceneState(); await refreshFn(); } } as UIPart
        ]);
    });
}

// ── MAP ─────────────────────────────────────────────────────────────────────
async function openCalendarModal(): Promise<void> {
    let calHandle: any = null;
    let setOpen = false;
    let setDayVal = 0;
    let setHourVal = 0;

    async function renderCal() {
        let state: any = await getSceneState();
        let parts: UIPart[] = [];
        let clk: any = state ? state.clock : null;

        if (!clk) {
            parts.push(_aeHudInfo('No clock available. Enable "Show date in context" in World Settings > Time & Calendar.'));
            parts.push(_aeHudClose(function() { return calHandle; }));
            try { if (calHandle && !calHandle.isClosed()) { await calHandle.update({ content: parts }); return; } } catch (e) {}
            calHandle = await openEngineModal({ id: 'ae-calendar', title: 'Calendar', size: 'medium', content: parts });
            return;
        }

        parts.push(_aeHudHeader('Clock'));
        parts.push({ type: 'text', text: clk.stamp || '', style: { fontSize: '15px', fontWeight: 'bold', marginBottom: '6px' } } as UIPart);
        parts.push(_aeHudRow([
            { type: 'button', text: '+1 Hour', iconId: 'clock', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {
                let c2 = await loadClock(); await applyClockChange(c2.hours + 1); await renderCal();
            } } as UIPart,
            { type: 'button', text: '+1 Day', iconId: 'calendar', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {
                let c2 = await loadClock(); await applyClockChange(c2.hours + 24); await renderCal();
            } } as UIPart,
            { type: 'button', text: setOpen ? 'Cancel' : 'Set', iconId: 'edit', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {
                if (!setOpen) { setDayVal = clk.absoluteDay; setHourVal = clk.hourOfDay; }
                setOpen = !setOpen; await renderCal();
            } } as UIPart
        ]));
        if (setOpen) {
            parts.push(_aeHudRow([
                { type: 'text', text: 'Day', style: { fontSize: '11px', opacity: '0.6', alignSelf: 'center' } } as UIPart,
                { type: 'numberInput', initialValue: setDayVal, style: { width: '70px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) { setDayVal = Math.max(0, Math.floor(Number(v) || 0)); } } as UIPart,
                { type: 'text', text: 'Hour', style: { fontSize: '11px', opacity: '0.6', alignSelf: 'center' } } as UIPart,
                { type: 'numberInput', initialValue: setHourVal, style: { width: '70px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) { let h = Math.floor(Number(v) || 0); if (h < 0) h = 0; if (h > 23) h = 23; setHourVal = h; } } as UIPart,
                { type: 'button', text: 'Apply', style: { margin: 0, fontSize: '12px', backgroundColor: 'rgba(126,200,160,0.15)' }, callback: async function() {
                    await applyClockChange(setDayVal * 24 + setHourVal); setOpen = false; await renderCal();
                } } as UIPart
            ]));
        }

        // [v1.6.1] Mirrors the World-Build Wizard's Characters tab button (same
        // text, icon, and target modal) so schedules are reachable from the
        // calendar too, not just the wizard.
        parts.push({ type: 'button', text: '\ud83d\udd52 View All Schedules', iconId: 'clock' as any, style: { width: '100%', marginTop: '4px', marginBottom: '10px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.10)' }, callback: async function() { await openAllSchedulesModal(); } } as UIPart);

        parts.push(_aeHudHeader('Upcoming (Narrative)'));
        let timed: any[] = (clk.timedActions || []);
        let dayNames: string[] = (clk.dayNames || []);
        let todayCycle: number = clk.dayOfCycle;

        let dayBuckets: any = {};
        let dailyActions: any[] = [];
        function pushBucket(d: number, a: any) { if (!dayBuckets[d]) dayBuckets[d] = []; dayBuckets[d].push(a); }
        for (let i = 0; i < timed.length; i++) {
            let a = timed[i];
            let placed = false;
            if (typeof a.dayOfCycle === 'number' && a.dayOfCycle >= 1 && a.dayOfCycle <= 28) { pushBucket(a.dayOfCycle, a); placed = true; }
            if (typeof a.dayOfWeek === 'number' && a.dayOfWeek >= 1 && a.dayOfWeek <= 7) {
                for (let w = 0; w < 4; w++) { pushBucket(w * 7 + a.dayOfWeek, a); } placed = true;
            }
            if (!placed && typeof a.absoluteDay === 'number') {
                let cyc = ((a.absoluteDay % 28) + 28) % 28 + 1;
                let curCycleStart = (clk.absoluteDay - (todayCycle - 1));
                if (a.absoluteDay >= curCycleStart && a.absoluteDay < curCycleStart + 28) { pushBucket(cyc, a); placed = true; }
            }
            if (!placed) dailyActions.push(a);
        }

        let header: UIPart[] = [];
        for (let c = 0; c < 7; c++) {
            let nm = dayNames[c] ? String(dayNames[c]).slice(0, 3) : String(c + 1);
            header.push({ type: 'text', text: nm, style: { flex: '1 1 0', fontSize: '10px', opacity: '0.6', textAlign: 'center', fontWeight: 'bold' } } as UIPart);
        }
        parts.push({ type: 'row', style: { gap: '3px', marginBottom: '3px' }, content: header } as UIPart);

        for (let wk = 0; wk < 4; wk++) {
            let rowCells: UIPart[] = [];
            for (let c = 0; c < 7; c++) {
                let dnum = wk * 7 + c + 1;
                let has = !!(dayBuckets[dnum] && dayBuckets[dnum].length);
                let isToday = (dnum === todayCycle);
                let cnt = has ? dayBuckets[dnum].length : 0;
                let bg = has ? 'rgba(126,200,160,0.22)' : 'rgba(255,255,255,0.03)';
                let bord = isToday ? '2px solid #7ec8a0' : (has ? '1px solid rgba(126,200,160,0.4)' : '1px solid rgba(255,255,255,0.06)');
                let label = String(dnum) + (cnt ? ' \u2022' : '');
                let capturedDay = dnum;
                rowCells.push({ type: 'button', text: label, style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '6px 0', backgroundColor: bg, border: bord, color: has ? '#cfeede' : undefined, opacity: (has || isToday) ? '1' : '0.55' }, callback: async function() {
                    let acts = dayBuckets[capturedDay] || [];
                    let dParts: UIPart[] = [];
                    let dh: any = null;
                    dParts.push({ type: 'text', text: 'Day ' + capturedDay + ' of 28', style: { fontSize: '13px', fontWeight: 'bold', marginBottom: '6px' } } as UIPart);
                    if (acts.length === 0) {
                        dParts.push(_aeHudInfo('Nothing tied to this day.'));
                    } else {
                        for (let z = 0; z < acts.length; z++) {
                            let act = acts[z];
                            dParts.push({ type: 'box', style: { padding: '6px 8px', marginBottom: '4px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '6px', borderLeft: act.auto ? '3px solid #88ccff' : '3px solid #e8a87c' }, content: [
                                { type: 'text', text: (act.auto ? '\u26a1 ' : '') + (act.name || 'Action'), style: { fontSize: '12px', fontWeight: 'bold' } } as UIPart,
                                { type: 'text', text: act.summary || '', style: { fontSize: '10px', opacity: '0.65', marginTop: '2px' } } as UIPart
                            ] } as UIPart);
                        }
                    }
                    dParts.push({ type: 'button', text: 'Close', style: { marginTop: '8px' }, callback: async function() { try { if (dh && !dh.isClosed()) await dh.close(); } catch (e) {} } } as UIPart);
                    dh = await openEngineModal({ id: 'ae-cal-day', title: 'Day ' + capturedDay, size: 'small', content: dParts });
                } } as UIPart);
            }
            parts.push({ type: 'row', style: { gap: '3px', marginBottom: '3px' }, content: rowCells } as UIPart);
        }

        if (dailyActions.length > 0) {
            parts.push(_aeHudHeader('Every Day'));
            for (let i = 0; i < dailyActions.length; i++) {
                let a = dailyActions[i];
                parts.push({ type: 'box', style: { padding: '5px 8px', marginBottom: '3px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '5px', borderLeft: a.auto ? '3px solid #88ccff' : '3px solid #e8a87c' }, content: [
                    { type: 'text', text: (a.auto ? '\u26a1 ' : '') + (a.name || 'Action') + '  \u2014  ' + (a.summary || ''), style: { fontSize: '11px' } } as UIPart
                ] } as UIPart);
            }
        }
        if (timed.length === 0) parts.push(_aeHudInfo('No actions are tied to the calendar yet. Add a time condition (Day of Cycle, Day of Week, ...) to a library action.'));

        parts.push(_aeHudClose(function() { return calHandle; }));
        try { if (calHandle && !calHandle.isClosed()) { await calHandle.update({ content: parts }); return; } } catch (e) {}
        calHandle = await openEngineModal({ id: 'ae-calendar', title: 'Calendar', size: 'medium', content: parts });
    }
    await renderCal();
}

// ── CALENDAR / CLOCK ───────────────────────────────────────────────────────
async function openMapModal(): Promise<void> {
    let mapHandle: any = null;

    // Resolve the outbound edge (child / sibling / connection) for a destination id.
    // Parent (return trip) has no edge and is free.
    function _mapEdge(g: any, id: string): any {
        let all: any[] = ([] as any[]).concat(g.children || [], g.siblings || [], g.connections || []);
        return all.filter(function(e: any) { return e.id === id; })[0] || null;
    }
    // Human cost string: time first ("2h"), then resource ("5 currency").
    function _mapCost(edge: any): string {
        if (!edge) return '';
        let bits: string[] = [];
        if (edge.timeCost && edge.timeCost > 0) bits.push(edge.timeCost + 'h');
        if (edge.resourceCost && edge.resourceTag) bits.push(edge.resourceCost + ' ' + String(edge.resourceTag).replace('#', ''));
        return bits.join('  +  ');
    }

    async function renderMap() {
        let state: any = await getSceneState();
        let parts: UIPart[] = [];
        if (!state) {
            parts.push(_aeHudInfo('No scene state available.'));
            parts.push(_aeHudClose(function() { return mapHandle; }));
            try { if (mapHandle && !mapHandle.isClosed()) { await mapHandle.update({ content: parts }); return; } } catch (e) {}
            mapHandle = await openEngineModal({ id: 'ae-nav-map', title: 'Map', size: 'medium', content: parts });
            return;
        }
        let g: any = state.locationGraph || {};

        // Current location header + body + atmosphere.
        parts.push({ type: 'text', text: (g.currentIcon ? g.currentIcon + ' ' : '') + (state.locationName || 'Unknown location'), style: { fontSize: '15px', fontWeight: 'bold', marginBottom: '2px' } } as UIPart);
        if (state.locationDescription) parts.push({ type: 'text', text: state.locationDescription, style: { fontSize: '11px', opacity: '0.75', lineHeight: '1.4', marginBottom: '3px' } } as UIPart);
        if (state.locationAtmosphere) parts.push({ type: 'text', text: state.locationAtmosphere, style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '3px' } } as UIPart);

        // "Looking at" panel: the inspected destination, its cost, and the Travel /
        // Teleport actions. Sits directly under the current location so the buttons
        // have the full modal width and room for the cost line.
        if (_aeMapInspectId && _aeMapInspectId !== state.locationId) {
            let insEnt: any = null;
            try { insEnt = await loadEntity(_aeMapInspectId); } catch (eIns) { insEnt = null; }
            if (insEnt) {
                let edge = _mapEdge(g, _aeMapInspectId);
                let isParent = (g.parentId === _aeMapInspectId);
                let costLine = _mapCost(edge);
                let gated = edge ? !!edge.gated : false;
                let panel: UIPart[] = [];
                panel.push({ type: 'text', text: 'Looking at', style: { fontSize: '10px', opacity: '0.55', fontWeight: 'bold', marginBottom: '2px' } } as UIPart);
                panel.push({ type: 'text', text: aeIconPfx(insEnt.icon) + (insEnt.name || ''), style: { fontSize: '14px', fontWeight: 'bold', color: '#a9d4f5', marginBottom: '3px' } } as UIPart);
                panel.push({ type: 'text', text: insEnt.description || 'No description recorded.', style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);
                if (costLine) panel.push({ type: 'text', text: 'Travel cost:  ' + costLine, style: { fontSize: '11px', color: '#e8c07d', marginBottom: '6px' } } as UIPart);
                else if (isParent) panel.push({ type: 'text', text: 'Return trip \u2014 no cost.', style: { fontSize: '11px', opacity: '0.55', marginBottom: '6px' } } as UIPart);
                else panel.push({ type: 'text', text: 'No travel cost.', style: { fontSize: '11px', opacity: '0.55', marginBottom: '6px' } } as UIPart);
                if (gated) panel.push({ type: 'text', text: '\ud83d\udd12 Locked \u2014 travel unavailable.', style: { fontSize: '11px', color: '#d98a8a', marginBottom: '6px' } } as UIPart);
                panel.push(_aeHudRow([
                    { type: 'button', text: 'Travel' + (costLine ? '  (' + costLine + ')' : ''), iconId: 'corner-down-right', disabled: gated, style: { flex: '2 1 0', fontSize: '12px', margin: 0, fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, callback: async function() {
                        let dest = _aeMapInspectId;
                        try { if (mapHandle && !mapHandle.isClosed()) await mapHandle.close(); } catch (e0) {}
                        try { await performTravelRequest(dest); } catch (eTrav) { api.v1.error('[AE:hud] travel:', eTrav); }
                    } } as UIPart,
                    { type: 'button', text: 'Teleport', iconId: 'navigation', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {
                        let dest = _aeMapInspectId;
                        try { await commitTravel(dest, true); } catch (eTp) {}
                        _aeMapInspectId = '';
                        await renderMap();
                    } } as UIPart
                ]));
                parts.push({ type: 'box', style: { padding: '9px 11px', marginTop: '8px', marginBottom: '2px', backgroundColor: 'rgba(136,204,255,0.08)', border: '1px solid rgba(136,204,255,0.25)', borderRadius: '8px' }, content: panel } as UIPart);
            }
        }

        // Destination list: each location is a full-width name button that loads it
        // into the "Looking at" panel above. Grouped Above / Nearby / Inside.
        function navBtn(id: string, label: string, icon: any): UIPart {
            let sel = (_aeMapInspectId === id);
            return { type: 'button', text: aeIconPfx(icon) + label, iconId: 'eye', style: { width: '100%', textAlign: 'left', fontSize: '12px', marginBottom: '3px', backgroundColor: sel ? 'rgba(136,204,255,0.15)' : undefined, border: sel ? '1px solid rgba(136,204,255,0.4)' : undefined }, callback: async function() { _aeMapInspectId = id; await renderMap(); } } as UIPart;
        }

        parts.push(_aeHudHeader('Travel'));
        let anyConn = false;

        if (g.parentId) {
            parts.push(_aeHudSub('Above'));
            parts.push(navBtn(g.parentId, g.parentName || 'Up one level', g.parentIcon));
            anyConn = true;
        }

        let nearby: any[] = [];
        (g.siblings || []).forEach(function(s: any) { nearby.push({ id: s.id, name: s.name, icon: s.icon }); });
        (g.connections || []).forEach(function(c: any) { nearby.push({ id: c.id, name: c.name + (c.label ? '  \u2014 ' + c.label : ''), icon: c.icon }); });
        if (nearby.length > 0) {
            parts.push(_aeHudSub('Nearby'));
            nearby.forEach(function(n: any) { parts.push(navBtn(n.id, n.name, n.icon)); });
            anyConn = true;
        }

        if ((g.children || []).length > 0) {
            parts.push(_aeHudSub('Inside'));
            (g.children || []).forEach(function(c: any) { parts.push(navBtn(c.id, c.name, c.icon)); });
            anyConn = true;
        }

        if (!anyConn) parts.push(_aeHudInfo('No connected locations.'));

        parts.push(_aeHudClose(function() { return mapHandle; }));
        try { if (mapHandle && !mapHandle.isClosed()) { await mapHandle.update({ content: parts }); return; } } catch (e) {}
        mapHandle = await openEngineModal({ id: 'ae-nav-map', title: 'Map', size: 'medium', content: parts });
    }
    await renderMap();
}

// ── CHARACTER INSPECTION VIEW ──────────────────────────────────────────────────
// [v0.9.9.7] Full character detail view opened by tapping a name in Inspect. Reads
// buildEntityDetailPayload directly (in-worker, no message round-trip) -- the SAME
// data source the bridge focus banner uses, so both stay in lockstep by construction.
async function openCharInspectModal(charId: string): Promise<void> {
    let ciHandle: any = null;

    async function renderCI() {
        let parts: UIPart[] = [];
        let char = await loadCharacter(charId);
        if (!char) {
            parts.push(_aeHudInfo('Character not found.'));
            parts.push(_aeHudClose(function() { return ciHandle; }));
            try { if (ciHandle && !ciHandle.isClosed()) { await ciHandle.update({ content: parts }); return; } } catch (e) {}
            ciHandle = await openEngineModal({ id: 'ae-char-inspect', title: 'Character', size: 'medium', content: parts });
            return;
        }
        let ent = char.entityId ? await loadEntity(char.entityId) : null;
        let cfg = await loadConfig();
        let detail = await buildEntityDetailPayload(charId, char, ent);
        let clk = await loadClock(cfg);
        let curAbsDay = clockAbsoluteDay(clk.hours);

        // Name + Edit Profile.
        parts.push(_aeHudRow([
            { type: 'text', text: char.name || 'Character', style: { flex: '1 1 0', fontSize: '15px', fontWeight: 'bold', alignSelf: 'center' } } as UIPart,
            { type: 'button', text: 'Edit Profile', iconId: 'edit-3', style: { fontSize: '11px', margin: 0 }, callback: async function() { try { await openCharEditModal(charId); } catch (e) {} } } as UIPart
        ]));

        // Dramatis persona + thoughts line.
        parts.push({ type: 'text', text: _aeCharDramatis(char), style: { fontSize: '11px', opacity: '0.75', lineHeight: '1.4', marginBottom: '3px' } } as UIPart);
        let thought = (char.ephemeral && char.ephemeral.compressedLine) ? char.ephemeral.compressedLine : '';
        if (thought) parts.push({ type: 'text', text: '\ud83d\udcad ' + thought, style: { fontSize: '11px', opacity: '0.6', fontStyle: 'italic', marginBottom: '6px' } } as UIPart);

        // Snapshot -- collapsible, defaults closed. Generates/regenerates the written
        // appearance snapshot via the same GLM pipeline the bridge's Snapshots section uses.
        let snapText = await api.v1.storyStorage.getOrDefault(STORAGE_CHAR_SNAP_PFX + charId, '') as string;
        let snapBody: UIPart[] = [];
        snapBody.push({ type: 'button', text: snapText ? 'Regenerate Snapshot' : 'Generate Snapshot', iconId: 'edit-3', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() {
            if (!ent) { api.v1.ui.toast('No scene context for snapshot.', { type: 'warning' }); return; }
            try {
                let text = await generateCharacterSnapshot(char, ent, cfg);
                if (text) { await api.v1.storyStorage.set(STORAGE_CHAR_SNAP_PFX + charId, text); api.v1.ui.toast('\u270d\ufe0f Snapshot ready', { type: 'success', autoClose: 1500 }); }
                else { api.v1.ui.toast('Snapshot generation failed.', { type: 'warning' }); }
            } catch (eSnap) { api.v1.error('[AE:hud] snapshot:', eSnap); }
            await renderCI();
        } } as UIPart);
        if (snapText) snapBody.push({ type: 'text', text: snapText, style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.5', whiteSpace: 'pre-wrap' } } as UIPart);
        else snapBody.push(_aeHudInfo('No snapshot generated yet.'));
        parts.push({ type: 'collapsibleSection', title: 'Snapshot' + (snapText ? ' \u2014 ready' : ''), initialCollapsed: true, storageKey: 'temp:ae_char_snap_' + charId, content: snapBody } as UIPart);

        // Follow Me / Stay Here -- non-protagonist only, identical rule to the bridge toggle.
        if (!detail.isProtagonist && detail.isFollowing !== undefined) {
            parts.push({ type: 'button', text: detail.isFollowing ? '\ud83d\udc64 Stay here' : '\ud83d\udc65 Follow me', iconId: detail.isFollowing ? 'user' : 'users', style: { width: '100%', fontSize: '12px', marginBottom: '8px', backgroundColor: detail.isFollowing ? undefined : 'rgba(126,200,160,0.15)', color: detail.isFollowing ? undefined : '#7ec8a0' }, callback: async function() { await toggleCharFollow(charId); await renderCI(); } } as UIPart);
        }

        let hooks = detail.hooks || [];
        parts.push({ type: 'collapsibleSection', title: 'Active Hooks (' + hooks.length + ')', initialCollapsed: false, storageKey: 'temp:ae_char_hooks_' + charId, content: _aeHookRows(hooks, charId, renderCI) } as UIPart);

        let children = detail.children || [];
        let items = children.filter(function(c: any) { return c.type === 'item'; });
        parts.push({ type: 'collapsibleSection', title: 'Inventory (' + items.length + ')', initialCollapsed: false, storageKey: 'temp:ae_char_inv_' + charId, content: items.length ? _aeItemSection(items, charId, renderCI) : [_aeHudInfo('No carried items.')] } as UIPart);

        let narrs = children.filter(function(c: any) { return c.type === 'narrative'; });
        parts.push({ type: 'collapsibleSection', title: 'Narratives (' + narrs.length + ')', initialCollapsed: false, storageKey: 'temp:ae_char_narr_' + charId, content: narrs.length ? _aeNarrativeSection(narrs, curAbsDay, renderCI) : [_aeHudInfo('No narrative threads.')] } as UIPart);

        let cres = detail.charResources || [];
        parts.push({ type: 'collapsibleSection', title: 'Resources (' + cres.length + ')', initialCollapsed: true, storageKey: 'temp:ae_char_res_' + charId, content: _aeResourceRows(charId, cres, renderCI) } as UIPart);

        parts.push(_aeHudClose(function() { return ciHandle; }));
        try { if (ciHandle && !ciHandle.isClosed()) { await ciHandle.update({ content: parts }); return; } } catch (e) {}
        ciHandle = await openEngineModal({ id: 'ae-char-inspect', title: 'Character', size: 'medium', content: parts });
    }
    await renderCI();
}

// ── INSPECT ───────────────────────────────────────────────────────────────────
async function openInspectModal(): Promise<void> {
    let insHandle: any = null;

    async function renderInspect() {
        let parts: UIPart[] = [];
        let state: any = await getSceneState();
        if (!state) {
            parts.push(_aeHudInfo('No scene state available.'));
            parts.push(_aeHudClose(function() { return insHandle; }));
            try { if (insHandle && !insHandle.isClosed()) { await insHandle.update({ content: parts }); return; } } catch (e) {}
            insHandle = await openEngineModal({ id: 'ae-nav-inspect', title: 'Inspect', size: 'medium', content: parts });
            return;
        }

        let chars = (state.presentCharacters || []).filter(function(c: any) { return !c.isProtagonist; });
        parts.push({ type: 'row', style: { alignItems: 'center', gap: '6px', marginTop: '4px', marginBottom: '2px' }, content: [
            { type: 'text', text: 'Characters', style: { flex: '1 1 0', fontWeight: 'bold', fontSize: '12px' } },
            { type: 'button', text: '\u27f3 Detect', iconId: 'refresh-cw', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 8px', opacity: '0.8' }, callback: async function() { await aeRefreshPresence(); await renderInspect(); } }
        ] } as UIPart);
        parts.push({ type: 'button', text: '+ Add Character to Scene', iconId: 'user-plus', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() {
            const acAll = await loadAllCharacters();
            const acPresent = new Set((state.presentCharacters || []).map(function(pc: any) { return pc.id; }));
            const acCands = acAll.filter(function(ac) { return ac.active && !ac.isProtagonist && (ac as any).npcClass !== 'minor' && !acPresent.has(ac.id); });
            // Pre-resolve each candidate's current location name for the picker sublabel.
            const acIdx = await loadEntityIndex();
            const acLocById: { [k: string]: string } = {};
            for (const ac of acCands) {
                let locName = 'no location';
                if (ac.entityId) {
                    let room = getEffectiveRoomId(ac.entityId, acIdx);
                    if (room) { let rn = acIdx.find(function(m) { return m.id === room; }); if (rn && rn.name) locName = rn.name; }
                }
                acLocById[ac.id] = locName;
            }
            await openPickerModal({
                title: 'Add Character to Scene',
                items: acCands,
                getId: function(it: any) { return it.id; },
                getLabel: function(it: any) { return it.name; },
                getSublabel: function(it: any) { return '\ud83d\udccd ' + (acLocById[it.id] || 'no location'); },
                searchable: true,
                emptyText: 'Everyone active is already here.',
                onSelect: async function(it: any) { await aeMoveCharToScene(it.id); await renderInspect(); }
            });
        } } as UIPart);
        if (chars.length === 0) parts.push(_aeHudInfo('No one else is here.'));
        chars.forEach(function(c: any) {
            parts.push({ type: 'row', style: { gap: '4px', marginBottom: '3px', alignItems: 'center' }, content: [
                { type: 'button', text: c.name + (c.compressedLine ? '  \u2014  ' + c.compressedLine : ''), iconId: 'user', style: { flex: '1 1 0', textAlign: 'left', fontSize: '12px' }, callback: async function() { try { await openCharInspectModal(c.id); } catch (e) {} } },
                { type: 'button', text: 'Exclude', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px', opacity: '0.8' }, callback: async function() { await aeSetCharScenePresent(c.id, false); await renderInspect(); } }
            ] } as UIPart);
        });

        // Items / narratives native to THIS location -- pulled from the same
        // buildEntityDetailPayload children the character inventory view uses, so
        // descriptions/actions/state are real instead of the old name-only buttons.
        let locEnt = state.locationId ? await loadEntity(state.locationId) : null;
        let locDetail = state.locationId ? await buildEntityDetailPayload(state.locationId, null, locEnt) : null;
        let locChildren = locDetail ? (locDetail.children || []) : [];
        let items = locChildren.filter(function(c: any) { return c.type === 'item'; });
        let narrs = locChildren.filter(function(c: any) { return c.type === 'narrative'; });

        // [vNEXT] Minor NPCs present at this location, rendered like items (brief +
        // actions + promote), plus a quick drop-in creator scoped to this location.
        let minorIds = new Set((state.presentMinorNpcs || []).map(function(n: any) { return n.id; }));
        let minors = locChildren.filter(function(c: any) { return minorIds.has(c.id); });
        parts.push(_aeHudHeader('Present NPCs (' + minors.length + ')'));
        parts.push({ type: 'button', text: '+ Add NPC Here', iconId: 'user-plus', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() { await openAddMinorNpcModal(state.locationId, renderInspect); } } as UIPart);
        if (minors.length === 0) parts.push(_aeHudInfo('No minor NPCs here.'));
        else parts.push.apply(parts, _aeMinorNpcSection(minors, renderInspect));

        parts.push(_aeHudHeader('Items (' + items.length + ')'));
        if (items.length === 0) parts.push(_aeHudInfo('Nothing here.'));
        else parts.push.apply(parts, _aeItemSection(items, undefined, renderInspect));

        if (narrs.length > 0) {
            let cfg = await loadConfig();
            let clk = await loadClock(cfg);
            parts.push(_aeHudHeader('Narratives (' + narrs.length + ')'));
            parts.push.apply(parts, _aeNarrativeSection(narrs, clockAbsoluteDay(clk.hours), renderInspect));
        }

        parts.push(_aeHudClose(function() { return insHandle; }));
        try { if (insHandle && !insHandle.isClosed()) { await insHandle.update({ content: parts }); return; } } catch (e) {}
        insHandle = await openEngineModal({ id: 'ae-nav-inspect', title: 'Inspect', size: 'medium', content: parts });
    }
    await renderInspect();
}

// ── ACTION (Goal & Approach) ──────────────────────────────────────────────────
async function openActionModal(prefillGoal?: string): Promise<void> {
    let actHandle: any = null;
    if (typeof prefillGoal === 'string' && prefillGoal.length > 0) _aeNavGoal = prefillGoal;

    function composeInstance(): any {
        let tt = (_aeNavTarget === 'none') ? 'none' : (_aeNavTarget === 'self' ? 'self' : 'entity');
        return {
            id: 'qi_' + Date.now().toString(36) + Math.floor(Math.random() * 1000000).toString(36),
            name: (_aeNavGoal.trim().slice(0, 32) || 'Quick Action'),
            prompt: _aeNavGoal.trim(),
            targetType: tt,
            targetId: (tt === 'entity') ? _aeNavTarget : null,
            skillTag: _aeNavAttr || null,
            stakeDefId: _aeNavStake || null,
            luckSpend: _aeNavLuck || 0
        };
    }

    async function renderAction() {
        let state: any = await getSceneState();
        if (!state) state = { protagSkills: [], stakeDefs: [], presentCharacters: [], presentItems: [], protagResources: [], quickInstances: [] } as any;
        let skills = state.protagSkills || [];
        let stakes = state.stakeDefs || [];

        // Defaults on first open: first skill + its smart stake.
        // [v0.9.9.6] Apply composer defaults exactly once per session. Using a distinct
        // init flag (not _aeNavAttr === null) so that an explicit 'No check' (null) sticks.
        if (!_aeNavInit) {
            if (skills.length) _aeNavAttr = '#' + String(skills[0].name).toLowerCase();
            _aeNavStake = _aeDefaultStakeFor(state, _aeNavAttr);
            _aeNavStakeAuto = true;
            _aeNavInit = true;
        }

        let silent = await getSilentMode();
        let parts: UIPart[] = [];

        // Header + Story/Silent toggle.
        parts.push(_aeHudRow([
            { type: 'text', text: 'Goal & Approach', style: { flex: '1 1 0', fontSize: '13px', fontWeight: 'bold', color: '#7ec8a0' } } as UIPart,
            { type: 'button', text: silent ? 'Silent' : 'Story', iconId: silent ? 'bell-off' : 'bell', style: { width: '90px', margin: 0, fontSize: '11px' }, callback: async function() { await setSilentMode(!silent); await renderAction(); } } as UIPart
        ]));

        parts.push({ type: 'multilineTextInput', placeholder: 'Describe your goal and how you attempt to accomplish it. This informs what success or failure looks like.', initialValue: _aeNavGoal, style: { minHeight: '54px', marginBottom: '6px' }, onChange: async function(v: string) { _aeNavGoal = v; } } as UIPart);

        // [v0.9.9.6] Skill / Stakes / Target -- one compact row of three pickers.
        // Button text is the current value; the empty state IS the label
        // ("No check" / "No stake" / "No target"). No leading header prefix.
        let skillLabel = 'No check';
        if (_aeNavAttr) { let sk = skills.filter(function(s: any) { return '#' + String(s.name).toLowerCase() === _aeNavAttr; })[0]; if (sk) skillLabel = sk.name + ' (' + (sk.sheetMod >= 0 ? '+' : '') + sk.sheetMod + ')'; }
        let skillBtn = { type: 'button', text: skillLabel, iconId: 'target', style: { flex: '1 1 0', textAlign: 'left', fontSize: '11px', margin: 0 }, callback: async function() {
            await openPickerModal({
                title: 'Skill / Attribute', items: skills, size: 'small',
                getId: function(s: any) { return '#' + String(s.name).toLowerCase(); },
                getLabel: function(s: any) { return s.name + ' (' + (s.sheetMod >= 0 ? '+' : '') + s.sheetMod + ')'; },
                selectedId: _aeNavAttr || undefined,
                pinnedOptions: [{ id: '__nocheck__', label: 'No check', onSelect: async function() { _aeNavAttr = null; if (_aeNavStakeAuto) _aeNavStake = ''; await renderAction(); } }],
                onSelect: async function(s: any) { _aeNavAttr = '#' + String(s.name).toLowerCase(); if (_aeNavStakeAuto) _aeNavStake = _aeDefaultStakeFor(state, _aeNavAttr); await renderAction(); }
            });
        } } as UIPart;

        let stakeLabel = 'No stake';
        if (_aeNavStake) { let sd = stakes.filter(function(s: any) { return s.id === _aeNavStake; })[0]; if (sd) stakeLabel = sd.name; }
        let stakeBtn = { type: 'button', text: stakeLabel, iconId: 'award', style: { flex: '1 1 0', textAlign: 'left', fontSize: '11px', margin: 0 }, callback: async function() {
            await openPickerModal({
                title: 'Stakes', items: stakes, size: 'small',
                getId: function(s: any) { return s.id; }, getLabel: function(s: any) { return s.name; },
                selectedId: _aeNavStake || undefined,
                pinnedOptions: [{ id: '__nostake__', label: 'No stake', onSelect: async function() { _aeNavStake = ''; _aeNavStakeAuto = false; await renderAction(); } }],
                onSelect: async function(s: any) { _aeNavStake = s.id; _aeNavStakeAuto = false; await renderAction(); }
            });
        } } as UIPart;

        let tgtItems: any[] = [];
        if (state.locationId) tgtItems.push({ tid: state.locationId, label: 'Here \u2014 ' + (state.locationName || ''), icon: 'map-pin' });
        (state.presentCharacters || []).forEach(function(c: any) { if (!c.isProtagonist && c.entityId) tgtItems.push({ tid: c.entityId, label: c.name, icon: 'user' }); });
        (state.presentItems || []).forEach(function(it: any) { tgtItems.push({ tid: it.id, label: it.name, icon: 'package' }); });
        (state.presentMinorNpcs || []).forEach(function(n: any) { if (n.id) tgtItems.push({ tid: n.id, label: n.name, icon: 'user' }); });
        let tgtLabel = 'No target';
        if (_aeNavTarget === 'self') tgtLabel = 'Self';
        else if (_aeNavTarget !== 'none') { let ti = tgtItems.filter(function(t: any) { return t.tid === _aeNavTarget; })[0]; tgtLabel = ti ? ti.label : 'No target'; }
        let tgtBtn = { type: 'button', text: tgtLabel, iconId: 'crosshair', style: { flex: '1 1 0', textAlign: 'left', fontSize: '11px', margin: 0 }, callback: async function() {
            await openPickerModal({
                title: 'Target', items: tgtItems, size: 'small',
                getId: function(t: any) { return t.tid; }, getLabel: function(t: any) { return t.label; }, getIcon: function(t: any) { return undefined; },
                selectedId: (_aeNavTarget !== 'none' && _aeNavTarget !== 'self') ? _aeNavTarget : undefined,
                pinnedOptions: [
                    { id: '__none__', label: 'No target', onSelect: async function() { _aeNavTarget = 'none'; await renderAction(); } },
                    { id: '__self__', label: 'Self', onSelect: async function() { _aeNavTarget = 'self'; await renderAction(); } }
                ],
                onSelect: async function(t: any) { _aeNavTarget = t.tid; await renderAction(); }
            });
        } } as UIPart;

        parts.push(_aeHudRow([skillBtn, stakeBtn, tgtBtn]));

        // Luck stepper (only when a #luck personal resource is positive).
        let luckRes = (state.protagResources || []).filter(function(r: any) { return r.tag === '#luck'; })[0];
        let luckMax = luckRes ? (luckRes.value || 0) : 0;
        if (luckMax > 0) {
            if (_aeNavLuck > luckMax) _aeNavLuck = luckMax;
            parts.push(_aeHudRow([
                { type: 'text', text: 'Spend Luck (max ' + luckMax + ')', style: { flex: '1 1 0', fontSize: '11px', opacity: '0.7' } } as UIPart,
                { type: 'numberInput', initialValue: _aeNavLuck, style: { width: '70px', margin: 0 }, onChange: async function(v: number) { _aeNavLuck = Math.max(0, Math.min(luckMax, Math.floor(v || 0))); } } as UIPart
            ]));
        } else { _aeNavLuck = 0; }

        // Save / Execute.
        parts.push(_aeHudRow([
            { type: 'button', text: 'Save Preset', iconId: 'save', style: { flex: '1 1 0', margin: 0, fontSize: '12px' }, callback: async function() {
                if (!_aeNavGoal.trim()) { api.v1.ui.toast('Describe your goal first.', { type: 'warning' }); return; }
                try { let list = await loadQuickInstances(); let rec: any = composeInstance(); list.push(rec); await saveQuickInstances(list); api.v1.ui.toast('Preset saved.', { type: 'success', autoClose: 1500 }); await renderAction(); }
                catch (e) { api.v1.error('[AE:hud] save preset:', e); }
            } } as UIPart,
            { type: 'button', text: 'Execute', iconId: 'zap', style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, callback: async function() {
                if (!_aeNavGoal.trim()) { api.v1.ui.toast('Describe your goal first.', { type: 'warning' }); return; }
                try { if (actHandle && !actHandle.isClosed()) await actHandle.close(); } catch (e0) {}
                try { await runQuickInstance(composeInstance(), { silentOverride: silent }); } catch (eRun) { api.v1.error('[AE:hud] execute:', eRun); }
            } } as UIPart
        ]));

        // [v0.9.9.7] Available actions, grouped by WHERE each one comes from (Player /
        // Location / a present character / an item) instead of one flat list. Runs
        // through the shared aeRunEntityAction resolver (same RUN_ACTION_INSTANCE path;
        // target-gated actions pick a target first). Source is the group header now,
        // so it is no longer repeated in the button label.
        function availActionRow(inst: any): UIPart {
            let costStr = inst.hasCost ? ('  [' + inst.costAmount + ' ' + String(inst.costTag || '').replace('#', '') + ']') : '';
            let label = inst.name + (inst.requiresTarget ? '  (target)' : '') + costStr;
            return { type: 'button', text: label, iconId: inst.silent ? 'eye-off' : 'play', style: { width: '100%', textAlign: 'left', fontSize: '12px', marginBottom: '3px' }, callback: async function() {
                await aeRunEntityAction(inst.entityId, inst.id, async function() { try { if (actHandle && !actHandle.isClosed()) await actHandle.close(); } catch (e0) {} });
            } } as UIPart;
        }
        let avails = state.availableInstances || [];
        if (avails.length > 0) {
            let protagEntry = (state.presentCharacters || []).find(function(c: any) { return c.isProtagonist; });
            let protagEntId = protagEntry ? protagEntry.entityId : '';
            function availSourceLabel(entId: string, entName: string): string {
                if (entId === protagEntId) return 'Player';
                if (entId === state.locationId) return 'Location';
                let pc = (state.presentCharacters || []).find(function(c: any) { return c.entityId === entId && !c.isProtagonist; });
                if (pc) return pc.name;
                return entName || 'Other';
            }
            let availGroups: { key: string; label: string; insts: any[] }[] = [];
            avails.forEach(function(inst: any) {
                let grp = availGroups.filter(function(g) { return g.key === inst.entityId; })[0];
                if (!grp) { grp = { key: inst.entityId, label: availSourceLabel(inst.entityId, inst.entityName), insts: [] }; availGroups.push(grp); }
                grp.insts.push(inst);
            });
            parts.push(_aeHudHeader('Available Actions (' + avails.length + ')'));
            availGroups.forEach(function(g) {
                parts.push(_aeHudSub(g.label));
                g.insts.forEach(function(inst: any) { parts.push(availActionRow(inst)); });
            });
        }

        // Saved presets.
        let qis = state.quickInstances || [];
        if (qis.length > 0) {
            parts.push(_aeHudHeader('Saved Presets (' + qis.length + ')'));
            qis.forEach(function(qi: any) {
                parts.push(_aeHudRow([
                    { type: 'button', text: qi.name + (qi.targetId ? '  (target)' : ''), iconId: 'zap', style: { flex: '1 1 0', textAlign: 'left', fontSize: '12px', margin: 0 }, callback: async function() {
                        try { if (actHandle && !actHandle.isClosed()) await actHandle.close(); } catch (e0) {}
                        try { let l = await loadQuickInstances(); let found = l.filter(function(x: any) { return x.id === qi.id; })[0]; if (found) await runQuickInstance(found); } catch (eP) { api.v1.error('[AE:hud] preset run:', eP); }
                    } } as UIPart,
                    { type: 'button', text: '', iconId: 'trash-2', style: { width: '34px', margin: 0, color: '#d98a8a' }, callback: async function() {
                        try { let l = await loadQuickInstances(); l = l.filter(function(x: any) { return x.id !== qi.id; }); await saveQuickInstances(l); await renderAction(); } catch (eD) {}
                    } } as UIPart
                ]));
            });
        }

        parts.push(_aeHudClose(function() { return actHandle; }));
        try { if (actHandle && !actHandle.isClosed()) { await actHandle.update({ content: parts }); return; } } catch (e) {}
        actHandle = await openEngineModal({ id: 'ae-nav-action', title: 'Action', size: 'medium', content: parts });
    }
    await renderAction();
}

// ── PLAYER ────────────────────────────────────────────────────────────────────
// [v0.9.9.7] Tabbed: Resources / Stats / Factions / Inventory / Quests. Inventory
// and Quests read buildEntityDetailPayload(protagId).children -- the exact same
// data source and row renderer as the Character Inspection view and the top-level
// Inspect modal, so a carried item or quest looks and behaves identically everywhere.
async function openPlayerModal(): Promise<void> {
    let plHandle: any = null;

    async function renderPlayer() {
        let parts: UIPart[] = [];
        let protagId = await getProtagonistId();
        let state: any = await getSceneState();
        if (!state || !protagId) {
            parts.push(_aeHudInfo('No scene state available.'));
            parts.push(_aeHudClose(function() { return plHandle; }));
            try { if (plHandle && !plHandle.isClosed()) { await plHandle.update({ content: parts }); return; } } catch (e) {}
            plHandle = await openEngineModal({ id: 'ae-nav-player', title: 'Player', size: 'medium', content: parts });
            return;
        }
        let pid: string = protagId;
        let protagChar = await loadCharacter(pid);
        let protagEnt = (protagChar && protagChar.entityId) ? await loadEntity(protagChar.entityId) : null;
        let detail = await buildEntityDetailPayload(pid, protagChar, protagEnt);
        let cfg = await loadConfig();
        let clk = await loadClock(cfg);
        let curAbsDay = clockAbsoluteDay(clk.hours);

        parts.push(_aeHudRow([
            { type: 'text', text: (protagChar ? protagChar.name : 'Player'), style: { flex: '1 1 0', fontSize: '15px', fontWeight: 'bold', alignSelf: 'center' } } as UIPart,
            { type: 'button', text: 'Journal', iconId: 'book', style: { fontSize: '11px', margin: 0 }, callback: async function() { try { await openJournalModal(); } catch (e) { api.v1.error('[AE:hud] journal:', e); } } } as UIPart,
            { type: 'button', text: 'Edit Profile', iconId: 'edit-3', style: { fontSize: '11px', margin: 0 }, callback: async function() { try { await openCharEditModal(pid); } catch (e) {} } } as UIPart
        ]));

        let activeTab = await api.v1.tempStorage.getOrDefault('temp:ae_player_tab', 'resources') as string;
        function tabBtn(id: string, label: string): UIPart {
            let on = activeTab === id;
            return { type: 'button', text: label, style: { flex: '1 1 0', margin: 0, fontSize: '11px', fontWeight: on ? 'bold' : 'normal', backgroundColor: on ? 'rgba(126,200,160,0.15)' : 'transparent', color: on ? '#7ec8a0' : undefined, border: on ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { await api.v1.tempStorage.set('temp:ae_player_tab', id); await renderPlayer(); } } as UIPart;
        }
        parts.push(_aeHudRow([tabBtn('resources', 'Resources'), tabBtn('stats', 'Stats'), tabBtn('factions', 'Factions')]));
        parts.push(_aeHudRow([tabBtn('inventory', 'Inventory'), tabBtn('quests', 'Quests')]));

        if (activeTab === 'resources') {
            let cres = detail.charResources || [];
            if (cres.length === 0) parts.push(_aeHudInfo('No personal resources.'));
            else parts.push.apply(parts, _aeResourceRows(pid, cres, renderPlayer));
        } else if (activeTab === 'stats') {
            let skills = state.protagSkills || [];
            if (skills.length === 0) parts.push(_aeHudInfo('No skills defined.'));
            else skills.forEach(function(s: any) { parts.push({ type: 'text', text: s.name + '   ' + (s.sheetMod >= 0 ? '+' : '') + s.sheetMod, style: { fontSize: '12px', marginBottom: '4px' } } as UIPart); });
        } else if (activeTab === 'factions') {
            let facs = state.factionRelationships || [];
            if (facs.length === 0) parts.push(_aeHudInfo('No faction relationships tracked.'));
            else facs.forEach(function(f: any) { parts.push({ type: 'text', text: f.name + '  \u2014  ' + (f.stateLabel || ''), style: { fontSize: '12px', marginBottom: '4px' } } as UIPart); });
        } else if (activeTab === 'inventory') {
            let items = (detail.children || []).filter(function(c: any) { return c.type === 'item'; });
            if (items.length === 0) parts.push(_aeHudInfo('No items carried.'));
            else parts.push.apply(parts, _aeItemSection(items, pid, renderPlayer));
        } else if (activeTab === 'quests') {
            let narrs = (detail.children || []).filter(function(c: any) { return c.type === 'narrative'; });
            if (narrs.length === 0) parts.push(_aeHudInfo('No active quests.'));
            else parts.push.apply(parts, _aeNarrativeSection(narrs, curAbsDay, renderPlayer));
        }

        parts.push(_aeHudClose(function() { return plHandle; }));
        try { if (plHandle && !plHandle.isClosed()) { await plHandle.update({ content: parts }); return; } } catch (e) {}
        plHandle = await openEngineModal({ id: 'ae-nav-player', title: 'Player', size: 'medium', content: parts });
    }
    await renderPlayer();
}

// ── JOURNAL ─────────────────────────────────────────────────────────────────────
// [v1.7.0 JOURNAL] Native Player Journal UI. Opens from the Player modal. Renderer
// only — every verb lives in Section 10b so the bridge HUD can reuse them later.
// Draft text is held in module-level vars (updated via onChange, never mid-render)
// so re-rendering the modal after an action never clobbers what the user is typing.
var _aeJrnlEditingId: string | null = null;   // id of the bubble currently in edit mode
var _aeJrnlBusy: boolean = false;             // generation in flight (disables buttons)
var _aeJrnlShowArchived: boolean = false;     // archived list visibility toggle
var _aeJrnlCompose: string = '';              // draft for the "new entry" box
var _aeJrnlEditDraft: string = '';            // draft for the bubble being edited
var _aeJrnlStampNew: boolean = false;         // stamp-on-add toggle

async function openJournalModal(): Promise<void> {
    let jHandle: any = null;

    // Kick a rewrite/compress: seed edit mode, run story-aware generation, then load
    // the result into the edit draft for review. Never commits without an explicit Save.
    async function runJrnlGen(kind: string, b: JournalBubble): Promise<void> {
        if (_aeJrnlBusy) return;
        const srcText = (_aeJrnlEditingId === b.id) ? (_aeJrnlEditDraft || b.text) : b.text;
        _aeJrnlBusy = true; _aeJrnlEditingId = b.id;
        await renderJournal();
        let out: string | null = null;
        try { out = (kind === 'rewrite') ? await journalGenerateRewrite(srcText) : await journalGenerateCompress(srcText); }
        catch (e) { api.v1.error('[AE:hud] journal gen:', e); }
        _aeJrnlBusy = false;
        if (out) { _aeJrnlEditDraft = out; api.v1.ui.toast(kind === 'rewrite' ? 'Rewritten \u2014 review and Save.' : 'Compressed \u2014 review and Save.', { type: 'success' }); }
        else { api.v1.ui.toast('Generation failed or returned nothing.', { type: 'error' }); }
        await renderJournal();
    }

    function renderBubble(b: JournalBubble, isArchived: boolean, cfg: GlobalConfig): UIPart {
        const editing = _aeJrnlEditingId === b.id;
        const body: UIPart[] = [];

        // Header line: in-story stamp (if any) or an "Archived" tag.
        body.push({ type: 'row', style: { marginBottom: '4px' }, content: [
            { type: 'text', text: (b.stamped ? journalStampFromHours(b.storyHours, cfg) : (isArchived ? 'Archived' : '')), style: { fontSize: '10px', opacity: '0.6', flex: '1 1 0', alignSelf: 'center' } } as UIPart
        ] } as UIPart);

        if (editing && _aeJrnlBusy) {
            body.push(_aeHudInfo('Working\u2026'));
        } else if (editing) {
            body.push({ type: 'multilineTextInput', initialValue: _aeJrnlEditDraft, placeholder: 'Edit this entry\u2026', onChange: function(v: string) { _aeJrnlEditDraft = v; }, style: { minHeight: '120px', marginBottom: '6px' } } as UIPart);
            body.push(_aeHudRow([
                { type: 'button', text: 'Save', iconId: 'save', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, callback: async function() { await journalUpdateBubble(b.id, _aeJrnlEditDraft); _aeJrnlEditingId = null; api.v1.ui.toast('Saved.', { type: 'success' }); await renderJournal(); } } as UIPart,
                { type: 'button', text: 'Cancel', iconId: 'x', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlEditingId = null; await renderJournal(); } } as UIPart
            ]));
            body.push(_aeHudRow([
                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] jrnl rewrite:', e); }); } } as UIPart,
                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] jrnl compress:', e); }); } } as UIPart
            ]));
        } else {
            // Reading surface: grows with content, then scrolls — never squished/clipped.
            body.push({ type: 'box', style: { maxHeight: '240px', overflowY: 'auto', padding: '8px 10px', backgroundColor: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: '6px', marginBottom: '6px' }, content: [
                { type: 'text', text: (b.text && b.text.trim()) ? b.text : '(empty)', noTemplate: true, style: { fontSize: '12px', lineHeight: '1.5', whiteSpace: 'pre-wrap', wordBreak: 'break-word' } } as UIPart
            ] } as UIPart);
            body.push(_aeHudRow([
                { type: 'button', text: 'Edit', iconId: 'edit-3', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlEditDraft = b.text || ''; _aeJrnlEditingId = b.id; await renderJournal(); } } as UIPart,
                { type: 'button', text: b.stamped ? 'Unstamp' : 'Stamp', iconId: 'clock', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalToggleStamp(b.id); await renderJournal(); } } as UIPart,
                isArchived
                    ? { type: 'button', text: 'Unarchive', iconId: 'refresh', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalSetArchived(b.id, false); api.v1.ui.toast('Restored to Always-On.', { type: 'success' }); await renderJournal(); } } as UIPart
                    : { type: 'button', text: 'Archive', iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalSetArchived(b.id, true); api.v1.ui.toast('Archived \u2014 removed from context.', { type: 'success' }); await renderJournal(); } } as UIPart
            ]));
            body.push(_aeHudRow([
                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] jrnl rewrite:', e); }); } } as UIPart,
                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] jrnl compress:', e); }); } } as UIPart,
                { type: 'button', text: 'Delete', iconId: 'trash', disabled: _aeJrnlBusy, style: { flex: '0 0 auto', margin: 0, fontSize: '11px', color: '#d98a8a' }, callback: async function() { await journalDeleteBubble(b.id); if (_aeJrnlEditingId === b.id) _aeJrnlEditingId = null; api.v1.ui.toast('Deleted.', { type: 'success' }); await renderJournal(); } } as UIPart
            ]));
        }

        return { type: 'box', style: { padding: '8px', marginBottom: '8px', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '8px', opacity: isArchived ? '0.55' : '1', backgroundColor: isArchived ? 'rgba(255,255,255,0.01)' : 'rgba(126,200,160,0.04)' }, content: body } as UIPart;
    }

    async function renderJournal(): Promise<void> {
        const state = await loadJournal();
        const cfg = await loadConfig();
        const active   = state.bubbles.filter(function(b) { return !b.archived; });
        const archived = state.bubbles.filter(function(b) { return b.archived; });
        const parts: UIPart[] = [];

        parts.push(_aeHudInfo('Your running record. Active entries stay Always-On in the lorebook as \u201CThe story so far\u201D, so they survive context. Archived entries are kept but never injected.'));

        // Compose new entry
        parts.push(_aeHudSub('New entry'));
        parts.push({ type: 'multilineTextInput', initialValue: _aeJrnlCompose, placeholder: 'Write what just happened\u2026', onChange: function(v: string) { _aeJrnlCompose = v; }, style: { minHeight: '80px', marginBottom: '6px' } } as UIPart);
        parts.push(_aeHudRow([
            { type: 'checkboxInput', label: 'Stamp with date/time', initialValue: _aeJrnlStampNew, onChange: function(v: boolean) { _aeJrnlStampNew = v; }, style: { flex: '1 1 0', alignSelf: 'center', fontSize: '11px' } } as UIPart,
            { type: 'button', text: 'Add', iconId: 'plus', disabled: _aeJrnlBusy, style: { margin: 0, fontSize: '11px' }, callback: async function() {
                const txt = (_aeJrnlCompose || '').trim();
                if (!txt) { api.v1.ui.toast('Nothing to add.', { type: 'warning' }); return; }
                _aeJrnlCompose = '';
                await journalAddBubble(txt, _aeJrnlStampNew);
                api.v1.ui.toast('Added to journal.', { type: 'success' });
                await renderJournal();
            } } as UIPart
        ]));

        // Toolbar: merge-down + archived visibility
        const tools: UIPart[] = [];
        if (active.length > 1) {
            tools.push({ type: 'button', text: 'Merge all', iconId: 'chevrons-down', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() {
                const n = active.length;
                await journalMergeDown();
                _aeJrnlEditingId = null;
                api.v1.ui.toast('Merged ' + n + ' entries into one.', { type: 'success' });
                await renderJournal();
            } } as UIPart);
        }
        if (archived.length > 0) {
            tools.push({ type: 'button', text: (_aeJrnlShowArchived ? 'Hide archived (' + archived.length + ')' : 'Show archived (' + archived.length + ')'), iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlShowArchived = !_aeJrnlShowArchived; await renderJournal(); } } as UIPart);
        }
        if (tools.length > 0) parts.push(_aeHudRow(tools));

        // Active entries
        parts.push(_aeHudSub('Entries (' + active.length + ')'));
        if (active.length === 0) parts.push(_aeHudInfo('No entries yet. Add one above.'));
        else active.forEach(function(b) { parts.push(renderBubble(b, false, cfg)); });

        // Archived entries (optional)
        if (_aeJrnlShowArchived && archived.length > 0) {
            parts.push(_aeHudSub('Archived (' + archived.length + ')'));
            archived.forEach(function(b) { parts.push(renderBubble(b, true, cfg)); });
        }

        parts.push(_aeHudClose(function() { return jHandle; }));
        try { if (jHandle && !jHandle.isClosed()) { await jHandle.update({ content: parts }); return; } } catch (e) {}
        jHandle = await openEngineModal({ id: 'ae-nav-journal', title: 'Journal', size: 'medium', content: parts });
    }

    await renderJournal();
}

// ── CYOA ──────────────────────────────────────────────────────────────────────
async function openCyoaModal(): Promise<void> {
    let cyHandle: any = null;
    let lastOptions: any[] = [];
    async function renderCyoa(loading: boolean) {
        let parts: UIPart[] = [];
        parts.push(_aeHudInfo('Generate intent-based options, then pick one to load into the Action composer (you choose the skill/stakes).'));
        function modeBtn(mode: string, label: string): UIPart {
            return { type: 'button', text: label, style: { flex: '1 1 0', margin: 0, fontSize: '12px' }, disabled: loading, callback: async function() {
                await renderCyoa(true);
                try { let r = await prepareCyoaOptions(mode); lastOptions = r.options || []; } catch (e) { lastOptions = []; api.v1.error('[AE:hud] cyoa gen:', e); }
                await renderCyoa(false);
            } } as UIPart;
        }
        parts.push(_aeHudRow([ modeBtn('action', 'Action'), modeBtn('dialog', 'Dialog'), modeBtn('mix', 'Mix') ]));
        if (loading) {
            parts.push(_aeHudInfo('Generating choices\u2026'));
        } else if (lastOptions.length > 0) {
            parts.push(_aeHudHeader('Options'));
            lastOptions.forEach(function(opt: any) {
                parts.push({ type: 'button', text: opt.text, style: { width: '100%', textAlign: 'left', fontSize: '12px', marginBottom: '4px', lineHeight: '1.3' }, callback: async function() {
                    try { if (cyHandle && !cyHandle.isClosed()) await cyHandle.close(); } catch (e0) {}
                    await openActionModal(opt.text);
                } } as UIPart);
            });
        }
        parts.push(_aeHudClose(function() { return cyHandle; }));
        try { if (cyHandle && !cyHandle.isClosed()) { await cyHandle.update({ content: parts }); return; } } catch (e) {}
        cyHandle = await openEngineModal({ id: 'ae-nav-cyoa', title: 'CYOA', size: 'medium', content: parts });
    }
    await renderCyoa(false);
}

// ── Registration + mode switch ─────────────────────────────────────────────────
// Builds the script UI extension set (sidebar panel + optional toolbar tray) from
// the current cfg.interfaceMode and registers it. Re-callable to apply a mode change.
async function registerEngineUI(): Promise<void> {
    let cfg = await loadConfig();
    let mode = (cfg as any).interfaceMode || 'native';
    let ext: any[] = [
        { type: 'sidebarPanel', id: 'ce-panel', name: '\ud83d\uddfa Adventure', iconId: 'users', content: [{ type: 'text', text: 'Loading\u2026' }] }
    ];
    if (mode === 'native' || mode === 'both') {
        ext.push({ type: 'toolbarButton', id: 'ae-tb-map',     text: 'Map',     iconId: 'map',     callback: function() { openMapModal().catch(function(e) { api.v1.error('[AE:hud] map:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-inspect', text: 'Inspect', iconId: 'search',  callback: function() { openInspectModal().catch(function(e) { api.v1.error('[AE:hud] inspect:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-action',  text: 'Action',  iconId: 'zap',     callback: function() { openActionModal().catch(function(e) { api.v1.error('[AE:hud] action:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-player',  text: 'Player',  iconId: 'user',    callback: function() { openPlayerModal().catch(function(e) { api.v1.error('[AE:hud] player:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-cyoa',    text: 'CYOA',    iconId: 'compass', callback: function() { openCyoaModal().catch(function(e) { api.v1.error('[AE:hud] cyoa:', e); }); } });
        ext.push({ type: 'toolbarButton', id: 'ae-tb-clock',   text: 'Calendar', iconId: 'calendar', callback: function() { openCalendarModal().catch(function(e) { api.v1.error('[AE:hud] calendar:', e); }); } });
    }
    await api.v1.ui.register(ext);
}

// [v0.9.9.5] Set a specific HUD mode (native | bridge | both) and re-register UI.
async function setInterfaceMode(mode: string): Promise<void> {
    try {
        if (mode !== 'native' && mode !== 'bridge' && mode !== 'both') mode = 'bridge';
        let cfg = await loadConfig();
        if (((cfg as any).interfaceMode || 'native') === mode) return;
        (cfg as any).interfaceMode = mode;
        await saveConfig(cfg);
        await registerEngineUI();
        await refreshSidebar();
        api.v1.ui.toast('HUD mode: ' + mode, { type: 'info', autoClose: 1500 });
    } catch (e) { api.v1.error('[AE:hud] setInterfaceMode:', e); }
}

// Cycles bridge -> native -> both -> bridge and re-registers the UI immediately.
async function cycleInterfaceMode(): Promise<void> {
    try {
        let cfg = await loadConfig();
        let cur = (cfg as any).interfaceMode || 'native';
        let next = (cur === 'bridge') ? 'native' : ((cur === 'native') ? 'both' : 'bridge');
        (cfg as any).interfaceMode = next;
        await saveConfig(cfg);
        await registerEngineUI();
        await refreshSidebar();
        api.v1.ui.toast('HUD mode: ' + next, { type: 'info', autoClose: 1800 });
    } catch (e) { api.v1.error('[AE:hud] cycleInterfaceMode:', e); }
}

api.v1.hooks.register('onScriptsLoaded', async function() {
    try {
        // 1. Register NAI UI: sidebar panel + (when cfg.interfaceMode is native/both)
        //    the native toolbar HUD tray. Bridge mode registers the panel only.
        await registerEngineUI();

        // 2. Permissions
        await api.v1.permissions.request(['fileInput', 'fileDownload', 'lorebookEdit', 'storyEdit', 'documentEdit', 'editorDecorations']);
        await api.v1.timers.sleep(300);

        // 3. [CHANGE] Load image settings before bridge connects so auto-snap is ready.
        await loadImageSettings();

        // 3b. [v0.9.7.9] Lorebook world-pack auto-import. Runs only when storyStorage
        //     has no config (fresh story created from a packed scenario). Non-destructive:
        //     existing stories are always skipped. Runs before bridge handshake so the
        //     first SCENE_STATE_UPDATE already reflects the imported world.
        try { await loadConfigFromLorebook(); } catch (eLcInit) { api.v1.log('[AE:pack] init import error:', eLcInit); }

        // 4. [CHANGE] Pre-seed cachedCharVisuals from storage so getCharacterData() works
        //    immediately on the first generation, even before bridge handshake completes.
        await buildCharacterDataPayload();

        // 5. [CHANGE] initMessaging() — sends HANDSHAKE_REQUEST to bridge. When bridge
        //    ACKs, handleBridgeMessage → broadcastCharacterData + broadcastSceneState.
        await initMessaging();

        // 6. Story init path
        const rawIndex = await api.v1.storyStorage.get(STORAGE_INDEX);
        const isFreshStory = !rawIndex || (Array.isArray(rawIndex) && (rawIndex as any[]).length === 0);

        if (isFreshStory) {
            await showNewStoryPrompt();
            // Modal callbacks own ensureProtagonistExists + refreshSidebar + queueSceneStateBroadcast.
        } else {
            await ensureProtagonistExists();
            await refreshSidebar();
            queueSceneStateBroadcast();

            // 6b. [UNIFY] One-time migration of faction-standing args on entity-attached
            // action instances (action TEMPLATES are already migrated on every loadConfig
            // call above). Only relevant for existing stories — a fresh one has no entities
            // yet. Gated internally by a storyStorage flag so it only ever runs once.
            try { await migrateFactionArgsOnEntities(await loadConfig()); } catch (eFacMig) { api.v1.log('[AE:migrate] entity faction-arg migration skipped:', eFacMig); }
        }

        api.v1.log('[AE] Adventure Engine initialized.');
    } catch (e) {
        api.v1.error('[AE] Init error:', e);
    }
});
