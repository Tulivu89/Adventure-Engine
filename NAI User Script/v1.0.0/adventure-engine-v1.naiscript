    { id: 'arch_slowburn',  name: 'Slow Burn',        stages: ['Strangers', 'Curious', 'Drawn In', 'Smitten'] },
    { id: 'arch_e2l',       name: 'Enemies to Lovers', stages: ['Enemies', 'Reluctant Allies', 'Uneasy Trust', 'Falling', 'Lovers'] },
    { id: 'arch_familial',  name: 'Strained Familial', stages: ['Estranged', 'Tense', 'Reconciling', 'Bonded'] },
    { id: 'arch_custom',    name: 'Custom',           stages: [] }
];

var DEFAULT_GENERAL_STYLE = 'Use punchy, direct, and efficient narrative language. Focus on actionable character details. Omit flowery adjectives. Write as a concise psychological dossier.';

var DEFAULT_TEMPLATES: ContextTemplates = {
    trackedNarrative: "[Current objective: |description|][ — route: |pathNames|]",
    location: "[|playerName| is currently at |name|.][ |description|][ |atmosphere|]",
    player: "[Present with |playerName|: |presentNames|.]",
    npc: "[|name|][ — |relArchetype|, |relStage|][ with |primaryRelationship.targetName|][ (|conditionStates|)][. Goal: |midRange.currentDesire|][. Thinking: |ephemeral.compressedLine|]",
    npcWeb: "[|charA_name| and |charB_name| — |dynamic|]",
    activeNarrative: "[|name|][ — |description|]"
};

// [v0.9.8.4] Previous (pre-rework) default templates. migrateConfig() upgrades a
// stored template to the new default ONLY if it still exactly matches the matching
