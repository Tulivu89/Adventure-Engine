// [vNEXT] Default Stakes seeded to reproduce the prior smart-default behavior
// (force/finesse -> health, focus -> luck, flair -> gold), now fully editable.
function _stakeBand(playerTag: string, playerAmt: number, targetTag: string, targetAmt: number): StakeBand {
    return { player: { tag: playerTag, amount: playerAmt }, target: { tag: targetTag, amount: targetAmt } };
}
var DEFAULT_STAKE_DEFS: StakeDef[] = [
