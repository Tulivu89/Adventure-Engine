      partial: _stakeBand('#health', -1, '#health', -1),
      miss:    _stakeBand('#health', -1, '', 0) },
    { id: 'stake_luck', name: 'Luck', defaultForAttrs: ['#focus'],
      strong:  _stakeBand('', 0, '#luck', -1),
      partial: _stakeBand('#luck', -1, '#luck', -1),
      miss:    _stakeBand('#luck', -1, '', 0) },
    { id: 'stake_currency', name: 'Currency', defaultForAttrs: ['#flair'],
      strong:  _stakeBand('', 0, '#currency', -1),
      partial: _stakeBand('#currency', -1, '#currency', -1),
      miss:    _stakeBand('#currency', -1, '', 0) }
];

// [vNEXT] Starter Memory-block sections for the World-Build Wizard. Setting Name first
// (establishes scope); the rest are optional focuses the user enables as desired. Each
// carries its own scope instructions so per-section generation stays distinct. Style
// targets the Author's Note; everything else assembles into the static Memory block.
var DEFAULT_WIZARD_SECTIONS: WizardMemorySection[] = [
    { id: 'wsec_premise', label: 'Premise', enabled: true, content: '', target: 'memory',
      instructions: 'Write the player\'s establishing premise in SECOND PERSON, opening with "You are " and the protagonist\'s name (e.g. "You are Rowan, a ..."). Establish who the player is and their standing place in the setting as a permanent, evergreen frame. Keep it present-tense and open-ended: no plot events, no goals, no resolution, nothing that will change as the story unfolds \u2014 this line persists unchanged throughout. One or two sentences.' },
    { id: 'wsec_setting', label: 'Setting Name', enabled: true, content: '', target: 'memory',
      instructions: 'State ONLY the setting and its scope in a few words — is this a kingdom, a household, a war, a single conflict? Name the stage the story sits on. Do not describe plot, characters, or themes here.' },
    { id: 'wsec_style', label: 'Style', enabled: true, content: '', target: 'an',
      instructions: 'Describe ONLY the prose style and narrative voice: tense, person, tone, pacing, density. No setting facts, no plot, no themes — only how the writing should read.' },
    { id: 'wsec_themes', label: 'Themes', enabled: true, content: '', target: 'memory',
      instructions: 'Name ONLY the core themes the story explores. Abstract throughlines, not events. Do not restate the setting or describe characters.' },
    { id: 'wsec_conflict', label: 'Conflict', enabled: false, content: '', target: 'memory',
      instructions: 'Describe ONLY the central conflict — the opposing forces and what is contested. Not its resolution, not side characters, not theme.' },
    { id: 'wsec_romance', label: 'Romance and Consequences', enabled: false, content: '', target: 'memory',
      instructions: 'Describe ONLY how romance and intimacy function in this world and what consequences follow from them. Tone and rules of attraction, not specific pairings.' },
    { id: 'wsec_combat', label: 'Combat and Consequences', enabled: false, content: '', target: 'memory',
      instructions: 'Describe ONLY how violence and combat function in this world and what consequences follow. Lethality, aftermath, how the narrative treats it — not specific fights.' },
    { id: 'wsec_stakes', label: 'Stakes', enabled: false, content: '', target: 'memory',
      instructions: 'Describe ONLY what is at risk in this story at the largest scale — what can be won or lost. Not the mechanics, not the plot beats.' }
];

// [vNEXT] Starter topic registry. 'Initial Concept' is the general rolling chat that
// feeds context to the rest; 'World Memory' develops the canon and fans out to the
// Memory sections on commit; 'Style & Voice' develops the Author's Note voice. Later
// phases register entity-producing topics (Characters, Factions, Locations, ...).
var DEFAULT_WIZARD_TOPICS: WizardTopic[] = [
    { id: 'wtopic_concept', label: 'Initial Concept', commitKind: 'concept',
      instructions: 'You are a narrative designer acting as a sounding board to develop a story\'s core concept. Your goal is to help the user refine their title, genre, and initial premise into a playable, cohesive foundation.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Offer one or two concrete suggestions that push the premise forward, exploring exciting themes or tensions.\n4. Ask exactly ONE focused question per turn to expand the world or clarify the core hook.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_memory', label: 'World Memory', commitKind: 'memoryFanout',
      instructions: 'You are a precise world-builder helping the user define the static canon of their world. This data will form the permanent memory block: the Premise (a second-person "You are ..." line establishing the player in the setting, evergreen and unchanging), Setting Scope, Core Themes, Central Conflict, Rules of Romance/Combat, and Macro Stakes.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Focus strictly on establishing immutable facts, abstract throughlines, and world rules. Do not discuss plot events or character arcs.\n4. If the user\'s ideas are vague, critique them directly and offer concrete alternatives.\n5. Ask exactly ONE focused question per turn to pin down a specific canon detail.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_style', label: 'Style & Voice', commitKind: 'memoryFanout',
      instructions: 'You are a prose stylist helping the user define the narrative voice for the Author\'s Note. You must establish the tense, perspective, tone, pacing, and density.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Discuss writing mechanics, not story content. Critique generic style choices (e.g., "dark") and suggest specific literary techniques, emotional registers, or authorial blends.\n4. Ask exactly ONE focused question per turn to clarify how the text should read and feel to the player.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_species', label: 'Species', commitKind: 'speciesBatch',
      instructions: 'You are an anthropologist helping the user design distinct species, peoples, or creature-types. This will generate structured lorebook entries.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Focus on what makes a species fundamentally distinct: anatomical realities, inherent cultural drives, and their systemic role in the world.\n4. Critique generic fantasy tropes directly. Suggest strange, grounded, or biologically unique traits.\n5. Ask exactly ONE focused question per turn to flesh out a specific species\' lore.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_factions', label: 'Factions', commitKind: 'factionsBatch',
      instructions: 'You are a political architect helping the user design factions, organizations, and power structures. This will generate structured lorebook entries.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Dig into the gap between a faction\'s public stated goals and their private realities, methods, or hidden tensions.\n4. Critique monolithic "good" or "evil" factions. Ensure every group has legitimate claims and inherent flaws.\n5. Ask exactly ONE focused question per turn to drill down into a faction\'s motives or resources.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_locations', label: 'Locations', commitKind: 'locationsBatch',
      instructions: 'You are an expert structural world-builder helping the user map out their setting. Your goal is to establish specific locations, their scale (Region, Settlement, or precise Room), their immediate camera-view description, and their deep background lore for the lorebook.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Pull out two distinct layers of information for each place: (A) The immediate scene-present description (1-2 sentences capturing what a camera physically senses on arrival, regardless of whether it is a vast countryside or a small bedroom), and (B) The hidden history, culture, or systemic details reserved strictly for the lorebook entry.\n4. Ensure the immediate description never duplicates the historical lorebook details.\n5. Ask exactly ONE focused question per turn to drill down into scale, atmosphere, or structural connections.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_characters', label: 'Characters', commitKind: 'charactersBatch',
      instructions: 'You are a direct, insightful narrative designer workshopping a character. Your goal is to help the user define the character\'s static baseline: Name, Age, Gender, Species, Role, a tight 1-sentence dramatis personae summary, physical camera-view description, core contradictions, vocal timbre/mannerisms, and formative background.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Do not ask for all fields at once. Ask EXACTLY ONE focused question per turn to dig deeper into specific visual or psychological details.\n4. If a user\'s idea is flat or cliché, critique it directly and concisely. Offer concrete, sensual, or grounded alternatives instead of asking vague questions.\n5. Focus strictly on static identity. Do not workshop momentary feelings, immediate goals, or shifting relationships.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_drama', label: 'Drama & Tension', commitKind: 'dramaSeed',
      instructions: 'You are a dramaturg helping the user seed the dramatic engine of an interactive story: the directed tensions characters carry, the charged dynamics between them, and the plot threads that will drive play.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. Reason only about the established cast and world — do not invent new named people. Tie every tension to a specific person, debt, secret, or want, and name concrete stakes.\n4. Critique symmetric or toothless conflicts directly. Push for asymmetry, hidden motives, and tensions that demand eventual action.\n5. Ask exactly ONE focused question per turn to sharpen a specific hook, dynamic, or thread.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_intro', label: 'Intro / Opening', commitKind: 'introScene',
      instructions: 'You are an exacting writing coach helping the user design the OPENING scene of an interactive story. A strong interactive intro must start *in media res* (already in the location, mid-action), ground the player in immediate sensory details, avoid all backstory or exposition, and end on an unresolved beat that demands player action.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. If the user\'s idea relies on backstory, lore dumping, or starting "before" the action (e.g., waking up, or traveling to the location), critique it directly. Push them into the immediate, physical moment.\n4. Ask exactly ONE focused question per turn to sharpen the sensory atmosphere, the immediate situation, or the unresolved tension that will hand control to the player.\n\nRespond with 2-4 sentences max.' },
    { id: 'wtopic_bestiary', label: 'Bestiary', commitKind: 'archetypeBatch',
      seedMessage: 'I can help you stock a bestiary of drop-in minor NPCs \u2014 the quick, disposable folk and creatures you spawn into a scene: skeletons to fight, a guard to bribe, a vendor to haggle with. Each archetype is a small template with four parts: a NAME or label (which can vary at spawn, like "{Brittle|Rattling|Ancient} Skeleton"); a BRIEF \u2014 one line on what they are doing here, their reason for being in the scene; RESOURCES \u2014 a small stake or two like a Health track, whose state labels read as flavor ("looks close to death"); and ACTION TAGS \u2014 which of your library actions they can use or have used against them. Tell me the kind of world or encounter you are stocking, and we will rough out a few archetypes together.',
      instructions: 'You are a creature-and-cast designer helping the user stock a bestiary of MINOR, drop-in NPCs \u2014 the lightweight, disposable figures spawned into a scene (mobs to fight, folk to bargain with or seduce, ambient background people), NOT deep named characters.\n\nCRITICAL RULES:\n1. Write in pure prose. DO NOT use markdown, bolding, italics, headers, or lists of any kind.\n2. Do not use pleasantries, greetings, or filler praise.\n3. For each archetype, pin down four things: a short NAME or label (offer spawn-time variety with {a|b|c} alternation where it fits), a one-line BRIEF of what they are doing here (their reason to be present), a small RESOURCE stake or two with evocative state labels (e.g. a Health track reading "unharmed \u2192 close to death"), and which ACTION TAGS they use or can be targeted by.\n4. Keep them shallow by design \u2014 no backstory, no arc, no inner life. If the user over-develops one, steer them toward promoting it to a full character instead.\n5. Ask exactly ONE focused question per turn to sharpen a specific archetype.\n\nRespond with 2-4 sentences max.' }
];

// ── World-Build Wizard: chat storage + CRUD (storyStorage) ───────────────────
async function loadWizardChats(): Promise<WizardChat[]> {
    let raw = await api.v1.storyStorage.getOrDefault(STORAGE_WIZ_CHATS, '[]') as string;
    try {
        let arr = JSON.parse(raw);
        if (Array.isArray(arr)) { for (let mc of arr) { if (!mc.characterIds) mc.characterIds = []; } return arr; }
        return [];
    } catch (e) {
        api.v1.error('[AE:wizard] loadWizardChats parse error:', e);
        return [];
    }
}

async function saveWizardChats(chats: WizardChat[]): Promise<void> {
    await api.v1.storyStorage.set(STORAGE_WIZ_CHATS, JSON.stringify(chats || []));
}

async function loadWizardChat(id: string): Promise<WizardChat | null> {
    let chats = await loadWizardChats();
    return chats.find(function(c) { return c.id === id; }) || null;
}

async function saveWizardChat(chat: WizardChat): Promise<void> {
    if (!chat || !chat.id) return;
    let chats = await loadWizardChats();
    let idx = chats.findIndex(function(c) { return c.id === chat.id; });
    chat.updatedAt = Date.now();
    if (idx >= 0) chats[idx] = chat;
    else chats.push(chat);
    await saveWizardChats(chats);
}

async function createWizardChat(topicId: string, title: string): Promise<WizardChat> {
    // [vNEXT] Seed the topic's opening message (if any) so a new chat greets the user
    // and explains what this topic produces.
    let seedMsgs: WizardChatMessage[] = [];
    try {
        let seedCfg = await loadConfig();
        let seedTopic = getWizardTopic(seedCfg, topicId);
        if (seedTopic && (seedTopic as any).seedMessage && String((seedTopic as any).seedMessage).trim()) {
            seedMsgs.push({ role: 'assistant', content: String((seedTopic as any).seedMessage).trim() });
        }
    } catch (eSeed) { /* non-fatal: start empty */ }
    let chat: WizardChat = {
        id: 'wchat_' + generateId(),
        topicId: topicId,
        title: title || 'New Chat',
        messages: seedMsgs,
        contextChatIds: [],
        includeStory: false,
        lorebookEntryIds: [],
        characterIds: [],
        createdAt: Date.now(),
        updatedAt: Date.now()
    };
    await saveWizardChat(chat);
    return chat;
}

async function deleteWizardChat(id: string): Promise<void> {
    let chats = await loadWizardChats();
    chats = chats.filter(function(c) { return c.id !== id; });
    await saveWizardChats(chats);
}

// [vNEXT] Export World-Build Wizard chat transcripts to a JSON file the user can
// save. Reuses the same api.v1.file.save pattern as the world export (fileDownload
// permission is requested at init). scope 'all' dumps every chat; scope 'one' dumps
// just the chat with the given id. Each chat carries its topic label (resolved from
// the registry) for readability. Returns the number of chats written (0 = nothing to
// export / failure), and surfaces its own toasts.
async function exportWizardChats(scope: 'all' | 'one', chatId?: string): Promise<number> {
    try {
        const cfg = await loadConfig();
        let chats = await loadWizardChats();
        if (scope === 'one') {
            chats = chats.filter(function(c) { return c.id === chatId; });
        }
        if (!chats.length) {
            api.v1.ui.toast('No wizard chats to export.', { type: 'info', autoClose: 2500 });
            return 0;
        }

        // Attach a human-readable topic label to each exported chat without mutating
        // the stored records.
        const exportChats = chats.map(function(c) {
            const topic = getWizardTopic(cfg, c.topicId);
            return {
                id: c.id,
                title: c.title,
                topicId: c.topicId,
                topicLabel: topic ? topic.label : '',
                includeStory: !!c.includeStory,
                contextChatIds: c.contextChatIds || [],
                lorebookEntryIds: c.lorebookEntryIds || [],
                characterIds: (c as any).characterIds || [],
                createdAt: c.createdAt,
                updatedAt: c.updatedAt,
                messages: (c.messages || []).map(function(m) { return { role: m.role, content: m.content }; })
            };
        });

        const payload = {
            _aeWizardChats: true,
            aeVersion: '0.9.9.2',
            exportedAt: new Date().toISOString(),
            projectName: (cfg as any).projectName || '',
            chatCount: exportChats.length,
            chats: exportChats
        };

        const safeBase = (((cfg as any).projectName || 'ae_world').replace(/[^a-z0-9]/gi, '_').toLowerCase()) || 'ae_world';
        const fname = safeBase + (scope === 'one' ? '_wizardchat' : '_wizardchats') + '.json';
        await api.v1.file.save(fname, JSON.stringify(payload, null, 2));
        api.v1.ui.toast('Exported ' + exportChats.length + ' chat' + (exportChats.length === 1 ? '' : 's') + '.', { type: 'success', autoClose: 3000 });
        return exportChats.length;
    } catch (e) {
        api.v1.error('[AE:wizard] exportWizardChats failed:', e);
        api.v1.ui.toast('Chat export failed — see engine log.', { type: 'error', autoClose: 3000 });
        return 0;
    }
}

// [vNEXT] Resolve a topic by id from the config registry (falls back to the seeded
// defaults if config has none yet).
function getWizardTopic(cfg: GlobalConfig, topicId: string): WizardTopic | null {
    let list = ((cfg as any).wizardTopics && (cfg as any).wizardTopics.length)
        ? (cfg as any).wizardTopics
        : DEFAULT_WIZARD_TOPICS;
    return list.find(function(t: WizardTopic) { return t.id === topicId; }) || null;
}

