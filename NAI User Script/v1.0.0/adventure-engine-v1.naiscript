// upward navigation (player retreats to parent location). Editable in the
// Action Library like any system template; trash button is suppressed.
// __self__ resolves to the parent location name via the standard scope
// convention (sourceEnt = destination).
const SYS_RETURN_TRAVEL: ActionInstance = {
    id: 'sys_return_travel',
    name: 'Return Travel',
    tags: ['_system'],
    conditions: [
        { id: '_ru_g', type: 'entity_locked', args: { scope: '__self__', value: 'false' } }
    ],
    successEffects: [
        { id: '_ru_n', type: 'inject_narrative', args: { text: 'You return to __self__.' } },
        { id: '_ru_m', type: 'move_player_to_self', args: {} }
    ],
    failureEffects: [],
    alwaysEffects: [],
    hidden: false
};

// [v0.9.82] Tier travel templates — clones of Default Travel for the top-level (tier-1)
// and sub-location (tier-2) bands. The Locations wizard stamps a created location's
// entryActionId to the matching one and syncs its cost effect (id '_tier_cost') + silent
// flag from cfg.tierTravelDefaults. Editable in the Action Library like the other system
// templates; trash suppressed. Deeper locations fall through to sys_default_travel.
const SYS_TRAVEL_TIER1: ActionInstance = {
    id: 'sys_travel_tier1',
    name: 'Tier-1 Travel (Top-level)',
    tags: ['_system'],
    conditions: [
        { id: '_t1_g', type: 'entity_locked', args: { scope: '__self__', value: 'false' } }
    ],
    successEffects: [
        { id: '_t1_n', type: 'inject_narrative', args: { text: 'You set out for __self__.' } },
        { id: '_t1_m', type: 'move_player_to_self', args: {} }
    ],
    failureEffects: [],
    alwaysEffects: [],
    hidden: false
};

const SYS_TRAVEL_TIER2: ActionInstance = {
    id: 'sys_travel_tier2',
    name: 'Tier-2 Travel (Sub-location)',
    tags: ['_system'],
    conditions: [
        { id: '_t2_g', type: 'entity_locked', args: { scope: '__self__', value: 'false' } }
    ],
    successEffects: [
        { id: '_t2_n', type: 'inject_narrative', args: { text: 'You head to __self__.' } },
        { id: '_t2_m', type: 'move_player_to_self', args: {} }
    ],
    failureEffects: [],
    alwaysEffects: [],
    hidden: false
};

// [v0.9.82] Default per-tier travel bands. Index 0 = top-level (regions), 1 = sub-locations,
// 2 = deeper/default (configures the universal sys_default_travel). No cost, narrated by default.
const DEFAULT_TIER_TRAVEL: TierTravelDefault[] = [
    { templateId: 'sys_travel_tier1',   label: 'Top-level (regions)', costTag: '', costAmount: 0, narrated: true },
    { templateId: 'sys_travel_tier2',   label: 'Sub-locations',       costTag: '', costAmount: 0, narrated: true },
    { templateId: 'sys_default_travel', label: 'Deeper / default',     costTag: '', costAmount: 0, narrated: true }
];

// [v0.9.67] Default resolution template — the visible, swappable 2d6 fail-forward Stakes
// system. Shows in the Action Library and is editable like the travel templates. Quick
// actions clone it and bind the runtime stake: skillTag <- chosen attribute, the '#stake'
// placeholder tag <- the wagered resource, and amount <- the wagered magnitude. __target__
// effects are dropped when no target is chosen. To change rule systems, edit this template
// (band ranges, labels, and which bands spend the stake on whom).
const SYS_DEFAULT_RESOLUTION: ActionInstance = {
    id: 'sys_default_resolution',
    name: 'Default Resolution (2d6 Stakes)',
    tags: ['_system'],
    conditions: [],
    resolution: {
        type: 'fail_forward_2d6',
        skillTag: '',
        bands: [
            { id: 'band_miss',    min: -999, max: 6,   label: 'Failure',         gmNote: 'The attempt fails. Describe the setback honestly and let it create a complication \u2014 no convenient last-second save.', effects: [
                { id: 'fx_miss_self',  type: 'modify_char_resource', args: { scope: '__player__', tag: '#stake', op: 'subtract', amount: 1 } }
            ] },
            { id: 'band_partial', min: 7,    max: 9,   label: 'Partial Success', gmNote: 'The goal is achieved, but at a cost. Describe what the protagonist must risk, pay, or sacrifice to get it.', effects: [
                { id: 'fx_part_tgt',   type: 'modify_char_resource', args: { scope: '__target__', tag: '#stake', op: 'subtract', amount: 1 } },
                { id: 'fx_part_self',  type: 'modify_char_resource', args: { scope: '__player__', tag: '#stake', op: 'subtract', amount: 1 } }
            ] },
            { id: 'band_strong',  min: 10,   max: 999, label: 'Strong Hit',      gmNote: 'The attempt clearly succeeds. Describe a clean, decisive outcome \u2014 no cost, no complication.', effects: [
                { id: 'fx_strong_tgt', type: 'modify_char_resource', args: { scope: '__target__', tag: '#stake', op: 'subtract', amount: 1 } }
            ] }
        ]
    },
    successEffects: [],
    failureEffects: [],
    alwaysEffects: [],
    hidden: false
};

// ── Resources ────────────────────────────────────────────────────────────────

type ResourceType = 'pool' | 'track' | 'discrete';

interface ResourceDef {
    id: string;
    name: string;
    type: ResourceType;
    tag: string;        // e.g. #gold, #health
    icon?: string;
    hasBounds: boolean;
    min?: number;
    max?: number;
    states?: string[];  // for 'track' type — ordered state labels
}

interface PartyState {
    resourceValues: Record<string, number>;         // maps Resource ID to current value (amount for pools, index for tracks)
    factionRelationships: Record<string, number>;   // maps Faction ID to current relationship state index
}

// [v0.9.9.2] Time & Calendar interfaces. TimeBandDef is a VIEW layered over the raw
// 24h clock; a band whose startHour > endHour wraps past midnight (e.g. Night 22->6).
// endHour is exclusive. ClockState is the mutable clock, stored in HISTORY storage so
// undo rewinds both the hour count and the auto-advance cadence counter together.
interface TimeBandDef { label: string; startHour: number; endHour: number; }
interface ClockState { hours: number; gensSinceTick: number; }
// [v0.9.9.2] One row of a character's hourly timetable: from this hour, they are at
// locationId. Resolved at travel/manual-time when the player is not co-present.
interface ScheduleRow { startHour: number; locationId: string; }

// ── Image Settings ───────────────────────────────────────────────────────────
// [CHANGE] Formalised from AI engine's anonymous objects. Five presets are stored;
// activeIndex points to which is currently active.

interface ImagePreset {
    width: number;
    height: number;
    steps: number;
    scale: number;
    qualityTags: string;
    negativeTags: string;
}

interface GlobalImageSettings {
    autoDownload: boolean;
    contextSize: number;         // number of story paragraphs fed to the architect prompt
    architectPrompt: string;     // GLM system prompt for image prompt generation
    architectAutoSnap: boolean;  // whether to run architect pass on auto-snap
}

// ── Bridge Payload Shapes ────────────────────────────────────────────────────
// [CHANGE] New types documenting the data shapes sent from engine to bridge.
// These are broadcast via broadcastToTM and received by handleEngineMessage.

interface SceneCharacterInfo {
    // Compact character snapshot included in SCENE_STATE_UPDATE.
    id: string;
    name: string;
    entityId: string;
    briefDescription: string;
    socialMask: string;       // midRange.socialMask — what they are performing
    compressedLine: string;   // ephemeral.compressedLine — immediate state line
    isProtagonist: boolean;
    isFollowing?: boolean;         // [v0.9.31 FOLLOW1] entity body is under protagonist body
}

interface SceneResourceInfo {
    // Party resource summary included in SCENE_STATE_UPDATE.
    id: string;
    name: string;
    type: 'pool' | 'track' | 'discrete';
    value: number;
    tag: string;
    icon?: string;
    min?: number;
    max?: number;
    states?: string[];
}

interface SceneActionInfo {
    // Available entity action summarised for the HUD action grid.
    id: string;
    entityId: string;
    entityName: string;
    label: string;
    hidden: boolean;
    outcomeNote: string;
    hasSkillGate: boolean;
    hasCost: boolean;
    costTag?: string;
    costAmount?: number;
    costIcon?: string;
    silent?: boolean;
}

interface SceneInstanceInfo {
    // [WP-5] A new-system ActionInstance summarised for the HUD Actions tab.
    id: string;
    entityId: string;
    entityName: string;
    name: string;
    hasResolution: boolean;
    requiresTarget: boolean;   // targetMode === 'player_pick'
    outcomeNote: string;
    silent: boolean;
    hasCost?: boolean;         // [v0.9.20] true when a modify_resource subtract effect exists
    costTag?: string;          // e.g. '#gold'
    costAmount?: number;       // magnitude of the deduction
    costIcon?: string;
}

interface SceneStatePayload {
    // Full payload sent as EVT_SCENE_STATE after any state-changing operation.
    // Bridge renders this into the Scene HUD.
    locationId: string;
    locationName: string;
    locationDescription: string;
    locationAtmosphere: string;
    locationState: string;
    presentCharacters: SceneCharacterInfo[];
    partyResources: SceneResourceInfo[];
    availableActions: SceneActionInfo[];
    availableInstances: SceneInstanceInfo[];   // [WP-5] new-system typed actions
    lastRoll?: any;                              // [WP-5] last resolution diagnostic for the HUD
    quickInstances: QuickInstance[];   // [WP-5] new-system player quick actions
    locationGraph?: any;          // graph of current location: parent, children, connections
    activeNarratives?: { id: string; name: string; storyState: string; parentId?: string | null; icon?: string; inPlayerHierarchy?: boolean; isTracked?: boolean; }[];  // all narratives; inPlayerHierarchy = under player subtree; isTracked = pinned quest
    factionRelationships?: { id: string; name: string; states: string[]; stateIdx: number; stateLabel: string; isParty: boolean; }[];
    protagSkills?: { name: string; sheetMod: number; displayValue: string; fieldType: string; enumValues: string[]; categoryId: string; fieldId: string; }[];
    protagResources?: SceneResourceInfo[];   // [v0.9.68] protagonist personal resources (Stakes picker / HUD bar)
    stakeDefs?: { id: string; name: string; defaultForAttrs: string[]; }[];   // [vNEXT] named Stakes for the composer picker
    presentItems?: { id: string; name: string; icon?: string; }[];  // item entities at current location
    presentMinorNpcs?: { id: string; charId: string; name: string; brief: string; }[];  // [vNEXT] minor NPCs present in scene (id = entity body id)
    inVehicleId?: string | null;          // set when the player's effective location IS a vehicle entity
    vehicleWorldLocationId?: string | null; // parentId of the vehicle — the world location it is docked at
    defaultBgUrl?: string;          // [v0.9.40] cfg.defaultBackgroundUrl forwarded to bridge for the location banner
    clock?: SceneClockInfo;         // [v0.9.9.2] world clock + calendar state for the HUD
}

// [v0.9.9.2] World clock + calendar snapshot for the bridge/native HUD. The raw 24h
// fields are the source of truth; bands/labels are presentation layered on top.
interface SceneClockInfo {
    enabled: boolean;
    hours: number;
    hourOfDay: number;
    dayOfCycle: number;
    week: number;
    dayOfWeek: number;
    absoluteDay: number;
    band: string;
    stamp: string;
    dayLabel: string;
    weekLabel: string;
    bands: TimeBandDef[];
    dayNames: string[];
    weekNames: string[];
    autoAdvanceEnabled: boolean;
    advanceHours: number;
    advanceEveryGens: number;
    timedActions: SceneTimedActionInfo[];
}

// [v0.9.9.2] A library action carrying a time condition, surfaced as a calendar
// marker. dayOfWeek/dayOfCycle/absoluteDay/band are placement hints (any may be
// absent); summary is the human description for a tooltip.
interface SceneTimedActionInfo {
    name: string;
    entityName: string;
    summary: string;
    auto: boolean;
    dayOfWeek?: number;
    dayOfCycle?: number;
    absoluteDay?: number;
    band?: string;
}

interface CharacterVisualRecord {
    // Per-character visual data payload sent as EVT_CHAR_DATA_SYNC.
    // Bridge uses this as the source of truth for image generation character matching.
    id: string;
    name: string;
    nicknames: string[];
    // Visual identity fields
    visuals: string;
    uc: string;
    sceneVisuals: string;
    avatarVisuals: string;
    avatarWidth: number;
    avatarHeight: number;
    avatarSeed: number;
    // Narrative identity fields (used to build chat persona — replaces separate roster persona)
    species: string;
    age: string;
    gender: string;
    briefDescription: string;
    physicalDescription: string;
    personalityCore: string;
    voiceAndMannerisms: string;
    background: string;
}

// ── Helpers ──────────────────────────────────────────────────────────────────
// [CHANGE] Moved here from mid-file where they were declared alongside functions.

interface SkillModifierResult {
    total: number;
    sheetMod: number;
    itemMods: { name: string; mod: number }[];
}

interface ActiveModifier {
    // Temporary skill modifier applied by an action effect. Lives in historyStorage
    // so it reverts cleanly with undo. Cleared by remove_modifier effect.
    id: string;
    charId: string;      // character the modifier applies to
    skillTag: string;    // normalised (no '#', lowercase) e.g. 'combat'
    delta: number;       // bonus (positive) or penalty (negative)
    sourceLabel: string; // display label for diagnostics (e.g. 'Empowered Blade')
}

interface ImportResult {
    charCount: number;
    entityCount: number;
    configImported: boolean;
    npcWebImported: boolean;
    partyStateImported: boolean;
}


// ============================================================================
// SECTION 2 — CONSTANTS
// All fixed values: storage keys, event names, UI icons, defaults.
// Grouped by concern. Never use raw strings for storage keys or event names —
// always reference these constants so renames are one-line safe.
// ============================================================================

// ── Storage Keys — Character & Config (storyStorage) ────────────────────────
// These keys map to api.v1.storyStorage entries. All character and entity data
// for a story lives under these keys.

var STORAGE_INDEX         = 'ce_index';           // CharacterMeta[]
var STORAGE_CONFIG        = 'ce_config';           // GlobalConfig
var STORAGE_CHAR_PFX      = 'ce_char_';            // + charId → CharacterRecord
var STORAGE_LORE_IDS      = 'ce_active_lore';      // JSON string of active lorebook entry IDs
var STORAGE_TOKENS        = 'ce_last_tokens';       // DEPRECATED v0.9.24 — retained as tombstone
var STORAGE_GEN_COUNT     = 'ae_gen_count';           // [v0.9.24 E1] number — persistent story generation count
var STORAGE_PARTY         = 'ce_party_state';       // PartyState
var STORAGE_WIZ_CHATS     = 'ae_wizard_chats';      // [vNEXT] WizardChat[] (World-Build Wizard transcripts)
var STORAGE_JOURNAL       = 'ae_journal_v1';        // [v1.7.0 JOURNAL] JournalState — player journal bubbles + projected lore entry ids
// [CHANGE] Moved here from mid-file (was declared just above loadPartyState)
const STORAGE_NPC_WEB     = 'ae_npc_web';           // JSON string of WebLink[]

// ── Storage Keys — Entity World Graph (storyStorage) ─────────────────────────

var STORAGE_ENTITY_INDEX  = 'ae_entity_index';          // EntityMeta[]
var STORAGE_ENTITY_PFX    = 'ae_entity_data_';          // + entityId → EntityRecord

// ── Storage Keys — Engine State (tempStorage) ────────────────────────────────
// tempStorage is cleared when the session ends. Used for transient UI and engine state.

var STORAGE_PLAYER_LOC        = 'ce_player_location';   // string — current location entity ID
var STORAGE_ENTITY_HISTORY    = 'ce_loc_history';       // string[] — recent location IDs
var STORAGE_ACTIVE_TAB        = 'ce_active_tab';        // string — active sidebar tab
var STORAGE_WIZ_ACTIVE_CHAT   = 'ae_wiz_active_chat';   // [vNEXT] string — active wizard chat id
var STORAGE_WIZ_INPUT         = 'ae_wiz_input';         // [vNEXT] string — pending wizard chat input draft
var STORAGE_WIZ_TAB           = 'ae_wiz_tab';           // [vNEXT] string — active wizard modal tab
var STORAGE_WIZ_SEC_HINT      = 'ae_wiz_sec_hint_';     // [vNEXT] prefix — per-section regen hint draft
var STORAGE_WIZ_EDIT_MSG      = 'ae_wiz_edit_msg';      // [vNEXT] string — 'chatId:index' message in edit mode
var STORAGE_WIZ_MSG_DRAFT     = 'ae_wiz_msg_draft';     // [vNEXT] string — draft buffer for the message being edited
var STORAGE_WIZ_ITEM_HINT     = 'ae_wiz_item_hint_';    // [vNEXT] prefix — per-species/faction regen hint draft
var STORAGE_WIZ_GEN_COUNT     = 'ae_wiz_gen_count_';    // [vNEXT] prefix — batch generate count draft per kind
var STORAGE_WIZ_TAB_SRC       = 'ae_wiz_tab_src_';      // [v0.9.80] prefix — per-tab (species/faction) chosen context-source chat id
var STORAGE_WIZ_LOC_PARENT    = 'ae_wiz_loc_parent';    // [v0.9.82] string — current parent entity id in the Locations wizard tree
var STORAGE_WIZ_HOOK_CHARS    = 'ae_wiz_hook_chars';   // [vNEXT] string — JSON char-id array selected for hook seeding in the Drama wizard
var STORAGE_WIZ_INTRO_LOC     = 'ae_wiz_intro_loc';     // [v0.9.85] string — chosen intro location entity id
var STORAGE_WIZ_INTRO_DRAFT   = 'ae_wiz_intro_draft';  // [v1.6.3] staged intro draft { locationId, prose } — generated, editable, committed on demand
var STORAGE_WIZ_TOPIC_PICK    = 'ae_wiz_topic_pick';    // [v0.9.8.2] string — id of the topic picked in the Chats tab new-chat UI
// [v0.9.7.9] Lorebook world-pack sentinel — the displayName of the hidden, disabled
// lorebook entry that stores the serialised AE world config for scenario sharing.
const AE_LOREBOOK_PACK_NAME = '[AE World]';
var STORAGE_PENDING_ENCOUNTER = 'ae_pending_encounter'; // DEPRECATED v0.9.25 E4 — retained as key tombstone
var STORAGE_CHAR_SNAP_PFX     = 'ae_snap_';             // + charId — character snapshot strings
var STORAGE_LAST_TRAVEL       = 'ae_last_travel';       // number — timestamp of last travel
var STORAGE_HUD_VEHICLE       = 'ae_hud_vehicle';       // string — active vehicle entity ID
var STORAGE_HUD_PLAYER_LOCKED = 'ae_hud_player_locked'; // boolean — player HUD locked state
var STORAGE_HUD_FACADE        = 'ae_hud_facade';        // object — facade inspection target
var STORAGE_ACTION_CLIPBOARD  = 'ae_action_clipboard';  // ActionRule — copied rule
var STORAGE_TRACKED_NARRATIVE = 'ae_tracked_narrative'; // string — quest-tracked narrative entity ID
var STORAGE_PENDING_KNOWLEDGE = 'ae_pending_knowledge'; // object — pending knowledge query injection
var STORAGE_PENDING_INJECT    = 'ae_pending_inject';    // string — pending GM message injected on next generation
var STORAGE_PENDING_FLAVOR    = 'ae_pending_flavor';    // [v0.9.22 E5] string — player flavor to compose into next > prompt
var STORAGE_FAC_ENTITY_MIGRATED = 'ae_fac_entity_migrated_v1'; // [UNIFY] boolean — one-time entity-instance faction-arg migration ran
