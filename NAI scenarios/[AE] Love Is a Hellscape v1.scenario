      {
        "text": "{\"v\":1,\"aeVersion\":\"0.9.7.9\",\"packedAt\":1783199242777,\"config\":{\"contextTemplates\":{\"location\":\"[|playerName| is currently at |name|.][ |description|][ |atmosphere|]\",\"activeNarrative\":\"[|name|][ — |description|]\",\"trackedNarrative\":\"[Current objective: |description|][ — route: |pathNames|]\",\"player\":\"[Present with |playerName|: |presentNames|.]\",\"npc\":\"[|name|][ — |relArchetype|, |relStage|][ with |primaryRelationship.targetName|][ (|conditionStates|)][. Goal: |midRange.currentDesire|][. Thinking: |ephemeral.compressedLine|]\",\"npcWeb\":\"[|charA_name| and |charB_name| — |dynamic|]\"},\"interfaceMode\":\"native\",\"thoughtIntervalGens\":2,\"dynamicIntervalGens\":4,\"arcIntervalGens\":10,\"hookIntervalGens\":6,\"totalGenerations\":0,\"ephemeralCap\":3,\"maxDynamicCharacters\":0,\"sheetCategories\":[{\"id\":\"cat_attr\",\"name\":\"Attributes\",\"fieldType\":\"number\",\"enumValues\":[],\"fields\":[{\"id\":\"fld_force\",\"name\":\"Force\"},{\"id\":\"fld_finesse\",\"name\":\"Finesse\"},{\"id\":\"fld_focus\",\"name\":\"Focus\"},{\"id\":\"fld_flair\",\"name\":\"Flair\"}]}],\"autoUpdateDefault\":true,\"autoThoughtsDefault\":true,\"showFieldHeaders\":true,\"generalStyle\":\"Use punchy, direct, and efficient narrative language. Focus on actionable character details. Omit flowery adjectives. Write as a concise psychological dossier.\",\"fieldLabels\":{},\"fieldInstructions\":{},\"fieldBudgets\":{},\"customStaticFields\":[],\"relationshipArchetypes\":[{\"id\":\"arch_rivals\",\"name\":\"rivalry\",\"stages\":[\"antagonistic\",\"competitive\",\"friendly\"]},{\"id\":\"arch_friends\",\"name\":\"friendship\",\"stages\":[\"acquaintances\",\"distant\",\"close\",\"inseparable\"]},{\"id\":\"arch_dating\",\"name\":\"courtship\",\"stages\":[\"broken up\",\"on the rocks\",\"tentative\",\"lovers\"]},{\"id\":\"arch_slowburn\",\"name\":\"Slow Burn\",\"stages\":[\"Strangers\",\"Curious\",\"Drawn In\",\"Smitten\"]},{\"id\":\"arch_e2l\",\"name\":\"Enemies to Lovers\",\"stages\":[\"Enemies\",\"Reluctant Allies\",\"Uneasy Trust\",\"Falling\",\"Lovers\"]}],\"resources\":[],\"species\":[],\"factions\":[],\"projectName\":\"Love Is a Hellscape\",\"projectGenre\":\"paranormal dating sim, dark comedy, romance\",\"projectConcept\":\"A devilish dating sim: the player navigates Hell's social scene and a roster of demon, monster, and otherworldly love interests, each living on their own daily schedule. Time of day advances as you move, and the cast goes about their lives whether or not you're there to see it.\",\"wizardSections\":[{\"id\":\"wsec_setting\",\"label\":\"Setting Name\",\"enabled\":true,\"content\":\"\",\"target\":\"memory\",\"instructions\":\"State ONLY the setting and its scope in a few words — is this a kingdom, a household, a war, a single conflict? Name the stage the story sits on. Do not describe plot, characters, or themes here.\"},{\"id\":\"wsec_style\",\"label\":\"Style\",\"enabled\":true,\"content\":\"\",\"target\":\"an\",\"instructions\":\"Describe ONLY the prose style and narrative voice: tense, person, tone, pacing, density. No setting facts, no plot, no themes — only how the writing should read.\"},{\"id\":\"wsec_themes\",\"label\":\"Themes\",\"enabled\":true,\"content\":\"\",\"target\":\"memory\",\"instructions\":\"Name ONLY the core themes the story explores. Abstract throughlines, not events. Do not restate the setting or describe characters.\"},{\"id\":\"wsec_conflict\",\"label\":\"Conflict\",\"enabled\":false,\"content\":\"\",\"target\":\"memory\",\"instructions\":\"Describe ONLY the central conflict — the opposing forces and what is contested. Not its resolution, not side characters, not theme.\"},{\"id\":\"wsec_romance\",\"label\":\"Romance and Consequences\",\"enabled\":false,\"content\":\"\",\"target\":\"memory\",\"instructions\":\"Describe ONLY how romance and intimacy function in this world and what consequences follow from them. Tone and rules of attraction, not specific pairings.\"},{\"id\":\"wsec_combat\",\"label\":\"Combat and Consequences\",\"enabled\":false,\"content\":\"\",\"target\":\"memory\",\"instructions\":\"Describe ONLY how violence and combat function in this world and what consequences follow. Lethality, aftermath, how the narrative treats it — not specific fights.\"},{\"id\":\"wsec_stakes\",\"label\":\"Stakes\",\"enabled\":false,\"content\":\"\",\"target\":\"memory\",\"instructions\":\"Describe ONLY what is at risk in this story at the largest scale — what can be won or lost. Not the mechanics, not the plot beats.\"}],\"defaultBackgroundUrl\":\"\",\"timeAutoAdvanceEnabled\":false,\"timeAdvanceHours\":1,\"timeAdvanceEveryGens\":3,\"timeStartHours\":7,\"timeShowInAN\":true,\"timeBands\":[{\"label\":\"Morning\",\"startHour\":6,\"endHour\":12},{\"label\":\"Afternoon\",\"startHour\":12,\"endHour\":18},{\"label\":\"Evening\",\"startHour\":18,\"endHour\":22},{\"label\":\"Night\",\"startHour\":22,\"endHour\":6}],\"timeDayNames\":[],\"timeWeekNames\":[],\"actionTemplates\":[{\"id\":\"sys_return_travel\",\"name\":\"Return Travel\",\"tags\":[\"_system\"],\"conditions\":[{\"id\":\"_ru_g\",\"type\":\"entity_locked\",\"args\":{\"scope\":\"__self__\",\"value\":\"false\"}}],\"successEffects\":[{\"id\":\"_ru_n\",\"type\":\"inject_narrative\",\"args\":{\"text\":\"You return to __self__.\"}},{\"id\":\"_ru_m\",\"type\":\"move_player_to_self\",\"args\":{}}],\"failureEffects\":[],\"alwaysEffects\":[],\"hidden\":false},{\"id\":\"sys_default_travel\",\"name\":\"Default Travel\",\"tags\":[\"_system\"],\"conditions\":[{\"id\":\"_tr_g\",\"type\":\"entity_locked\",\"args\":{\"scope\":\"__self__\",\"value\":\"false\"}}],\"successEffects\":[{\"id\":\"_tr_n\",\"type\":\"inject_narrative\",\"args\":{\"text\":\"You leave for __self__.\"}},{\"id\":\"_tr_m\",\"type\":\"move_player_to_self\",\"args\":{}}],\"failureEffects\":[],\"alwaysEffects\":[],\"hidden\":false},{\"id\":\"sys_travel_tier1\",\"name\":\"Tier-1 Travel (Top-level)\",\"tags\":[\"_system\"],\"condi