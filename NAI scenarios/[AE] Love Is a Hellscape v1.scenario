ry\":\"\",\"summary\":\"\",\"milestones\":[],\"archetypeId\":\"\",\"stageIndex\":0},\"eventHistory\":[],\"hooks\":[],\"ephemeral\":null,\"ephemeralHistory\":[],\"lastEphemeralGen\":0,\"midRange\":null,\"lastMidrangeGen\":0,\"lastArcGen\":0,\"lastHookGen\":0,\"equippedItemIds\":[],\"charResourceDefs\":[{\"id\":\"knmlbh12jmb4itkx9lj\",\"name\":\"Currency\",\"tag\":\"#currency\",\"type\":\"pool\",\"hasBounds\":true,\"min\":0,\"max\":9999},{\"id\":\"h3n8s183m8hxazw50ku\",\"name\":\"Luck\",\"tag\":\"#luck\",\"type\":\"pool\",\"hasBounds\":true,\"min\":0,\"max\":5},{\"id\":\"zccj0mv8cezga831psn\",\"name\":\"Health\",\"tag\":\"#health\",\"type\":\"track\",\"hasBounds\":true,\"states\":[\"Dead\",\"Severely Injured\",\"Mildly Injured\",\"Healthy\"]},{\"id\":\"xw9az0qbyrrvc2afw11\",\"name\":\"Attitude\",\"tag\":\"#attitude\",\"type\":\"track\",\"hasBounds\":true,\"states\":[\"Hostile\",\"Unfriendly\",\"Neutral\",\"Friendly\",\"Devoted\"]},{\"id\":\"5zoekcc3wpu0k1gmrff\",\"name\":\"Stamina\",\"tag\":\"#stamina\",\"type\":\"pool\",\"hasBounds\":true,\"min\":0,\"max\":6},{\"id\":\"mr6uqe3wktmrwkm339b\",\"name\":\"Condition\",\"tag\":\"#condition\",\"type\":\"discrete\",\"states\":[\"None\",\"drunk\",\"sick\",\"hurt\",\"bewitched—they cannot deny any request made of them\"]}],\"charResourceValues\":{\"knmlbh12jmb4itkx9lj\":0,\"h3n8s183m8hxazw50ku\":5,\"zccj0mv8cezga831psn\":3,\"xw9az0qbyrrvc2afw11\":2,\"5zoekcc3wpu0k1gmrff\":6,\"mr6uqe3wktmrwkm339b\":4},\"charFactionRelationships\":{},\"sheetValues\":{},\"charContextEnabled\":false,\"autoUpdateEnabled\":false,\"autoThoughtsEnabled\":false,\"hooksEnabled\":false,\"lastTokenEstimate\":0,\"entityId\":\"mqchar10000000002\",\"knownEntities\":[],\"createdAt\":1781628000001,\"updatedAt\":1782661217843,\"isStatic\":true},\"mquser10000000003\":{\"id\":\"mquser10000000003\",\"name\":\"Hairy Patters\",\"conceptDump\":\"\",\"nicknames\":[],\"species\":\"demon rat\",\"age\":\"\",\"gender\":\"male\",\"occupationRole\":\"Rat King\",\"briefDescr