appliesTo.length && t.appliesTo.indexOf('character') < 0) return false;\n        return true;\n    });\n    const eAllTags: string[] = [];\n    for (const eTpl of eTpls) {\n        for (const eTag of (((eTpl as any).tags || []) as string[])) {\n            if (typeof eTag === 'string' && eTag.charAt(0) !== '_' && eAllTags.indexOf(eTag) < 0) eAllTags.push(eTag);\n        }\n    }\n    eAllTags.sort();\n    const eSubs: string[] = eArch.tagSubscriptions || [];\n    eParts.push({ type: 'text', text: 'Action Tags', style: { fontSize: '12px', fontWeight: 'bold', marginTop: '10px', marginBottom: '4px' } } as UIPart);\n    if (eAllTags.length === 0) {\n        eParts.push({ type: 'text', text: 'No tagged library actions yet \\u2014 tag actions in the Action Library, then subscribe here. Tags resolve live, so editing the library updates every spawned NPC.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } } as UIPart);\n    } else {\n        eParts.push({ type: 'text', text: 'Checked tags live-include every matching library action on each spawned NPC. No copy is made \\u2014 edit the library action once and all copies update.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } } as UIPart);\n        for (const eTag of eAllTags) {\n            const captTag = eTag;\n            const eMatch = eTpls.filter(function(t) { return (((t as any).tags || []) as string[]).indexOf(captTag) >= 0; }).length;\n            eParts.push({ type: 'checkboxInput', label: captTag + '  (' + eMatch + ' action' + (eMatch === 1 ? '' : 's') + ')', initialValue: eSubs.indexOf(captTag) >= 0, onChange: async function(v: boolean) {\n                await aeMutateArchetype(function(a) {\n                    let arr: string[] = (a.tagSubscriptions || []).slice();\n                    if (v) { if (arr.indexOf(captTag) < 0) arr.push(captTag); }\n                    else   { arr = arr.filter(function(x) { return x !== captTag; }); }\n                    a.tagSubscriptions = arr;\n                });\n                await refreshArchetypeEditModal();\n            } } as UIPart);\n        }\n    }\n\n    eParts.push({ type: 'button', text: 'Done', style: { width: '100%', marginTop: '10px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, callback: async function() {\n        try { if (_aeArchEditHandle && !_aeArchEditHandle.isClosed()) await _aeArchEditHandle.close(); } catch (eCl) {}\n        await openBestiaryModal();\n    } } as UIPart);\n    return eParts;\n}\n\nasync function refreshArchetypeEditModal(): Promise<void> {\n    if (_aeArchEditHandle && typeof _aeArchEditHandle.isClosed === 'function' && !_aeArchEditHandle.isClosed()) {\n        let recContent = await buildArchetypeEditContent();\n        await _aeArchEditHandle.update({ content: recContent });\n    }\n}\n\nasync function openArchetypeEditModal(archId: string): Promise<void> {\n    _aeArchEditId = archId;\n    let aeContent = await buildArchetypeEditContent();\n    _aeArchEditHandle = await openEngineModal({ id: 'ae-arch-edit', title: 'Edit Archetype', size: 'medium', content: aeContent });\n}\n\nasync function buildBestiaryContent(): Promise<UIPart[]> {\n    const bCfg = await loadConfig();\n    const bArchs = (((bCfg as any).npcArchetypes || []) as NpcArchetypeDef[]);\n    let bParts: UIPart[] = [];\n    bParts.push({ type: 'text', text: 'Archetype templates for quick drop-in minor NPCs. Spawning deep-copies the template \\u2014 editing an archetype never touches already-spawned NPCs. Use the Spawn Minor NPC effect in the Action studio to fire these from encounters (different counts on different resolution bands = encounter variety).', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } } as UIPart);\n    bParts.push({ type: 'button', text: '+ New Archetype', iconId: 'plus', style: { width: '100%', marginBottom: '8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n        const nbCfg = await loadConfig();\n        if (!(nbCfg as any).npcArchetypes) (nbCfg as any).npcArchetypes = [];\n        const nbArch: NpcArchetypeDef = { id: generateId(), name: 'New Archetype', briefTemplate: '', charResourceDefs: [], actionInstances: [] };\n        ((nbCfg as any).npcArchetypes as NpcArchetypeDef[]).push(nbArch);\n        await saveConfig(nbCfg);\n        try { if (_aeBestiaryHandle && !_aeBestiaryHandle.isClosed()) await _aeBestiaryHandle.close(); } catch (eNb) {}\n        await openArchetypeEditModal(nbArch.id);\n    } } as UIPart);\n    if (bArchs.length === 0) bParts.push({ type: 'text', text: 'No archetypes yet.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic' } } as UIPart);\n    for (const bA of bArchs) {\n        const bId = bA.id;\n        const bDelArm = _aeBestiaryDelPending === bId;\n        bParts.push({ type: 'row', style: { gap: '4px', marginBottom: '4px', alignItems: 'center' }, content: [\n            { type: 'text', text: aeIconPfx(bA.icon) + bA.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },\n            { type: 'text', text: ((bA.charResourceDefs || []).length) + ' res \\u00b7 ' + ((bA.actionInstances || []).length) + ' act', style: { flex: '0 0 auto', fontSize: '10px', opacity: '0.5' } },\n            { type: 'button', text: 'Spawn', iconId: 'user-plus', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                let spLoc = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;\n                await spawnMinorNpc('', '', spLoc, bA, false);\n            } },\n            { type: 'button', text: '\\u2728', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                api.v1.ui.toast('Generating ' + bA.name + ' for the scene\\u2026', { id: 'ae-gen-b', autoClose: false });\n                let gsGen = await generateSceneNpc(bA);\n                if (gsGen) {\n                    let gsLoc = await api.v1.storyStorage.getOrDefault(STORAGE_PLAYER_LOC, null) as string | null;\n                    await spawnMinorNpc(gsGen.name, gsGen.brief, gsLoc, bA, false);\n                    api.v1.ui.toast('\\u2728 ' + gsGen.name + ' joins the scene.', { id: 'ae-gen-b', type: 'success', autoClose: 2500 });\n                } else {\n                    api.v1.ui.toast('Generation failed \\u2014 try again.', { id: 'ae-gen-b', type: 'warning', autoClose: 3000 });\n                }\n            } },\n            { type: 'button', text: 'Edit', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, callback: async function() {\n                try { if (_aeBestiaryHandle && !_aeBestiaryHandle.isClosed()) await _aeBestiaryHandle.close(); } catch (eBe) {}\n                await openArchetypeEditModal(bId);\n            } },\n            { type: 'button', text: bDelArm ? 'Sure?' : '\\u2715', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px', color: bDelArm ? '#ff8888' : 'inherit' }, callback: async function() {\n                if (_aeBestiaryDelPending !== bId) { _aeBestiaryDelPending = bId; await refreshBestiaryModal(); return; }\n                _aeBestiaryDelPending = null;\n                const dCfg = await loadConfig();\n                (dCfg as any).npcArchetypes = (((dCfg as any).npcArchetypes || []) as NpcArchetypeDef[]).filter(function(x) { return x.id !== bId; });\n                await saveConfig(dCfg);\n                await refreshBestiaryModal();\n            } }\n        ] } as UIPart);\n    }\n    return bParts;\n}\n\nasync function refreshBestiaryModal(): Promise<void> {\n    if (_aeBestiaryHandle && typeof _aeBestiaryHandle.isClosed === 'function' && !_aeBestiaryHandle.isClosed()) {\n        let rbContent = await buildBestiaryContent();\n        await _aeBestiaryHandle.update({ content: rbContent });\n    }\n}\n\nasync function openBestiaryModal(): Promise<void> {\n    _aeBestiaryDelPending = null;\n    let bmContent = await buildBestiaryContent();\n    _aeBestiaryHandle = await openEngineModal({ id: 'ae-bestiary', title: 'Bestiary', size: 'medium', content: bmContent });\n}\n\n// ── [vNEXT] Add-Minor-NPC modal (blank or from archetype) ─────────────────────\nvar _aeAddMinorHandle: any = null;\nvar _aeAddMinorName = '';\nvar _aeAddMinorBrief = '';\nvar _aeAddMinorArchId: string | null = null;\nvar _aeAddMinorLoc: string | null = null;\nvar _aeAddMinorRefresh: (() => Promise<void>) | null = null;\n\nasync function buildAddMinorContent(): Promise<UIPart[]> {\n    const amCfg = await loadConfig();\n    const amArchs = (((amCfg as any).npcArchetypes || []) as NpcArchetypeDef[]);\n    const amSel = amArchs.find(function(x) { return x.id === _aeAddMinorArchId; });\n    let amParts: UIPart[] = [];\n    amParts.push({ type: 'text', text: 'A quick drop-in NPC at the current location. No lorebook, no dossier \\u2014 just a name and what they are doing here. Promote later to flesh out.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } } as UIPart);\n    amParts.push({ type: 'row', style: { gap: '4px', marginBottom: '6px', alignItems: 'center' }, content: [\n        { type: 'text', text: 'Archetype:', style: { flex: '0 0 auto', fontSize: '11px', opacity: '0.7' } },\n        { type: 'button', text: amSel ? (aeIconPfx(amSel.icon) + amSel.name) : 'None (blank)', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() {\n            await openPickerModal({\n                title: 'Pick Archetype',\n                items: amArchs,\n                getId: function(it: any) { return it.id; },\n                getLabel: function(it: any) { return aeIconPfx(it.icon) + it.name; },\n                pinnedOptions: [{ id: '__none__', label: 'None (blank)', onSelect: async function() { _aeAddMinorArchId = null; await refreshAddMinorModal(); } }],\n                emptyText: 'No archetypes yet \\u2014 build them in the Bestiary (Characters tab).',\n                onSelect: async function(it: any) { _aeAddMinorArchId = it.id; await refreshAddMinorModal(); }\n            });\n        } }\n    ] } as UIPart);\n    amParts.push({ type: 'textInput', label: 'Name' + (amSel ? ' (blank = archetype name)' : ''), placeholder: amSel ? amSel.name : 'e.g. Skeleton, Gate Guard, Fruit Vendor', initialValue: _aeAddMinorName, onChange: function(v: string) { _aeAddMinorName = v; } } as UIPart);\n    amParts.push({ type: 'multilineTextInput', label: 'What are they doing here?' + (amSel ? ' (blank = archetype description)' : ''), placeholder: amSel ? (amSel.briefTemplate || '') : 'e.g. A brittle skeleton lurching forward to attack.', initialValue: _aeAddMinorBrief, style: { minHeight: '50px' }, onChange: function(v: string) { _aeAddMinorBrief = v; } } as UIPart);\n    amParts.push({ type: 'button', text: '\\u2728 Generate from Scene', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n        api.v1.ui.toast('Generating an NPC that fits the scene\\u2026', { id: 'ae-gen-am', autoClose: false });\n        let amGen = await generateSceneNpc(amSel || null);\n        if (amGen) {\n            _aeAddMinorName = amGen.name;\n            _aeAddMinorBrief = amGen.brief;\n            api.v1.ui.toast('Filled in \\u2014 tweak and Create, or generate again.', { id: 'ae-gen-am', type: 'success', autoClose: 2500 });\n            await refreshAddMinorModal();\n        } else {\n            api.v1.ui.toast('Could not generate \\u2014 type it in or try again.', { id: 'ae-gen-am', type: 'warning', autoClose: 3000 });\n        }\n    } } as UIPart);\n    amParts.push({ type: 'button', text: 'Create NPC', iconId: 'user-plus', style: { width: '100%', marginTop: '6px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {\n        if (!_aeAddMinorName.trim() && !amSel) { api.v1.ui.toast('Name required (or pick an archetype).', { type: 'warning' }); return; }\n        await spawnMinorNpc(_aeAddMinorName.trim(), _aeAddMinorBrief.trim(), _aeAddMinorLoc, amSel || null, false);\n        try { if (_aeAddMinorHandle && !_aeAddMinorHandle.isClosed()) await _aeAddMinorHandle.close(); } catch (eAc) {}\n        if (_aeAddMinorRefresh) await _aeAddMinorRefresh();\n    } } as UIPart);\n    return amParts;\n}\n\nasync function refreshAddMinorModal(): Promise<void> {\n    if (_aeAddMinorHandle && typeof _aeAddMinorHandle.isClosed === 'function' && !_aeAddMinorHandle.isClosed()) {\n        let ramContent = await buildAddMinorContent();\n        await _aeAddMinorHandle.update({ content: ramContent });\n    }\n}\n\nasync function openAddMinorNpcModal(locId: string | null, refreshFn: () => Promise<void>): Promise<void> {\n    _aeAddMinorName = '';\n    _aeAddMinorBrief = '';\n    _aeAddMinorArchId = null;\n    _aeAddMinorLoc = locId;\n    _aeAddMinorRefresh = refreshFn;\n    let oamContent = await buildAddMinorContent();\n    _aeAddMinorHandle = await openEngineModal({ id: 'ae-add-minor', title: 'Add Minor NPC', size: 'small', content: oamContent });\n}\n\nasync function killCharacter(charId: string): Promise<void> {\n    try {\n        let char = await loadCharacter(charId);\n        if (!char) return;\n\n        char.active = false;\n        char.scenePresent = false;\n\n        // --- INVENTORY DROP LOGIC ---\n        if (char.entityId) {\n            let allEnts = await loadEntityIndex();\n            let charBody = await loadEntity(char.entityId);\n            \n            if (charBody) {\n                // Determine where to drop the loot: the room they died in.\n                // If they are in the void (null), fallback to the player's room.\n                let dropRoomId = charBody.parentId; \n                if (!dropRoomId) {\n                    dropRoomId = await loadPlayerLocation(); \n                }\n\n                if (dropRoomId) {\n                    // Find all items/entities currently attached to the dying character\n                    let lootItems = allEnts.filter(function(e) { return e.parentId === char.entityId; });\n                    for (let lootMeta of lootItems) {\n                        let itemEnt = await loadEntity(lootMeta.id);\n                        if (itemEnt) {\n                            itemEnt.parentId = dropRoomId;\n                            await saveEntity(itemEnt);\n                        }\n                    }\n                }\n                \n                // Clear equipped items so they aren't still \"wielding\" things from the grave\n                char.equippedItemIds = [];\n            }\n        }\n\n        await saveCharacter(char);\n\n        // Send entity body to Graveyard\n        if (char.entityId) {\n            let allEnts = await loadEntityIndex();\n            let gyMeta = allEnts.find(function(e) { return e.name === 'Graveyard' && e.type === 'location'; });\n            if (!gyMeta) {\n                let gyEnt = makeDefaultEntity('Graveyard');\n                gyEnt.type = 'location';\n                gyEnt.parentId = null;\n                await saveEntity(gyEnt);\n                gyMeta = { id: gyEnt.id, name: 'Graveyard', type: 'location', parentId: null, childCount: 0, presentCharacterCount: 0, state: 'default' };\n            }\n            let gyBody = await loadEntity(char.entityId);\n            if (gyBody) { gyBody.parentId = gyMeta.id; await saveEntity(gyBody); }\n        }\n\n        // Move to bottom of character index\n        let idx = await loadIndex();\n        let pos = idx.findIndex(function(m) { return m.id === charId; });\n        if (pos >= 0 && pos < idx.length - 1) {\n            let item = idx.splice(pos, 1)[0];\n            idx.push(item);\n            await saveIndex(idx);\n        }\n\n        api.v1.ui.toast('💀 ' + char.name + ' — deceased.', { type: 'warning' });\n    } catch (e) { \n        api.v1.error('[AE] killCharacter:', e); \n    }\n}\n\n\n// ── Character Edit Modal ─────────────────────────────────────────────────────\n\nasync function openCharEditModal(charId: string): Promise<void> {\n    if (charEditModalHandle && !charEditModalHandle.isClosed()) charEditModalHandle.close();\n    editingCharId = charId;\n    charEditModalHandle = await openEngineModal({ id: 'ce-char-edit', size: 'full', fillWidth: true, title: 'Edit Character', content: await buildCharEditContent(charId) });\n}\n\nasync function refreshCharEditModal(): Promise<void> { \n    if (!charEditModalHandle || charEditModalHandle.isClosed() || !editingCharId) return; \n    await charEditModalHandle.update({ content: await buildCharEditContent(editingCharId) }); \n}\n\n\nasync function buildCharEditContent(charId: string): Promise<UIPart[]> {\n    const char = await loadCharacter(charId); if (!char) return [{ type: 'text', text: 'Character not found.' }];\n    \n    // --- DATA SAFETY PATCH (Fixes \"filter of undefined\" on new characters) ---\n    char.hooks = char.hooks || [];\n    char.eventHistory = char.eventHistory || [];\n    char.ephemeralHistory = char.ephemeralHistory || [];\n    char.nicknames = char.nicknames || [];\n    char.coreValues = char.coreValues || [];\n    if (!char.primaryRelationship) {\n        char.primaryRelationship = { targetName: '', enabled: false, archetype: '', howItStarted: '', threads: [], currentStatus: '', trajectory: '', summary: '', milestones: [] };\n    }\n    char.primaryRelationship.threads = char.primaryRelationship.threads || [];\n    char.primaryRelationship.milestones = char.primaryRelationship.milestones || [];\n    if (!char.customFieldValues) char.customFieldValues = {};\n    if (!char.sheetValues) char.sheetValues = {};\n    // ------------------------------------------------------------------------\n\n    const cfg = await loadConfig(); const parts: UIPart[] = [];\n    async function mut(fn: (c: CharacterRecord) => void): Promise<void> { const f = await loadCharacter(charId); if (!f) return; fn(f); await saveCharacter(f); await refreshSidebar(); }\n\n    // --- CONSOLIDATED HEADER (2-ROW LAYOUT) ---\n    const idx = await loadIndex();\n    const myMeta = idx.find(m => m.id === charId);\n    const currentLocationId = myMeta ? myMeta.currentLocationId : undefined;\n    const entIdx = await loadEntityIndex();\n    const locName = currentLocationId ? (entIdx.find(m => m.id === currentLocationId)?.name || 'Unknown') : 'No Location';\n\n    parts.push({ type: 'column', style: { gap: '4px', marginBottom: '12px' }, content: [\n        { type: 'textInput', placeholder: 'Character Name', initialValue: char.name, style: { fontSize: '15px', fontWeight: 'bold' }, onChange: async (v: string) => {\n            await mut(c => { c.name = v; });\n            const fresh = await loadCharacter(charId);\n            if (fresh?.entityId) { let nameEnt = await loadEntity(fresh.entityId); if (nameEnt) { nameEnt.name = v; await saveEntity(nameEnt); } }\n        }},\n        { type: 'row', style: { gap: '4px' }, content: [\n            { type: 'button', text: char.active ? '🌟 Active' : '⚰️ Inactive', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: char.active ? 'rgba(126,200,160,0.2)' : 'rgba(255,107,107,0.2)', color: char.active ? '#7ec8a0' : '#ff6b6b' }, callback: async () => { await mut(c => { c.active = !c.active; }); await refreshCharEditModal(); }},\n            { type: 'button', text: char.scenePresent ? '🟢 Scene' : '⚫ Away', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: char.scenePresent ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: char.scenePresent ? '#7ec8a0' : '#888' }, callback: async () => { await mut(c => { c.scenePresent = !c.scenePresent; }); await refreshCharEditModal(); }},\n            { type: 'button', text: (char as any).isStatic ? '▫️Static' : '⚡️Dynamic', style: { flex: '1 1 0', margin: 0, fontSize: '10px', backgroundColor: (char as any).isStatic ? 'rgba(255,255,255,0.05)' : 'rgba(136,204,255,0.15)', color: (char as any).isStatic ? '#888' : '#88ccff' }, callback: async () => { await mut(c => { (c as any).isStatic = !(c as any).isStatic; c.charContextEnabled = !(c as any).isStatic; c.autoUpdateEnabled = !(c as any).isStatic; c.autoThoughtsEnabled = !(c as any).isStatic; c.hooksEnabled = !(c as any).isStatic; }); await refreshCharEditModal(); }}\n        ]},\n        // [vNEXT] Dynamic-priority rank row (non-protagonist, non-minor only). Under a\n        // dynamic cap, lower rank = kept dynamic first. Assignment swaps to keep one\n        // character per rank.\n        ((char as any).isProtagonist || (char as any).npcClass === 'minor') ? { type: 'text', text: '', style: { height: '0px' } } : { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [\n            { type: 'text', text: 'Dynamic priority', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } },\n            { type: 'button', text: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? ('Rank #' + (char as any).dynamicPriorityRank) : 'Unranked', style: { flex: '1 1 0', margin: 0, fontSize: '10px', textAlign: 'left', backgroundColor: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? 'rgba(232,168,124,0.15)' : 'rgba(255,255,255,0.05)', color: (typeof (char as any).dynamicPriorityRank === 'number' && (char as any).dynamicPriorityRank > 0) ? '#e8a87c' : '#888' }, callback: async function() {\n                await openDynamicRankPicker(charId, async function() { await refreshCharEditModal(); await refreshSidebar(); });\n            } }\n        ]},\n        { type: 'row', style: { gap: '4px' }, content: [\n            { type: 'button', text: `📍 ${locName}`, style: { flex: '1 1 0', margin: 0, fontSize: '10px', textAlign: 'left', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }, callback: async function() {\n                const freshEntIdx = await loadEntityIndex();\n                const spatialNodes = freshEntIdx.filter(function(n: any) { return n.type !== 'character'; });\n                \n                const pickerContent = [\n                    { type: 'button', text: '✕ No Location', style: { width: '100%', marginBottom: '8px' }, callback: async function() {\n                        const f = await loadCharacter(char.id); if (!f) { pm.close(); return; }\n                        if (f.entityId) { let locEnt = await loadEntity(f.entityId); if (locEnt) { locEnt.parentId = null; await saveEntity(locEnt); } }\n                        await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshCharEditModal();\n                    } }\n                ];\n                \n                spatialNodes.filter(Boolean).forEach(function(l: any) {\n                    pickerContent.push({ type: 'button', text: `📍 ${l.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: currentLocationId === l.id ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {\n                        const f = await loadCharacter(char.id); if (!f) { pm.close(); return; }\n                        if (f.entityId) { let locEnt2 = await loadEntity(f.entityId); if (locEnt2) { locEnt2.parentId = l.id; await saveEntity(locEnt2); } }\n                        await saveCharacter(f); await recalculateScenePresence(); pm.close(); await refreshCharEditModal();\n                    } } as UIPart);\n                });\n\n                const pm = await openEngineModal({ title: 'Set Location', size: 'medium', content: pickerContent });\n            } },\n            { type: 'button', text: '💀 Kill', style: { flex: '0 1 auto', margin: 0, fontSize: '10px', color: '#ff6b6b' }, callback: async () => { await confirmDeleteChar(char.id, char.name); }},\n            { type: 'button', text: '❓ Help', style: { flex: '0 1 auto', margin: 0, fontSize: '10px' }, callback: async () => {\n                await openEngineModal({ title: 'Header Controls Help', size: 'medium', content: [\n                    { type: 'text', text: 'Active:', style: { fontWeight: 'bold', fontSize: '12px' } },\n                    { type: 'text', text: 'Removes the character from all context injections entirely, as if they don\\'t exist.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },\n                    { type: 'text', text: 'Scene:', style: { fontWeight: 'bold', fontSize: '12px' } },\n                    { type: 'text', text: 'Manually overrides scene presence. This will be automatically reset to the correct value when you change locations.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },\n                    { type: 'text', text: 'Dynamic:', style: { fontWeight: 'bold', fontSize: '12px' } },\n                    { type: 'text', text: 'Toggles all background AI updates for this character (thoughts, goals, hooks).', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },\n                    { type: 'text', text: 'Location:', style: { fontWeight: 'bold', fontSize: '12px' } },\n                    { type: 'text', text: 'Changes where the character\\'s physical body is located in the world graph.', style: { fontSize: '11px', opacity: '0.8', marginBottom: '8px' } },\n                    { type: 'text', text: 'Kill:', style: { fontWeight: 'bold', fontSize: '12px' } },\n                    { type: 'text', text: 'Sets the character to Inactive, drops their inventory at their last location, and moves their body to a \"Graveyard\" location. They can be restored by moving them out of the Graveyard and setting them back to Active.', style: { fontSize: '11px', opacity: '0.8' } }\n                ]});\n            }}\n        ]}\n    ]});\n\n    // [v0.9.8.5] Preview now mirrors the new split: the collapsed identity line is\n    // what the LOREBOOK entry leads with (static), e.g. \"Gareth — human male, 34,\n    // blacksmith\"; the dynamic layer is assembled separately into the Author's Note.\n    function getBiographicalPreviews(c: CharacterRecord) {\n        const idLeader = [(c.species || '').trim(), (c.gender || '').trim()].filter(Boolean).join(' ');\n        const idMid = [idLeader, (c.age || '').trim(), (c.occupationRole || '').trim()].filter(Boolean).join(', ');\n        let loreLine = (c.name || 'Unnamed').trim();\n        if (idMid) loreLine += ' \\u2014 ' + idMid;\n        return { anLine: loreLine };\n    }\n\n    // Fast non-flicker live preview update using api.v1.ui.updateParts()\n    async function updateBiographicalPreviews() {\n        const fresh = await loadCharacter(charId);\n        if (!fresh) return;\n        const previews = getBiographicalPreviews(fresh);\n        await api.v1.ui.updateParts([\n            { id: 'ae-an-preview', text: 'Lorebook: ' + previews.anLine }\n        ]).catch(function() {});\n    }\n\n    const initialPreviews = getBiographicalPreviews(char);\n\n    // Dramatis Personae\n    parts.push({ type: 'collapsibleSection', title: '📋 Dramatis Personae', initialCollapsed: false, storageKey: `temp:ce_dp_${charId}`, content: [\n        { type: 'text', text: char.name || '(Name not set)', style: { fontSize: '13px', fontWeight: 'bold', marginBottom: '6px' } },\n        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n            { type: 'textInput', placeholder: 'Age', initialValue: char.age || '', style: { flex: '1 1 0' }, onChange: async function(v) { await mut(function(c){ c.age = v; }); await updateBiographicalPreviews(); } },\n            { type: 'textInput', placeholder: 'Gender', initialValue: char.gender || '', style: { flex: '1 1 0' }, onChange: async function(v) { await mut(function(c){ c.gender = v; }); await updateBiographicalPreviews(); } },\n            (cfg.species && cfg.species.length > 0) ? { type: 'button', text: char.species?.trim() || 'Species', style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: char.species?.trim() ? 'rgba(136,204,255,0.1)' : 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.12)', color: char.species?.trim() ? '#88ccff' : '#666' }, callback: async function() {\n                const pm = await openEngineModal({ title: 'Set Species', size: 'small', content: [\n                    { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() { await mut(function(c) { c.species = ''; }); pm.close(); await refreshCharEditModal(); } },\n                    ...(cfg.species || []).map(function(sp) {\n                        const isCur = char.species === sp.name;\n                        return { type: 'button', text: sp.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: isCur ? 'rgba(136,204,255,0.15)' : undefined, color: isCur ? '#88ccff' : undefined }, callback: async function() { await mut(function(c) { c.species = sp.name; }); pm.close(); await refreshCharEditModal(); } } as UIPart;\n                    })\n                ]});\n            } } as UIPart : { type: 'textInput', placeholder: 'Species', initialValue: char.species || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mut(function(c) { c.species = v; }); await updateBiographicalPreviews(); } } as UIPart,\n            { type: 'textInput', placeholder: 'Role / occupation', initialValue: char.occupationRole || '', style: { flex: '2 1 0' }, onChange: async function(v) { await mut(function(c){ c.occupationRole = v; }); await updateBiographicalPreviews(); } }\n        ] },\n        { type: 'multilineTextInput', label: 'Brief Description', placeholder: 'One vivid sentence the generators must not contradict. Authoring anchor — not injected into context.', initialValue: char.briefDescription || '', style: { minHeight: '40px' }, onChange: async function(v) { await mut(function(c){ c.briefDescription = v; }); await updateBiographicalPreviews(); } },\n        { type: 'text', text: 'Authoring anchor for field/intro generation. Not injected into context — static identity rides the lorebook entry.', style: { fontSize: '10px', opacity: '0.45', marginTop: '4px', marginBottom: '8px' } },\n        \n        // --- REAL-TIME CONTEXT INJECTION PREVIEW BOX ---\n        { type: 'box', style: { backgroundColor: 'rgba(255,255,255,0.03)', border: '1px dashed rgba(255,255,255,0.1)', padding: '8px', borderRadius: '6px' }, content: [\n            { type: 'text', text: '👁 Live Context Injection Preview', style: { fontSize: '10px', fontWeight: 'bold', color: 'var(--ae-accent)', marginBottom: '4px', textTransform: 'uppercase' } },\n            { id: 'ae-an-preview', type: 'text', text: 'Lorebook: ' + initialPreviews.anLine, style: { fontSize: '11px', opacity: '0.9', marginBottom: '2px', fontFamily: 'monospace' } }\n        ] }\n    ] });\n    \n    // ── Static Fields ──────────────────────────────────────────────────────\n    const staticContent: UIPart[] = [];\n\n    // MOVED TO TOP: Concept Dump\n    staticContent.push({\n        type: 'multilineTextInput', \n        label: 'Concept Dump (Raw Notes)', \n        placeholder: 'Dump ideas, profiles, references — informs all static field generations. Not injected into live context.',\n        initialValue: char.conceptDump || '', \n        style: { minHeight: '80px', marginBottom: '12px' }, \n        onChange: async function(v: string) { \n            await mut(function(c) { c.conceptDump = v; }); \n        } \n    } as UIPart);\n\n    for (const fd of STATIC_FIELD_DEFS) {\n        const label      = cfg.fieldLabels[fd.key] || fd.label;\n        const promptKey  = `ce_prmt_${charId}_${fd.key}`;\n        const capturedFd = fd;\n        const capBudget  = cfg.fieldBudgets[fd.key] || fd.defaultBudget;\n        const capInst    = cfg.fieldInstructions[fd.key] || fd.defaultInstructions;\n        const currentHint = await api.v1.tempStorage.getOrDefault(promptKey, '') as string;\n\n        const rawVal = (char as any)[capturedFd.key];\n        const strVal = (rawVal !== null && rawVal !== undefined && !Array.isArray(rawVal))\n            ? String(rawVal)\n            : '';\n\n        staticContent.push({\n            type: 'multilineTextInput', label,\n            initialValue: strVal,\n            placeholder: '',\n            style: { minHeight: '55px' },\n            onChange: async function(v: string) {\n                await mut(function(c) { (c as any)[capturedFd.key] = v; });\n            }\n        } as UIPart);\n\n        staticContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '8px' }, content: [\n            { type: 'textInput', placeholder: 'Optional hint…', initialValue: currentHint, style: { flex: '1 1 0' },\n              onChange: async function(v: string) { await api.v1.tempStorage.set(promptKey, v); } },\n            { type: 'button', iconId: 'zap',\n              style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' },\n              disabledWhileCallbackRunning: true,\n              callback: async function() {\n                  const hint = await api.v1.tempStorage.get(promptKey) as string || '';\n                  api.v1.ui.toast(`Generating ${label}…`, { id: `gen-${capturedFd.key}`, autoClose: false, type: 'info' });\n                  const result = await generateFieldContent(char, label, capInst, cfg.generalStyle, hint, capBudget);\n                  if (result) {\n                      await mut(function(c) { (c as any)[capturedFd.key] = result; });\n                      await api.v1.tempStorage.remove(promptKey);\n                      api.v1.ui.toast('Generated.', { id: `gen-${capturedFd.key}`, type: 'success', autoClose: 1500 });\n                      await refreshCharEditModal();\n                  } else {\n                      api.v1.ui.toast('Failed.', { id: `gen-${capturedFd.key}`, type: 'error', autoClose: 2000 });\n                  }\n              }\n            }\n        ] } as UIPart);\n    }\n\n    // Core Values — stored as string[] on the record; edited here as semicolon-delimited text.\n    const cvHintKey  = `ce_prmt_${charId}_coreValues`;\n    const cvHint     = await api.v1.tempStorage.getOrDefault(cvHintKey, '') as string;\n    const cvInitial  = (char.coreValues || []).filter(Boolean).join('; ');\n    staticContent.push({\n        type: 'multilineTextInput', label: 'Core Values',\n        initialValue: cvInitial,\n        placeholder: 'e.g. Loyalty; Honesty; Freedom  (semicolon-separated)',\n        style: { minHeight: '45px' },\n        onChange: async function(v: string) {\n            await mut(function(c) {\n                c.coreValues = v.split(';').map(function(s) { return s.trim(); }).filter(Boolean);\n            });\n        }\n    } as UIPart);\n    staticContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '8px' }, content: [\n        { type: 'textInput', placeholder: 'Optional hint…', initialValue: cvHint, style: { flex: '1 1 0' },\n          onChange: async function(v: string) { await api.v1.tempStorage.set(cvHintKey, v); } },\n        { type: 'button', iconId: 'zap',\n          style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' },\n          disabledWhileCallbackRunning: true,\n          callback: async function() {\n              const hint = await api.v1.tempStorage.get(cvHintKey) as string || '';\n              api.v1.ui.toast('Generating Core Values…', { id: 'gen-coreValues', autoClose: false, type: 'info' });\n              const result = await generateFieldContent(char, 'Core Values',\n                  'List 3–5 deeply held values that drive this character\\'s decisions. Return them as a semicolon-separated list only.',\n                  cfg.generalStyle, hint, 80);\n              if (result) {\n                  const vals = result.split(';').map(function(s) { return s.trim(); }).filter(Boolean);\n                  await mut(function(c) { c.coreValues = vals; });\n                  await api.v1.tempStorage.remove(cvHintKey);\n                  api.v1.ui.toast('Generated.', { id: 'gen-coreValues', type: 'success', autoClose: 1500 });\n                  await refreshCharEditModal();\n              } else {\n                  api.v1.ui.toast('Failed.', { id: 'gen-coreValues', type: 'error', autoClose: 2000 });\n              }\n          }\n        }\n    ] } as UIPart);\n\n    // Custom fields\n    for (const cf of cfg.customStaticFields.filter(Boolean)) {\n        const capturedCf     = cf;\n        const promptKeyCustom = `ce_prmt_${charId}_custom_${capturedCf.id}`;\n        const currentHintCustom = await api.v1.tempStorage.getOrDefault(promptKeyCustom, '') as string;\n\n        staticContent.push({ type: 'multilineTextInput', label: capturedCf.label,\n            initialValue: char.customFieldValues[capturedCf.id] || '',\n            placeholder: capturedCf.placeholder || '',\n            style: { minHeight: '45px' },\n            onChange: async function(v: string) { await mut(function(c) { c.customFieldValues[capturedCf.id] = v; }); }\n        } as UIPart);\n        staticContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '8px' }, content: [\n            { type: 'textInput', placeholder: 'Optional hint…', initialValue: currentHintCustom, style: { flex: '1 1 0' },\n              onChange: async function(v: string) { await api.v1.tempStorage.set(promptKeyCustom, v); } },\n            { type: 'button', iconId: 'zap',\n              style: { margin: 0, padding: '4px 8px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.3)' },\n              disabledWhileCallbackRunning: true,\n              callback: async function() {\n                  const hint   = await api.v1.tempStorage.get(promptKeyCustom) as string || '';\n                  const budget = cfg.fieldBudgets[capturedCf.id] || 150;\n                  api.v1.ui.toast('Generating…', { id: `gen-cf-${capturedCf.id}`, autoClose: false, type: 'info' });\n                  const result = await generateFieldContent(char, capturedCf.label, capturedCf.instructions, cfg.generalStyle, hint, budget);\n                  if (result) {\n                      await mut(function(c) { c.customFieldValues[capturedCf.id] = result; });\n                      await api.v1.tempStorage.remove(promptKeyCustom);\n                      api.v1.ui.toast('Generated.', { id: `gen-cf-${capturedCf.id}`, type: 'success', autoClose: 1500 });\n                      await refreshCharEditModal();\n                  } else {\n                      api.v1.ui.toast('Failed.', { id: `gen-cf-${capturedCf.id}`, type: 'error', autoClose: 2000 });\n                  }\n              }\n            }\n        ] } as UIPart);\n    }\n\n    // Lorebook sync convenience — MOVED from its own section into static fields\n    const tmpNickKey = `ce_tmp_nick_${char.id}`;\n    const nickItems: UIPart[] = (char.nicknames || []).filter(Boolean).map(function(nick, i) { return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [{ type: 'text', text: nick, style: { flex: '1 1 0', fontSize: '12px' } }, { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.nicknames.splice(i, 1); await saveCharacter(f); await refreshCharEditModal(); } }] } as UIPart; });\n\n    staticContent.push({ type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: (function() {\n        const lbContent: UIPart[] = [];\n        if (char.lorebookEntryId) {\n            lbContent.push(\n                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },\n                { type: 'text', text: `Keys: ${getLorebookKeys(char).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },\n                { type: 'row', style: { gap: '6px' }, content: [\n                    { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncLorebookEntry(char.id); } },\n                    { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.lorebookEntryId = undefined; await saveCharacter(f); await refreshCharEditModal(); } }\n                ] }\n            );\n        } else {\n            lbContent.push(\n                { type: 'text', text: \"No lorebook entry. Creating one lets NAI natively inject this character's static profile when their name appears.\", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },\n                { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { if (typeof createLinkedLorebookEntry === 'function') { await createLinkedLorebookEntry(char.id); await refreshCharEditModal(); } } }\n            );\n        }\n        \n        lbContent.push({ type: 'text', text: 'Nicknames / Aliases (added as lorebook keys):', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });\n        \n        nickItems.forEach(function(item) {\n            lbContent.push(item);\n        });\n        \n        lbContent.push({ type: 'row', style: { gap: '4px' }, content: [\n            { type: 'textInput', placeholder: 'Add nickname or alias...', storageKey: `temp:${tmpNickKey}`, style: { flex: '1 1 0' } },\n            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpNickKey) as string || ''; if (!v.trim()) return; const f = await loadCharacter(char.id); if (!f) return; if (!f.nicknames.includes(v.trim())) f.nicknames.push(v.trim()); await saveCharacter(f); await api.v1.tempStorage.remove(tmpNickKey); await refreshCharEditModal(); } }\n        ] });\n        \n        return lbContent;\n    })()});\n\n    parts.push({ type: 'collapsibleSection', title: '✍ Static Fields', initialCollapsed: false,\n        storageKey: `temp:ce_static_${charId}`, content: staticContent });\n\n    parts.push(buildDynamicStateSection(char, cfg));\n\n    // Inner Builders — Engine reference data (read-only runtime state)\n    parts.push({ type: 'text', text: '── Engine Reference Only ──', style: { fontSize: '10px', opacity: '0.35', textAlign: 'center', letterSpacing: '1px', margin: '6px 0 2px' } });\n\n    // Image Generation — character visual tags for image gen (engine + bridge)\n    parts.push({ type: 'collapsibleSection', title: '🖼 Image Generation', initialCollapsed: true,\n        storageKey: `temp:ce_imggen_${charId}`, content: [\n        { type: 'text', text: 'Used for all character image generations. Tags like: hair color, eye color, clothing.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px' } },\n        { type: 'multilineTextInput', label: 'Base Character Visuals', placeholder: '1girl, brown hair, blue eyes, red dress...', initialValue: char.visuals || '', style: { minHeight: '55px' }, onChange: async function(v: string) { await mut(function(c) { c.visuals = v; }); } } as UIPart,\n        { type: 'text', text: 'Tags to suppress in all this character\\'s images.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '6px', marginTop: '10px' } },\n        { type: 'multilineTextInput', label: 'Character Unwanted Content', placeholder: 'lowres, bad anatomy, extra limbs...', initialValue: char.uc || '', style: { minHeight: '40px' }, onChange: async function(v: string) { await mut(function(c) { c.uc = v; }); } } as UIPart\n    ] });\n\n    // [v0.9.86] Tag Subscriptions — character-side shortcut to set tagSubscriptions on\n    // the character's entity. Keeps the same live-resolve model; no copies are made.\n    await (async function() {\n        if (!(char as any).entityId) return;\n        const _ctsCfg = await loadConfig();\n        const _ctsTpls = ((_ctsCfg.actionTemplates || []) as ActionInstance[]);\n        const _ctsAllTags: string[] = [];\n        // Characters can have a 'character' type entity — filter appliesTo accordingly.\n        const _ctsApplicable = _ctsTpls.filter(function(t) {\n            if (t.appliesTo && t.appliesTo.length && t.appliesTo.indexOf('character') < 0) return false;\n            return true;\n        });\n        for (const _ctsTpl of _ctsApplicable) {\n            for (const _ctsTag of ((_ctsTpl as any).tags || [])) {\n                if (typeof _ctsTag === 'string' && !_ctsTag.startsWith('_') && _ctsAllTags.indexOf(_ctsTag) < 0) {\n                    _ctsAllTags.push(_ctsTag);\n                }\n            }\n        }\n        _ctsAllTags.sort();\n        if (!_ctsAllTags.length) return;\n\n        const _ctsEnt = await loadEntity((char as any).entityId);\n        if (!_ctsEnt) return;\n        const _ctsSubs: string[] = ((_ctsEnt as any).tagSubscriptions || []);\n        const _ctsRows: UIPart[] = [\n            { type: 'text', text: 'Checked tags auto-include all matching library actions on this character\\'s entity. Applied live — no copy is made.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '6px' } }\n        ];\n        for (const _ctsTag of _ctsAllTags) {\n            const captCTag = _ctsTag;\n            const matchCount = _ctsApplicable.filter(function(t) { return ((t as any).tags || []).indexOf(captCTag) >= 0; }).length;\n            const isSubbed = _ctsSubs.indexOf(captCTag) >= 0;\n            _ctsRows.push({\n                type: 'checkboxInput',\n                label: captCTag + '  (' + matchCount + ' action' + (matchCount === 1 ? '' : 's') + ')',\n                initialValue: isSubbed,\n                onChange: async function(v: boolean) {\n                    const f = await loadCharacter(charId); if (!f || !(f as any).entityId) return;\n                    const _ctsEntFresh = await loadEntity((f as any).entityId); if (!_ctsEntFresh) return;\n                    let _ctsArr: string[] = (((_ctsEntFresh as any).tagSubscriptions || []) as string[]).slice();\n                    if (v) { if (_ctsArr.indexOf(captCTag) < 0) _ctsArr.push(captCTag); }\n                    else   { _ctsArr = _ctsArr.filter(function(x) { return x !== captCTag; }); }\n                    (_ctsEntFresh as any).tagSubscriptions = _ctsArr;\n                    await saveEntity(_ctsEntFresh);\n                    await refreshCharEditModal();\n                }\n            } as UIPart);\n        }\n        parts.push({ type: 'collapsibleSection', title: '\\ud83c\\udff7 Tag Subscriptions (' + _ctsSubs.filter(function(s) { return _ctsAllTags.indexOf(s) >= 0; }).length + ' active)', initialCollapsed: true, storageKey: `temp:ce_tagsubs_${charId}`, content: _ctsRows });\n    })();\n    parts.push(await buildKnowledgeSection(char));\n    // ── EQUIPMENT ─────────────────────────────────────────────────────\n    parts.push({ type: 'collapsibleSection', title: '🎒 Equipment', initialCollapsed: true, storageKey: `temp:ce_equip_${char.id}`, content: await (async function() {\n        const equippedParts: UIPart[] = [];\n        const entIdx = await loadEntityIndex();\n        const invItems = entIdx.filter(function(e) { return e.type === 'item' && e.parentId === char.entityId; });\n\n        if (invItems.length === 0) {\n            equippedParts.push({ type: 'text', text: 'No items in inventory. Add item entities as children of this character\\'s entity.', style: { fontSize: '11px', opacity: '0.5' } });\n        } else {\n            for (const item of invItems) {\n                const isEquipped = (char.equippedItemIds || []).includes(item.id);\n                equippedParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                    { type: 'text', text: item.name, style: { flex: '1 1 0', fontSize: '12px', color: isEquipped ? '#7ec8a0' : undefined } },\n                    { type: 'button', text: isEquipped ? '✓ Equipped' : 'Equip', style: { margin: 0, fontSize: '11px', backgroundColor: isEquipped ? 'rgba(126,200,160,0.15)' : 'rgba(255,255,255,0.05)', color: isEquipped ? '#7ec8a0' : undefined }, callback: async function() {\n                        const f = await loadCharacter(char.id); if (!f) return;\n                        if (!f.equippedItemIds) f.equippedItemIds = [];\n                        if (isEquipped) {\n                            f.equippedItemIds = f.equippedItemIds.filter(function(id) { return id !== item.id; });\n                        } else {\n                            f.equippedItemIds.push(item.id);\n                        }\n                        await saveCharacter(f); await refreshCharEditModal();  // [v0.9.8.5] equipment rides ephemeral temp entry; no lorebook sync\n                    } }\n                ] });\n            }\n        }\n        return equippedParts;\n    })() });\n    // [v0.9.9.2] Daily Schedule - hourly timetable for when the player is not present.\n    parts.push({ type: 'collapsibleSection', title: '\\ud83d\\udd52 Daily Schedule', initialCollapsed: true, storageKey: `temp:ce_sched_${char.id}`, content: await (async function() {\n        const schedParts: UIPart[] = [];\n        char.schedule = char.schedule || [];\n        const rows = char.schedule;\n        const entIdxS = await loadEntityIndex();\n        const locOptsS = entIdxS.filter(function(e) { return e.type === 'location'; });\n\n        schedParts.push({ type: 'text', text: 'Places this character goes by hour of day, used only while the player is not present in their scene. Resolved on travel.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });\n\n        schedParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [\n            { type: 'text', text: char.scheduleEnabled ? '\\u2705 Schedule Active' : '\\u26ab Schedule Inactive', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: char.scheduleEnabled ? '#7ec8a0' : undefined } },\n            { type: 'button', text: char.scheduleEnabled ? 'Disable' : 'Enable', style: { margin: 0, fontSize: '11px' }, callback: async function() {\n                const f = await loadCharacter(charId); if (!f) return;\n                f.scheduleEnabled = !f.scheduleEnabled;\n                await saveCharacter(f); await refreshCharEditModal();\n            } }\n        ] });\n\n        if (rows.length === 0) {\n            schedParts.push({ type: 'text', text: 'No schedule rows yet. Add one below.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });\n        } else {\n            const sortedRows = rows.map(function(r, i) { return { r: r, i: i }; }).sort(function(a, b) { return a.r.startHour - b.r.startHour; });\n            for (const entry of sortedRows) {\n                const row = entry.r; const rowIdx = entry.i;\n                const locMeta = locOptsS.find(function(l) { return l.id === row.locationId; });\n                schedParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                    { type: 'numberInput', initialValue: row.startHour, style: { width: '56px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) {\n                        const f = await loadCharacter(charId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;\n                        let hv = Math.floor(Number(v) || 0); if (hv < 0) hv = 0; if (hv > 23) hv = 23;\n                        f.schedule[rowIdx].startHour = hv;\n                        await saveCharacter(f);\n                    } },\n                    { type: 'text', text: ':00 \\u2192', style: { fontSize: '11px', opacity: '0.6' } },\n                    { type: 'button', text: locMeta ? ('\\ud83c\\udf0d ' + locMeta.name) : '(pick location)', style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left' }, callback: async function() {\n                        await openPickerModal({\n                            title: 'Pick Schedule Location',\n                            items: locOptsS,\n                            getId: function(item) { return item.id; },\n                            getLabel: function(item) { return item.name; },\n                            getIcon: function() { return '\\ud83c\\udf0d'; },\n                            searchable: true,\n                            selectedId: row.locationId,\n                            emptyText: 'No locations found. Create a location entity first.',\n                            onSelect: async function(item) {\n                                const f = await loadCharacter(charId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;\n                                f.schedule[rowIdx].locationId = item.id;\n                                await saveCharacter(f); await refreshCharEditModal();\n                            }\n                        });\n                    } },\n                    { type: 'button', text: '\\u2715', style: { margin: 0, fontSize: '11px', width: '28px' }, callback: async function() {\n                        const f = await loadCharacter(charId); if (!f || !f.schedule) return;\n                        f.schedule = f.schedule.filter(function(_rr, ri2) { return ri2 !== rowIdx; });\n                        await saveCharacter(f); await refreshCharEditModal();\n                    } }\n                ] });\n            }\n        }\n\n        schedParts.push({ type: 'button', text: '+ Add Schedule Row', style: { width: '100%', marginTop: '4px', fontSize: '11px' }, callback: async function() {\n            const f = await loadCharacter(charId); if (!f) return;\n            f.schedule = f.schedule || [];\n            f.schedule.push({ startHour: 8, locationId: (locOptsS[0] ? locOptsS[0].id : '') });\n            await saveCharacter(f); await refreshCharEditModal();\n        } });\n\n        schedParts.push({ type: 'button', text: '\\ud83d\\udd04 Process Schedule Now', style: { width: '100%', marginTop: '8px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)' }, callback: async function() {\n            try {\n                await resolveSchedules();\n                await refreshSidebar();\n                await refreshCharEditModal();\n            } catch (e) { api.v1.error('[AE:charEdit] manual schedule resolve error:', e); }\n        } });\n\n        return schedParts;\n    })() });\n\n    if (cfg.sheetCategories && cfg.sheetCategories.length > 0) parts.push(buildSheetSection(char, cfg));\n    \n// ── CHARACTER RESOURCES ────────────────────────────────────────────\n    parts.push(await (async function(): Promise<UIPart> {\n        const defs = char.charResourceDefs || [];\n        const vals = char.charResourceValues || {};\n        const resParts: UIPart[] = [];\n\n        resParts.push({ type: 'text', text: 'Personal resources tracked on this character. Adjustable here and targetable by action rules.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });\n\n        for (let ri = 0; ri < defs.length; ri++) {\n            const res = defs[ri];\n            const captRi = ri;\n            const captId = res.id;\n            const val = vals[res.id] || 0;\n            const states = res.states || [];\n\n            resParts.push({ type: 'box', style: { padding: '8px', marginBottom: '8px', backgroundColor: 'rgba(255,255,255,0.02)', borderRadius: '6px', borderLeft: res.type === 'pool' ? '3px solid #88ccff' : '3px solid #e8a87c' }, content: [\n                // Definition row\n                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n                    { type: 'textInput', initialValue: res.name, placeholder: 'Name', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].name = v; await saveCharacter(f); } },\n                    { type: 'textInput', initialValue: res.tag, placeholder: '#tag', style: { width: '80px', fontSize: '11px' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].tag = v; await saveCharacter(f); } },\n                    { type: 'button', text: res.type === 'pool' ? 'Pool' : 'Track', style: { margin: 0, fontSize: '10px', backgroundColor: res.type === 'pool' ? 'rgba(136,204,255,0.15)' : 'rgba(232,168,124,0.15)', color: res.type === 'pool' ? '#88ccff' : '#e8a87c', border: 'none' }, callback: async function() {\n                        const f = await loadCharacter(charId); if (!f) return;\n                        f.charResourceDefs[captRi].type = f.charResourceDefs[captRi].type === 'pool' ? 'track' : 'pool';\n                        await saveCharacter(f); await refreshCharEditModal();\n                    } },\n                    { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() {\n                        const f = await loadCharacter(charId); if (!f) return;\n                        f.charResourceDefs.splice(captRi, 1);\n                        delete f.charResourceValues[captId];\n                        await saveCharacter(f); await refreshCharEditModal();\n                    } }\n                ] },\n                // Bounds / states config\n                res.type === 'pool' ? { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n                    { type: 'checkboxInput', label: 'Bounded', initialValue: !!res.hasBounds, onChange: async function(v: boolean) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].hasBounds = v; await saveCharacter(f); await refreshCharEditModal(); } },\n                    res.hasBounds ? { type: 'textInput', placeholder: 'Min', initialValue: res.min !== undefined ? res.min.toString() : '0', style: { width: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; const n = parseInt(v, 10); f.charResourceDefs[captRi].min = isNaN(n) ? 0 : n; await saveCharacter(f); } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart,\n                    res.hasBounds ? { type: 'text', text: '–', style: { opacity: '0.5' } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart,\n                    res.hasBounds ? { type: 'textInput', placeholder: 'Max', initialValue: res.max !== undefined ? res.max.toString() : '10', style: { width: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(charId); if (!f) return; const n = parseInt(v, 10); f.charResourceDefs[captRi].max = isNaN(n) ? 10 : n; await saveCharacter(f); } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart\n                ] } as UIPart : aeRenderIndexedStatesEditor(states, async function(next) { const f = await loadCharacter(charId); if (!f) return; f.charResourceDefs[captRi].states = next; await saveCharacter(f); }, refreshCharEditModal, 'State'),\n                // [vNEXT] Value editing restored — GM-adjustable here for corrections/manual\n                // grants, in addition to changing through gameplay (resolution effects).\n                res.type === 'pool'\n                    ? { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [\n                        { type: 'text', text: 'Current:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                        { type: 'button', text: '−', style: { margin: 0, padding: '2px 8px' }, callback: async function() {\n                            const f = await loadCharacter(charId); if (!f) return;\n                            const cur = f.charResourceValues[captId] || 0;\n                            const lo = res.hasBounds && res.min !== undefined ? res.min : -999999;\n                            f.charResourceValues[captId] = Math.max(lo, cur - 1);\n                            await saveCharacter(f); await refreshCharEditModal();\n                        } } as UIPart,\n                        { type: 'numberInput', initialValue: val, style: { width: '64px', margin: 0, textAlign: 'center' } as any, onChange: async function(v: number) {\n                            const f = await loadCharacter(charId); if (!f) return;\n                            let nv = (v === null || v === undefined) ? 0 : v;\n                            if (res.hasBounds) { nv = Math.max(res.min !== undefined ? res.min : 0, Math.min(res.max !== undefined ? res.max : 999999, nv)); }\n                            f.charResourceValues[captId] = nv;\n                            await saveCharacter(f);\n                        } } as UIPart,\n                        { type: 'button', text: '+', style: { margin: 0, padding: '2px 8px' }, callback: async function() {\n                            const f = await loadCharacter(charId); if (!f) return;\n                            const cur = f.charResourceValues[captId] || 0;\n                            const hi = res.hasBounds && res.max !== undefined ? res.max : 999999;\n                            f.charResourceValues[captId] = Math.min(hi, cur + 1);\n                            await saveCharacter(f); await refreshCharEditModal();\n                        } } as UIPart,\n                        res.hasBounds && res.max !== undefined ? { type: 'text', text: '/ ' + res.max, style: { fontSize: '11px', opacity: '0.5' } } as UIPart : { type: 'box', style: { width: '0' }, content: [] } as UIPart\n                    ] as UIPart[] }\n                    : { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [\n                        { type: 'text', text: 'State:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                        { type: 'button', text: '‹', style: { margin: 0, padding: '2px 8px' }, callback: async function() {\n                            const f = await loadCharacter(charId); if (!f) return;\n                            const cur = f.charResourceValues[captId] || 0;\n                            f.charResourceValues[captId] = Math.max(0, cur - 1);\n                            await saveCharacter(f); await refreshCharEditModal();\n                        } } as UIPart,\n                        { type: 'text', text: states[val] || '?', style: { fontSize: '13px', fontWeight: 'bold', flex: '1 1 0', textAlign: 'center', color: '#e8a87c' } as any } as UIPart,\n                        { type: 'button', text: '›', style: { margin: 0, padding: '2px 8px' }, callback: async function() {\n                            const f = await loadCharacter(charId); if (!f) return;\n                            const cur = f.charResourceValues[captId] || 0;\n                            f.charResourceValues[captId] = Math.min(states.length - 1, cur + 1);\n                            await saveCharacter(f); await refreshCharEditModal();\n                        } } as UIPart\n                    ] as UIPart[] }\n            ] });\n        }\n\n        if (defs.length === 0) {\n            resParts.push({ type: 'text', text: 'No character resources defined.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '6px' } });\n        }\n\n        resParts.push({ type: 'button', text: '+ New Resource', style: { width: '100%', margin: '2px 0 0 0', fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {\n            const f = await loadCharacter(charId); if (!f) return;\n            if (!f.charResourceDefs) f.charResourceDefs = [];\n            const newId = generateId();\n            f.charResourceDefs.push({ id: newId, name: 'New Resource', tag: '#res_' + newId.slice(-4), type: 'pool', hasBounds: true, min: 0, max: 10 });\n            if (!f.charResourceValues) f.charResourceValues = {};\n            f.charResourceValues[newId] = 0;\n            await saveCharacter(f); await refreshCharEditModal();\n        } });\n\n        return { type: 'collapsibleSection', title: '💠 Character Resources (' + defs.length + ')', initialCollapsed: defs.length === 0, storageKey: 'temp:ce_cres_' + charId, content: resParts };\n    })());\n// ── CHARACTER FACTION RELATIONSHIPS ────────────────────────────────\n    const trackedFactions = cfg.factions ? cfg.factions.filter(function(f) { return char.charFactionRelationships && char.charFactionRelationships[f.id] !== undefined; }) : [];\n    const untrackedFactions = cfg.factions ? cfg.factions.filter(function(f) { return !char.charFactionRelationships || char.charFactionRelationships[f.id] === undefined; }) : [];\n\n    if (cfg.factions && cfg.factions.length > 0) {\n        const facRelParts: UIPart[] = [];\n        facRelParts.push({ type: 'text', text: 'Track faction relationships for this character independently of the player\\'s standing.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });\n\n        for (let fi = 0; fi < trackedFactions.length; fi++) {\n            let fac = trackedFactions[fi];\n            let captFacId = fac.id;\n            let relIdx = char.charFactionRelationships[fac.id] || 0;\n            let relState = (fac.relationshipStates || [])[relIdx] || 'Unknown';\n            facRelParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n                { type: 'text', text: fac.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },\n                { type: 'button', text: relState, style: { margin: 0, fontSize: '11px', minWidth: '90px', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {\n                    let states = fac.relationshipStates || [];\n                    let pm = await openEngineModal({ title: fac.name + ' — Relationship', size: 'small', content: states.map(function(s, idx) {\n                        return { type: 'button', text: s, style: { width: '100%', marginBottom: '4px', backgroundColor: relIdx === idx ? 'rgba(126,200,160,0.2)' : undefined, color: relIdx === idx ? '#7ec8a0' : undefined }, callback: async function() {\n                            const f2 = await loadCharacter(charId); if (!f2) return;\n                            if (!f2.charFactionRelationships) f2.charFactionRelationships = {};\n                            f2.charFactionRelationships[captFacId] = idx; await saveCharacter(f2); pm.close(); await refreshCharEditModal();\n                        } } as UIPart;\n                    })});\n                } },\n                { type: 'button', text: '✕', style: { margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() {\n                    const f2 = await loadCharacter(charId); if (!f2) return;\n                    delete f2.charFactionRelationships[captFacId]; await saveCharacter(f2); await refreshCharEditModal();\n                } }\n            ] });\n        }\n\n        if (untrackedFactions.length > 0) {\n            facRelParts.push({ type: 'button', text: '+ Track Faction', style: { fontSize: '11px', width: '100%', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {\n                let pm = await openEngineModal({ title: 'Track Faction Relationship', size: 'small', content: untrackedFactions.map(function(f) {\n                    return { type: 'button', text: f.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() {\n                        const f2 = await loadCharacter(charId); if (!f2) return;\n                        if (!f2.charFactionRelationships) f2.charFactionRelationships = {};\n                        f2.charFactionRelationships[f.id] = 0; await saveCharacter(f2); pm.close(); await refreshCharEditModal();\n                    } } as UIPart;\n                })});\n            } });\n        }\n\n        if (trackedFactions.length === 0) facRelParts.push({ type: 'text', text: 'No factions tracked. Use \"+ Track Faction\" to add.', style: { fontSize: '11px', opacity: '0.4' } });\n        parts.push({ type: 'collapsibleSection', title: '⚔️ Faction Relationships (' + trackedFactions.length + ')', initialCollapsed: true, storageKey: 'temp:ce_facrel_' + charId, content: facRelParts });\n    }\n\n    // --- EVENT HISTORY ---\n    if (typeof buildEventHistorySection === 'function') {\n        const eventPart = buildEventHistorySection(char, cfg); \n        if (eventPart) {\n            parts.push(eventPart); \n        }\n    }\n\n    // --- SYSTEM ACTIONS (Export, Repair, Delete) ---\n    \n    // Check if the physical body is missing or the ID is a dead link\n    let charBodyIsMissing = true;\n    if (char.entityId) {\n        let checkEnt = await loadEntity(char.entityId);\n        if (checkEnt) charBodyIsMissing = false;\n    }\n\n    const systemActionsContent: UIPart[] = [\n        { type: 'text', text: 'Manage character database links and lorebook sync.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } }\n    ];\n\n    // Inject the Repair tool only if the body is actually missing\n    if (charBodyIsMissing) {\n        systemActionsContent.push(\n            { type: 'button', text: '🔧 Generate Missing Physical Body', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', border: '1px solid rgba(255,180,50,0.3)', color: '#ffb432' }, callback: async function() { \n                if (typeof makeDefaultEntity === 'function') {\n                    let repairEnt = makeDefaultEntity(char.name);\n                    repairEnt.type = 'character';\n                    repairEnt.parentId = null;\n                    await saveEntity(repairEnt);\n                    \n                    const f = await loadCharacter(char.id);\n                    if (f) { \n                        f.entityId = repairEnt.id; \n                        await saveCharacter(f); \n                        await refreshCharEditModal(); \n                        if (typeof refreshSidebar === 'function') await refreshSidebar();\n                    }\n                }\n            } }\n        );\n    }\n\n    systemActionsContent.push(\n        { type: 'button', text: '🗑️ Delete Character', style: { width: '100%', color: '#ff6b6b', backgroundColor: 'rgba(255,107,107,0.1)', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { \n            if (typeof confirmDeleteChar === 'function') await confirmDeleteChar(char.id, char.name); \n        } }\n    );\n\n    parts.push({ \n        type: 'collapsibleSection', \n        title: '⚙️ System Actions', \n        initialCollapsed: true, \n        storageKey: `temp:ce_system_${char.id}`, \n        content: systemActionsContent\n    });\n\n    // Padding for smooth scrolling at the bottom\n    parts.push({ type: 'text', text: ' ', style: { marginBottom: '48px' } });\n    \n    return parts.filter(Boolean) as UIPart[];\n}\n\n// ============================================================================\n// CHARACTER KNOWLEDGE SECTION BUILDER\n// ============================================================================\nasync function buildKnowledgeSection(char: CharacterRecord): Promise<UIPart> {\n    const knownEntities = char.knownEntities || [];\n    const knowParts: UIPart[] = [];\n\n    // Search filter\n    const ksSearchKey = 'temp:ce_ks_char_' + char.id;\n    const ksTerm = ((await api.v1.tempStorage.getOrDefault(ksSearchKey, '')) as string).toLowerCase();\n\n    if (knownEntities.length > 0) {\n        knowParts.push({ type: 'textInput', placeholder: '🔍 Filter knowledge entries...', initialValue: ksTerm, onChange: async function(v: string) { await api.v1.tempStorage.set(ksSearchKey, v); await refreshCharEditModal(); } });\n    }\n\n    const filtered = knownEntities.filter(function(e) {\n        if (!ksTerm) return true;\n        return e.entityName.toLowerCase().includes(ksTerm) || e.snapshot.toLowerCase().includes(ksTerm);\n    });\n\n    if (filtered.length === 0 && knownEntities.length === 0) {\n        knowParts.push({ type: 'text', text: 'No knowledge entries yet. Add via the entity picker below or from an entity\\'s Characters & Knowledge panel.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });\n    }\n\n    for (let ki = 0; ki < filtered.length; ki++) {\n        const ke = filtered[ki];\n        const captKe = ke;\n        const captKi = ki;\n        const origIdx = knownEntities.findIndex(function(e) { return e.id === ke.id; });\n        knowParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: ke.isManual ? 'rgba(255,180,50,0.05)' : 'rgba(255,255,255,0.03)', borderRadius: '4px', border: '1px solid ' + (ke.isManual ? 'rgba(255,180,50,0.15)' : 'rgba(255,255,255,0.08)') }, content: [\n            { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [\n                { type: 'text', text: (ke.isManual ? '📝 ' : '🔗 ') + ke.entityName, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: ke.isManual ? '#ffb432' : '#88ccff' } },\n                ...(ke.entityId ? [{ type: 'button', text: '↺', style: { margin: 0, padding: '2px 6px', fontSize: '11px', backgroundColor: 'transparent', opacity: '0.6' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    // Re-sync from entity\n                    const f = await loadCharacter(char.id); if (!f) return;\n                    if (!f.knownEntities) return;\n                    const entry = f.knownEntities.find(function(e) { return e.id === captKe.id; });\n                    if (!entry || !entry.entityId) return;\n                    const freshEnt = await loadEntity(entry.entityId);\n                    if (freshEnt?.knowledgeString) { entry.snapshot = freshEnt.knowledgeString; entry.entityName = freshEnt.name; }\n                    else { entry.snapshot = await buildEntityKnowledgeString(entry.entityId); }\n                    await saveCharacter(f); await refreshCharEditModal();\n                    api.v1.ui.toast('Entry refreshed.', { type: 'success', autoClose: 1500 });\n                } } as UIPart] : []),\n                { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() {\n                    const f = await loadCharacter(char.id); if (!f || !f.knownEntities) return;\n                    f.knownEntities = f.knownEntities.filter(function(e) { return e.id !== captKe.id; });\n                    await saveCharacter(f); await refreshCharEditModal();\n                } }\n            ] },\n            { type: 'text', text: ke.snapshot || '(no snapshot)', style: { fontSize: '11px', opacity: '0.7', lineHeight: '1.4' } }\n        ] });\n    }\n\n    // Add from entity picker\n    knowParts.push({ type: 'button', text: '+ Link Entity Knowledge', style: { width: '100%', fontSize: '11px', marginTop: '4px', backgroundColor: 'rgba(136,204,255,0.06)', color: '#88ccff' }, callback: async function() {\n        await api.v1.tempStorage.set('temp:ce_klink_search', '');\n        async function drawKlinkPicker(pm4: any) {\n            const term4 = ((await api.v1.tempStorage.getOrDefault('temp:ce_klink_search', '')) as string).toLowerCase();\n            const allEnts4 = await loadEntityIndex();\n            const existing4 = (char.knownEntities || []).map(function(e) { return e.entityId; }).filter(Boolean);\n            const pickable4 = allEnts4.filter(function(m) {\n                if (existing4.includes(m.id)) return false;\n                if (!term4) return true;\n                return m.name.toLowerCase().includes(term4);\n            });\n            const content4: UIPart[] = [\n                { type: 'textInput', placeholder: '🔍 Search entities...', initialValue: term4, onChange: async function(v: string) { await api.v1.tempStorage.set('temp:ce_klink_search', v); await drawKlinkPicker(pm4); } } as UIPart,\n                ...pickable4.map(function(m) { return { type: 'button', text: (ENTITY_TYPE_ICONS[m.type] || '●') + ' ' + m.name, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() {\n                    pm4.close();\n                    const f4 = await loadCharacter(char.id); if (!f4) return;\n                    if (!f4.knownEntities) f4.knownEntities = [];\n                    // Get or build snapshot from entity\n                    const targetEnt4 = await loadEntity(m.id);\n                    let snap4 = targetEnt4?.knowledgeString || '';\n                    if (!snap4.trim()) snap4 = await buildEntityKnowledgeString(m.id);\n                    // Also update entity's knowledgeString and awareCharacterIds\n                    if (targetEnt4) {\n                        if (!targetEnt4.knowledgeString || !targetEnt4.knowledgeString.trim()) targetEnt4.knowledgeString = snap4;\n                        if (!targetEnt4.awareCharacterIds.includes(f4.id)) targetEnt4.awareCharacterIds.push(f4.id);\n                        await saveEntity(targetEnt4);\n                    }\n                    f4.knownEntities.push({ id: generateId(), entityId: m.id, entityName: m.name, snapshot: snap4, addedAt: Date.now() });\n                    await saveCharacter(f4); await refreshCharEditModal();\n                } } as UIPart; })\n            ];\n            if (pm4 && !pm4.isClosed()) { await pm4.update({ content: content4 }); }\n            else { pm4 = await openEngineModal({ id: 'ce-klink-picker', title: 'Link Entity Knowledge', size: 'medium', content: content4 }); }\n        }\n        let pm4: any = null;\n        await drawKlinkPicker(pm4);\n    } });\n\n    // Manual entry\n    knowParts.push({ type: 'button', text: '+ Manual Entry', style: { width: '100%', fontSize: '11px', marginTop: '4px', backgroundColor: 'rgba(255,180,50,0.06)', color: '#ffb432' }, callback: async function() {\n        let manualSubject = '';\n        let manualDesc = '';\n        const manualPm = await openEngineModal({ title: 'Add Manual Knowledge Entry', size: 'medium', content: [\n            { type: 'text', text: 'Subject', style: { fontSize: '11px', opacity: '0.7', marginBottom: '2px' } },\n            { type: 'textInput', placeholder: 'e.g. \"the old smuggler\\'s tunnel\"', initialValue: '', onChange: function(v: string) { manualSubject = v; } },\n            { type: 'text', text: 'Description', style: { fontSize: '11px', opacity: '0.7', marginTop: '8px', marginBottom: '2px' } },\n            { type: 'multilineTextInput', placeholder: 'What does this character know about it?', initialValue: '', onChange: function(v: string) { manualDesc = v; } },\n            { type: 'button', text: '✓ Add Entry', style: { width: '100%', marginTop: '10px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432' }, callback: async function() {\n                if (!manualSubject.trim()) { api.v1.ui.toast('Subject required.', { type: 'warning' }); return; }\n                manualPm.close();\n                const f5 = await loadCharacter(char.id); if (!f5) return;\n                if (!f5.knownEntities) f5.knownEntities = [];\n                f5.knownEntities.push({ id: generateId(), entityName: manualSubject.trim(), snapshot: manualDesc.trim(), isManual: true, addedAt: Date.now() });\n                await saveCharacter(f5); await refreshCharEditModal();\n            } }\n        ] });\n    } });\n\n    return { type: 'collapsibleSection', title: '💬 Knowledge Base (' + knownEntities.length + ')', initialCollapsed: true, storageKey: `temp:ce_know_${char.id}`, content: knowParts };\n}\n\nfunction buildDynamicStateSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {\n    const eph = char.ephemeral; const mid = char.midRange;\n    const ephContent: UIPart[] = [];\n    if (eph) {\n        ephContent.push(\n            { type: 'box', style: { backgroundColor: 'bg1', padding: '8px', borderRadius: '4px', marginBottom: '8px' }, content: [\n                { type: 'text', text: `Event: \"${eph.eventAnchor}\"`, style: { fontSize: '11px', marginBottom: '2px' } },\n                { type: 'text', text: `Feeling: \"${eph.emotionalResponse}\"`, style: { fontSize: '11px', marginBottom: '2px' } },\n                { type: 'text', text: `Drive: \"${eph.immediateDesire}\"`, style: { fontSize: '11px', marginBottom: '6px' } },\n                { type: 'text', text: 'Override thought (replaces AI fallback line):', style: { fontSize: '9px', opacity: '0.55', marginTop: '6px', marginBottom: '2px' } },\n                { type: 'multilineTextInput', label: 'Override', placeholder: 'Leave blank to use AI-generated line. Type here to manually set.', initialValue: eph.compressedLine, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.ephemeral) { f.ephemeral.compressedLine = v; await saveCharacter(f); } } }\n            ] },\n            { type: 'row', style: { gap: '4px' }, content: [\n                { type: 'button', text: '↺ Regenerate', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-eph', autoClose: false, type: 'info' }); const ok = await generateEphemeral(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-eph', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } },\n                { type: 'button', text: 'Clear', style: { margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.ephemeral = null; f.ephemeralHistory = []; f.lastEphemeralGen = 0; await saveCharacter(f); await refreshCharEditModal(); } }\n            ] }\n        );\n        if (char.ephemeralHistory.filter(Boolean).length > 0) {\n            ephContent.push({ type: 'text', text: 'History:', style: { fontSize: '10px', opacity: '0.5', marginTop: '8px' } });\n            for (const h of char.ephemeralHistory.filter(Boolean)) { ephContent.push({ type: 'text', text: `  ${h.compressedLine}`, style: { fontSize: '10px', opacity: '0.4' } }); }\n        }\n    } else {\n        ephContent.push({ type: 'text', text: 'No snapshot yet. Generates automatically on generation end.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });\n        ephContent.push({ type: 'button', text: '⚡ Force Generate', style: { fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-eph', autoClose: false, type: 'info' }); const ok = await generateEphemeral(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-eph', type: ok ? 'success' : 'error', autoClose: ok ? 2000 : 3000 }); if (ok) await refreshCharEditModal(); } });\n    }\n    const midContent: UIPart[] = [];\nif (mid) {\n        midContent.push(\n            { type: 'multilineTextInput', label: 'Current Goal', initialValue: mid.currentDesire, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.currentDesire = v; await saveCharacter(f); } } },\n            { type: 'multilineTextInput', label: 'Social Mask (performing vs. interior)', initialValue: mid.socialMask, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.socialMask = v; await saveCharacter(f); } } },\n            { type: 'multilineTextInput', label: 'Shifted View (what they now believe that changed)', initialValue: mid.shiftedView, style: { fontSize: '11px', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f && f.midRange) { f.midRange.shiftedView = v; await saveCharacter(f); } } },\n            { type: 'button', text: '↺ Regenerate', style: { fontSize: '11px', marginTop: '4px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-mid', autoClose: false, type: 'info' }); const ok = await generateMidRange(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-mid', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } }\n        );\n    } else {\n        midContent.push({ type: 'text', text: 'No mid-range state yet.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } });\n        midContent.push({ type: 'button', text: '⚡ Force Generate', style: { fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-mid', autoClose: false, type: 'info' }); const ok = await generateMidRange(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-mid', type: ok ? 'success' : 'error', autoClose: ok ? 2000 : 3000 }); if (ok) await refreshCharEditModal(); } });\n    }\n    return { type: 'collapsibleSection', title: '⚡ Dynamic State', initialCollapsed: false, storageKey: `temp:ce_dyn_${char.id}`, content: [\n        // ── Individual Switches ────────────────────────────────────────────\n        { type: 'text', text: 'Master toggle is the ⚡️Dynamic/▫️Static button on the character card. Individual switches below can be adjusted after.', style: { fontSize: '10px', opacity: '0.45', marginBottom: '8px', fontStyle: 'italic' } },\n        { type: 'row', style: { gap: '8px', marginBottom: '10px', flexWrap: 'wrap' }, content: [\n            { type: 'checkboxInput', label: 'Ephemeral Thoughts (injected)', initialValue: !!char.autoThoughtsEnabled, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (!f) return; f.autoThoughtsEnabled = v; await saveCharacter(f); } },\n            { type: 'checkboxInput', label: 'Goal/Mask/View updates (engine reference)', initialValue: !!char.autoUpdateEnabled, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (!f) return; f.autoUpdateEnabled = v; await saveCharacter(f); } }\n        ] },\n        // ── Ephemeral Thoughts ─────────────────────────────────────────────\n        { type: 'collapsibleSection', title: 'Ephemeral Thoughts (injected)', initialCollapsed: false, storageKey: `temp:ce_eph_${char.id}`, content: ephContent },\n        // ── Mid-range State ────────────────────────────────────────────────\n        { type: 'collapsibleSection', title: 'Mid-range State (engine reference)', initialCollapsed: true, storageKey: `temp:ce_mid_${char.id}`, content: midContent },\n        // ── Primary Relationship ───────────────────────────────────────────\n        buildRelationshipSection(char, cfg),\n        // ── Hooks ─────────────────────────────────────────────────────────\n        buildHooksSection(char, cfg)\n    ] };\n}\n\n// [CHANGE] buildArcSection removed — arc UI retired. Data fields kept for backward compat.\n\nfunction buildRelationshipSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {\n    const rel = char.primaryRelationship;\n    \n    const threadItems: UIPart[] = rel.threads.filter(Boolean).map(function(thread, i) {\n        const ti = i; return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [\n            { type: 'textInput', initialValue: thread, style: { flex: '1 1 0', fontSize: '12px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads[ti] = v; await saveCharacter(f); } } },\n            { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads.splice(ti, 1); await saveCharacter(f); await refreshCharEditModal(); } } }\n        ] } as UIPart;\n    });\n    const tkTh = `ce_tmp_rth_${char.id}`;\n    \n    return { type: 'collapsibleSection', title: '🔗 Primary Relationship', initialCollapsed: true, storageKey: `temp:ce_prel_${char.id}`, content: [\n        { type: 'button', text: rel.targetName === '__player__' ? '👑 Player Character' : (rel.targetName ? `👤 ${rel.targetName}` : 'Select Character...'), style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {\n            const others = await loadCharacterListForPicker(char.id);\n            const pm = await openEngineModal({ title: 'Relationship Target', size: 'small', content: [\n                { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.targetName = ''; await saveCharacter(f); } pm.close(); await refreshCharEditModal(); } },\n                { type: 'button', text: '👑 Player Character (protagonist)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.2)' }, callback: async function() {\n                    const f = await loadCharacter(char.id); if (!f) return;\n                    f.primaryRelationship.targetName = '__player__';\n                    if (!f.primaryRelationship.enabled) f.primaryRelationship.enabled = true;\n                    await saveCharacter(f); pm.close(); await refreshCharEditModal();\n                } },\n                ...others.map(function(m) {\n                    return { type: 'button', text: m.name, style: { width: '100%', marginBottom: '4px', backgroundColor: rel.targetName === m.name ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() {\n                        const f = await loadCharacter(char.id); if (!f) return;\n                        f.primaryRelationship.targetName = m.name; await saveCharacter(f); pm.close(); await refreshCharEditModal();\n                    } } as UIPart;\n                })\n            ]});\n        } },\n        \n        // NEW: The Enable/Disable Checkbox (Defaults to false/off)\n        { type: 'row', alignment: 'center', style: { gap: '8px', marginTop: '6px', marginBottom: '4px' }, content: [\n            { type: 'checkboxInput', initialValue: !!rel.enabled, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.enabled = v; await saveCharacter(f); await refreshCharEditModal(); } } },\n            { type: 'text', text: 'Enable in AI Context', style: { fontSize: '12px', fontWeight: 'bold', color: rel.enabled ? '#7ec8a0' : '#888' } }\n        ] },\n\n        { type: 'column', style: { gap: '2px', marginTop: '8px', marginBottom: '8px' }, content: (function() {\n            let archDef = findArchetypeDef(cfg, rel);\n            let stageName = resolveArchetypeStage(cfg, rel);\n            let hasStages = !!(archDef && archDef.stages && archDef.stages.length);\n            let curStageIdx = (typeof rel.stageIndex === 'number') ? rel.stageIndex : 0;\n            let archCol: UIPart[] = [\n                { type: 'text', text: 'Archetype', style: { fontSize: '11px', opacity: '0.6' } },\n                { type: 'button', text: rel.archetype || '(Select Archetype)', style: { margin: 0, textAlign: 'left', fontSize: '12px' }, callback: async function() {\n                    let items: PickItem[] = (cfg.relationshipArchetypes || []).map(function(d) { return { id: d.id, label: d.name + (d.stages && d.stages.length ? '  (' + d.stages.length + ' stages)' : ''), selected: rel.archetypeId === d.id || rel.archetype === d.name }; });\n                    await openSearchPicker('Archetype', items, async function(id) {\n                        const f = await loadCharacter(char.id); if (!f) return;\n                        let picked = (cfg.relationshipArchetypes || []).find(function(d) { return d.id === id; });\n                        if (picked) { f.primaryRelationship.archetypeId = picked.id; f.primaryRelationship.archetype = picked.name; f.primaryRelationship.stageIndex = 0; await saveCharacter(f); }\n                        await refreshCharEditModal();\n                    });\n                } }\n            ];\n            if (hasStages) {\n                archCol.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginTop: '4px' }, content: [\n                    { type: 'text', text: 'Stage:', style: { fontSize: '11px', width: '44px', opacity: '0.7' } },\n                    { type: 'button', text: '\\u25c0', style: { margin: 0, width: '32px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { let m = Math.max(0, Math.min((archDef!.stages.length - 1), curStageIdx - 1)); f.primaryRelationship.stageIndex = m; await saveCharacter(f); await refreshCharEditModal(); } } },\n                    { type: 'text', text: (curStageIdx + 1) + '/' + archDef!.stages.length + ' \\u2014 ' + (stageName || ''), style: { flex: '1', fontSize: '11px', textAlign: 'center', color: '#7ec8a0' } },\n                    { type: 'button', text: '\\u25b6', style: { margin: 0, width: '32px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { let m = Math.max(0, Math.min((archDef!.stages.length - 1), curStageIdx + 1)); f.primaryRelationship.stageIndex = m; await saveCharacter(f); await refreshCharEditModal(); } } }\n                ] } as UIPart);\n            }\n            return archCol;\n        })() },\n        { type: 'textInput', label: 'How It Started', initialValue: rel.howItStarted, placeholder: 'Origin of the dynamic...', onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.howItStarted = v; await saveCharacter(f); } } },\n        { type: 'text', text: 'Threads', style: { fontSize: '11px', opacity: '0.6', marginTop: '8px', marginBottom: '2px' } },\n        ...threadItems,\n        { type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [\n            { type: 'textInput', placeholder: 'Add thread...', storageKey: `temp:${tkTh}`, style: { flex: '1 1 0' } },\n            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tkTh) as string || ''; if (!v.trim()) return; const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.threads.push(v.trim()); await saveCharacter(f); await api.v1.tempStorage.remove(tkTh); await refreshCharEditModal(); } } }\n        ] },\n        { type: 'multilineTextInput', label: 'Current Status', initialValue: rel.currentStatus, placeholder: 'Observable surface behavior — how do they act toward each other right now?', style: { minHeight: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.currentStatus = v; await saveCharacter(f); } } },\n        { type: 'multilineTextInput', label: 'Trajectory', initialValue: rel.trajectory, placeholder: 'The force pushing it — what event or tension is driving change?', style: { minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.trajectory = v; await saveCharacter(f); } } },\n        { type: 'multilineTextInput', label: 'Summary', initialValue: rel.summary, placeholder: 'The core knot — what do they each need that the other cannot give?', style: { minHeight: '60px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.primaryRelationship.summary = v; await saveCharacter(f); } } },\n        { type: 'button', text: '↺ Regen Relationship', style: { width: '100%', marginTop: '8px', fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number; api.v1.ui.toast('Generating…', { id: 'ce-rel', autoClose: false, type: 'info' }); const ok = await generateRelationshipUpdate(f, cfg, tc); api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-rel', type: ok ? 'success' : 'error', autoClose: 2000 }); if (ok) await refreshCharEditModal(); } }\n    ] };\n}\n\n// ============================================================================\n// CHARACTER EDIT — HOOKS SECTION\n// ============================================================================\n\nfunction npcPressureLabel(p: number): string {\n    if (p < 25) return 'Latent';\n    if (p < 60) return 'Building';\n    if (p < 85) return 'Urgent';\n    return 'Critical';\n}\n\nfunction buildHooksSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {\n    const hookItems: UIPart[] = char.hooks.filter(Boolean).map(function(hk, i) {\n        const hi = i; const imperative = npcPressureLabel(hk.pressureLevel);\n        const captHi = hi; const captHk = hk;\n        let hkDisplayTarget = hk.targetName === '__player__' ? '👑 Player' : (hk.targetName || 'Unknown');\n        return { type: 'collapsibleSection', title: (hk.pressureLevel >= 85 ? '🔥 ' : '') + hkDisplayTarget + ' — ' + imperative + ' (' + hk.pressureLevel + ')', initialCollapsed: true, storageKey: `temp:ce_hk_${char.id}_${hk.id}`, content: [\n            \n            // --- SEARCHABLE TARGET PICKER ---\n            { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [\n                { type: 'text', text: 'Target:', style: { fontSize: '11px', width: '50px', opacity: '0.7' } },\n                { type: 'button', text: hk.targetName === '__player__' ? '👑 Player' : (hk.targetName || '(Select Target)'), style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {\n                    await api.v1.tempStorage.set('ce_hk_target_search', '');\n                    \n                    async function drawSearchablePicker() {\n                        const term = await api.v1.tempStorage.getOrDefault('ce_hk_target_search', '') as string;\n                        const chars = typeof loadIndex === 'function' ? await loadIndex() : [];\n                        const pickable = chars.filter(function(m) { \n                            return m.id !== char.id && m.name.toLowerCase().includes(term.toLowerCase()); \n                        });\n                        \n                        const contentParts: UIPart[] = [];\n                        contentParts.push({ type: 'textInput', placeholder: '🔍 Search characters...', initialValue: term, onChange: async function(v: string) { await api.v1.tempStorage.set('ce_hk_target_search', v); await drawSearchablePicker(); } });\n                        contentParts.push({ type: 'button', text: '✕ Clear Target', style: { width: '100%', marginBottom: '4px', marginTop: '8px', color: '#ff6b6b' }, callback: async function() { \n                            const f = await loadCharacter(char.id); \n                            if (f) { f.hooks[hi].targetName = ''; await saveCharacter(f); pm.close(); await refreshCharEditModal(); } \n                        } });\n                        contentParts.push({ type: 'button', text: '👑 Player Character (protagonist)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(255,180,50,0.1)', color: '#ffb432', border: '1px solid rgba(255,180,50,0.2)' }, callback: async function() { \n                            const f = await loadCharacter(char.id); \n                            if (f) { f.hooks[hi].targetName = '__player__'; await saveCharacter(f); pm.close(); await refreshCharEditModal(); } \n                        } });\n                        \n                        pickable.forEach(function(m) {\n                            contentParts.push({ type: 'button', text: `👤 ${m.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left', backgroundColor: hk.targetName === m.name ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() { \n                                const f = await loadCharacter(char.id); \n                                if (f) { f.hooks[hi].targetName = m.name; await saveCharacter(f); pm.close(); await refreshCharEditModal(); } \n                            } } as UIPart);\n                        });\n\n                        if (pm && typeof pm.isClosed === 'function' && !pm.isClosed()) {\n                            await pm.update({ content: contentParts });\n                        } else {\n                            pm = await openEngineModal({ id: 'ce-hk-target-picker', title: 'Select Hook Target', size: 'medium', content: contentParts });\n                        }\n                    }\n                    let pm: any;\n                    await drawSearchablePicker();\n                }}\n            ]},\n\n            { type: 'multilineTextInput', label: 'Hook Description (the core tension)', initialValue: hk.description, style: { minHeight: '50px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].description = v; await saveCharacter(f); } } },\n            { type: 'sliderInput', label: `Pressure Level — ${imperative}`, min: 0, max: 100, step: 5, initialValue: hk.pressureLevel, onChange: async function(v: number) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].pressureLevel = v; await saveCharacter(f); } } },\n            { type: 'text', text: 'Pressure 60+: injects as Active Tension (global cap: 2). Pressure 85+: injects as Critical (global cap: 1).', style: { fontSize: '10px', opacity: '0.45', marginBottom: '6px' } },\n            hk.developmentNotes.filter(Boolean).length > 0 ? { type: 'box', style: { backgroundColor: 'bg1', padding: '6px', borderRadius: '4px', marginBottom: '4px' }, content: hk.developmentNotes.filter(Boolean).map(function(n) { return { type: 'text', text: `• ${n}`, style: { fontSize: '10px', opacity: '0.6' } } as UIPart; }) } as UIPart : null,\n            { type: 'checkboxInput', label: 'Resolved', initialValue: hk.resolved, onChange: async function(v: boolean) { const f = await loadCharacter(char.id); if (f) { f.hooks[hi].resolved = v; await saveCharacter(f); await refreshCharEditModal(); } } },\n            { type: 'button', text: '🗑 Remove Hook', style: { fontSize: '11px', marginTop: '6px', color: '#ff6b6b' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.hooks.splice(hi, 1); await saveCharacter(f); await refreshCharEditModal(); } } }\n        ].filter(Boolean) as UIPart[] } as UIPart;\n    });\n    return { type: 'collapsibleSection', title: (function() {\n        const activeHooks = char.hooks.filter(function(h){ return !h.resolved; });\n        const critCount = activeHooks.filter(function(h){ return h.pressureLevel >= 85; }).length;\n        return '🎣 Hooks' + (activeHooks.length > 0 ? ' (' + (critCount > 0 ? '🔥 ' : '') + activeHooks.length + ' active)' : '');\n    })(), initialCollapsed: true, storageKey: `temp:ce_hooks_${char.id}`, content: [\n        { type: 'text', text: 'Dramatic tensions between this character and another. Tracked by pressure level and injected into context when high enough.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },\n        ...hookItems,\n        { type: 'row', style: { gap: '4px', marginTop: '8px' }, content: [\n            { type: 'button', text: '+ Add Blank Hook', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.hooks.push({ id: api.v1.uuid(), targetName: '', description: '', pressureLevel: 30, developmentNotes: [], resolved: false }); await saveCharacter(f); await refreshCharEditModal(); } } },\n            { type: 'button', text: '↺ Scan Hooks', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                const f = await loadCharacter(char.id); if (!f) return;\n                const cfg2 = await loadConfig(); const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;\n                api.v1.ui.toast('Scanning…', { id: 'ce-hk', autoClose: false, type: 'info' });\n                const ok = await generateHookUpdates(f, cfg2, tc);\n                api.v1.ui.toast(ok ? 'Updated.' : 'Failed.', { id: 'ce-hk', type: ok ? 'success' : 'error', autoClose: 2000 });\n                if (ok) await refreshCharEditModal();\n            } },\n            { type: 'button', text: '✓ Resolve Hook', style: { margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.08)', color: '#7ec8a0', border: '1px solid rgba(126,200,160,0.3)' }, disabled: char.hooks.length === 0, callback: async function() {\n                const f = await loadCharacter(char.id); if (!f || f.hooks.length === 0) return;\n                const hDesc = f.hooks[0].description.substring(0, 50);\n                f.hooks = []; await saveCharacter(f);\n                api.v1.ui.toast('✓ Hook resolved: ' + hDesc, { type: 'success', autoClose: 3000 });\n                await refreshCharEditModal();\n            } }\n        ] }\n    ] };\n}\n\n// ============================================================================\n// CHARACTER EDIT — WARDROBE / EQUIPMENT SECTION\n// ============================================================================\n\nasync function buildInventorySection(char: CharacterRecord): Promise<UIPart> {\n    if (!char.entityId) {\n        return { type: 'collapsibleSection', title: '🎒 Inventory', initialCollapsed: true, storageKey: `temp:ce_inv_${char.id}`, content: [\n            { type: 'text', text: 'Character must be linked to an Entity to hold items.', style: { fontSize: '11px', opacity: '0.5' } }\n        ] };\n    }\n\n    const entIdx = await loadEntityIndex();\n    const items = entIdx.filter(m => m.type === 'item' && m.parentId === char.entityId);\n    \n    const rows: UIPart[] = items.map(function(item) {\n        const isEq = char.equippedItemId === item.id;\n        return { type: 'box', style: { marginBottom: '4px', backgroundColor: 'bg1', padding: '6px', borderRadius: '4px', borderLeft: `3px solid ${isEq ? '#7ec8a0' : 'transparent'}` }, content: [\n            { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [\n                { type: 'text', text: isEq ? '●' : '○', style: { fontSize: '12px', color: isEq ? '#7ec8a0' : '#555', flexShrink: '0' } },\n                { type: 'text', text: item.name, style: { flex: '1 1 0', fontWeight: 'bold', fontSize: '12px' } },\n                { type: 'button', text: isEq ? 'Unequip' : 'Equip', style: { margin: 0, fontSize: '11px', color: isEq ? '#888' : '#7ec8a0' }, callback: async function() { const f = await loadCharacter(char.id); if (!f) return; f.equippedItemId = isEq ? undefined : item.id; await saveCharacter(f); await refreshCharEditModal(); } },\n                { type: 'button', iconId: 'edit', style: { margin: 0 }, callback: async function() { await openEntityEditModal(item.id); } }\n            ] }\n        ] } as UIPart;\n    });\n\n    return { type: 'collapsibleSection', title: `🎒 Inventory (${items.length})`, initialCollapsed: true, storageKey: `temp:ce_inv_${char.id}`, content: [\n        { type: 'text', text: 'Items physically parented to this character.', style: { fontSize: '10px', opacity: '0.6', marginBottom: '8px' } },\n        ...(rows.length > 0 ? rows : [{ type: 'text', text: 'Inventory is empty.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '6px' } } as UIPart]),\n        { type: 'button', text: '+ Create Item', iconId: 'plus', style: { marginTop: '8px' }, callback: async function() { \n            const newItem = makeDefaultEntity('New Item');\n            newItem.type = 'item';\n            newItem.parentId = char.entityId || null;\n            await saveEntity(newItem);\n            await openEntityEditModal(newItem.id); // Drops them straight into the new item!\n        } }\n    ] };\n}\n\n// ============================================================================\n// CHARACTER EDIT — CHARACTER SHEET SECTION\n// ============================================================================\n\nfunction buildSheetSection(char: CharacterRecord, cfg: GlobalConfig): UIPart {\n    if (cfg.sheetCategories.filter(Boolean).length === 0) {\n        return { type: 'collapsibleSection', title: '📊 Character Sheet', initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}`, content: [{ type: 'text', text: 'No categories defined. Add them in ⚙ Settings.', style: { fontSize: '11px', opacity: '0.5' } }] };\n    }\n    const cats: UIPart[] = cfg.sheetCategories.filter(Boolean).map(function(cat) {\n        const fields: UIPart[] = cat.fields.filter(Boolean).map(function(field) {\n            const key = `${cat.id}.${field.id}`; const cur = char.sheetValues[key] || '';\n            if (cat.fieldType === 'enum' && cat.enumValues.filter(Boolean).length > 0) {\n                return { type: 'column', style: { marginBottom: '8px' }, content: [\n                    { type: 'text', text: field.name, style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },\n                    { type: 'button', text: cur || '(Select…)', style: { margin: 0, textAlign: 'left', fontSize: '12px' }, callback: async function() {\n                        const p = await openEngineModal({ title: field.name, size: 'small', content: cat.enumValues.filter(Boolean).map(function(v) {\n                            return { type: 'button', text: v, style: { margin: '2px', width: '100%', backgroundColor: v === cur ? 'rgba(126,200,160,0.2)' : undefined }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } p.close(); await refreshCharEditModal(); } } as UIPart;\n                        }) });\n                    } }\n                ] } as UIPart;\n            } else if (cat.fieldType === 'number') {\n                return { type: 'numberInput', label: field.name, initialValue: Number(cur) || 0, style: { marginBottom: '8px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } } } as UIPart;\n            } else {\n                return { type: 'textInput', label: field.name, initialValue: cur, style: { marginBottom: '8px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.sheetValues[key] = v; await saveCharacter(f); } } } as UIPart;\n            }\n        });\n        return { type: 'collapsibleSection', title: cat.name, initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}_${cat.id}`, content: fields.filter(Boolean) as UIPart[] } as UIPart;\n    });\n    return { type: 'collapsibleSection', title: '📊 Character Sheet', initialCollapsed: true, storageKey: `temp:ce_sheet_${char.id}`, content: cats };\n}\n\n// ============================================================================\n// CHARACTER EDIT — EVENT HISTORY SECTION\n// ============================================================================\n\nfunction buildEventHistorySection(char: CharacterRecord, cfg: GlobalConfig): UIPart {\n    const events: UIPart[] = char.eventHistory.filter(Boolean).map(function(ev, i) {\n        const ei = i;\n        return { type: 'row', style: { marginBottom: '6px', gap: '4px' }, content: [\n            { type: 'multilineTextInput', initialValue: ev.summary, style: { flex: '1 1 0', minHeight: '40px' }, onChange: async function(v: string) { const f = await loadCharacter(char.id); if (f) { f.eventHistory[ei].summary = v; await saveCharacter(f); } } },\n            { type: 'button', iconId: 'trash', style: { margin: 0 }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.eventHistory.splice(ei, 1); await saveCharacter(f); await refreshCharEditModal(); } } }\n        ] } as UIPart;\n    });\n    return { type: 'collapsibleSection', title: `📜 Event History (${char.eventHistory.length})`, initialCollapsed: true, storageKey: `temp:ce_evts_${char.id}`, content: [\n        { type: 'text', text: 'Major character-shaping events. Used as background context by the engine.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },\n        ...events,\n        { type: 'row', style: { gap: '4px', marginTop: '8px' }, content: [\n            { type: 'button', text: '+ Add Blank', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { const f = await loadCharacter(char.id); if (f) { f.eventHistory.push({ id: api.v1.uuid(), summary: '', timestamp: Date.now() }); await saveCharacter(f); await refreshCharEditModal(); } } },\n            { type: 'button', text: '⚡ Generate from Context', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                api.v1.ui.toast('Generating summary…', { id: 'ce-ev', autoClose: false, type: 'info' });\n                const cfg2 = await loadConfig(); const summ = await generateEventSummary(char, cfg2);\n                if (summ) { const f = await loadCharacter(char.id); if (f) { f.eventHistory.push({ id: api.v1.uuid(), summary: summ, timestamp: Date.now() }); await saveCharacter(f); api.v1.ui.toast('Added.', { id: 'ce-ev', type: 'success', autoClose: 1000 }); await refreshCharEditModal(); } }\n                else api.v1.ui.toast('Failed to generate.', { id: 'ce-ev', type: 'error', autoClose: 2000 });\n            } }\n        ] }\n    ] };\n}\n\n\n// ============================================================================\n// TEMPLATE BUILDER UI SYSTEM\n// ============================================================================\n\nconst MACRO_DICTIONARIES = {\n    trackedNarrative: ['name', 'description', 'storyState', 'pathNames'],\n    location: ['playerName', 'name', 'description', 'atmosphere', 'state'],\n    player: ['playerName', 'presentNames', 'name', 'res.<tag>'],\n    npc: ['name', 'primaryRelationship.targetName', 'primaryRelationship.currentStatus', 'relArchetype', 'relStage', 'conditionStates', 'res.<tag>', 'midRange.currentDesire', 'midRange.socialMask', 'midRange.shiftedView', 'ephemeral.eventAnchor', 'ephemeral.emotionalResponse', 'ephemeral.immediateDesire', 'ephemeral.compressedLine', 'hookDescription'],\n    npcWeb: ['charA_name', 'charB_name', 'dynamic'],\n    activeNarrative: ['name', 'description']            // [v0.9.24] deprecated; preview only\n};\n\n// [v0.9.26 DRM1] Preview-only sample data. res is a wildcard (res.<tag>), so the\n// sample res objects carry the common tags an author might reference (condition,\n// health, mood, luck, stamina, mana, drunk). _resProxyForPreview() below also\n// supplies a generic fallback for any res tag not listed here, so EVERY res.<x>\n// macro renders something in the live preview.\nfunction _resPreview(base: Record<string, string>): any {\n    // Returns base merged with a fallback so unknown res tags still preview.\n    let out: Record<string, string> = {};\n    let common = { condition: 'Steady', health: 'Healthy', mood: 'Calm', luck: '3', stamina: 'Rested', mana: 'Full', drunk: 'Sober', hunger: 'Fed', morale: 'High' };\n    for (let k in common) { out[k] = (common as any)[k]; }\n    for (let k2 in base) { out[k2] = base[k2]; }\n    return out;\n}\nconst DUMMY_DATA: Record<string, any> = {\n    trackedNarrative: { name: 'The Stolen Relic', description: 'Recover the amulet from the thieves guild.', storyState: 'active', pathNames: 'Tavern → Alley → Docks' },\n    location: { playerName: 'Aria', name: 'The Rusty Anchor', description: 'A dimly lit tavern smelling of stale ale.', atmosphere: 'Tense and quiet.', state: 'Crowded' },\n    player: { playerName: 'Aria', presentNames: 'Barkeeper, Sel', name: 'Aria', res: _resPreview({ health: 'Steady', luck: '3' }) },\n    npc: {\n        name: 'Barkeeper',\n        primaryRelationship: { targetName: 'Aria', currentStatus: 'suspicious' },\n        relArchetype: 'Enemies to Lovers', relStage: 'Uneasy Trust',\n        conditionStates: 'Tipsy, Wary',\n        res: _resPreview({ mood: 'Grumpy', drunk: 'Tipsy', condition: 'Wary' }),\n        midRange: { currentDesire: 'get paid before the night ends', socialMask: 'Friendly smile', shiftedView: 'Starting to respect you' },\n        ephemeral: { eventAnchor: 'You slammed coins on the bar', emotionalResponse: 'Surprised, then pleased', immediateDesire: 'Hear your offer', compressedLine: 'this stranger knows too much' },\n        hookDescription: 'Needs someone to clear the cellar rats.'\n    },\n    npcWeb: { charA_name: 'Barkeeper', charB_name: 'Thief', dynamic: 'Owes money to the other.' },\n    activeNarrative: { name: 'A Brewing Storm', description: 'Tensions rise between the guilds.' }\n};\n\nasync function copyMacroToClipboard(macroName: string) {\n    try {\n        await api.v1.permissions.request(['clipboardWrite']);\n        const templateStr = `[ |${macroName}| ]`;\n        await api.v1.clipboard.writeText(templateStr);\n        api.v1.ui.toast('Copied: ' + templateStr, { type: 'success', autoClose: 2000 });\n    } catch (e) {\n        api.v1.ui.toast('Clipboard permission denied. Type it manually.', { type: 'error' });\n    }\n}\n\nfunction buildMacroButtons(type: keyof typeof MACRO_DICTIONARIES): any {\n    return {\n        type: 'row',\n        wrap: true,\n        style: { gap: '4px', marginBottom: '4px' },\n        content: MACRO_DICTIONARIES[type].map(m => ({\n            type: 'button',\n            text: m,\n            style: { padding: '2px 6px', fontSize: '9px', margin: 0, backgroundColor: 'rgba(255,255,255,0.05)' },\n            callback: () => copyMacroToClipboard(m)\n        }))\n    };\n}\n\nfunction buildTemplateEditor(\n    label: string, \n    type: keyof typeof MACRO_DICTIONARIES, \n    currentValue: string, \n    onSave: (val: string) => void\n): any[] {\n    const previewText = parseMacroTemplate(currentValue, DUMMY_DATA[type]);\n    \n    return [\n        { type: 'text', text: `${label}`, style: { marginTop: '12px', fontSize: '11px', color: '#88ccff' } },\n        buildMacroButtons(type),\n        {\n            type: 'multilineTextInput',\n            initialValue: currentValue,\n            placeholder: 'Enter macro template...',\n            style: { fontFamily: 'monospace', fontSize: '11px', minHeight: '50px' },\n            onChange: onSave\n        },\n        { type: 'text', text: `Preview: ${previewText || '(Blank)'}`, style: { fontSize: '11px', opacity: 0.7, marginBottom: '8px', fontStyle: 'italic' } }\n    ];\n}\n\nasync function getGlobalTemplateUIParts(refreshUI: () => void): Promise<UIPart[]> {\n    const cfg = await loadConfig();\n    const parts: any[] = [\n        { type: 'text', text: 'Click a macro to copy its Tripartite Bracket format `[ Prefix | macro.path | Suffix ]` to your clipboard.', style: { fontSize: '10px', opacity: 0.6, marginBottom: '8px' } }\n    ];\n\n    // [v0.9.8.4] Editors ordered to match the injection / scene flow:\n    // quest -> location -> roster -> character dynamics -> background webs.\n    parts.push(...buildTemplateEditor('Tracked Narrative (Quest)', 'trackedNarrative', cfg.contextTemplates.trackedNarrative, async (v) => {\n        cfg.contextTemplates.trackedNarrative = v; await saveConfig(cfg); refreshUI();\n    }));\n    parts.push(...buildTemplateEditor('Location & Scene', 'location', cfg.contextTemplates.location, async (v) => {\n        cfg.contextTemplates.location = v; await saveConfig(cfg); refreshUI();\n    }));\n    parts.push(...buildTemplateEditor('Scene Roster (Present With)', 'player', cfg.contextTemplates.player, async (v) => {\n        cfg.contextTemplates.player = v; await saveConfig(cfg); refreshUI();\n    }));\n    parts.push(...buildTemplateEditor('Character Dynamics', 'npc', cfg.contextTemplates.npc, async (v) => {\n        cfg.contextTemplates.npc = v; await saveConfig(cfg); refreshUI();\n    }));\n    parts.push(...buildTemplateEditor('NPC Web (Background)', 'npcWeb', cfg.contextTemplates.npcWeb, async (v) => {\n        cfg.contextTemplates.npcWeb = v; await saveConfig(cfg); refreshUI();\n    }));\n    // [v0.9.26 DRM2] Active Narrative editor removed — Tracked Narrative covers it; activeNarrative macro dict retained for preview only.\n\n    return parts;\n}\n\n// ============================================================================\n// SECTION 21 — SIDEBAR: DRAMA TAB\n// buildDramaTabContent: NPC hooks, narrative arcs, web links.\n// ============================================================================\n\nasync function buildDramaTabContent(): Promise<UIPart[]> {\n    const allChars = await loadAllCharacters();\n    let parts: UIPart[] = [];\n\n    // [v0.9.17] Resolve the player's display name so __player__ targets show a real name.\n    const _dramaCfg = await loadConfig();\n    const _dramaProtag = allChars.find(function(c) { return (c as any).isProtagonist; });\n    const _playerDisplayName = _dramaProtag ? _dramaProtag.name : ((_dramaCfg as any).protagonistName || 'Player');\n\n    // --- 1. THE HOOK QUEUE (COLLAPSIBLE) ---\n    let hookParts: UIPart[] = [\n        { type: 'text', text: 'Hooks are active dramatic tensions involving characters. Pressure 60+ (Urgent) injects into the Scene Drama block at the bottom of the AI context. Pressure 85+ (Critical) injects as a high-priority Imperative at the top of context.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }\n    ];\n    let allHooks: { charId: string, charName: string, hook: UnresolvedHook }[] = [];\n    \n    for (const c of allChars) {\n        if (!c.active || !c.hooks) continue;\n        for (const h of c.hooks) {\n            // Under the new rules, this will realistically only find 1 active hook per character\n            if (!h.resolved) allHooks.push({ charId: c.id, charName: c.name, hook: h });\n        }\n    }\n\n    allHooks.sort(function(a, b) { return b.hook.pressureLevel - a.hook.pressureLevel; });\n\n    if (allHooks.length === 0) {\n        hookParts.push({ type: 'text', text: 'No active hooks. The tea is cold.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '8px', textAlign: 'center' } });\n    } else {\n        for (const item of allHooks) {\n            const h = item.hook;\n            \n            // Color Logic & Glow\n            let pColor = '#f1c40f'; // Yellow (< 60)\n            let shadow = 'none';\n            if (h.pressureLevel >= 85) {\n                pColor = '#ff6b6b'; // Red (Critical)\n                shadow = '0 0 10px rgba(255, 107, 107, 0.3)';\n            } else if (h.pressureLevel >= 60) {\n                pColor = '#ffb432'; // Orange (Urgent)\n                shadow = '0 0 6px rgba(255, 180, 50, 0.15)';\n            }\n\n            hookParts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.3)', padding: '8px', marginBottom: '8px', borderLeft: `3px solid ${pColor}`, borderRadius: '4px', boxShadow: shadow }, content: [\n                \n                // ROW 1: Title, %, Edit, Delete\n                { type: 'row', alignment: 'center', style: { marginBottom: '4px', gap: '4px' }, content: [\n                    { type: 'text', text: `${item.charName} ➝ ${h.targetName === '__player__' ? _playerDisplayName : (h.targetName || 'Unknown')}`, style: { fontWeight: 'bold', fontSize: '13px', flex: '1 1 0', color: '#e8a87c', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } },\n                    { type: 'text', text: `${h.pressureLevel}%`, style: { fontSize: '11px', color: pColor, fontWeight: 'bold', backgroundColor: 'rgba(0,0,0,0.5)', padding: '2px 6px', borderRadius: '4px' } },\n                    { type: 'button', iconId: 'edit-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent' }, callback: async function() { await openCharEditModal(item.charId); } },\n                    { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async function() {\n                        const f = await loadCharacter(item.charId);\n                        if (f && f.hooks) {\n                            f.hooks = f.hooks.filter(function(x) { return x.id !== h.id; });\n                            await saveCharacter(f);\n                            await refreshSidebar(); \n                        }\n                    }}\n                ]},\n                \n                // ROW 2: Description\n                { type: 'text', text: h.description, style: { fontSize: '12px', opacity: '0.85', lineHeight: '1.4', marginBottom: '8px' } },\n                \n                // ROW 3: Slider & Manual Force-Update Button\n                { type: 'row', alignment: 'center', style: { gap: '8px' }, content: [\n                    { type: 'sliderInput', min: 0, max: 100, step: 5, initialValue: h.pressureLevel, style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: number) {\n                        const f = await loadCharacter(item.charId);\n                        if (f && f.hooks) {\n                            const targetHook = f.hooks.find(function(x) { return x.id === h.id; });\n                            if (targetHook) {\n                                targetHook.pressureLevel = v;\n                                await saveCharacter(f);\n                                // Note: Slider saves backend state silently to avoid UI crash. \n                                // User clicks 🔄 to actually trigger the color/text refresh.\n                            }\n                        }\n                    }},\n                    { type: 'button', text: '🔄 Update', style: { margin: 0, padding: '4px 8px', fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.05)', border: '1px solid rgba(255,255,255,0.1)' }, disabledWhileCallbackRunning: true, callback: async function() {\n                        const f = await loadCharacter(item.charId);\n                        if (!f) return;\n                        const cfg = await loadConfig();\n                        const tc = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;\n                        \n                        api.v1.ui.toast(`Scanning scene for ${f.name}...`, { id: 'hk-upd', autoClose: false, type: 'info' });\n                        const ok = await generateHookUpdates(f, cfg, tc); // Calls the background engine manually\n                        api.v1.ui.toast(ok ? 'Tension Updated.' : 'No changes detected.', { id: 'hk-upd', type: ok ? 'success' : 'warning', autoClose: 2000 });\n                        \n                        // Redraws the sidebar to apply the new colors/text\n                        await refreshSidebar();\n                    }}\n                ]}\n            ]});\n        }\n    }\n\n    parts.push({ type: 'collapsibleSection', title: `🔥 The Hook Queue (${allHooks.length})`, initialCollapsed: false, storageKey: 'temp:drama_hooks', content: hookParts });\n\n// --- 2. THE NPC WEB (COLLAPSIBLE) ---\n    const npcWeb = await loadNpcWeb();\n    let webParts: UIPart[] = [\n        { type: 'text', text: 'Bilateral dynamics between characters. When both characters are present in the scene, priority 70+ injects as an Imperative (top of context), while lower priorities inject as Background Drama.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }\n    ];\n\n    // Helper to fetch character names for the UI buttons\n    function getCharName(id: string) {\n        const c = allChars.find(function(x) { return x.id === id; });\n        return c ? c.name : 'Select...';\n    }\n\n    for (let i = 0; i < npcWeb.length; i++) {\n        const link = npcWeb[i];\n        \n        // NEW: Check if both characters are currently in the scene!\n        const cA = allChars.find(function(x) { return x.id === link.charA_id; });\n        const cB = allChars.find(function(x) { return x.id === link.charB_id; });\n        const bothPresent = !!(cA && cA.scenePresent && cB && cB.scenePresent);\n        \n        // Green if active in scene, Blue if background\n        const webBorderColor = bothPresent ? '#7ec8a0' : '#88ccff'; \n        const webShadow = bothPresent ? '0 0 8px rgba(126,200,160,0.2)' : 'none';\n\n        // Modal helper to select a character\n        async function selectChar(isCharA: boolean) {\n            const pm = await openEngineModal({\n                title: 'Select Character',\n                size: 'small',\n                content: allChars.map(function(c) {\n                    return { type: 'button', text: c.name, style: { margin: '2px', width: '100%', backgroundColor: 'rgba(255,255,255,0.02)' }, callback: async function() {\n                        const web = await loadNpcWeb();\n                        if (isCharA) web[i].charA_id = c.id;\n                        else web[i].charB_id = c.id;\n                        await saveNpcWeb(web);\n                        pm.close();\n                        await refreshSidebar();\n                    } } as UIPart;\n                })\n            });\n        }\n\n        webParts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.3)', padding: '8px', marginBottom: '8px', borderLeft: `3px solid ${webBorderColor}`, boxShadow: webShadow, borderRadius: '4px' }, content: [\n            \n            // ROW 1: Character A ⇄ Character B + Delete\n            { type: 'row', alignment: 'center', style: { marginBottom: '6px', gap: '4px' }, content: [\n                { type: 'button', text: getCharName(link.charA_id), style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '4px', color: (cA && cA.scenePresent) ? '#7ec8a0' : undefined }, callback: async function() { await selectChar(true); } },\n                { type: 'text', text: '⇄', style: { fontSize: '14px', opacity: '0.6', margin: '0 2px' } },\n                { type: 'button', text: getCharName(link.charB_id), style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '4px', color: (cB && cB.scenePresent) ? '#7ec8a0' : undefined }, callback: async function() { await selectChar(false); } },\n                { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px 4px', backgroundColor: 'transparent', color: '#ff6b6b' }, callback: async function() {\n                    const web = await loadNpcWeb();\n                    web.splice(i, 1);\n                    await saveNpcWeb(web);\n                    await refreshSidebar();\n                }}\n            ]},\n            \n            // ROW 2: The Dynamic Input\n            { type: 'textInput', placeholder: 'Describe their dynamic (e.g., Bitter rivals...)', initialValue: link.dynamic, style: { fontSize: '12px', marginBottom: '6px' }, onChange: async function(v: string) {\n                const web = await loadNpcWeb();\n                web[i].dynamic = v;\n                await saveNpcWeb(web);\n            }},\n            \n            // ROW 3: The Priority Slider\n            { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [\n                { type: 'text', text: 'Priority', style: { fontSize: '10px', opacity: '0.6' } },\n                { type: 'sliderInput', min: 0, max: 100, step: 10, initialValue: link.priority, showValue: false, style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: number) {\n                    const web = await loadNpcWeb();\n                    web[i].priority = v;\n                    await saveNpcWeb(web);\n                }},\n                { type: 'text', text: `${link.priority}`, style: { fontSize: '10px', fontWeight: 'bold', width: '24px', textAlign: 'right', color: webBorderColor } }\n            ]}\n        ]});\n    }\n\n    // Add New Link Button\n    webParts.push({ type: 'button', text: '+ Add Web Link', iconId: 'plus', style: { width: '100%', fontSize: '11px', marginTop: '4px', backgroundColor: 'rgba(136,204,255,0.1)' }, callback: async function() {\n        const web = await loadNpcWeb();\n        web.push({ id: api.v1.uuid(), charA_id: '', charB_id: '', dynamic: '', priority: 30 });\n        await saveNpcWeb(web);\n        await refreshSidebar();\n    }});\n\n    parts.push({ type: 'collapsibleSection', title: `🕸️ The NPC Web (${npcWeb.length})`, initialCollapsed: true, storageKey: 'temp:drama_npcweb', content: webParts });\n    // --- 3. NARRATIVE THREADS (QUEST TREE) ---\n    const entIdx = await loadEntityIndex();\n    const narratives = entIdx.filter(function(n) { return n.type === 'narrative'; });\n    let storyParts: UIPart[] = [\n        { type: 'text', text: 'Active story threads. Their descriptions inject into the Scene Drama block (bottom of context) to remind the AI of ongoing plots when they are active.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '12px', lineHeight: '1.4' } }\n    ];\n\n    // Recursive Tree Builder\n    async function renderNarrativeTree(narrativeParentId: string | null, depth: number) {\n        const children = narratives.filter(function(n) { return (n.narrativeParentId || null) === narrativeParentId; });\n        for (const child of children) {\n            const hasChildren = narratives.some(function(n) { return n.narrativeParentId === child.id; });\n            \n            // Emoji logic based on storyState\n            let stateEmoji = '🔒';\n            let nameColor = '#888';\n            if (child.storyState === 'active') { stateEmoji = '🔥'; nameColor = '#ffb432'; }\n            else if (child.storyState === 'completed') { stateEmoji = '✅'; nameColor = '#7ec8a0'; }\n\n            storyParts.push({\n                type: 'row', alignment: 'center', style: { paddingLeft: `${depth * 14}px`, marginBottom: '4px' }, content: [\n                    { type: 'text', text: stateEmoji, style: { marginRight: '6px', fontSize: '12px' } },\n                    { type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', color: nameColor, fontWeight: depth === 0 ? 'bold' : 'normal' } },\n                    { type: 'button', iconId: 'edit', style: { margin: 0, padding: '2px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } }\n                ]\n            });\n\n            if (hasChildren) await renderNarrativeTree(child.id, depth + 1);\n        }\n    }\n\n    await renderNarrativeTree(null, 0);\n\n    if (narratives.length === 0) {\n        storyParts.push({ type: 'text', text: 'No narrative threads created yet.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', textAlign: 'center', marginBottom: '8px' } });\n    }\n\n    storyParts.push({ type: 'button', text: '+ New Narrative Thread', iconId: 'plus', style: { marginTop: '8px', fontSize: '11px', backgroundColor: 'rgba(232, 168, 124, 0.1)' }, callback: async function() {\n        const ent = makeDefaultEntity('New Thread');\n        ent.type = 'narrative';\n        ent.storyState = 'locked';\n        await saveEntity(ent);\n        await openEntityEditModal(ent.id);\n        await refreshSidebar();\n    }});\n\n    parts.push({ type: 'collapsibleSection', title: `📜 Narrative Threads (${narratives.length})`, initialCollapsed: false, storageKey: 'temp:drama_narratives', content: storyParts });\n    \n    // --- 4. GLOBAL CONTEXT TEMPLATE BUILDER ---\n    const templateParts = await getGlobalTemplateUIParts(async () => await refreshSidebar());\n    parts.push({ type: 'collapsibleSection', title: '⚙️ Context Templates', initialCollapsed: true, storageKey: 'temp:drama_templates', content: templateParts });\n    \n    return parts;\n}\n\n// ============================================================================\n// SECTION 22 — SIDEBAR: WORLD / ENTITIES TAB\n// [CHANGE] renderSceneHUD() -> queueSceneStateBroadcast() in travel callbacks.\n// ============================================================================\n\nasync function buildEntitiesTab(): Promise<UIPart[]> {\n    const parts: UIPart[] = [];\n    \n    // 1. Fetch the active search query for entities from temporary storage\n    const searchQuery = await api.v1.tempStorage.getOrDefault('temp:ae_entity_search', '') as string;\n    \n    // Top Row: Create Node Button\n    parts.push({ \n        type: 'button', \n        text: '➕ Create Node', \n        primary: true, \n        style: { marginBottom: '8px' }, \n        callback: async function() { \n            const ent = makeDefaultEntity('New Node');\n            await saveEntity(ent);\n            await openEntityEditModal(ent.id);\n            await refreshSidebar();\n        } \n    });\n\n    // 2. Add the Search Bar component\n    parts.push({\n        type: 'textInput', \n        placeholder: '🔍 Search entities...', \n        initialValue: searchQuery,\n        style: { marginBottom: '12px' }, \n        onChange: async function(v: string) {\n            // Save the query and re-render the UI\n            await api.v1.tempStorage.set('temp:ae_entity_search', v);\n            await refreshSidebar();\n        }\n    });\n\n    // Load the master entity index\n    const entIdx = await loadEntityIndex();\n    \n    // 3. Filter the index based on the search query\n    let displayEntIdx = entIdx;\n    if (searchQuery) {\n        const sq = searchQuery.toLowerCase();\n        displayEntIdx = displayEntIdx.filter(m => (m.name || '').toLowerCase().includes(sq));\n    }\n    \n    // Empty state message (Optional but recommended)\n    if (displayEntIdx.length === 0) {\n        parts.push({ \n            type: 'text', \n            text: searchQuery ? 'No entities match your search.' : 'No entities yet.', \n            style: { fontSize: '12px', opacity: '0.6', marginBottom: '8px' } \n        });\n    }\n    \n    // Helper to swap order in the index array\n    async function moveEntity(id: string, direction: -1 | 1) {\n        const currentIndex = await loadEntityIndex();\n        const childMeta = currentIndex.find(function(m) { return m.id === id; });\n        if (!childMeta) return;\n\n        // Get siblings in their current exact order\n        const siblings = currentIndex.filter(function(m) { return m.parentId === childMeta.parentId; });\n        const sibIdx = siblings.findIndex(function(m) { return m.id === id; });\n\n        if (direction === -1 && sibIdx > 0) {\n            // Move Up (Swap with previous sibling)\n            const targetId = siblings[sibIdx - 1].id;\n            const pos1 = currentIndex.findIndex(function(m) { return m.id === id; });\n            const pos2 = currentIndex.findIndex(function(m) { return m.id === targetId; });\n            const temp = currentIndex[pos1]; currentIndex[pos1] = currentIndex[pos2]; currentIndex[pos2] = temp;\n            await saveEntityIndex(currentIndex);\n            await refreshSidebar();\n        } else if (direction === 1 && sibIdx < siblings.length - 1) {\n            // Move Down (Swap with next sibling)\n            const targetId = siblings[sibIdx + 1].id;\n            const pos1 = currentIndex.findIndex(function(m) { return m.id === id; });\n            const pos2 = currentIndex.findIndex(function(m) { return m.id === targetId; });\n            const temp = currentIndex[pos1]; currentIndex[pos1] = currentIndex[pos2]; currentIndex[pos2] = temp;\n            await saveEntityIndex(currentIndex);\n            await refreshSidebar();\n        }\n    }\n\n    if (searchQuery) {\n        // Render a flat list when searching, since tree hierarchy parents might not match the search\n        for (const child of displayEntIdx) {\n            const icon = (child as any).icon || ENTITY_TYPE_ICONS[child.type] || '●';\n            parts.push({\n                type: 'row', alignment: 'center',\n                style: { marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: '4px' },\n                content: [\n                    { type: 'text', text: icon, style: { marginRight: '6px', fontSize: '14px' } },\n                    { type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', opacity: child.type === 'item' ? '0.7' : '1' } },\n                    { type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } }\n                ]\n            });\n        }\n    } else {\n        // Async Recursive Tree Builder with Collapse Memory\n        async function renderEntityTree(parentId: string | null, depth: number) {\n            const children = entIdx.filter(function(m) { return m.parentId === parentId; });\n            \n            for (let i = 0; i < children.length; i++) {\n                const child = children[i];\n                const hasChildren = entIdx.some(function(m) { return m.parentId === child.id; });\n                const isCollapsed = await api.v1.tempStorage.getOrDefault(`ce_col_${child.id}`, false);\n\n                const icon = (child as any).icon || ENTITY_TYPE_ICONS[child.type] || '●';\n                \n                const rowContent: UIPart[] = [];\n                \n                // 1. The Collapse Toggle Chevron\n                if (hasChildren) {\n                    rowContent.push({\n                        type: 'button', iconId: isCollapsed ? 'chevron-right' : 'chevron-down',\n                        style: { margin: '0 4px 0 0', padding: '2px', backgroundColor: 'transparent' },\n                        callback: async function() {\n                            await api.v1.tempStorage.set(`ce_col_${child.id}`, !isCollapsed);\n                            await refreshSidebar();\n                        }\n                    });\n                } else {\n                    rowContent.push({ type: 'text', text: '', style: { minWidth: '24px', marginRight: '4px' } });\n                }\n                \n                // 2. The Icon & Name\n                rowContent.push({ type: 'text', text: icon, style: { marginRight: '6px', fontSize: '14px' } });\n                rowContent.push({ type: 'text', text: child.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: depth === 0 ? 'bold' : 'normal', opacity: child.type === 'item' ? '0.7' : '1' } });\n                \n                // 3. Sorting Chevrons (Up / Down)\n                const isFirst = i === 0;\n                const isLast = i === children.length - 1;\n                \n                rowContent.push({\n                    type: 'button', iconId: 'chevron-up', disabled: isFirst,\n                    style: { margin: 0, padding: '2px', backgroundColor: 'transparent', opacity: isFirst ? '0.1' : '0.5' },\n                    callback: async function() { await moveEntity(child.id, -1); }\n                });\n                \n                rowContent.push({\n                    type: 'button', iconId: 'chevron-down', disabled: isLast,\n                    style: { margin: '0 4px 0 0', padding: '2px', backgroundColor: 'transparent', opacity: isLast ? '0.1' : '0.5' },\n                    callback: async function() { await moveEntity(child.id, 1); }\n                });\n\n                // 4. The Edit Button\n                rowContent.push({ type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(child.id); } });\n\n                // Push the assembled row\n                parts.push({\n                    type: 'row', alignment: 'center',\n                    style: { paddingLeft: `${depth * 14}px`, marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.05)', paddingBottom: '4px' },\n                    content: rowContent\n                });\n                \n                // 5. Recurse!\n                if (hasChildren && !isCollapsed) {\n                    await renderEntityTree(child.id, depth + 1);\n                }\n            }\n        }\n        \n        // Kick off the recursion starting at the Root level (null)\n        await renderEntityTree(null, 0);\n    }\n\n    if (entIdx.length === 0) {\n        parts.push({ type: 'text', text: 'No nodes created yet.', style: { fontSize: '12px', opacity: '0.6' } });\n    }\n\n    // ── LOST & FOUND: entities with broken parent references ────────────\n    let orphanEnts = entIdx.filter(function(m) {\n        return m.parentId !== null && !entIdx.find(function(p) { return p.id === m.parentId; });\n    });\n    if (orphanEnts.length > 0) {\n        let lostParts: UIPart[] = [\n            { type: 'text', text: 'These entities have a parent that no longer exists. Move to Root or edit to reparent.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } }\n        ];\n        for (let orphan of orphanEnts) {\n            let captOrphanId = orphan.id;\n            let oIcon = ENTITY_TYPE_ICONS[orphan.type] || '❓';\n            lostParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px', padding: '6px 8px', backgroundColor: 'rgba(255,180,50,0.07)', borderRadius: '4px', border: '1px solid rgba(255,180,50,0.2)' }, content: [\n                { type: 'text', text: oIcon, style: { fontSize: '13px', flexShrink: '0' } },\n                { type: 'text', text: orphan.name, style: { flex: '1 1 0', fontSize: '12px', color: '#ffb432' } },\n                { type: 'button', text: 'Root', style: { margin: 0, fontSize: '10px', padding: '2px 8px', backgroundColor: 'rgba(255,255,255,0.06)' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let fe = await loadEntity(captOrphanId); if (!fe) return;\n                    fe.parentId = null; await saveEntity(fe); await refreshSidebar();\n                } },\n                { type: 'button', iconId: 'edit', style: { margin: 0, padding: '4px', backgroundColor: 'transparent' }, callback: async function() { await openEntityEditModal(captOrphanId); } }\n            ] });\n        }\n        parts.push({ type: 'collapsibleSection', title: '⚠️ Lost Entities (' + orphanEnts.length + ')', initialCollapsed: false, storageKey: 'temp:ce_lost_ents', content: lostParts });\n    }\n\n    return parts;\n}\n\n// ============================================================================\n// ENTITY EDIT MODAL\n// ============================================================================\n\nasync function openEntityEditModal(id: string): Promise<void> {\n    const ent = await loadEntity(id);\n    if (!ent) return;\n\n    const allNodes = await loadEntityIndex();\n    const cfg = await loadConfig(); \n    let parts: UIPart[] = [];\n\n    // --- PRE-CALCULATE COMBINED SKILL OPTIONS ---\n    const skillOptions: { tag: string, name: string }[] = [];\n    (cfg.resources || []).forEach(function(r: any) { skillOptions.push({ tag: r.tag, name: `[Resource] ${r.name}` }); });\n    (cfg.sheetCategories || []).forEach(function(cat: any) {\n        (cat.fields || []).forEach(function(f: any) {\n            const tag = `#${f.name.toLowerCase().replace(/[^a-z0-9]/g, '')}`;\n            skillOptions.push({ tag: tag, name: `[Skill] ${f.name}` });\n        });\n    });\n\n    // --- ALWAYS VISIBLE (Top Level) ---\n    parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n        { type: 'textInput', label: 'Entity Name', initialValue: ent.name, style: { flex: '1 1 0' }, onChange: async function(val: string) { ent.name = val; await saveEntity(ent); await refreshSidebar(); } },\n        { type: 'textInput', label: 'Icon', placeholder: '🌍', initialValue: ent.icon || '', style: { width: '52px', flexShrink: '0', textAlign: 'center' }, onChange: async function(val: string) { ent.icon = val.trim() || undefined; await saveEntity(ent); await refreshSidebar(); queueSceneStateBroadcast(); } },\n        { type: 'button', text: '⧉ Copy', style: { margin: 0, fontSize: '11px', flexShrink: '0', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n            await copyEntity(ent.id, false);\n        } },\n        { type: 'button', text: '⧉+ Deep', style: { margin: 0, fontSize: '11px', flexShrink: '0', backgroundColor: 'rgba(232,168,124,0.1)', border: '1px solid rgba(232,168,124,0.3)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {\n            await copyEntity(ent.id, true);\n        } }\n    ] });\n\n    const typeOpts = [\n        { id: 'location', icon: '🌍', label: 'Location' },\n        { id: 'item', icon: '🎒', label: 'Item' },\n        { id: 'narrative', icon: '📜', label: 'Narrative' },\n        { id: 'character', icon: '👤', label: 'Character' }\n    ];\n    \n    parts.push({ type: 'text', text: 'Entity Type', style: { fontSize: '12px', fontWeight: 'bold', marginBottom: '4px', marginTop: '8px' } });\n    parts.push({ type: 'row', style: { gap: '4px', marginBottom: '12px' }, content: typeOpts.map(function(opt) { \n        const isActive = ent.type === opt.id; \n        return { \n            type: 'button', text: `${opt.icon} ${opt.label}`, \n            style: { \n                flex: '1 1 0', margin: 0, fontSize: '11px', \n                backgroundColor: isActive ? 'rgba(126,200,160,0.22)' : 'transparent', \n                border: isActive ? '1px solid rgba(126,200,160,0.55)' : '1px solid rgba(255,255,255,0.1)', \n                fontWeight: isActive ? 'bold' : 'normal' \n            }, \n            callback: async function() { ent.type = opt.id as any; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } \n        } as UIPart; \n    }) });\n\n    // --- NARRATIVE SPECIFIC CONTROLS ---\n    if (ent.type === 'narrative') {\n        parts.push({ type: 'text', text: 'Story State', style: { fontSize: '12px', fontWeight: 'bold', marginBottom: '4px', marginTop: '8px', color: '#e8a87c' } });\n        parts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [\n            { type: 'button', text: '🔒 Locked', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'locked' ? 'rgba(136,136,136,0.2)' : 'transparent', border: ent.storyState === 'locked' ? '1px solid #888' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'locked'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } },\n            { type: 'button', text: '🔥 Active', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'active' ? 'rgba(255,180,50,0.2)' : 'transparent', border: ent.storyState === 'active' ? '1px solid #ffb432' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'active'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } },\n            { type: 'button', text: '✅ Done', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: ent.storyState === 'completed' ? 'rgba(126,200,160,0.2)' : 'transparent', border: ent.storyState === 'completed' ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { ent.storyState = 'completed'; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } }\n        ]});\n\n        const narrativeNodes = allNodes.filter(function(n) { return n.type === 'narrative' && n.id !== ent.id; });\n        const narrParentName = ent.narrativeParentId ? (narrativeNodes.find(function(n) { return n.id === ent.narrativeParentId; })?.name || 'Unknown') : 'None (Root Plot)';\n        \n        parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '12px', backgroundColor: 'rgba(232, 168, 124, 0.05)', padding: '8px', borderRadius: '4px' }, content: [\n            { type: 'text', text: `Plot Parent: ${narrParentName}`, style: { fontSize: '11px', flex: '1 1 0', color: '#e8a87c', fontWeight: 'bold' } },\n            { type: 'button', text: 'Set Parent', style: { margin: 0, fontSize: '11px' }, callback: async function() {\n                const pm = await openEngineModal({ id: 'ce-nparent-picker', title: 'Nest Under Plotline', size: 'medium', content: [\n                    { type: 'button', text: '✕ None (Make Root Plot)', style: { width: '100%', marginBottom: '8px' }, callback: async function() { ent.narrativeParentId = null; await saveEntity(ent); pm.close(); await openEntityEditModal(ent.id); await refreshSidebar(); } },\n                    ...narrativeNodes.map(function(m) { return { type: 'button', text: `📜 ${m.name}`, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() { ent.narrativeParentId = m.id; await saveEntity(ent); pm.close(); await openEntityEditModal(ent.id); await refreshSidebar(); } } as UIPart; })\n                ]});\n            }}\n        ]});\n\n        // --- QUEST TARGET ---\n        const allEntForTarget = await loadEntityIndex();\n        const qtMeta = ent.questTarget ? allEntForTarget.find(function(m) { return m.id === ent.questTarget; }) : null;\n        const qtDisplay = qtMeta ? (ENTITY_TYPE_ICONS[qtMeta.type] || '●') + ' ' + qtMeta.name : 'None set';\n        parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px', padding: '8px', backgroundColor: 'rgba(136,204,255,0.05)', borderRadius: '4px', border: '1px solid rgba(136,204,255,0.1)' }, content: [\n            { type: 'text', text: '🎯 Quest Target:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n            { type: 'text', text: qtDisplay, style: { flex: '1 1 0', fontSize: '12px', color: qtMeta ? '#88ccff' : '#888' } },\n            ...(ent.questTarget ? [{ type: 'button', text: '✕', style: { margin: 0, padding: '2px 8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() {\n                const fe = await loadEntity(ent.id); if (!fe) return;\n                fe.questTarget = ''; await saveEntity(fe); await openEntityEditModal(ent.id);\n            } } as UIPart] : []),\n            { type: 'button', text: 'Set', style: { margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.08)', color: '#88ccff' }, callback: async function() {\n                await api.v1.tempStorage.set('temp:ce_qt_search', '');\n                async function drawQtPicker(pm3: any) {\n                    const term3 = ((await api.v1.tempStorage.getOrDefault('temp:ce_qt_search', '')) as string).toLowerCase();\n                    const pickable3 = allEntForTarget.filter(function(m) { return m.id !== ent.id && (!term3 || m.name.toLowerCase().includes(term3)); });\n                    const content3: UIPart[] = [\n                        { type: 'textInput', placeholder: '🔍 Search all entities...', initialValue: term3, onChange: async function(v: string) { await api.v1.tempStorage.set('temp:ce_qt_search', v); await drawQtPicker(pm3); } } as UIPart,\n                        ...pickable3.map(function(m) { return { type: 'button', text: (ENTITY_TYPE_ICONS[m.type] || '●') + ' ' + m.name, style: { width: '100%', marginBottom: '2px', textAlign: 'left' }, callback: async function() {\n                            pm3.close();\n                            const fe3 = await loadEntity(ent.id); if (!fe3) return;\n                            fe3.questTarget = m.id; await saveEntity(fe3); await openEntityEditModal(ent.id);\n                        } } as UIPart; })\n                    ];\n                    if (pm3 && !pm3.isClosed()) { await pm3.update({ content: content3 }); }\n                    else { pm3 = await openEngineModal({ id: 'ce-qt-picker', title: 'Set Quest Target', size: 'medium', content: content3 }); }\n                }\n                let pm3: any = null;\n                await drawQtPicker(pm3);\n            } }\n        ] });\n    }\n\n    // --- 1. CORE DESCRIPTION ---\n    let coreParts: UIPart[] = [];\n    const parentName = ent.parentId ? (allNodes.find(function(m){ return m.id === ent.parentId; })?.name || 'Unknown') : 'None (Root Level)';\n    \n    coreParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '12px', backgroundColor: 'rgba(255,255,255,0.05)', padding: '8px', borderRadius: '4px' }, content: [\n        { type: 'text', text: 'Parent:', style: { fontSize: '12px', fontWeight: 'bold' } },\n        { type: 'button', text: '❓', style: { margin: 0, padding: '2px 8px', fontSize: '11px', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.2)', opacity: '0.7' }, callback: async function() {\n            await api.v1.ui.modal.open({ \n                title: 'About Parents & Children', size: 'small', \n                content: [ { type: 'text', markdown: true, text: 'The Engine uses a strict parent/child hierarchy.\\n\\n- **Locations**: If a Room is parented to a Building, entering the Room automatically moves the player down the tree.\\n- **Items/Characters**: Assigning a location as a parent places them inside that location.' } ] \n            });\n        } },\n        { type: 'button', text: parentName, style: { margin: 0, fontSize: '11px', flex: '1 1 0' }, callback: async function() {\n            await openPickerModal({\n                title: 'Nest Under Entity',\n                items: allNodes.filter(function(m) { return m.id !== ent.id; }),\n                getId: function(m) { return m.id; },\n                getLabel: function(m) { return m.name; },\n                getIcon: function(m) { return m.icon || '\\ud83d\\udccd'; },\n                getSublabel: function(m) { return m.type; },\n                selectedId: ent.parentId || undefined,\n                searchable: true,\n                pinnedOptions: [\n                    { id: '__none__', label: 'None (Make Root Level)', icon: '\\u2715', onSelect: async function() { ent.parentId = null; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); } }\n                ],\n                onSelect: async function(m) { ent.parentId = m.id; await saveEntity(ent); await openEntityEditModal(ent.id); await refreshSidebar(); }\n            });\n        } }\n    ] });\n\n    if (ent.type === 'item') {\n        coreParts.push({ \n            type: 'checkboxInput', \n            label: '🎒 Equipped to Parent (Targetable State)', \n            initialValue: !!(ent as any).isEquipped, \n            onChange: async function(val: boolean) { \n                const fe = await loadEntity(ent.id);\n                if (!fe) return;\n                \n                (fe as any).isEquipped = val;\n                (fe as any).equippedToCharId = (val && fe.parentId) ? fe.parentId : null;\n                await saveEntity(fe); \n                \n                // Cross-sync equippedItemIds to the parent\n                if (fe.parentId) {\n                    let parentChar = await loadCharacter(fe.parentId).catch(() => null);\n                    if (parentChar) {\n                        if (!parentChar.equippedItemIds) parentChar.equippedItemIds = [];\n                        if (val && !parentChar.equippedItemIds.includes(fe.id)) parentChar.equippedItemIds.push(fe.id);\n                        if (!val) parentChar.equippedItemIds = parentChar.equippedItemIds.filter(function(i: string) { return i !== fe.id; });\n                        await saveCharacter(parentChar);\n                    } else {\n                        // Fallback in case items are parented to non-character entities\n                        let parentEnt = await loadEntity(fe.parentId).catch(() => null);\n                        if (parentEnt) {\n                            if (!(parentEnt as any).equippedItemIds) (parentEnt as any).equippedItemIds = [];\n                            if (val && !(parentEnt as any).equippedItemIds.includes(fe.id)) (parentEnt as any).equippedItemIds.push(fe.id);\n                            if (!val) (parentEnt as any).equippedItemIds = (parentEnt as any).equippedItemIds.filter(function(i: string) { return i !== fe.id; });\n                            await saveEntity(parentEnt);\n                        }\n                    }\n                }\n            } \n        });\n    }\n\n    // --- SILENT TOGGLE (top-level, no header) ---\n    parts.push({ type: 'checkboxInput', label: '🔕 Silent Interaction (does not trigger AI)', initialValue: !!(ent as any).isSilent, onChange: async function(val: boolean) { (ent as any).isSilent = val; await saveEntity(ent); } });\n    if (ent.type === 'location') {\n        parts.push({ type: 'checkboxInput', label: '🚀 Vehicle — Can be piloted, moving all children with it', initialValue: !!(ent as any).isVehicle, onChange: async function(val: boolean) { (ent as any).isVehicle = val; await saveEntity(ent); } });\n    }\n\n    coreParts.push({ type: 'multilineTextInput', label: 'Description', initialValue: ent.description, style: { minHeight: '80px' }, onChange: async function(val) { ent.description = val; await saveEntity(ent); } });\n    if (ent.type === 'location') {\n        coreParts.push({ type: 'text', text: 'Brief description that exists in AN if present.', style: { fontSize: '10px', opacity: '0.6', marginTop: '2px', marginBottom: '8px' } });\n        coreParts.push({ type: 'multilineTextInput', label: '🎨 Location Visuals', placeholder: 'Image tags for how this place looks (e.g. \"stone tavern interior, fireplace, wooden beams\"). Used by image generations specific to this location.', initialValue: (ent as any).locationVisuals || '', style: { minHeight: '50px' }, onChange: async function(val: string) { (ent as any).locationVisuals = val; await saveEntity(ent); } });\n    } else if (ent.type === 'item') {\n        coreParts.push({ type: 'text', text: 'Item names are listed under Equipped character in AN. Item descriptions are added to Equipped character lorebooks. Unequipping removes from lorebook.', style: { fontSize: '10px', opacity: '0.6', marginTop: '2px', marginBottom: '8px' } });\n    }\n\n    parts.push({ type: 'collapsibleSection', title: '📝 Core Details', initialCollapsed: false, storageKey: `temp:ce_core_${ent.id}`, content: coreParts });\n\n    // [WP-1] ENTITY LOREBOOK\n    if (ent.type !== 'character') {\n        const loreParts: UIPart[] = [];\n        const loreLinked = !!ent.lorebookEntryId;\n        loreParts.push({ type: 'multilineTextInput', label: '📖 Lorebook Entry', placeholder: 'Extended info NOT already in the description — history, secrets, rules, reputation. Injected only when the name or an added key is mentioned (Sync after editing).', initialValue: ent.lorebookText || '', style: { minHeight: '70px' }, onChange: async function(val: string) { ent.lorebookText = val; await saveEntity(ent); } });\n        loreParts.push({ type: 'text', text: loreLinked ? '✅ Linked — injects when a key below appears in the story.' : 'Not linked. Create an entry to inject this entity into context when its name (or a key) appears.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '6px' } });\n        loreParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n            { type: 'button', text: loreLinked ? '🔄 Sync' : '➕ Create Lorebook', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { if (ent.lorebookEntryId) { await syncEntityLorebookEntry(ent.id); } else { await createLinkedEntityLorebookEntry(ent.id); } await openEntityEditModal(ent.id); } }\n        ].concat(loreLinked ? [{ type: 'button', text: '🔗 Unlink', style: { margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() { await unlinkEntityLorebookEntry(ent.id); await openEntityEditModal(ent.id); } } as UIPart] : []) });\n        loreParts.push({ type: 'text', text: '🔑 Keys: ' + [ent.name].concat(ent.lorebookTags || []).join(', '), style: { fontSize: '11px', opacity: '0.8', marginBottom: '4px' } });\n        (ent.lorebookTags || []).forEach(function(tg, ti) {\n            const captTi = ti;\n            loreParts.push({ type: 'row', alignment: 'center', style: { gap: '4px' }, content: [\n                { type: 'text', text: '• ' + tg, style: { fontSize: '11px', flex: '1 1 0' } },\n                { type: 'button', text: '✕', style: { margin: 0, padding: '2px 6px', fontSize: '10px', color: '#ff6b6b', backgroundColor: 'transparent' }, callback: async function() { let fe = await loadEntity(ent.id); if (!fe) return; fe.lorebookTags = (fe.lorebookTags || []).filter(function(_t, i) { return i !== captTi; }); await saveEntity(fe); if (fe.lorebookEntryId) await syncEntityLorebookEntry(fe.id, true); await openEntityEditModal(fe.id); } }\n            ] });\n        });\n        loreParts.push({ type: 'button', text: '+ Add Key', style: { margin: '4px 0 0 0', fontSize: '11px', width: '100%' }, callback: async function() {\n            let addModal: any; let pending = '';\n            addModal = await openEngineModal({ id: 'ae-lore-key-add', title: 'Add Lorebook Key', size: 'small', content: [\n                { type: 'text', text: 'Extra trigger word or phrase. The entity name is always a key.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '6px' } },\n                { type: 'textInput', placeholder: 'e.g. the old mill', initialValue: '', onChange: function(v: string) { pending = v; } },\n                { type: 'button', text: 'Add', style: { width: '100%', marginTop: '6px' }, callback: async function() { let t = (pending || '').trim(); if (t) { let fe = await loadEntity(ent.id); if (fe) { if (!fe.lorebookTags) fe.lorebookTags = []; if (fe.lorebookTags.indexOf(t) < 0) fe.lorebookTags.push(t); await saveEntity(fe); if (fe.lorebookEntryId) await syncEntityLorebookEntry(fe.id, true); } } await addModal.close(); await openEntityEditModal(ent.id); } }\n            ] });\n        } });\n        parts.push({ type: 'collapsibleSection', title: '📖 Lorebook', initialCollapsed: true, storageKey: `temp:ce_lore_${ent.id}`, content: loreParts });\n    }\n    \n    // --- MERGED DYNAMIC DETAILS & STATE OVERRIDES ---\n    const attrParts: UIPart[] = [];\n    if (ent.type === 'location' || ent.type === 'narrative' || ent.type === 'item') {\n        attrParts.push({ type: 'textInput', label: 'Default State', placeholder: 'Baseline condition shown in context — changes on triggers (flooded, broken, sold) or just sets the mood', initialValue: ent.atmosphere || '', onChange: async function(val: string) { ent.atmosphere = val; await saveEntity(ent); } });\n        attrParts.push({ type: 'text', text: 'This text is added below the description and can be switched out with other text by actions, such as flooding or changing ownership.', style: { fontSize: '10px', opacity: '0.6', marginTop: '2px', marginBottom: '12px' } });\n\n        const overrideKeys = Object.keys(ent.stateDescriptions || {}).filter(function(k) { return k !== 'default'; });\n        const isDefaultActive = !ent.state || ent.state === 'default';\n\n        attrParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '10px', padding: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '6px' }, content: [\n            { type: 'text', text: 'Active:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n            { type: 'button', \n              text: isDefaultActive ? '⬜ Default State' : ent.state, \n              style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: isDefaultActive ? 'rgba(255,255,255,0.05)' : 'rgba(232,168,124,0.15)', color: isDefaultActive ? undefined : '#e8a87c', border: isDefaultActive ? '1px solid rgba(255,255,255,0.1)' : '1px solid rgba(232,168,124,0.4)' }, \n              callback: async function() {\n                const freshEnt = await loadEntity(ent.id); if (!freshEnt) return;\n                const freshKeys = Object.keys(freshEnt.stateDescriptions || {}).filter(function(k) { return k !== 'default'; });\n                const pm = await openEngineModal({ title: 'Set Active State', size: 'small', content: [\n                    { type: 'button', text: '⬜ Default State', style: { width: '100%', marginBottom: '6px', textAlign: 'left', backgroundColor: (!freshEnt.state || freshEnt.state === 'default') ? 'rgba(126,200,160,0.15)' : undefined, color: (!freshEnt.state || freshEnt.state === 'default') ? '#7ec8a0' : undefined }, callback: async function() { freshEnt.state = 'default'; await saveEntity(freshEnt); pm.close(); await openEntityEditModal(ent.id); } },\n                    ...freshKeys.map(function(sk) {\n                        const isActive = freshEnt.state === sk;\n                        return { type: 'button', text: sk, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: isActive ? 'rgba(232,168,124,0.15)' : undefined, color: isActive ? '#e8a87c' : undefined }, callback: async function() { freshEnt.state = sk; await saveEntity(freshEnt); pm.close(); await openEntityEditModal(ent.id); } } as UIPart;\n                    })\n                ]});\n            } }\n        ] });\n\n        if (overrideKeys.length === 0) {\n            attrParts.push({ type: 'text', text: 'No overrides defined. Default State is always active.', style: { fontSize: '11px', opacity: '0.45', marginBottom: '6px' } });\n        }\n\n        for (let oi = 0; oi < overrideKeys.length; oi++) {\n            const sk = overrideKeys[oi];\n            const sd = ent.stateDescriptions[sk] || '';\n            const isActive = ent.state === sk;\n            const captKey = sk;\n\n            attrParts.push({ type: 'box', style: { padding: '8px', marginBottom: '8px', backgroundColor: isActive ? 'rgba(232,168,124,0.06)' : 'rgba(255,255,255,0.02)', borderRadius: '6px', borderLeft: isActive ? '3px solid #e8a87c' : '3px solid rgba(255,255,255,0.08)' }, content: [\n                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n                    { type: 'textInput', \n                      placeholder: 'State name (e.g. flooded, night, ruined)...', \n                      initialValue: sk, \n                      style: { flex: '1 1 0', fontSize: '12px', fontWeight: isActive ? 'bold' : 'normal' }, \n                      onChange: async function(v: string) {\n                        const newKey = v.trim();\n                        if (!newKey || newKey === captKey) return;\n                        const txt = ent.stateDescriptions[captKey];\n                        delete ent.stateDescriptions[captKey];\n                        ent.stateDescriptions[newKey] = txt || '';\n                        if (ent.state === captKey) ent.state = newKey;\n                        await saveEntity(ent); await openEntityEditModal(ent.id);\n                      } },\n                    isActive\n                        ? { type: 'text', text: '● Active', style: { fontSize: '10px', color: '#e8a87c', flexShrink: '0', opacity: '0.8' } } as UIPart\n                        : { type: 'button', text: 'Set Active', style: { margin: 0, fontSize: '10px', flexShrink: '0' }, callback: async function() { ent.state = captKey; await saveEntity(ent); await openEntityEditModal(ent.id); } } as UIPart,\n                    { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() {\n                        delete ent.stateDescriptions[captKey];\n                        if (ent.state === captKey) ent.state = 'default';\n                        await saveEntity(ent); await openEntityEditModal(ent.id);\n                    } }\n                ] },\n                { type: 'multilineTextInput', \n                  placeholder: 'Atmosphere text when this state is active...', \n                  initialValue: sd, \n                  style: { minHeight: '44px', fontSize: '11px' }, \n                  onChange: async function(v: string) { ent.stateDescriptions[captKey] = v; await saveEntity(ent); } }\n            ] });\n        }\n\n        attrParts.push({ type: 'button', text: '+ State Override', style: { marginTop: '2px', fontSize: '11px', width: '100%', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {\n            const freshEnt = await loadEntity(ent.id); if (!freshEnt) return;\n            let newKey = 'override';\n            let n = 1;\n            while (freshEnt.stateDescriptions[newKey]) { newKey = 'override-' + n; n++; }\n            freshEnt.stateDescriptions[newKey] = '';\n            await saveEntity(freshEnt); await openEntityEditModal(ent.id);\n        } });\n    }\n\n    if (attrParts.length > 0) {\n        parts.push({ type: 'collapsibleSection', title: '✨ Dynamic Details', initialCollapsed: true, storageKey: `temp:ce_attr_${ent.id}`, content: attrParts });\n    }\n\n    // [WP-5] 🎬 Action Studio\n    const aeInsts = (((ent as any).actionInstances || []) as ActionInstance[]);\n    const aeInstParts: UIPart[] = [];\n    // [v0.9.17] Preload one-shot latch states so the list can show used/ready + Reset.\n    let aeOneShotUsed: Record<string, boolean> = {};\n    for (const _osInst of aeInsts) {\n        if (_osInst.oneShot) aeOneShotUsed[_osInst.id] = await api.v1.historyStorage.getOrDefault('ae_inst_1shot_' + ent.id + '_' + _osInst.id, false) as boolean;\n    }\n    aeInsts.forEach(function(inst) {\n        let osIsUsed = !!aeOneShotUsed[inst.id];\n        let aeRowKids: UIPart[] = [\n            { type: 'text', text: (inst.name || 'Action') + (inst.resolution ? ' \\ud83c\\udfb2' : '') + (inst.targetMode === 'player_pick' ? ' \\ud83c\\udfaf' : '') + (inst.oneShot ? (osIsUsed ? ' \\u2014 \\u2713 used' : ' \\u2014 \\u26ab one-shot') : ''), style: { flex: '1', fontSize: '12px', fontWeight: 'bold', opacity: (inst.oneShot && osIsUsed) ? '0.55' : '1' } },\n            { type: 'button', text: '\\u25b6 Test', style: { margin: 0, padding: '2px 6px', fontSize: '10px', backgroundColor: 'rgba(126,200,160,0.2)' }, callback: async function() {\n                let feR = await loadEntity(ent.id); let fcR = await loadConfig(); if (!feR) return;\n                let fiR = (((feR as any).actionInstances || []) as ActionInstance[]).find(function(x) { return x.id === inst.id; });\n                if (!fiR) return;\n                await runActionInstance(fiR, feR, fcR, {});\n            } }\n        ];\n        if (inst.oneShot) {\n            aeRowKids.push({ type: 'button', text: osIsUsed ? '\\u21ba Reset' : 'ready', style: { margin: 0, padding: '2px 6px', fontSize: '10px', backgroundColor: osIsUsed ? 'rgba(232,168,124,0.22)' : 'rgba(255,255,255,0.05)', opacity: osIsUsed ? '1' : '0.55' }, callback: async function() {\n                if (!osIsUsed) { api.v1.ui.toast('One-shot hasn\\u2019t fired yet.', { type: 'info', autoClose: 1400 }); return; }\n                await api.v1.historyStorage.set('ae_inst_1shot_' + ent.id + '_' + inst.id, false);\n                api.v1.ui.toast('\\u21ba Reset: ' + (inst.name || 'Action'), { type: 'success', autoClose: 1500 });\n                await openEntityEditModal(ent.id);\n            } });\n        }\n        aeRowKids.push({ type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px', color: '#ff6b6b' }, callback: async function() {\n            let feD = await loadEntity(ent.id); if (!feD) return;\n            (feD as any).actionInstances = (((feD as any).actionInstances || []) as ActionInstance[]).filter(function(x) { return x.id !== inst.id; });\n            await saveEntity(feD); await openEntityEditModal(ent.id);\n        } });\n        aeInstParts.push({ type: 'row', spacing: 'space-between', alignment: 'center', style: { gap: '6px', marginBottom: '4px', borderBottom: '1px solid rgba(255,255,255,0.08)', paddingBottom: '4px' }, content: aeRowKids });\n    });\n    if (aeInsts.length === 0) aeInstParts.push({ type: 'text', text: 'No actions yet. Add from Library or create a new one.', style: { fontSize: '11px', opacity: '0.45' } });\n    \n    aeInstParts.push({ type: 'row', style: { gap: '6px', marginTop: '6px' }, content: [\n        { type: 'button', text: '\\ud83d\\udcda + Action Library', style: { flex: '1 1 0', fontSize: '11px', margin: 0, backgroundColor: 'rgba(136,204,255,0.12)' }, callback: async function() {\n            let lc = await loadConfig();\n            let templates = (((lc as any).actionTemplates || []) as ActionInstance[]);\n            let applicable = templates.filter(function(t) { return !t.appliesTo || !t.appliesTo.length || t.appliesTo.indexOf(ent.type) >= 0; });\n            if (!applicable.length) { api.v1.ui.toast('No library actions yet — create one in the Actions tab.', { type: 'info' }); return; }\n            let pickItems: PickItem[] = applicable.map(function(t) { return { id: t.id, label: (t.name || 'Action') + (((t as any).tags && (t as any).tags.length) ? '  🏷 ' + (t as any).tags.join(', ') : '') }; });\n            await openSearchPicker('Copy from Action Library', pickItems, async function(tid) {\n                let t = applicable.find(function(x) { return x.id === tid; }); if (!t) return;\n                let feC = await loadEntity(ent.id); if (!feC) return;\n                let copy = JSON.parse(JSON.stringify(t)) as ActionInstance;\n                copy.id = generateId();\n                copy.templateId = t.id;\n                (copy.conditions || []).forEach(function(r) { r.id = generateId(); });\n                (copy.successEffects || []).forEach(function(r) { r.id = generateId(); });\n                (copy.failureEffects || []).forEach(function(r) { r.id = generateId(); });\n                ((copy as any).alwaysEffects || []).forEach(function(r: AERule) { r.id = generateId(); });\n                if (!(feC as any).actionInstances) (feC as any).actionInstances = [];\n                (feC as any).actionInstances.push(copy);\n                await saveEntity(feC); await openEntityEditModal(ent.id);\n            });\n        } }\n    ] });\n\n    // [v0.9.86] Tag Subscriptions — live-resolved from library; no copies made.\n    // Hides _system / _travel tags (internal plumbing the user shouldn't touch).\n    const _tsAllTags: string[] = [];\n    const _tsCfg = cfg;\n    const _tsTplsAll = ((_tsCfg.actionTemplates || []) as ActionInstance[]);\n    const _tsApplicable = _tsTplsAll.filter(function(t) {\n        if (t.appliesTo && t.appliesTo.length && t.appliesTo.indexOf(ent.type) < 0) return false;\n        return true;\n    });\n    for (const _tsTpl of _tsApplicable) {\n        for (const _tsTag of ((_tsTpl as any).tags || [])) {\n            if (typeof _tsTag === 'string' && !_tsTag.startsWith('_') && _tsAllTags.indexOf(_tsTag) < 0) {\n                _tsAllTags.push(_tsTag);\n            }\n        }\n    }\n    _tsAllTags.sort();\n\n    if (_tsAllTags.length > 0) {\n        const _tsSubs: string[] = (ent as any).tagSubscriptions || [];\n        const _tsRows: UIPart[] = [\n            { type: 'text', text: 'Check a tag to auto-include all matching library actions on this entity. Actions are resolved live — no copy is made.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '6px' } }\n        ];\n        for (const _tsTag of _tsAllTags) {\n            const captTag = _tsTag;\n            const matchCount = _tsApplicable.filter(function(t) { return ((t as any).tags || []).indexOf(captTag) >= 0; }).length;\n            const isSubbed = _tsSubs.indexOf(captTag) >= 0;\n            _tsRows.push({\n                type: 'checkboxInput',\n                label: captTag + '  (' + matchCount + ' action' + (matchCount === 1 ? '' : 's') + ')',\n                initialValue: isSubbed,\n                onChange: async function(v: boolean) {\n                    let _tsFreshEnt = await loadEntity(ent.id); if (!_tsFreshEnt) return;\n                    let _tsArr: string[] = ((_tsFreshEnt as any).tagSubscriptions || []).slice();\n                    if (v) { if (_tsArr.indexOf(captTag) < 0) _tsArr.push(captTag); }\n                    else   { _tsArr = _tsArr.filter(function(x) { return x !== captTag; }); }\n                    (_tsFreshEnt as any).tagSubscriptions = _tsArr;\n                    await saveEntity(_tsFreshEnt);\n                    await openEntityEditModal(ent.id);\n                }\n            } as UIPart);\n        }\n        aeInstParts.push({ type: 'collapsibleSection', title: '\\ud83c\\udff7 Tag Subscriptions (' + _tsSubs.filter(function(s) { return _tsAllTags.indexOf(s) >= 0; }).length + ' active)', initialCollapsed: true, storageKey: 'temp:ce_tagsubs_' + ent.id, content: _tsRows });\n    }\n    \n    parts.push({ type: 'collapsibleSection', title: '\\ud83c\\udfac Action Studio (' + aeInsts.length + ')', initialCollapsed: true, storageKey: 'temp:ce_actinst_' + ent.id, content: aeInstParts });\n\n    // --- 4. CONNECTIONS ---\n    const implicitRows: UIPart[] = [];\n    if (ent.parentId) { \n        const pMeta = allNodes.find(function(m) { return m.id === ent.parentId; }); \n        if (pMeta) implicitRows.push({ type: 'text', text: `↑ Go back to ${pMeta.name} (Parent)`, style: { fontSize: '11px', opacity: '0.6', marginLeft: '8px', marginBottom: '2px' } }); \n    }\n    const children = allNodes.filter(function(m) { return m.parentId === ent.id; });\n    for (const child of children) {\n        const captChild = child;\n        const childEntForGate = await loadEntity(child.id);\n        const childIsGated = !!(childEntForGate as any)?.gated;\n        // [v1.6.3 LOCK-SELF] The lock control now lives on each location's OWN modal\n        // (self-lock toggle at the top of this section). Here we keep only a read-only\n        // indicator so the parent view still flags which children are currently locked.\n        implicitRows.push({ type: 'text', text: (childIsGated ? '🔒 ' : '↓ ') + 'Enter ' + captChild.name + ' (Child)' + (childIsGated ? ' — locked' : ''), style: { fontSize: '11px', opacity: '0.7', marginLeft: '8px', marginBottom: '2px' } });\n    }\n    \n    let connParts: UIPart[] = [\n        // [v1.6.3 LOCK-SELF] Self-lock lives on the location itself and gates travel in\n        // BOTH directions (the entity_locked guard checks the target's own .gated, so a\n        // locked location can't be entered from a parent, child, or sibling).\n        ...(ent.type === 'location' ? [{ type: 'row', alignment: 'center', style: { gap: '8px', marginTop: '2px', marginBottom: '8px', padding: '6px 8px', borderRadius: '6px', backgroundColor: (ent as any).gated ? 'rgba(255,85,85,0.10)' : 'rgba(255,255,255,0.03)', border: '1px solid ' + ((ent as any).gated ? 'rgba(255,85,85,0.35)' : 'rgba(255,255,255,0.12)') }, content: [\n            { type: 'text', text: ((ent as any).gated ? '🔒' : '🔓') + ' Lock this location', style: { fontSize: '12px', fontWeight: 'bold', flex: '1 1 0' } },\n            { type: 'checkboxInput', label: 'Locked (blocks travel in & out)', initialValue: !!(ent as any).gated, onChange: async function(v: boolean) {\n                const slfEnt = await loadEntity(ent.id); if (!slfEnt) return;\n                (slfEnt as any).gated = v; await saveEntity(slfEnt); queueSceneStateBroadcast(); await openEntityEditModal(ent.id);\n            } }\n        ] } as UIPart] : []),\n        { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '4px', marginBottom: '2px' }, content: [\n            { type: 'button', text: ent.entryActionId ? '⚙ Entry Action' : '+ Entry Action', style: { flex: '1 1 0', margin: 0, fontSize: '10px', padding: '3px 6px', backgroundColor: ent.entryActionId ? 'rgba(136,204,255,0.1)' : 'transparent', border: '1px solid rgba(255,255,255,0.18)' }, callback: async function() {\n                let eaCEnt = await loadEntity(ent.id); if (!eaCEnt) return;\n                let eaCfg  = await loadConfig();\n                let eaId = (eaCEnt as any).entryActionId as string | undefined;\n                if (!eaId || !(eaCfg.actionTemplates || []).find(function(t: any) { return t.id === eaId; })) {\n                    eaId = generateId();\n                    let sysDef = (eaCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });\n                    const eaNew: any = sysDef ? JSON.parse(JSON.stringify(sysDef)) : { id: eaId, name: 'Enter: ' + ent.name, tags: ['_travel'], conditions: [], successEffects: [], failureEffects: [], alwaysEffects: [], hidden: true };\n                    eaNew.id = eaId;\n                    eaNew.name = 'Enter: ' + ent.name;\n                    eaNew.tags = ['_travel'];\n                    eaNew.hidden = true;\n                    if (!eaCfg.actionTemplates) eaCfg.actionTemplates = [];\n                    eaCfg.actionTemplates.push(eaNew);\n                    await saveConfig(eaCfg);\n                    (eaCEnt as any).entryActionId = eaId;\n                    await saveEntity(eaCEnt);\n                }\n                await openActionBuilderModal(eaId);\n            } },\n            ...(ent.entryActionId ? [{ type: 'button', iconId: 'trash', style: { margin: 0, padding: '3px 6px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.2)' }, callback: async function() {\n                let rEnt = await loadEntity(ent.id); if (!rEnt) return;\n                let oldId = (rEnt as any).entryActionId;\n                (rEnt as any).entryActionId = undefined;\n                await saveEntity(rEnt);\n                if (oldId) {\n                    let ecfg = await loadConfig();\n                    if (ecfg.actionTemplates) {\n                        ecfg.actionTemplates = ecfg.actionTemplates.filter(function(t: any) { return t.id !== oldId; });\n                        await saveConfig(ecfg);\n                    }\n                }\n                await openEntityEditModal(ent.id);\n            } } as UIPart] : [])\n        ] },\n        { type: 'text', text: 'Resource required to travel downward in map to location', style: { fontSize: '10px', opacity: '0.6', marginLeft: '6px', marginBottom: '10px' } },\n        { type: 'box', style: { marginBottom: '12px', padding: '6px', backgroundColor: 'rgba(255,255,255,0.02)', borderRadius: '4px' }, content: [\n            { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                { type: 'text', text: 'Implicit Tree Connections:', style: { fontSize: '11px', fontWeight: 'bold' } },\n                { type: 'button', text: '❓', style: { margin: 0, padding: '2px 6px', fontSize: '10px', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.2)', opacity: '0.7' }, callback: async function() {\n                    await api.v1.ui.modal.open({ title: 'Implicit vs Explicit Connections', size: 'medium', content: [ { type: 'text', markdown: true, text: 'The engine automatically creates **Implicit** \"Up\" and \"Down\" connections based on parents and children (e.g., moving from the House down to the Bedroom).\\n\\n**Explicit** Connections are custom travel routes to entities that aren\\'t strictly parents/children (e.g., a teleporter or road).' } ] });\n                } }\n            ] },\n            ...(implicitRows.length > 0 ? implicitRows : [{ type: 'text', text: 'No parent or children.', style: { fontSize: '11px', opacity: '0.4', marginLeft: '8px', marginBottom: '2px' } } as UIPart])\n        ]}\n    ];\n\n    ent.connectedEntityIds.filter(Boolean).forEach(function(conn, i) {\n        const targetMeta = allNodes.find(function(m) { return m.id === conn.targetId; });\n        const targetName = targetMeta?.name || `Unknown (${conn.targetId.substring(0, 8)})`; \n        \n        connParts.push({ type: 'box', style: { padding: '8px', backgroundColor: 'rgba(255,255,255,0.05)', marginBottom: '4px' }, content: [\n            { type: 'textInput', label: `→ ${targetName} Label`, initialValue: conn.label, placeholder: 'e.g. \"Head to the market\"', onChange: async function(v: string) { ent.connectedEntityIds[i].label = v; await saveEntity(ent); } },\n            { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '4px', marginBottom: '4px' }, content: [\n                { type: 'checkboxInput', label: 'Requires Vehicle', initialValue: !!conn.requiresVehicle, onChange: async function(val: boolean) { let fe = await loadEntity(ent.id); if (!fe) return; fe.connectedEntityIds[i].requiresVehicle = val; await saveEntity(fe); } }\n            ] },\n            \n            { type: 'checkboxInput', label: '🔕 Silent Travel (No text/AI gen)', initialValue: !!conn.isSilent, onChange: async function(val) { ent.connectedEntityIds[i].isSilent = val; await saveEntity(ent); } },\n\n            { type: 'row', alignment: 'center', style: { gap: '4px', marginTop: '6px' }, content: [\n                { type: 'button', text: conn.travelActionId ? '⚙ Travel Action' : '+ Travel Action', style: { flex: '1 1 0', margin: 0, fontSize: '10px', padding: '3px 6px', backgroundColor: conn.travelActionId ? 'rgba(136,204,255,0.1)' : 'transparent', border: '1px solid rgba(255,255,255,0.18)' }, callback: async function() {\n                    let taCEnt = await loadEntity(ent.id); if (!taCEnt) return;\n                    let taCfg  = await loadConfig();\n                    let taConnIdx = taCEnt.connectedEntityIds.findIndex(function(c) { return c.targetId === conn.targetId; });\n                    if (taConnIdx < 0) return;\n                    let taId = (taCEnt.connectedEntityIds[taConnIdx] as any).travelActionId as string | undefined;\n                    if (!taId || !(taCfg.actionTemplates || []).find(function(t: any) { return t.id === taId; })) {\n                        taId = generateId();\n                        let sysDef = (taCfg.actionTemplates || []).find(function(t: any) { return t.id === 'sys_default_travel'; });\n                        const taNew: any = sysDef ? JSON.parse(JSON.stringify(sysDef)) : { id: taId, name: 'Travel: ' + targetName, tags: ['_travel'], conditions: [], successEffects: [], failureEffects: [], alwaysEffects: [], hidden: true };\n                        taNew.id = taId;\n                        taNew.name = 'Travel: ' + targetName;\n                        taNew.tags = ['_travel'];\n                        taNew.hidden = true;\n                        if (!taCfg.actionTemplates) taCfg.actionTemplates = [];\n                        taCfg.actionTemplates.push(taNew);\n                        await saveConfig(taCfg);\n                        (taCEnt.connectedEntityIds[taConnIdx] as any).travelActionId = taId;\n                        await saveEntity(taCEnt);\n                    }\n                    await openActionBuilderModal(taId);\n                } },\n                ...(conn.travelActionId ? [{ type: 'button', iconId: 'trash', style: { margin: 0, padding: '3px 6px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.2)' }, callback: async function() {\n                    let rCEnt = await loadEntity(ent.id); if (!rCEnt) return;\n                    let rConnIdx = rCEnt.connectedEntityIds.findIndex(function(c) { return c.targetId === conn.targetId; });\n                    if (rConnIdx >= 0) {\n                        let oldId = (rCEnt.connectedEntityIds[rConnIdx] as any).travelActionId;\n                        (rCEnt.connectedEntityIds[rConnIdx] as any).travelActionId = undefined;\n                        await saveEntity(rCEnt);\n                        if (oldId) {\n                            let ecfg2 = await loadConfig();\n                            if (ecfg2.actionTemplates) {\n                                ecfg2.actionTemplates = ecfg2.actionTemplates.filter(function(t: any) { return t.id !== oldId; });\n                                await saveConfig(ecfg2);\n                            }\n                        }\n                    }\n                    await openEntityEditModal(ent.id);\n                } } as UIPart] : []),\n                { type: 'button', text: !!(targetMeta as any)?.gated ? '🔒 Locked' : '🔓 Open', style: { margin: 0, fontSize: '10px', padding: '3px 8px', backgroundColor: !!(targetMeta as any)?.gated ? 'rgba(255,85,85,0.12)' : 'transparent', border: '1px solid rgba(255,255,255,0.18)' }, callback: async function() {\n                    let glEnt = await loadEntity(conn.targetId); if (!glEnt) return;\n                    (glEnt as any).gated = !(glEnt as any).gated; await saveEntity(glEnt); await openEntityEditModal(ent.id);\n                } }\n            ] },\n\n            { type: 'button', text: 'Remove', style: { color: '#ff6b6b', marginTop: '4px' }, callback: async function() { ent.connectedEntityIds.splice(i, 1); await saveEntity(ent); await openEntityEditModal(ent.id); } }\n        ] });\n    });\n\n    const existingTargetIds = new Set(ent.connectedEntityIds.map(function(c) { return c.targetId; }));\n    const pickableConns = allNodes.filter(function(m) { return m.id !== ent.id && !existingTargetIds.has(m.id); });\n    if (pickableConns.length > 0) {\n        connParts.push({ type: 'button', text: '+ Add Explicit Connection', style: { marginTop: '6px', fontSize: '11px' }, callback: async function() {\n            const pickerModal = await openEngineModal({ id: 'ce-conn-picker', size: 'medium', title: 'Pick Destination', content: [\n                ...pickableConns.map(function(m) { return { type: 'button', text: `📍 ${m.name}`, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() { pickerModal.close(); ent.connectedEntityIds.push({ targetId: m.id, label: `Go to ${m.name}`, resourceCost: 0 }); await saveEntity(ent); await openEntityEditModal(ent.id); } } as UIPart; })\n            ] });\n        } });\n    }\n    parts.push({ type: 'collapsibleSection', title: `🔗 Connections (${ent.connectedEntityIds.length})`, initialCollapsed: true, storageKey: `temp:ce_conn_${ent.id}`, content: connParts });\n    \n    // --- 5b. SKILL BONUSES (items only) ---\n    if (ent.type === 'item') {\n        const bonuses = ent.skillBonuses || [];\n        const bonusParts: UIPart[] = [];\n\n        bonusParts.push({ type: 'text', text: 'When equipped, adds these modifiers to matching skill rolls.', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });\n\n        if (bonuses.length === 0) {\n            bonusParts.push({ type: 'text', text: 'No bonuses defined.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '6px' } });\n        }\n\n        for (let bi = 0; bi < bonuses.length; bi++) {\n            const bonus = bonuses[bi];\n            const captBi = bi;\n            const matchedSkill = skillOptions.find(function(s) { return s.tag === bonus.skillTag; });\n            const skillLabel = matchedSkill ? matchedSkill.name : (bonus.skillTag || 'Pick Skill...');\n\n            bonusParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n                { type: 'button', text: skillLabel, style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left', backgroundColor: 'rgba(255,255,255,0.05)' }, callback: async function() {\n                    const pm = await openEngineModal({ title: 'Select Skill', size: 'small', content: [\n                        { type: 'button', text: '✕ Clear', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b' }, callback: async function() {\n                            const fe = await loadEntity(ent.id); if (!fe) return;\n                            fe.skillBonuses[captBi].skillTag = ''; await saveEntity(fe); pm.close(); await openEntityEditModal(ent.id);\n                        } },\n                        ...skillOptions.map(function(opt) {\n                            return { type: 'button', text: opt.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: bonus.skillTag === opt.tag ? 'rgba(136,204,255,0.15)' : undefined, color: bonus.skillTag === opt.tag ? '#88ccff' : undefined }, callback: async function() {\n                                const fe = await loadEntity(ent.id); if (!fe) return;\n                                fe.skillBonuses[captBi].skillTag = opt.tag; await saveEntity(fe); pm.close(); await openEntityEditModal(ent.id);\n                            } } as UIPart;\n                        })\n                    ]});\n                } },\n                { type: 'text', text: 'Mod:', style: { fontSize: '11px', opacity: '0.6', flexShrink: '0' } },\n                { type: 'textInput', initialValue: bonus.modifier.toString(), placeholder: '±0', style: { width: '50px', textAlign: 'center' }, onChange: async function(v: string) {\n                    const fe = await loadEntity(ent.id); if (!fe) return;\n                    const num = parseInt(v, 10);\n                    fe.skillBonuses[captBi].modifier = isNaN(num) ? 0 : num;\n                    await saveEntity(fe);\n                } },\n                { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() {\n                    const fe = await loadEntity(ent.id); if (!fe) return;\n                    fe.skillBonuses.splice(captBi, 1); await saveEntity(fe); await openEntityEditModal(ent.id);\n                } }\n            ] });\n        }\n\n        bonusParts.push({ type: 'button', text: '+ Add Skill Bonus', style: { marginTop: '2px', fontSize: '11px', width: '100%', backgroundColor: 'rgba(255,255,255,0.04)' }, callback: async function() {\n            const fe = await loadEntity(ent.id); if (!fe) return;\n            if (!fe.skillBonuses) fe.skillBonuses = [];\n            fe.skillBonuses.push({ skillTag: '', modifier: 1 });\n            await saveEntity(fe); await openEntityEditModal(ent.id);\n        } });\n\n        parts.push({ type: 'collapsibleSection', title: '⚔️ Skill Bonuses (' + bonuses.length + ')', initialCollapsed: bonuses.length === 0, storageKey: 'temp:ce_bonus_' + ent.id, content: bonusParts });\n    }\n    // --- 6. ENCOUNTERS --- [v0.9.25 E4] Removed — replaced by action system\n    // --- 6. CHARACTERS ---\n    const charIdx = await loadIndex();\n    const chars = await loadAllCharacters();\n    const presentChars = chars.filter(function(c) { return c.currentLocationId === ent.id; });\n    let charParts: UIPart[] = [];\n    // --- Present characters (read-only, auto-synced) ---\n    charParts.push({ type: 'text', text: 'Present (auto-synced from entity tree)', style: { fontWeight: 'bold', fontSize: '11px', opacity: '0.6', marginBottom: '4px' } });\n    if (presentChars.length === 0) {\n        charParts.push({ type: 'text', text: 'None currently.', style: { fontSize: '11px', opacity: '0.4' } });\n    } else {\n        presentChars.forEach(function(c) { charParts.push({ type: 'text', text: '• ' + c.name, style: { fontSize: '12px', marginLeft: '8px', marginBottom: '2px' } }); });\n    }\n\n    // --- Knowledge string (canonical truth for this entity) ---\n    charParts.push({ type: 'text', text: 'Knowledge String', style: { fontWeight: 'bold', fontSize: '12px', marginTop: '12px', marginBottom: '4px' } });\n    charParts.push({ type: 'text', text: 'This is the master knowledge text synced to any aware characters. Edit freely, then re-sync.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });\n    charParts.push({ type: 'multilineTextInput', storageKey: 'temp:ce_ks_' + ent.id,\n        initialValue: ent.knowledgeString || '',\n        onChange: async function(v: string) { const fe = await loadEntity(ent.id); if (fe) { fe.knowledgeString = v; await saveEntity(fe); } }\n    });\n    charParts.push({ type: 'row', style: { gap: '6px', marginTop: '6px' }, content: [\n        { type: 'button', text: '⟳ Build from Entity', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(255,255,255,0.05)' }, disabledWhileCallbackRunning: true, callback: async function() {\n            const built = await buildEntityKnowledgeString(ent.id);\n            const fe = await loadEntity(ent.id); if (!fe) return;\n            fe.knowledgeString = built; await saveEntity(fe);\n            api.v1.ui.toast('Knowledge string built.', { type: 'success', autoClose: 2000 });\n            await openEntityEditModal(ent.id);\n        } },\n        { type: 'button', text: '↺ Sync to All Aware', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.06)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n            const fe = await loadEntity(ent.id); if (!fe) return;\n            await syncEntityKnowledgeToAwareChars(fe);\n            api.v1.ui.toast('Synced to ' + (fe.awareCharacterIds || []).length + ' character(s).', { type: 'success', autoClose: 2500 });\n        } }\n    ] });\n\n    // --- Aware characters (knowledge recipients) ---\n    charParts.push({ type: 'text', text: 'Aware Characters (receive synced knowledge)', style: { fontWeight: 'bold', fontSize: '12px', marginTop: '12px', marginBottom: '4px' } });\n    // Search filter\n    const awareSearchKey = 'temp:ce_aware_search_' + ent.id;\n    const awareTerm = ((await api.v1.tempStorage.getOrDefault(awareSearchKey, '')) as string).toLowerCase();\n    if (ent.awareCharacterIds.length > 0) {\n        charParts.push({ type: 'textInput', placeholder: '🔍 Filter aware characters...', initialValue: awareTerm, onChange: async function(v: string) { await api.v1.tempStorage.set(awareSearchKey, v); await openEntityEditModal(ent.id); } });\n    }\n    const filteredAware = ent.awareCharacterIds.filter(Boolean).filter(function(charId) {\n        if (!awareTerm) return true;\n        const cMeta = charIdx.find(function(m) { return m.id === charId; });\n        return (cMeta?.name || '').toLowerCase().includes(awareTerm);\n    });\n    if (filteredAware.length === 0 && ent.awareCharacterIds.length === 0) {\n        charParts.push({ type: 'text', text: 'No aware characters yet.', style: { fontSize: '11px', opacity: '0.4', marginBottom: '4px' } });\n    }\n    filteredAware.forEach(function(charId) {\n        const cMeta = charIdx.find(function(m) { return m.id === charId; });\n        charParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n            { type: 'text', text: cMeta?.name || 'Unknown', style: { flex: '1 1 0', fontSize: '12px' } },\n            { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() {\n                const fe = await loadEntity(ent.id); if (!fe) return;\n                fe.awareCharacterIds = fe.awareCharacterIds.filter(function(id) { return id !== charId; });\n                await saveEntity(fe); await openEntityEditModal(ent.id);\n            } }\n        ] });\n    });\n    // Add aware character — searchable picker\n    charParts.push({ type: 'button', text: '+ Add Aware Character', style: { fontSize: '11px', marginTop: '4px', width: '100%' }, callback: async function() {\n        await api.v1.tempStorage.set('temp:ce_aap_search', '');\n        async function drawAwareAddPicker(pm2: any) {\n            const term2 = ((await api.v1.tempStorage.getOrDefault('temp:ce_aap_search', '')) as string).toLowerCase();\n            const pickable2 = charIdx.filter(function(m) { return !ent.awareCharacterIds.includes(m.id) && (!term2 || m.name.toLowerCase().includes(term2)); });\n            const content2: UIPart[] = [\n                { type: 'textInput', placeholder: '🔍 Search characters...', initialValue: term2, onChange: async function(v: string) { await api.v1.tempStorage.set('temp:ce_aap_search', v); await drawAwareAddPicker(pm2); } } as UIPart,\n                ...pickable2.map(function(m) { return { type: 'button', text: m.name, style: { width: '100%', marginBottom: '4px', textAlign: 'left' }, callback: async function() {\n                    pm2.close();\n                    const fe2 = await loadEntity(ent.id); if (!fe2) return;\n                    if (!fe2.awareCharacterIds.includes(m.id)) fe2.awareCharacterIds.push(m.id);\n                    // Auto-build string if empty\n                    if (!fe2.knowledgeString || !fe2.knowledgeString.trim()) {\n                        fe2.knowledgeString = await buildEntityKnowledgeString(fe2.id);\n                    }\n                    await saveEntity(fe2);\n                    // Push snapshot to the character\n                    const char2 = await loadCharacter(m.id); if (!char2) return;\n                    if (!char2.knownEntities) char2.knownEntities = [];\n                    const existing2 = char2.knownEntities.find(function(e) { return e.entityId === fe2.id; });\n                    if (!existing2) {\n                        char2.knownEntities.push({ id: generateId(), entityId: fe2.id, entityName: fe2.name, snapshot: fe2.knowledgeString, addedAt: Date.now() });\n                    }\n                    await saveCharacter(char2);\n                    await openEntityEditModal(ent.id);\n                } } as UIPart; })\n            ];\n            if (pm2 && !pm2.isClosed()) { await pm2.update({ content: content2 }); }\n            else { pm2 = await openEngineModal({ id: 'ce-aware-add-picker', title: 'Add Aware Character', size: 'medium', content: content2 }); }\n        }\n        let pm2: any = null;\n        await drawAwareAddPicker(pm2);\n    } });\n\n    parts.push({ type: 'collapsibleSection', title: '👥 Characters & Knowledge', initialCollapsed: true, storageKey: `temp:ce_chars_${ent.id}`, content: charParts });\n    \n    // --- 7. EXPORT / DELETE ---\n    parts.push({ type: 'row', style: { gap: '8px', marginTop: '16px' }, content: [\n        { type: 'button', text: 'Delete Node', style: { flex: '1 1 0', margin: 0, fontSize: '11px', color: '#ff6b6b' }, callback: async function() { if (typeof confirmDeleteEntity === 'function') { await confirmDeleteEntity(ent.id, ent.name); } editingEntityId = null; } }\n    ] });\n\n    await openEngineModal({ id: 'entity-edit-modal', title: `Edit: ${ent.name}`, size: 'large', content: parts });\n}\n\n// ============================================================================\n// ENTITY DELETION & GRAVEYARD PROTECTION\n// ============================================================================\n\n\nasync function confirmDeleteEntity(id: string, name: string): Promise<void> {\n    const pm = await openEngineModal({\n        title: 'Confirm Deletion',\n        size: 'small',\n        content: [\n            { type: 'text', text: `Are you sure you want to remove ${name}?`, style: { marginBottom: '12px' } },\n            \n            // THE GRAVEYARD SHUNT\n            { type: 'button', text: '⚰️ Send to Graveyard (Keep data, hide from play)', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,136,136,0.2)' }, callback: async function() {\n                const allEnts = await loadEntityIndex();\n                let gyMeta = allEnts.find(function(e) { return e.name === 'Graveyard' && e.type === 'location'; });\n                \n                // Forge the Graveyard if it doesn't exist\n                if (!gyMeta) {\n                    const gy = typeof makeDefaultEntity === 'function' ? makeDefaultEntity('Graveyard') : { id: generateId(), name: 'Graveyard' };\n                    gy.type = 'location';\n                    gy.parentId = null;\n                    await saveEntity(gy);\n                    gyMeta = { id: gy.id, name: gy.name, type: gy.type, parentId: null };\n                }\n                \n                const ent = await loadEntity(id);\n                if (ent) {\n                    ent.parentId = gyMeta.id;\n                    await saveEntity(ent);\n                }\n                \n                pm.close();\n                if (typeof editingEntityId !== 'undefined' && editingEntityId === id) await openEntityEditModal(id);\n                await refreshSidebar();\n            }},\n            \n            // THE ORPHAN PROTECTOR\n            { type: 'button', text: '🗑️ Permanently Delete', style: { width: '100%', marginBottom: '8px', color: '#ff6b6b', backgroundColor: 'rgba(255,107,107,0.1)' }, callback: async function() {\n                const allEnts = await loadEntityIndex();\n                const children = allEnts.filter(function(e) { return e.parentId === id; });\n                \n                // Failsafe: Shunt all internal items/characters back to Root\n                for (const childMeta of children) {\n                    const child = await loadEntity(childMeta.id);\n                    if (child) {\n                        child.parentId = null; \n                        await saveEntity(child);\n                    }\n                }\n                \n                // Now permanently delete the target node\n                if (typeof deleteEntity === 'function') await deleteEntity(id);\n                pm.close();\n                \n                // Close modal if deleting the one we are actively editing\n                if (typeof editingEntityId !== 'undefined' && editingEntityId === id) {\n                    const em = await openEngineModal({id: 'entity-edit-modal', title: 'Closed', content: []});\n                    em.close();\n                }\n                await refreshSidebar();\n            }},\n            { type: 'button', text: 'Cancel', style: { width: '100%' }, callback: async function() { pm.close(); } }\n        ]\n    });\n}\n\n// ============================================================================\n// SECTION 23 — WORLDBUILDING MODAL (New Setup Hub)\n// ============================================================================\n\nvar worldbuildingModalHandle: any = null;\n\nasync function refreshWorldbuildingModal(): Promise<void> {\n    if (!worldbuildingModalHandle || worldbuildingModalHandle.isClosed()) return;\n    await worldbuildingModalHandle.update({ content: await buildWorldbuildingContent() });\n}\n\n// ── World-Build Wizard: engine-native interface ──────────────────────────\n// [vNEXT] Engine-only interface for the wizard (the bridge HUD will mirror every\n// function later). Tabbed so future groups (Characters, Factions, Species, ...)\n// slot in without the modal growing unmanageable. Data lives in storyStorage\n// (chats) and config (sections/project fields); the modal reloads fresh data on\n// every redraw rather than holding a snapshot.\n// [v0.9.8.2] iconId replaces emoji labels; tab order: setup, chats, memory,\n// species, factions, locations, characters, intro, drama.\nvar WIZARD_TABS: { id: string; label: string; iconId: string }[] = [\n    { id: 'setup',      label: 'Setup',      iconId: 'settings'        },\n    { id: 'chats',      label: 'Chats',      iconId: 'message-square'  },\n    { id: 'memory',     label: 'Memory',     iconId: 'file-text'       },\n    { id: 'species',    label: 'Species',    iconId: 'activity'        },\n    { id: 'factions',   label: 'Factions',   iconId: 'shield'          },\n    { id: 'bestiary',   label: 'Bestiary',   iconId: 'target'          },\n    { id: 'locations',  label: 'Locations',  iconId: 'map-pin'         },\n    { id: 'characters', label: 'Characters', iconId: 'user'            },\n    { id: 'intro',      label: 'Intro',      iconId: 'film'            },\n    { id: 'drama',      label: 'Drama',      iconId: 'zap'             },\n    { id: 'help',       label: 'Help',       iconId: 'help'            }\n];\n\n// [v1.6.1] All-Schedules modal — every character's daily timetable in one place,\n// now read/write. Was read-only (see prior comment below); this reuses the exact\n// same row mechanics as each character's own Daily Schedule section (same\n// loadCharacter/saveCharacter/openPickerModal calls) so both surfaces stay on one\n// source of truth — nothing here is a separate copy of the schedule data.\n// One pass over the character index + one location-index load per render; nothing\n// here runs unless the user opens it, so it adds zero runtime scan cost.\nasync function openAllSchedulesModal(): Promise<void> {\n    let asHandle: any = null;\n\n    async function renderAll() {\n        let asParts: UIPart[] = [];\n        try {\n            let asChars = await loadAllCharacters();\n            let asEntIdx = await loadEntityIndex();\n            let asLocOpts = asEntIdx.filter(function(e) { return e.type === 'location'; });\n            let asLocName: Record<string, string> = {};\n            asLocOpts.forEach(function(e) { asLocName[e.id] = e.name; });\n\n            asParts.push({ type: 'text', text: 'Every character\\u2019s daily timetable. Schedules position offstage NPCs by hour of day while the player is elsewhere. Edit directly here or from a character\\u2019s own card (Daily Schedule) \\u2014 both read and write the same data.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px', lineHeight: '1.4' } } as UIPart);\n\n            asParts.push({ type: 'button', text: '\\ud83d\\udd04 Process All Schedules Now', style: { width: '100%', marginBottom: '10px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)' }, callback: async function() {\n                try { await resolveSchedules(); await refreshSidebar(); await renderAll(); }\n                catch (e) { api.v1.error('[AE:schedules] manual resolve error:', e); }\n            } } as UIPart);\n\n            if (asChars.length === 0) {\n                asParts.push({ type: 'text', text: 'No characters yet.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic' } } as UIPart);\n            } else {\n                // Sort: enabled schedules first, then has-rows-but-disabled, then empty, then by name.\n                let asSorted = asChars.slice().sort(function(a, b) {\n                    let aRank = a.scheduleEnabled ? 0 : ((a.schedule && a.schedule.length) ? 1 : 2);\n                    let bRank = b.scheduleEnabled ? 0 : ((b.schedule && b.schedule.length) ? 1 : 2);\n                    if (aRank !== bRank) return aRank - bRank;\n                    return String(a.name || '').localeCompare(String(b.name || ''));\n                });\n\n                for (let c of asSorted) {\n                    let cCharId = c.id;\n                    let statusDot = c.scheduleEnabled ? '\\u2705' : '\\u26ab';\n                    let rowCount = (c.schedule || []).length;\n                    let sectionTitle = statusDot + ' ' + (c.name || 'Unnamed') + (rowCount ? ' (' + rowCount + ')' : '');\n\n                    asParts.push({ type: 'collapsibleSection', title: sectionTitle, initialCollapsed: true, storageKey: `temp:as_sched_${cCharId}`, content: await (async function() {\n                        let secParts: UIPart[] = [];\n                        let secRows = (c.schedule || []);\n\n                        secParts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [\n                            { type: 'text', text: c.scheduleEnabled ? '\\u2705 Schedule Active' : '\\u26ab Schedule Inactive', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: c.scheduleEnabled ? '#7ec8a0' : undefined } },\n                            { type: 'button', text: c.scheduleEnabled ? 'Disable' : 'Enable', style: { margin: 0, fontSize: '11px' }, callback: async function() {\n                                let f = await loadCharacter(cCharId); if (!f) return;\n                                f.scheduleEnabled = !f.scheduleEnabled;\n                                await saveCharacter(f); await renderAll();\n                            } }\n                        ] } as UIPart);\n\n                        if (secRows.length === 0) {\n                            secParts.push({ type: 'text', text: 'No schedule rows yet. Add one below.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '6px' } } as UIPart);\n                        } else {\n                            let sortedRows = secRows.map(function(r, i) { return { r: r, i: i }; }).sort(function(a, b) { return a.r.startHour - b.r.startHour; });\n                            for (let entry of sortedRows) {\n                                let row = entry.r; let rowIdx = entry.i;\n                                let locMeta = asLocOpts.find(function(l) { return l.id === row.locationId; });\n                                secParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                                    { type: 'numberInput', initialValue: row.startHour, style: { width: '56px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) {\n                                        let f = await loadCharacter(cCharId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;\n                                        let hv = Math.floor(Number(v) || 0); if (hv < 0) hv = 0; if (hv > 23) hv = 23;\n                                        f.schedule[rowIdx].startHour = hv;\n                                        await saveCharacter(f);\n                                    } },\n                                    { type: 'text', text: ':00 \\u2192', style: { fontSize: '11px', opacity: '0.6' } },\n                                    { type: 'button', text: locMeta ? ('\\ud83c\\udf0d ' + locMeta.name) : (asLocName[row.locationId] || '(pick location)'), style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left' }, callback: async function() {\n                                        await openPickerModal({\n                                            title: 'Pick Schedule Location',\n                                            items: asLocOpts,\n                                            getId: function(item) { return item.id; },\n                                            getLabel: function(item) { return item.name; },\n                                            getIcon: function() { return '\\ud83c\\udf0d'; },\n                                            searchable: true,\n                                            selectedId: row.locationId,\n                                            emptyText: 'No locations found. Create a location entity first.',\n                                            onSelect: async function(item) {\n                                                let f = await loadCharacter(cCharId); if (!f || !f.schedule || !f.schedule[rowIdx]) return;\n                                                f.schedule[rowIdx].locationId = item.id;\n                                                await saveCharacter(f); await renderAll();\n                                            }\n                                        });\n                                    } },\n                                    { type: 'button', text: '\\u2715', style: { margin: 0, fontSize: '11px', width: '28px' }, callback: async function() {\n                                        let f = await loadCharacter(cCharId); if (!f || !f.schedule) return;\n                                        f.schedule = f.schedule.filter(function(_rr, ri2) { return ri2 !== rowIdx; });\n                                        await saveCharacter(f); await renderAll();\n                                    } }\n                                ] } as UIPart);\n                            }\n                        }\n\n                        secParts.push({ type: 'button', text: '+ Add Schedule Row', style: { width: '100%', marginTop: '4px', fontSize: '11px' }, callback: async function() {\n                            let f = await loadCharacter(cCharId); if (!f) return;\n                            f.schedule = f.schedule || [];\n                            f.schedule.push({ startHour: 8, locationId: (asLocOpts[0] ? asLocOpts[0].id : '') });\n                            await saveCharacter(f); await renderAll();\n                        } } as UIPart);\n\n                        return secParts;\n                    })() } as UIPart);\n                }\n            }\n        } catch (e) {\n            api.v1.error('[AE:schedules] build error:', e);\n            asParts.push({ type: 'text', text: 'Could not load schedules.', style: { fontSize: '11px', opacity: '0.5' } } as UIPart);\n        }\n\n        asParts.push(_aeHudClose(function() { return asHandle; }));\n        try { if (asHandle && !asHandle.isClosed()) { await asHandle.update({ content: asParts }); return; } } catch (e) {}\n        asHandle = await openEngineModal({ id: 'ae-all-schedules', title: 'All Character Schedules', size: 'medium', content: asParts });\n    }\n\n    try {\n        await renderAll();\n    } catch (e) {\n        api.v1.error('[AE:schedules] open error:', e);\n    }\n}\n\nasync function openWizardModal(): Promise<void> {\n    let pm: any;\n\n    async function redraw(): Promise<void> {\n        if (pm && typeof pm.isClosed === 'function' && pm.isClosed()) return;\n        let content = await buildWizardContent();\n        if (pm && !pm.isClosed()) { await pm.update({ content: content }); }\n    }\n\n    function tabBar(activeTab: string): UIPart {\n        return { type: 'row', style: { gap: '3px', flexWrap: 'wrap', marginBottom: '10px', borderBottom: '1px solid rgba(255,255,255,0.08)', paddingBottom: '4px' }, content: WIZARD_TABS.map(function(t) {\n            let on = activeTab === t.id;\n            // [v0.9.8.2] iconId on each tab button; text provides the accessible label.\n        return { type: 'button', iconId: t.iconId as any, text: t.label, style: { flex: '1 1 auto', minWidth: '76px', margin: 0, padding: '4px 3px', fontSize: '10px', fontWeight: on ? 'bold' : 'normal', borderBottom: on ? '2px solid #88ccff' : '2px solid transparent', borderRadius: '4px 4px 0 0', backgroundColor: on ? 'rgba(136,204,255,0.12)' : 'transparent', opacity: on ? '1' : '0.65' }, callback: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_TAB, t.id); await redraw(); } } as UIPart;\n        }) };\n    }\n\n    async function buildWizardContent(): Promise<UIPart[]> {\n        let cfg = await loadConfig();\n        let chats = await loadWizardChats();\n        let activeId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_ACTIVE_CHAT, '') as string;\n        let active = chats.find(function(c) { return c.id === activeId; }) || null;\n        let topics = ((cfg as any).wizardTopics && (cfg as any).wizardTopics.length) ? (cfg as any).wizardTopics : DEFAULT_WIZARD_TOPICS;\n        let activeTab = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_TAB, 'setup') as string;\n        if (activeTab === 'story') { activeTab = 'setup'; } // [v0.9.8.2] legacy redirect\n        let parts: UIPart[] = [];\n        parts.push(tabBar(activeTab));\n\n        if (activeTab === 'setup') {\n            // ── SETUP: project fields + helper text ──────────────────────────────────\n            parts.push({ type: 'text', text: 'Name your project and jot the initial concept. These seed every wizard chat and all world generation when no chat is selected.', style: { fontSize: '12px', opacity: '0.7', lineHeight: '1.5', marginBottom: '12px' } });\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '8px' }, content: [\n                { type: 'textInput', label: 'Project Name', initialValue: cfg.projectName || '', placeholder: 'Untitled Project', style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: string) { await mutConfig(function(c) { c.projectName = v; }); } },\n                { type: 'textInput', label: 'Genre', initialValue: cfg.projectGenre || '', placeholder: 'e.g. dark fantasy, cyberpunk noir…', style: { flex: '1 1 0', margin: 0 }, onChange: async function(v: string) { await mutConfig(function(c) { c.projectGenre = v; }); } }\n            ] });\n            parts.push({ type: 'multilineTextInput', label: 'Initial Concept', initialValue: cfg.projectConcept || '', placeholder: 'The working idea your wizard chats start from…', style: { minHeight: '80px', marginBottom: '10px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.projectConcept = v; }); } } as UIPart);\n\n        } else if (activeTab === 'chats') {\n            // ── CHATS [v0.9.8.3]: two collapsible panels + bare transcript ──────────\n            // Panel 1 — Select Chat: topic picker modal, new-chat, existing-chat modal.\n            // Panel 2 — active chat config: name edit + context sources.\n            // Below: transcript + send input (no extra wrapping).\n            let topicPickId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_TOPIC_PICK, topics[0] ? topics[0].id : '') as string;\n            let pickedTopic = topics.find(function(tp0: WizardTopic) { return tp0.id === topicPickId; }) || topics[0] || null;\n\n            // ─── Panel 1: Select Chat ──────────────────────────────────────────────\n            let selParts: UIPart[] = [];\n\n            // ─ Topic picker ──────────────────────────────────────────────────────────────\n            selParts.push({ type: 'button', text: 'Select Topic' + (pickedTopic ? ': ' + pickedTopic.label : '…'), iconId: 'tag' as any, style: { width: '100%', marginBottom: '4px', textAlign: 'left', backgroundColor: 'rgba(136,204,255,0.08)', border: '1px solid rgba(136,204,255,0.2)' }, callback: async function() {\n                await openSearchPicker('Select Topic', topics.map(function(tp1: WizardTopic) { return { id: tp1.id, label: tp1.label, selected: tp1.id === topicPickId }; }), async function(id: string) {\n                    await api.v1.tempStorage.set(STORAGE_WIZ_TOPIC_PICK, id); await redraw();\n                });\n            } });\n\n            // ─ New chat button ──────────────────────────────────────────────────────────\n            selParts.push({ type: 'button', text: '+ New ' + (pickedTopic ? '\"' + pickedTopic.label + '\" Chat' : 'Chat'), iconId: 'plus', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, callback: async function() {\n                let tid = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_TOPIC_PICK, topics[0] ? topics[0].id : '') as string;\n                let tp2 = topics.find(function(tp3: WizardTopic) { return tp3.id === tid; }) || topics[0];\n                if (!tp2) { api.v1.ui.toast('Select a topic first.', { type: 'error', autoClose: 2000 }); return; }\n                let nc = await createWizardChat(tp2.id, tp2.label);\n                await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, nc.id); await redraw();\n            } });\n\n            // ─ Existing-chat picker ────────────────────────────────────────────────────\n            if (chats.length > 0) {\n                selParts.push({ type: 'button', text: 'Open Chat' + (active ? ': ' + active.title : '…'), iconId: 'message-square' as any, style: { width: '100%', textAlign: 'left', backgroundColor: active ? 'rgba(126,200,160,0.08)' : 'transparent', border: '1px solid rgba(255,255,255,0.15)' }, callback: async function() {\n                    let chatItems = chats.map(function(c) { return { id: c.id, label: c.title, selected: !!(active && c.id === active.id) }; });\n                    await openSearchPicker('Open Chat', chatItems, async function(id: string) {\n                        await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, id); await redraw();\n                    });\n                } });\n            } else {\n                selParts.push({ type: 'text', text: 'No chats yet — select a topic and create one above.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });\n            }\n\n            // [vNEXT] Export every wizard chat transcript to a JSON file.\n            if (chats.length > 0) {\n                selParts.push({ type: 'button', text: '⬇ Export All Chats (JSON)', iconId: 'download' as any, style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.08)' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    await exportWizardChats('all');\n                } } as UIPart);\n            }\n\n            parts.push({ type: 'collapsibleSection', title: 'Select Chat', iconId: 'list' as any, initialCollapsed: !!active, storageKey: 'temp:wiz_sel', content: selParts } as UIPart);\n\n            // ─── Panel 2: active chat config ─────────────────────────────────────────\n            if (active) {\n                let activeTopic2 = topics.find(function(t: WizardTopic) { return t.id === active.topicId; });\n                let cfgTitle = (activeTopic2 ? activeTopic2.label + ' · ' : '') + active.title;\n                let cfgParts: UIPart[] = [];\n\n                cfgParts.push({ type: 'textInput', label: 'Chat Name', initialValue: active.title, style: { margin: '0 0 6px 0' }, onChange: async function(v: string) { let f = await loadWizardChat(active.id); if (!f) return; f.title = v; await saveWizardChat(f); } } as UIPart);\n                cfgParts.push({ type: 'checkboxInput', label: 'Include recent story text as context', initialValue: !!active.includeStory, onChange: async function(val: boolean) { let f = await loadWizardChat(active.id); if (!f) return; f.includeStory = val; await saveWizardChat(f); } } as UIPart);\n                let otherChs = chats.filter(function(oc) { return oc.id !== active.id; });\n                if (otherChs.length > 0) {\n                    cfgParts.push({ type: 'text', text: 'Also pull context from:', style: { fontSize: '10px', opacity: '0.6', marginTop: '4px', marginBottom: '2px' } });\n                    otherChs.forEach(function(oc) {\n                        let onOc = (active.contextChatIds || []).indexOf(oc.id) >= 0;\n                        cfgParts.push({ type: 'checkboxInput', label: oc.title, initialValue: onOc, onChange: async function(val: boolean) {\n                            let f = await loadWizardChat(active.id); if (!f) return;\n                            let ids = f.contextChatIds || [];\n                            if (val && ids.indexOf(oc.id) < 0) ids.push(oc.id);\n                            else if (!val) ids = ids.filter(function(x) { return x !== oc.id; });\n                            f.contextChatIds = ids; await saveWizardChat(f);\n                        } } as UIPart);\n                    });\n                }\n                cfgParts.push({ type: 'row', style: { gap: '6px', marginTop: '8px' }, content: [\n                    { type: 'button', text: 'Export this chat', iconId: 'download' as any, style: { flex: '1 1 0', margin: 0, fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {\n                        await exportWizardChats('one', active.id);\n                    } },\n                    { type: 'button', text: 'Delete this chat', iconId: 'trash', style: { flex: '1 1 0', margin: 0, fontSize: '11px', opacity: '0.7' }, callback: async function() {\n                        await deleteWizardChat(active.id);\n                        await api.v1.tempStorage.set(STORAGE_WIZ_ACTIVE_CHAT, ''); await redraw();\n                    } }\n                ] } as UIPart);\n\n                parts.push({ type: 'collapsibleSection', title: cfgTitle, iconId: 'message-square' as any, initialCollapsed: false, storageKey: 'temp:wiz_cfg', content: cfgParts } as UIPart);\n\n                // ─── Transcript + input (no collapsible wrapper) ───────────────────────────────\n                if (!active.messages || active.messages.length === 0) {\n                    parts.push({ type: 'text', text: '(empty — send a message to begin)', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '4px' } });\n                } else {\n                    let editTgt = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_EDIT_MSG, '') as string;\n                    active.messages.forEach(function(m, mi) {\n                        let isUser = m.role === 'user';\n                        let thisKey = active.id + ':' + mi;\n                        let isEditing = editTgt === thisKey;\n                        let editBtnPart: UIPart = isEditing\n                            ? { type: 'button', text: 'Done', style: { margin: 0, padding: '1px 6px', fontSize: '10px', backgroundColor: 'rgba(126,200,160,0.18)', color: '#7ec8a0' }, callback: async function() {\n                                let draftMsg = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_MSG_DRAFT, null) as any;\n                                if (draftMsg !== null) { let f = await loadWizardChat(active.id); if (f && f.messages[mi]) { f.messages[mi].content = String(draftMsg); await saveWizardChat(f); } }\n                                await api.v1.tempStorage.set(STORAGE_WIZ_EDIT_MSG, ''); await redraw();\n                            } }\n                            : { type: 'button', iconId: 'edit', style: { margin: 0, padding: '1px 4px' }, callback: async function() {\n                                await api.v1.tempStorage.set(STORAGE_WIZ_EDIT_MSG, thisKey);\n                                await api.v1.tempStorage.set(STORAGE_WIZ_MSG_DRAFT, m.content); await redraw();\n                            } };\n                        let msgRow: UIPart[] = [\n                            { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [\n                                { type: 'text', text: (isUser ? 'You' : 'Wiz'), style: { fontSize: '9px', opacity: '0.55', fontWeight: 'bold', flex: '1 1 0' } },\n                                editBtnPart,\n                                { type: 'button', iconId: 'trash', style: { margin: 0, padding: '1px 4px' }, callback: async function() {\n                                    let f = await loadWizardChat(active.id); if (!f) return;\n                                    f.messages.splice(mi, 1); await saveWizardChat(f);\n                                    if (editTgt === thisKey) await api.v1.tempStorage.set(STORAGE_WIZ_EDIT_MSG, '');\n                                    await redraw();\n                                } }\n                            ] }\n                        ];\n                        if (isEditing) {\n                            msgRow.push({ type: 'multilineTextInput', initialValue: m.content, style: { minHeight: '60px', fontSize: '12px' } as any, onChange: async function(v: string) { await api.v1.tempStorage.set(STORAGE_WIZ_MSG_DRAFT, v); } } as UIPart);\n                        } else {\n                            msgRow.push({ type: 'text', text: m.content, style: { fontSize: '12px', whiteSpace: 'pre-wrap' } as any });\n                        }\n                        parts.push({ type: 'box', style: { backgroundColor: isUser ? 'rgba(136,204,255,0.08)' : 'rgba(126,200,160,0.08)', padding: '5px 7px', borderRadius: '5px', marginBottom: '3px' }, content: msgRow });\n                    });\n                }\n\n                parts.push({ type: 'multilineTextInput', placeholder: 'Message the Wiz…', initialValue: '', style: { minHeight: '44px', marginTop: '6px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(STORAGE_WIZ_INPUT, v); } } as UIPart);\n                parts.push({ type: 'row', style: { gap: '6px', marginTop: '4px' }, content: [\n                    { type: 'button', text: 'Send', iconId: 'send', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                        let draftSend = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INPUT, '') as string;\n                        if (!draftSend || !draftSend.trim()) { api.v1.ui.toast('Type a message first.', { type: 'info', autoClose: 1500 }); return; }\n                        api.v1.ui.toast('Thinking…', { id: 'wiz-turn', autoClose: false, type: 'info' });\n                        let reply = await runWizardChatTurn(active.id, draftSend);\n                        await api.v1.tempStorage.set(STORAGE_WIZ_INPUT, '');\n                        api.v1.ui.toast(reply ? 'Replied.' : 'Generation failed.', { id: 'wiz-turn', type: reply ? 'success' : 'error', autoClose: 1500 });\n                        await redraw();\n                    } }\n                ] });\n\n                let activeTopic3 = topics.find(function(t: WizardTopic) { return t.id === active.topicId; });\n                if (activeTopic3 && activeTopic3.commitKind === 'memoryFanout') {\n                    parts.push({ type: 'button', text: 'Commit → generate enabled Memory sections', iconId: 'check', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {\n                        api.v1.ui.toast('Generating sections…', { id: 'wiz-commit', autoClose: false, type: 'info' });\n                        let nFan = await runWizardMemoryFanout(active.id);\n                        api.v1.ui.toast(nFan >= 0 ? ('Committed ' + nFan + ' section(s).') : 'Commit failed.', { id: 'wiz-commit', type: nFan >= 0 ? 'success' : 'error', autoClose: 2500 });\n                        await redraw();\n                    } });\n                }\n            }\n\n        } else if (activeTab === 'memory') {\n            // ── MEMORY SECTIONS ──\n            let activeChatId = active ? active.id : '';\n            parts.push({ type: 'text', text: 'Enabled sections are generated on commit and assembled into the static Memory block (Style → Author’s Note). Regenerate or edit any section individually below. Regeneration uses the active chat (' + (active ? active.title : 'none selected') + ') plus the hint.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });\n            (cfg.wizardSections || []).forEach(function(s: WizardMemorySection, si: number) {\n                let hintKey = STORAGE_WIZ_SEC_HINT + s.id;\n                parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: [\n                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [\n                        { type: 'checkboxInput', label: '', initialValue: !!s.enabled, onChange: async function(val: boolean) { await mutConfig(function(c) { c.wizardSections[si].enabled = val; }); } } as UIPart,\n                        { type: 'textInput', initialValue: s.label, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].label = v; }); } },\n                        { type: 'text', text: s.target === 'an' ? 'AN' : 'MEM', style: { fontSize: '9px', opacity: '0.5', flexShrink: '0' } },\n                        { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() { await mutConfig(function(c) { c.wizardSections.splice(si, 1); }); await redraw(); } }\n                    ] },\n                    { type: 'multilineTextInput', initialValue: s.content || '', placeholder: '(generated on commit; editable)', style: { minHeight: '40px', marginBottom: '3px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].content = v; }); } } as UIPart,\n                    { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '3px' }, content: [\n                        { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(hintKey, v); } },\n                        { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                            let hint = await api.v1.tempStorage.getOrDefault(hintKey, '') as string;\n                            api.v1.ui.toast('Regenerating “' + s.label + '”…', { id: 'wiz-regen', autoClose: false, type: 'info' });\n                            let r = await regenerateWizardSection(s.id, activeChatId, hint);\n                            api.v1.ui.toast(r ? ('Regenerated “' + s.label + '”.') : 'Regeneration failed.', { id: 'wiz-regen', type: r ? 'success' : 'error', autoClose: 2000 });\n                            await redraw();\n                        } }\n                    ] },\n                    { type: 'textInput', initialValue: s.instructions || '', placeholder: 'Scope instructions', style: { margin: 0, fontSize: '10px', opacity: '0.8' }, onChange: async function(v: string) { await mutConfig(function(c) { c.wizardSections[si].instructions = v; }); } }\n                ] });\n            });\n            parts.push({ type: 'button', text: '+ Add Section', style: { marginTop: '2px', fontSize: '11px' }, callback: async function() {\n                await mutConfig(function(c) { if (!c.wizardSections) c.wizardSections = []; c.wizardSections.push({ id: 'wsec_' + generateId(), label: 'New Section', enabled: false, content: '', instructions: 'Describe ONLY this section’s scope.', target: 'memory' }); });\n                await redraw();\n            } });\n            parts.push({ type: 'button', text: '✅ Commit to Memory + Author’s Note', style: { width: '100%', marginTop: '6px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {\n                let fresh = await loadConfig();\n                let ok = await commitWizardMemory(fresh);\n                api.v1.ui.toast(ok ? 'Committed to Memory and Author’s Note.' : 'Commit failed.', { type: ok ? 'success' : 'error', autoClose: 2000 });\n            } });\n            // [vNEXT] Sync every world lorebook (characters, locations, species, factions)\n            // in one pass. Creates entries that are missing OR whose stored link was\n            // deleted in NAI; syncs the rest. One lorebook read for the whole run.\n            parts.push({ type: 'text', text: 'Lorebook: create any missing entries and refresh existing ones for all characters, locations, species, and factions.', style: { fontSize: '10px', opacity: '0.55', marginTop: '10px', marginBottom: '4px' } });\n            parts.push({ type: 'button', text: '📚 Sync All Lorebooks', iconId: 'book-open' as any, style: { width: '100%', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.10)' }, disabledWhileCallbackRunning: true, callback: async function() {\n                api.v1.ui.toast('Syncing all lorebooks…', { id: 'wiz-lore-all', autoClose: false, type: 'info' });\n                try {\n                    let t = await syncAllLorebooks();\n                    let totCreated = t.characters.created + t.locations.created + t.species.created + t.factions.created;\n                    let totSynced  = t.characters.synced  + t.locations.synced  + t.species.synced  + t.factions.synced;\n                    api.v1.ui.toast(totCreated + ' created, ' + totSynced + ' synced (chars ' + t.characters.created + '+' + t.characters.synced + ', locs ' + t.locations.created + '+' + t.locations.synced + ', species ' + t.species.created + '+' + t.species.synced + ', factions ' + t.factions.created + '+' + t.factions.synced + ').', { id: 'wiz-lore-all', type: 'success', autoClose: 4000 });\n                } catch (e) {\n                    api.v1.error('[AE:lore] Sync All button:', e);\n                    api.v1.ui.toast('Sync All failed.', { id: 'wiz-lore-all', type: 'error', autoClose: 2500 });\n                }\n            } });\n        } else if (activeTab === 'species' || activeTab === 'factions') {\n            // ── SPECIES / FACTIONS (batch yoink generation + per-item regen) ──\n            let kind = (activeTab === 'factions') ? 'faction' : 'species';\n            let list: any[] = (kind === 'faction') ? (cfg.factions || []) : (cfg.species || []);\n            // [v0.9.81] Per-tab context sources: MULTI-select (checkboxes, mirroring the\n            // per-chat context model). Stored as a JSON id array per kind. Empty selection\n            // falls back to the active chat; no active chat falls back to project concept only.\n            let srcKey = STORAGE_WIZ_TAB_SRC + kind;\n            let storedSrcRaw = await api.v1.tempStorage.getOrDefault(srcKey, '') as string;\n            let storedSrcIds: string[] = [];\n            try { let parsedSrc = JSON.parse(storedSrcRaw || '[]'); if (Array.isArray(parsedSrc)) storedSrcIds = parsedSrc.filter(Boolean); } catch (eSrcParse) { storedSrcIds = []; }\n            storedSrcIds = storedSrcIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });\n            let effSrcIds = storedSrcIds.length ? storedSrcIds : (active ? [active.id] : []);\n            let countKey = STORAGE_WIZ_GEN_COUNT + kind;\n            let countDraft = await api.v1.tempStorage.getOrDefault(countKey, 3) as number;\n\n            parts.push({ type: 'text', text: 'Generate ' + (kind === 'faction' ? 'factions' : 'species') + ' from the chosen context source plus project context. Existing entries are fed in so new ones won\\'t duplicate them. Each becomes a record with a linked lorebook entry — regenerate or edit any individually below.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });\n\n            // Context sources (multi-select checkboxes, mirroring the per-chat context model).\n            parts.push({ type: 'text', text: 'Context sources' + (storedSrcIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, using project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });\n            if (chats.length === 0) {\n                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });\n            } else {\n                chats.forEach(function(pc) {\n                    let onSrc = storedSrcIds.indexOf(pc.id) >= 0;\n                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {\n                        let curRaw = await api.v1.tempStorage.getOrDefault(srcKey, '') as string;\n                        let curIds: string[] = [];\n                        try { let pj = JSON.parse(curRaw || '[]'); if (Array.isArray(pj)) curIds = pj.filter(Boolean); } catch (eSrcSet) { curIds = []; }\n                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);\n                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });\n                        await api.v1.tempStorage.set(srcKey, JSON.stringify(curIds));\n                        await redraw();\n                    } } as UIPart);\n                });\n                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });\n            }\n\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [\n                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'numberInput', initialValue: countDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(countKey, Math.max(1, Math.min(12, v || 1))); } },\n                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let n = await api.v1.tempStorage.getOrDefault(countKey, 3) as number;\n                    api.v1.ui.toast('Generating ' + n + ' ' + kind + '(s)…', { id: 'wiz-batch', autoClose: false, type: 'info' });\n                    let made = (kind === 'faction') ? await runWizardFactionsBatch(n, effSrcIds) : await runWizardSpeciesBatch(n, effSrcIds);\n                    api.v1.ui.toast(made > 0 ? ('Created ' + made + ' ' + kind + '(s).') : 'Generation failed.', { id: 'wiz-batch', type: made > 0 ? 'success' : 'error', autoClose: 2500 });\n                    await redraw();\n                } }\n            ] });\n\n            parts.push({ type: 'button', text: '+ Add blank ' + (kind === 'faction' ? 'faction' : 'species'), style: { width: '100%', marginBottom: '10px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {\n                await addBlankWizardEntity(kind);\n                await redraw();\n            } });\n\n            if (list.length === 0) {\n                parts.push({ type: 'text', text: 'None yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });\n            } else {\n                list.forEach(function(item: any, ii: number) {\n                    let hintKey = STORAGE_WIZ_ITEM_HINT + item.id;\n                    let boxContent: UIPart[] = [\n                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [\n                            { type: 'textInput', initialValue: item.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].name = v; }); } },\n                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {\n                                let capId = item.id;\n                                if (kind === 'faction') { await unlinkFactionLorebookEntry(capId).catch(function() {}); }\n                                else { await unlinkSpeciesLorebookEntry(capId).catch(function() {}); }\n                                await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; let idx = arr.findIndex(function(x: any) { return x.id === capId; }); if (idx >= 0) arr.splice(idx, 1); });\n                                await redraw();\n                            } }\n                        ] },\n                        { type: 'multilineTextInput', initialValue: item.description || '', placeholder: '(lore description)', style: { minHeight: '44px', marginBottom: '3px' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].description = v; }); } } as UIPart,\n                        { type: 'textInput', initialValue: (item.lorebookTags || []).join(', '), placeholder: 'Lorebook tags (comma-separated)', style: { margin: '0 0 3px 0', fontSize: '10px' }, onChange: async function(v: string) { await mutConfig(function(c) { let arr: any[] = (kind === 'faction') ? c.factions : c.species; if (arr[ii]) arr[ii].lorebookTags = v.split(',').map(function(s2: string) { return s2.trim(); }).filter(Boolean); }); } },\n                        { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [\n                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(hintKey, v); } },\n                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                                let hint = await api.v1.tempStorage.getOrDefault(hintKey, '') as string;\n                                api.v1.ui.toast('Regenerating “' + item.name + '”…', { id: 'wiz-ireg', autoClose: false, type: 'info' });\n                                let r = await regenerateWizardEntity(kind, item.id, effSrcIds, hint);\n                                api.v1.ui.toast(r ? ('Regenerated “' + item.name + '”.') : 'Regeneration failed.', { id: 'wiz-ireg', type: r ? 'success' : 'error', autoClose: 2000 });\n                                await redraw();\n                            } },\n                            { type: 'button', text: '🔗 Sync Lore', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                                if (kind === 'faction') await syncFactionLorebookEntry(item.id); else await syncSpeciesLorebookEntry(item.id);\n                            } }\n                        ] }\n                    ];\n                    if (kind === 'faction') {\n                        boxContent.push({ type: 'textInput', initialValue: (item.relationshipStates || []).join(' → '), placeholder: 'Standing track (lowest → highest)', style: { margin: 0, fontSize: '10px', opacity: '0.8' }, onChange: async function(v: string) { await mutConfig(function(c) { if (c.factions[ii]) c.factions[ii].relationshipStates = v.split('→').map(function(s2: string) { return s2.trim(); }).filter(Boolean); }); } });\n                    }\n                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: boxContent });\n                });\n            }\n        } else if (activeTab === 'bestiary') {\n            let bwCfg = await loadConfig();\n            let bwArchs = (((bwCfg as any).npcArchetypes || []) as NpcArchetypeDef[]);\n            let bwSrcKey = STORAGE_WIZ_TAB_SRC + 'bestiary';\n            let bwStoredRaw = await api.v1.tempStorage.getOrDefault(bwSrcKey, '') as string;\n            let bwStoredIds: string[] = [];\n            try { let bwParsed = JSON.parse(bwStoredRaw || '[]'); if (Array.isArray(bwParsed)) bwStoredIds = bwParsed.filter(Boolean); } catch (eBwParse) { bwStoredIds = []; }\n            bwStoredIds = bwStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });\n            let bwEffSrcIds = bwStoredIds.length ? bwStoredIds : (active ? [active.id] : []);\n            let bwCountKey = STORAGE_WIZ_GEN_COUNT + 'bestiary';\n            let bwCountDraft = await api.v1.tempStorage.getOrDefault(bwCountKey, 3) as number;\n\n            parts.push({ type: 'text', text: 'Generate minor-NPC archetypes \\u2014 drop-in creatures and background figures \\u2014 from the chosen context source plus project context. Existing archetypes are fed in so new ones won\\u2019t duplicate them. Each becomes a spawn template with an empty resources/tags to fill in below or in the Bestiary.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });\n\n            parts.push({ type: 'text', text: 'Context sources' + (bwStoredIds.length ? '' : (active ? ' \\u2014 none checked, using active chat \\u201c' + active.title + '\\u201d' : ' \\u2014 none, using project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });\n            if (chats.length === 0) {\n                parts.push({ type: 'text', text: 'No chats yet \\u2014 generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });\n            } else {\n                chats.forEach(function(bwc) {\n                    let bwOn = bwStoredIds.indexOf(bwc.id) >= 0;\n                    parts.push({ type: 'checkboxInput', label: bwc.title, initialValue: bwOn, onChange: async function(val: boolean) {\n                        let bwCurRaw = await api.v1.tempStorage.getOrDefault(bwSrcKey, '') as string;\n                        let bwCurIds: string[] = [];\n                        try { let bwPj = JSON.parse(bwCurRaw || '[]'); if (Array.isArray(bwPj)) bwCurIds = bwPj.filter(Boolean); } catch (eBwSet) { bwCurIds = []; }\n                        if (val && bwCurIds.indexOf(bwc.id) < 0) bwCurIds.push(bwc.id);\n                        else if (!val) bwCurIds = bwCurIds.filter(function(x) { return x !== bwc.id; });\n                        await api.v1.tempStorage.set(bwSrcKey, JSON.stringify(bwCurIds));\n                        await redraw();\n                    } } as UIPart);\n                });\n                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });\n            }\n\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [\n                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'numberInput', initialValue: bwCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(bwCountKey, Math.max(1, Math.min(12, v || 1))); } },\n                { type: 'button', text: '\\u26a1 Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let bwN = await api.v1.tempStorage.getOrDefault(bwCountKey, 3) as number;\n                    api.v1.ui.toast('Generating ' + bwN + ' archetype(s)\\u2026', { id: 'wiz-batch', autoClose: false, type: 'info' });\n                    let bwMade = await runWizardArchetypesBatch(bwN, bwEffSrcIds);\n                    api.v1.ui.toast(bwMade > 0 ? ('Created ' + bwMade + ' archetype(s).') : 'Generation failed.', { id: 'wiz-batch', type: bwMade > 0 ? 'success' : 'error', autoClose: 2500 });\n                    await redraw();\n                } }\n            ] });\n\n            parts.push({ type: 'button', text: '\\ud83d\\udc3e Open Bestiary (spawn, edit resources & tags)', style: { width: '100%', marginBottom: '10px', fontSize: '11px' }, callback: async function() { await openBestiaryModal(); } } as UIPart);\n\n            if (bwArchs.length === 0) {\n                parts.push({ type: 'text', text: 'None yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });\n            } else {\n                bwArchs.forEach(function(bwA) {\n                    parts.push({ type: 'row', style: { gap: '4px', marginBottom: '4px', alignItems: 'center' }, content: [\n                        { type: 'text', text: aeIconPfx(bwA.icon) + bwA.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },\n                        { type: 'text', text: (bwA.briefTemplate || '').slice(0, 46) + ((bwA.briefTemplate || '').length > 46 ? '\\u2026' : ''), style: { flex: '2 1 0', fontSize: '10px', opacity: '0.6' } },\n                        { type: 'button', text: 'Edit', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px' }, callback: async function() { await openArchetypeEditModal(bwA.id); } }\n                    ] } as UIPart);\n                });\n            }\n        } else if (activeTab === 'locations') {\n            // ── LOCATIONS (two-pass tree: scope top-level, then step into any node) ──\n            let lkind = 'locations';\n            // Context sources (multi-select, same model as species/factions).\n            let lSrcKey = STORAGE_WIZ_TAB_SRC + lkind;\n            let lStoredRaw = await api.v1.tempStorage.getOrDefault(lSrcKey, '') as string;\n            let lStoredIds: string[] = [];\n            try { let lpj = JSON.parse(lStoredRaw || '[]'); if (Array.isArray(lpj)) lStoredIds = lpj.filter(Boolean); } catch (eLSrc) { lStoredIds = []; }\n            lStoredIds = lStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });\n            let lEffIds = lStoredIds.length ? lStoredIds : (active ? [active.id] : []);\n\n            // Current parent navigation (Pass 2 step-into).\n            let lParentId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;\n            let lParentEnt = lParentId ? await loadEntity(lParentId) : null;\n            if (lParentId && !lParentEnt) { lParentId = ''; await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, ''); }\n            let lChildDepth = lParentId ? ((await computeEntityTier(lParentId)) + 1) : 0;\n            let lBandIdx = tierBandIndexForDepth(lChildDepth);\n            let lBand = (cfg.tierTravelDefaults || DEFAULT_TIER_TRAVEL)[lBandIdx];\n\n            // Breadcrumb / step-up.\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [\n                { type: 'text', text: lParentEnt ? ('📍 Inside: ' + lParentEnt.name) : '🌍 World root (top-level)', style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: '#88ccff' } }\n            ].concat(lParentEnt ? [{ type: 'button', text: '↑ Up', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, callback: async function() {\n                let up = (lParentEnt && lParentEnt.parentId) ? lParentEnt.parentId : '';\n                await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, up);\n                await redraw();\n            } } as UIPart] : []) });\n            parts.push({ type: 'text', text: lParentEnt ? ('Generating sub-locations of “' + lParentEnt.name + '” (' + lBand.label + ' tier).') : ('Generating top-level locations (' + lBand.label + ' tier). Step into any location below to build its sub-locations.'), style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });\n\n            // Tier travel rule for the tier being created (shared across that depth).\n            let lCostBtns: UIPart[] = [{ type: 'text', text: 'Cost:', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } } as UIPart];\n            // [v0.9.9.6] Offer both global resources AND per-character personal resources\n            // (Health/Wealth/Luck, etc). adjustResource/checkResource fall back to the\n            // protagonist's personal pool for any tag that is not a global resource.\n            let lResGlobals = (cfg.resources || []).map(function(r) { return { tag: r.tag, name: r.name }; });\n            let lGlobTags = lResGlobals.map(function(x) { return x.tag; });\n            let lResChars = (cfg.characterResourceDefs || []).filter(function(r) { return lGlobTags.indexOf(r.tag) < 0; }).map(function(r) { return { tag: r.tag, name: r.name }; });\n            let lResList = [{ tag: '', name: 'None' }].concat(lResGlobals).concat(lResChars);\n            lResList.forEach(function(rr) {\n                let onCost = (lBand.costTag || '') === rr.tag;\n                lCostBtns.push({ type: 'button', text: rr.name, style: { margin: 0, fontSize: '10px', padding: '2px 6px', backgroundColor: onCost ? 'rgba(136,204,255,0.25)' : 'transparent', border: '1px solid ' + (onCost ? '#88ccff' : 'rgba(255,255,255,0.18)'), color: onCost ? '#88ccff' : 'inherit' }, callback: async function() {\n                    await mutConfig(function(c) { if (!c.tierTravelDefaults) c.tierTravelDefaults = JSON.parse(JSON.stringify(DEFAULT_TIER_TRAVEL)); c.tierTravelDefaults[lBandIdx].costTag = rr.tag; if (!rr.tag) c.tierTravelDefaults[lBandIdx].costAmount = 0; syncTierTemplate(c, lBandIdx); });\n                    await redraw();\n                } } as UIPart);\n            });\n            let lRuleBox: UIPart[] = [\n                { type: 'text', text: '🧭 Travel rule for the ' + lBand.label + ' tier', style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '4px' } },\n                { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px', flexWrap: 'wrap' }, content: lCostBtns }\n            ];\n            if (lBand.costTag) {\n                lRuleBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                    { type: 'text', text: 'Amount:', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } },\n                    { type: 'numberInput', initialValue: lBand.costAmount || 0, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await mutConfig(function(c) { c.tierTravelDefaults[lBandIdx].costAmount = Math.max(0, v || 0); syncTierTemplate(c, lBandIdx); }); } }\n                ] } as UIPart);\n            }\n            lRuleBox.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                { type: 'text', text: 'Time (hours):', style: { fontSize: '10px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'numberInput', initialValue: lBand.timeCostHours || 0, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await mutConfig(function(c) { if (!c.tierTravelDefaults) c.tierTravelDefaults = JSON.parse(JSON.stringify(DEFAULT_TIER_TRAVEL)); c.tierTravelDefaults[lBandIdx].timeCostHours = Math.max(0, Math.floor(v || 0)); syncTierTemplate(c, lBandIdx); }); } }\n            ] } as UIPart);\n            lRuleBox.push({ type: 'checkboxInput', label: 'Narrate travel (uncheck = silent, no text/AI)', initialValue: !!lBand.narrated, onChange: async function(val: boolean) { await mutConfig(function(c) { c.tierTravelDefaults[lBandIdx].narrated = val; syncTierTemplate(c, lBandIdx); }); } } as UIPart);\n            parts.push({ type: 'box', style: { backgroundColor: 'rgba(136,204,255,0.06)', padding: '7px', borderRadius: '5px', marginBottom: '8px' }, content: lRuleBox });\n\n            // Context sources (multi-select checkboxes).\n            parts.push({ type: 'text', text: 'Context sources' + (lStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });\n            if (chats.length === 0) {\n                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });\n            } else {\n                chats.forEach(function(pc) {\n                    let onSrc = lStoredIds.indexOf(pc.id) >= 0;\n                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {\n                        let curRaw = await api.v1.tempStorage.getOrDefault(lSrcKey, '') as string;\n                        let curIds: string[] = [];\n                        try { let lpj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(lpj2)) curIds = lpj2.filter(Boolean); } catch (eLSrc2) { curIds = []; }\n                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);\n                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });\n                        await api.v1.tempStorage.set(lSrcKey, JSON.stringify(curIds));\n                        await redraw();\n                    } } as UIPart);\n                });\n                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });\n            }\n\n            // Generate + add-blank.\n            let lCountKey = STORAGE_WIZ_GEN_COUNT + lkind;\n            let lCountDraft = await api.v1.tempStorage.getOrDefault(lCountKey, 3) as number;\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [\n                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'numberInput', initialValue: lCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(lCountKey, Math.max(1, Math.min(12, v || 1))); } },\n                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let n = await api.v1.tempStorage.getOrDefault(lCountKey, 3) as number;\n                    let pId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;\n                    api.v1.ui.toast('Generating ' + n + ' location(s)…', { id: 'wiz-loc', autoClose: false, type: 'info' });\n                    let made = await runWizardLocationsBatch(n, pId || null, lEffIds);\n                    api.v1.ui.toast(made > 0 ? ('Created ' + made + ' location(s).') : 'Generation failed.', { id: 'wiz-loc', type: made > 0 ? 'success' : 'error', autoClose: 2500 });\n                    await redraw();\n                } }\n            ] });\n            parts.push({ type: 'button', text: '+ Add blank location', style: { width: '100%', marginBottom: '10px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {\n                let pId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_LOC_PARENT, '') as string;\n                await addBlankWizardLocation(pId || null);\n                await redraw();\n            } });\n\n            // Children list (locations under the current parent).\n            let lIdx = await loadEntityIndex();\n            let lKids = lIdx.filter(function(m) { return m.type === 'location' && m.parentId === (lParentId || null); });\n            if (lKids.length === 0) {\n                parts.push({ type: 'text', text: 'No locations here yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '6px' } });\n            } else {\n                for (let lk = 0; lk < lKids.length; lk++) {\n                    let kidMeta = lKids[lk];\n                    let kidEnt = await loadEntity(kidMeta.id);\n                    if (!kidEnt) continue;\n                    let kidId = kidMeta.id;\n                    let kidName = kidEnt.name;\n                    let lHintKey = STORAGE_WIZ_ITEM_HINT + kidId;\n                    let grandCount = lIdx.filter(function(m) { return m.type === 'location' && m.parentId === kidId; }).length;\n                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '6px' }, content: [\n                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [\n                            { type: 'textInput', initialValue: kidEnt.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; fe.name = v; await saveEntity(fe); } },\n                            { type: 'button', text: '↳ Into' + (grandCount ? (' (' + grandCount + ')') : ''), style: { margin: 0, fontSize: '10px', padding: '3px 8px', backgroundColor: 'rgba(136,204,255,0.12)', color: '#88ccff' }, callback: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_LOC_PARENT, kidId); await redraw(); } },\n                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() { await deleteEntity(kidId); await redraw(); } }\n                        ] },\n                        { type: 'multilineTextInput', initialValue: kidEnt.description || '', placeholder: 'Scene description (AN — short, what you sense on arrival)', style: { minHeight: '38px', marginBottom: '3px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; fe.description = v; await saveEntity(fe); } } as UIPart,\n                        { type: 'multilineTextInput', initialValue: (kidEnt as any).lorebookText || '', placeholder: '📖 Lorebook (comprehensive — history, significance, secrets)', style: { minHeight: '52px', marginBottom: '3px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; (fe as any).lorebookText = v; await saveEntity(fe); } } as UIPart,\n                        { type: 'button', text: (kidEnt as any).lorebookEntryId ? '🔗 Sync lorebook entry' : '+ Create lorebook entry', style: { width: '100%', margin: '0 0 3px 0', fontSize: '10px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() { let fe = await loadEntity(kidId); if (!fe) return; if ((fe as any).lorebookEntryId) await syncEntityLorebookEntry(kidId, false).catch(function() {}); else await createLinkedEntityLorebookEntry(kidId).catch(function() {}); await redraw(); } } as UIPart,\n                        { type: 'textInput', initialValue: (kidEnt as any).locationVisuals || '', placeholder: '🎨 Image tags (booru + plain language) — for the image pipeline', style: { margin: '0 0 3px 0', fontSize: '10px' }, onChange: async function(v: string) { let fe = await loadEntity(kidId); if (!fe) return; (fe as any).locationVisuals = v; await saveEntity(fe); } },\n                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [\n                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(lHintKey, v); } },\n                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                                let hint = await api.v1.tempStorage.getOrDefault(lHintKey, '') as string;\n                                api.v1.ui.toast('Regenerating “' + kidName + '”…', { id: 'wiz-lreg', autoClose: false, type: 'info' });\n                                let r = await regenerateWizardLocation(kidId, lEffIds, hint);\n                                api.v1.ui.toast(r ? ('Regenerated “' + kidName + '”.') : 'Regeneration failed.', { id: 'wiz-lreg', type: r ? 'success' : 'error', autoClose: 2000 });\n                                await redraw();\n                            } }\n                        ] }\n                    ] });\n                }\n            }\n        } else if (activeTab === 'characters') {\n            // ── CHARACTERS (seed-and-go: name + comprehensive dump -> fields -> create) ──\n            let ckind = 'characters';\n            let cSrcKey = STORAGE_WIZ_TAB_SRC + ckind;\n            let cStoredRaw = await api.v1.tempStorage.getOrDefault(cSrcKey, '') as string;\n            let cStoredIds: string[] = [];\n            try { let cpj = JSON.parse(cStoredRaw || '[]'); if (Array.isArray(cpj)) cStoredIds = cpj.filter(Boolean); } catch (eCSrc) { cStoredIds = []; }\n            cStoredIds = cStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });\n            let cEffIds = cStoredIds.length ? cStoredIds : (active ? [active.id] : []);\n\n            parts.push({ type: 'text', text: 'Generate characters from the selected context. Each gets a comprehensive concept dump organising everything the chat establishes about them; their dramatis-personae and static fields are then derived from that dump. New characters appear in the Characters tab — edit and regenerate individual fields there.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });\n\n            // Context sources (multi-select checkboxes).\n            parts.push({ type: 'text', text: 'Context sources' + (cStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });\n            if (chats.length === 0) {\n                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });\n            } else {\n                chats.forEach(function(pc) {\n                    let onSrc = cStoredIds.indexOf(pc.id) >= 0;\n                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {\n                        let curRaw = await api.v1.tempStorage.getOrDefault(cSrcKey, '') as string;\n                        let curIds: string[] = [];\n                        try { let cpj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(cpj2)) curIds = cpj2.filter(Boolean); } catch (eCSrc2) { curIds = []; }\n                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);\n                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });\n                        await api.v1.tempStorage.set(cSrcKey, JSON.stringify(curIds));\n                        await redraw();\n                    } } as UIPart);\n                });\n                parts.push({ type: 'text', text: '(Check one or more. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '8px' } });\n            }\n\n            // Generate N (each character runs several budget-free passes).\n            let cCountKey = STORAGE_WIZ_GEN_COUNT + ckind;\n            let cCountDraft = await api.v1.tempStorage.getOrDefault(cCountKey, 2) as number;\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [\n                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'numberInput', initialValue: cCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(cCountKey, Math.max(1, Math.min(8, v || 1))); } },\n                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let n = await api.v1.tempStorage.getOrDefault(cCountKey, 2) as number;\n                    api.v1.ui.toast('Generating ' + n + ' character(s) — a few passes each, please wait…', { id: 'wiz-char', autoClose: false, type: 'info' });\n                    let made = await runWizardCharactersBatch(n, cEffIds);\n                    api.v1.ui.toast(made > 0 ? ('Created ' + made + ' character(s).') : 'Generation failed.', { id: 'wiz-char', type: made > 0 ? 'success' : 'error', autoClose: 2500 });\n                    await redraw();\n                } }\n            ] });\n\n            // Manual add by name (ensures a specific character is generated).\n            let cNameKey = 'ae_wiz_char_addname';\n            let cNameDraft = await api.v1.tempStorage.getOrDefault(cNameKey, '') as string;\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '10px' }, content: [\n                { type: 'textInput', initialValue: cNameDraft, placeholder: 'Add a specific character by name…', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(cNameKey, v); } },\n                { type: 'button', text: '+ Generate', style: { margin: 0, fontSize: '11px', padding: '4px 10px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let nm = ((await api.v1.tempStorage.getOrDefault(cNameKey, '') as string) || '').trim();\n                    if (!nm) { api.v1.ui.toast('Enter a name first.', { type: 'error', autoClose: 2000 }); return; }\n                    api.v1.ui.toast('Generating “' + nm + '”…', { id: 'wiz-char1', autoClose: false, type: 'info' });\n                    let ok = await runWizardCharacterSingle(nm, cEffIds);\n                    api.v1.ui.toast(ok ? ('Created “' + nm + '”.') : 'Generation failed.', { id: 'wiz-char1', type: ok ? 'success' : 'error', autoClose: 2500 });\n                    if (ok) await api.v1.tempStorage.set(cNameKey, '');\n                    await redraw();\n                } }\n            ] });\n\n            // Existing character names (dedup visibility; managed in the Characters tab).\n            let cCharIdx = await loadIndex();\n            if (cCharIdx.length === 0) {\n                parts.push({ type: 'text', text: 'No characters yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });\n            } else {\n                parts.push({ type: 'text', text: 'Characters (' + cCharIdx.length + ') — generation avoids repeating these:', style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px' } });\n                cCharIdx.forEach(function(cm) {\n                    parts.push({ type: 'text', text: (cm.isProtagonist ? '★ ' : '• ') + cm.name + (cm.occupationRole ? (' — ' + cm.occupationRole) : ''), style: { fontSize: '11px', opacity: '0.85', marginBottom: '2px' } });\n                });\n            }\n            // [vNEXT] Overview of every character's daily schedule in one modal.\n            parts.push({ type: 'button', text: '\\ud83d\\udd52 View All Schedules', iconId: 'clock' as any, style: { width: '100%', marginTop: '10px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.10)' }, callback: async function() { await openAllSchedulesModal(); } } as UIPart);\n        } else if (activeTab === 'drama') {\n            // ── DRAMA (seed hooks, NPC web, narrative threads) ──\n            // [vNEXT] Seeds the three drama primitives the sidebar Drama tab + dynamic\n            // engine maintain. ONE shared context-source select feeds all three generators.\n            let dkind = 'drama';\n            let dSrcKey = STORAGE_WIZ_TAB_SRC + dkind;\n            let dStoredRaw = await api.v1.tempStorage.getOrDefault(dSrcKey, '') as string;\n            let dStoredIds: string[] = [];\n            try { let dpj = JSON.parse(dStoredRaw || '[]'); if (Array.isArray(dpj)) dStoredIds = dpj.filter(Boolean); } catch (eDSrc) { dStoredIds = []; }\n            dStoredIds = dStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });\n            let dEffIds = dStoredIds.length ? dStoredIds : (active ? [active.id] : []);\n            let dramaChars = await loadAllCharacters();\n\n            parts.push({ type: 'text', text: 'Seed the dramatic engine across the cast: directed hooks, bilateral web dynamics, and narrative threads. Generators read the cast plus the chosen context. Full editing of each lives in the sidebar Drama tab — this establishes the opening state.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '8px' } });\n\n            if (dramaChars.length === 0) {\n                parts.push({ type: 'text', text: 'No characters yet — create the cast in the Characters tab before seeding hooks or web dynamics.', style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '8px' } });\n            }\n\n            // Shared context sources (multi-select).\n            parts.push({ type: 'text', text: 'Context sources' + (dStoredIds.length ? '' : (active ? ' — none checked, using active chat “' + active.title + '”' : ' — none, project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });\n            if (chats.length === 0) {\n                parts.push({ type: 'text', text: 'No chats yet — generation uses project concept only.', style: { fontSize: '10px', opacity: '0.45', fontStyle: 'italic', marginBottom: '8px' } });\n            } else {\n                chats.forEach(function(pc) {\n                    let onDSrc = dStoredIds.indexOf(pc.id) >= 0;\n                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onDSrc, onChange: async function(val: boolean) {\n                        let dCurRaw = await api.v1.tempStorage.getOrDefault(dSrcKey, '') as string;\n                        let dCurIds: string[] = [];\n                        try { let dpj2 = JSON.parse(dCurRaw || '[]'); if (Array.isArray(dpj2)) dCurIds = dpj2.filter(Boolean); } catch (eDSrc2) { dCurIds = []; }\n                        if (val && dCurIds.indexOf(pc.id) < 0) dCurIds.push(pc.id);\n                        else if (!val) dCurIds = dCurIds.filter(function(x) { return x !== pc.id; });\n                        await api.v1.tempStorage.set(dSrcKey, JSON.stringify(dCurIds));\n                        await redraw();\n                    } } as UIPart);\n                });\n                parts.push({ type: 'text', text: '(Shared by all three generators below. Leave all unchecked to use the active chat.)', style: { fontSize: '9px', opacity: '0.4', marginBottom: '10px' } });\n            }\n\n            // ===== 1. HOOKS =====\n            parts.push({ type: 'text', text: '🔥 Hooks', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#e8a87c' } });\n            parts.push({ type: 'text', text: 'One directed opening tension per character (pressure 20–50, matching what the engine spawns mid-play). Check who to seed, then generate.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });\n\n            let hookSelRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;\n            let hookSelIds: string[] = [];\n            try { let hsp = JSON.parse(hookSelRaw || '[]'); if (Array.isArray(hsp)) hookSelIds = hsp.filter(Boolean); } catch (eHookSel) { hookSelIds = []; }\n            hookSelIds = hookSelIds.filter(function(id) { return dramaChars.some(function(c) { return c.id === id; }); });\n            let hookCandidates = dramaChars.filter(function(c) { return c.active; });\n\n            hookCandidates.forEach(function(hc) {\n                let curHook = (hc.hooks && hc.hooks.length) ? hc.hooks[0] : null;\n                let onHook = hookSelIds.indexOf(hc.id) >= 0;\n                let hookSubtitle = curHook ? ('▸ ' + (curHook.targetName === '__player__' ? 'the player' : (curHook.targetName || '?')) + ' · ' + curHook.pressureLevel + '% — ' + curHook.description) : '(no hook yet)';\n                let hookBox: UIPart[] = [\n                    { type: 'row', alignment: 'center', style: { gap: '6px' }, content: [\n                        { type: 'checkboxInput', label: '', initialValue: onHook, onChange: async function(val: boolean) {\n                            let hCurRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;\n                            let hCurIds: string[] = [];\n                            try { let hsp2 = JSON.parse(hCurRaw || '[]'); if (Array.isArray(hsp2)) hCurIds = hsp2.filter(Boolean); } catch (eHookSel2) { hCurIds = []; }\n                            if (val && hCurIds.indexOf(hc.id) < 0) hCurIds.push(hc.id);\n                            else if (!val) hCurIds = hCurIds.filter(function(x) { return x !== hc.id; });\n                            await api.v1.tempStorage.set(STORAGE_WIZ_HOOK_CHARS, JSON.stringify(hCurIds));\n                            await redraw();\n                        } } as UIPart,\n                        { type: 'text', text: (hc.isProtagonist ? '★ ' : '') + hc.name, style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold' } },\n                        { type: 'button', text: '⚡ Reseed', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                            api.v1.ui.toast('Seeding hook for ' + hc.name + '…', { id: 'wiz-hook1', autoClose: false, type: 'info' });\n                            let hOk = await runWizardHookSingle(hc.id, dEffIds, '');\n                            api.v1.ui.toast(hOk ? ('Hook seeded for ' + hc.name + '.') : 'No clean tension found.', { id: 'wiz-hook1', type: hOk ? 'success' : 'warning', autoClose: 2500 });\n                            await redraw();\n                        } }\n                    ] },\n                    { type: 'text', text: hookSubtitle, style: { fontSize: '10px', opacity: curHook ? '0.8' : '0.4', fontStyle: curHook ? 'normal' : 'italic', marginTop: '2px', lineHeight: '1.3' } }\n                ];\n                if (curHook) {\n                    hookBox.push({ type: 'button', text: '✕ Clear hook', style: { margin: '3px 0 0 0', fontSize: '9px', padding: '2px 6px', backgroundColor: 'transparent', color: '#ff6b6b', opacity: '0.85' }, callback: async function() {\n                        let fh = await loadCharacter(hc.id);\n                        if (fh) { fh.hooks = []; await saveCharacter(fh); }\n                        await redraw();\n                    } });\n                }\n                parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: hookBox });\n            });\n\n            if (hookCandidates.length > 0) {\n                parts.push({ type: 'button', text: '⚡ Seed hooks for checked characters', style: { width: '100%', margin: '2px 0 16px 0', fontSize: '11px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let hbRaw = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_HOOK_CHARS, '') as string;\n                    let hbIds: string[] = [];\n                    try { let hsp3 = JSON.parse(hbRaw || '[]'); if (Array.isArray(hsp3)) hbIds = hsp3.filter(Boolean); } catch (eHookSel3) { hbIds = []; }\n                    if (hbIds.length === 0) { api.v1.ui.toast('Check at least one character first.', { type: 'info', autoClose: 2000 }); return; }\n                    api.v1.ui.toast('Seeding ' + hbIds.length + ' hook(s)…', { id: 'wiz-hooks', autoClose: false, type: 'info' });\n                    let hbMade = await runWizardHooksBatch(hbIds, dEffIds);\n                    api.v1.ui.toast(hbMade > 0 ? ('Seeded ' + hbMade + ' hook(s).') : 'No clean tensions found.', { id: 'wiz-hooks', type: hbMade > 0 ? 'success' : 'warning', autoClose: 2500 });\n                    await redraw();\n                } });\n            }\n\n            // ===== 2. NPC WEB =====\n            parts.push({ type: 'text', text: '🕸 NPC Web', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#88ccff' } });\n            parts.push({ type: 'text', text: 'Bilateral dynamics between cast members. Generated pairs are mapped to real characters; self-pairs and duplicates are skipped.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });\n\n            let webCountKey = STORAGE_WIZ_GEN_COUNT + 'web';\n            let webCountDraft = await api.v1.tempStorage.getOrDefault(webCountKey, 3) as number;\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [\n                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'numberInput', initialValue: webCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(webCountKey, Math.max(1, Math.min(12, v || 1))); } },\n                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.15)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    if (dramaChars.length < 2) { api.v1.ui.toast('Need at least two characters.', { type: 'error', autoClose: 2000 }); return; }\n                    let wn = await api.v1.tempStorage.getOrDefault(webCountKey, 3) as number;\n                    api.v1.ui.toast('Generating ' + wn + ' web dynamic(s)…', { id: 'wiz-web', autoClose: false, type: 'info' });\n                    let wMade = await runWizardWebBatch(wn, dEffIds);\n                    api.v1.ui.toast(wMade > 0 ? ('Added ' + wMade + ' web link(s).') : 'No new links resolved.', { id: 'wiz-web', type: wMade > 0 ? 'success' : 'warning', autoClose: 2500 });\n                    await redraw();\n                } }\n            ] });\n\n            let dramaWeb = await loadNpcWeb();\n            if (dramaWeb.length === 0) {\n                parts.push({ type: 'text', text: 'No web links yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic', marginBottom: '14px' } });\n            } else {\n                dramaWeb.forEach(function(wl) {\n                    let wlA = dramaChars.find(function(c) { return c.id === wl.charA_id; });\n                    let wlB = dramaChars.find(function(c) { return c.id === wl.charB_id; });\n                    let wlHintKey = STORAGE_WIZ_ITEM_HINT + wl.id;\n                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: [\n                        { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '3px' }, content: [\n                            { type: 'text', text: (wlA ? wlA.name : '?') + ' ⇄ ' + (wlB ? wlB.name : '?'), style: { flex: '1 1 0', fontSize: '12px', fontWeight: 'bold', color: '#88ccff' } },\n                            { type: 'text', text: wl.priority + '%', style: { fontSize: '10px', opacity: '0.6' } },\n                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {\n                                let wFresh = await loadNpcWeb();\n                                let wIdx = wFresh.findIndex(function(x) { return x.id === wl.id; });\n                                if (wIdx >= 0) { wFresh.splice(wIdx, 1); await saveNpcWeb(wFresh); }\n                                await redraw();\n                            } }\n                        ] },\n                        { type: 'text', text: wl.dynamic || '(no dynamic yet)', style: { fontSize: '11px', opacity: wl.dynamic ? '0.85' : '0.4', fontStyle: wl.dynamic ? 'normal' : 'italic', lineHeight: '1.3', marginBottom: '4px' } },\n                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [\n                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(wlHintKey, v); } },\n                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                                let wHint = await api.v1.tempStorage.getOrDefault(wlHintKey, '') as string;\n                                api.v1.ui.toast('Regenerating dynamic…', { id: 'wiz-webreg', autoClose: false, type: 'info' });\n                                let wr = await regenerateWebLink(wl.id, dEffIds, wHint);\n                                api.v1.ui.toast(wr ? 'Dynamic updated.' : 'Regeneration failed.', { id: 'wiz-webreg', type: wr ? 'success' : 'error', autoClose: 2000 });\n                                await redraw();\n                            } }\n                        ] }\n                    ] });\n                });\n                parts.push({ type: 'box', style: { marginBottom: '14px' }, content: [] });\n            }\n\n            // ===== 3. NARRATIVE THREADS =====\n            parts.push({ type: 'text', text: '📜 Narrative Threads', style: { fontWeight: 'bold', fontSize: '13px', marginTop: '4px', marginBottom: '3px', color: '#ffb432' } });\n            parts.push({ type: 'text', text: 'Opening plot threads (quests, mysteries, obligations). Created at the top level — nest and re-state them in the sidebar Drama tab afterward.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '6px' } });\n\n            let narrCountKey = STORAGE_WIZ_GEN_COUNT + 'narrative';\n            let narrCountDraft = await api.v1.tempStorage.getOrDefault(narrCountKey, 3) as number;\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '8px' }, content: [\n                { type: 'text', text: 'How many:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'numberInput', initialValue: narrCountDraft, style: { width: '64px', margin: 0 }, onChange: async function(v: number) { await api.v1.tempStorage.set(narrCountKey, Math.max(1, Math.min(12, v || 1))); } },\n                { type: 'button', text: '⚡ Generate', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(255,180,50,0.15)', color: '#ffb432' }, disabledWhileCallbackRunning: true, callback: async function() {\n                    let nn = await api.v1.tempStorage.getOrDefault(narrCountKey, 3) as number;\n                    api.v1.ui.toast('Generating ' + nn + ' thread(s)…', { id: 'wiz-narr', autoClose: false, type: 'info' });\n                    let nMade = await runWizardNarrativesBatch(nn, dEffIds);\n                    api.v1.ui.toast(nMade > 0 ? ('Created ' + nMade + ' thread(s).') : 'Generation failed.', { id: 'wiz-narr', type: nMade > 0 ? 'success' : 'error', autoClose: 2500 });\n                    await redraw();\n                } }\n            ] });\n\n            parts.push({ type: 'button', text: '+ Add blank thread', style: { width: '100%', marginBottom: '8px', fontSize: '11px', opacity: '0.85' }, disabledWhileCallbackRunning: true, callback: async function() {\n                await addBlankWizardNarrative();\n                await redraw();\n            } });\n\n            let dramaNarrIdx = await loadEntityIndex();\n            let dramaNarratives = dramaNarrIdx.filter(function(n) { return n.type === 'narrative' && (n.narrativeParentId || null) === null; });\n            if (dramaNarratives.length === 0) {\n                parts.push({ type: 'text', text: 'No top-level threads yet.', style: { fontSize: '11px', opacity: '0.4', fontStyle: 'italic' } });\n            } else {\n                dramaNarratives.forEach(function(nm) {\n                    let nStateEmoji = nm.storyState === 'active' ? '🔥' : (nm.storyState === 'completed' ? '✅' : '🔒');\n                    let nHintKey = STORAGE_WIZ_ITEM_HINT + nm.id;\n                    parts.push({ type: 'box', style: { backgroundColor: 'rgba(0,0,0,0.2)', padding: '7px', borderRadius: '5px', marginBottom: '5px' }, content: [\n                        { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '3px' }, content: [\n                            { type: 'text', text: nStateEmoji, style: { fontSize: '12px' } },\n                            { type: 'textInput', initialValue: nm.name, style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { let nf = await loadEntity(nm.id); if (nf) { nf.name = v; await saveEntity(nf); } } },\n                            { type: 'button', iconId: 'edit', style: { margin: 0, padding: '2px' }, callback: async function() { await openEntityEditModal(nm.id); } },\n                            { type: 'button', iconId: 'trash', style: { margin: 0, padding: '2px' }, callback: async function() {\n                                await deleteEntity(nm.id);\n                                await redraw();\n                            } }\n                        ] },\n                        { type: 'row', alignment: 'center', style: { gap: '4px' }, content: [\n                            { type: 'textInput', placeholder: 'Regen hint (optional)', initialValue: '', style: { flex: '1 1 0', margin: 0, fontSize: '10px' }, onChange: async function(v: string) { await api.v1.tempStorage.set(nHintKey, v); } },\n                            { type: 'button', text: '⚡ Regen', style: { margin: 0, fontSize: '10px', padding: '3px 8px' }, disabledWhileCallbackRunning: true, callback: async function() {\n                                let nHint = await api.v1.tempStorage.getOrDefault(nHintKey, '') as string;\n                                api.v1.ui.toast('Regenerating “' + nm.name + '”…', { id: 'wiz-narrreg', autoClose: false, type: 'info' });\n                                let nr = await regenerateNarrativeThread(nm.id, dEffIds, nHint);\n                                api.v1.ui.toast(nr ? ('Updated “' + nm.name + '”.') : 'Regeneration failed.', { id: 'wiz-narrreg', type: nr ? 'success' : 'error', autoClose: 2000 });\n                                await redraw();\n                            } }\n                        ] }\n                    ] });\n                });\n            }\n\n        } else if (activeTab === 'intro') {\n            // ── INTRO / OPENING (unified location picker, generate & insert) ──\n            // [v0.9.86] Cast presence removed — set character locations in their character cards.\n            let ikind = 'intro';\n            let introLocId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;\n            let introLocEnt = introLocId ? await loadEntity(introLocId) : null;\n            if (introLocId && !introLocEnt) { introLocId = ''; await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, ''); }\n\n            parts.push({ type: 'text', text: '🎬 Opening scene', style: { fontWeight: 'bold', fontSize: '13px', marginBottom: '2px' } });\n            parts.push({ type: 'text', text: 'Choose the opening location and brainstorming context, then generate a draft opening. Review, edit, or regenerate it below before committing it into the story. Set which characters are present via their character cards.', style: { fontSize: '10px', opacity: '0.55', marginBottom: '10px' } });\n\n            // Location: unified picker button.\n            parts.push({ type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '10px' }, content: [\n                { type: 'text', text: '📍 Location:', style: { fontSize: '11px', opacity: '0.7', flexShrink: '0' } },\n                { type: 'button',\n                  text: introLocEnt ? introLocEnt.name : 'Pick location…',\n                  style: { flex: '1 1 0', margin: 0, fontSize: '11px', textAlign: 'left',\n                           backgroundColor: introLocEnt ? 'rgba(136,204,255,0.15)' : 'transparent',\n                           color: introLocEnt ? '#88ccff' : 'rgba(255,255,255,0.5)',\n                           border: '1px solid ' + (introLocEnt ? '#88ccff' : 'rgba(255,255,255,0.2)') },\n                  callback: async function() {\n                    let iLocIdx = (await loadEntityIndex()).filter(function(m) { return m.type === 'location'; });\n                    let curILocId = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;\n                    await openPickerModal({\n                        title: 'Intro location',\n                        items: iLocIdx,\n                        getId:       function(m) { return m.id; },\n                        getLabel:    function(m) { return m.name; },\n                        getIcon:     function(m) { return m.icon || '📍'; },\n                        getSublabel: function(m) {\n                            if (!m.parentId) return 'top-level';\n                            let par = iLocIdx.find(function(x) { return x.id === m.parentId; });\n                            return par ? ('in ' + par.name) : '';\n                        },\n                        selectedId:    curILocId || undefined,\n                        emptyText:     'No locations yet — build some in the Locations tab first.',\n                        pinnedOptions: curILocId ? [{ id: '__clear__', label: 'Clear selection', icon: '✕', onSelect: async function() { await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, ''); await redraw(); } }] : [],\n                        onSelect: async function(lm) { await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_LOC, lm.id); await redraw(); }\n                    });\n                  } } as UIPart\n            ] });\n\n            // Context sources (multi-select checkboxes).\n            let iSrcKey = STORAGE_WIZ_TAB_SRC + ikind;\n            let iStoredRaw = await api.v1.tempStorage.getOrDefault(iSrcKey, '') as string;\n            let iStoredIds: string[] = [];\n            try { let ipj = JSON.parse(iStoredRaw || '[]'); if (Array.isArray(ipj)) iStoredIds = ipj.filter(Boolean); } catch (eISrc) { iStoredIds = []; }\n            iStoredIds = iStoredIds.filter(function(id) { return chats.some(function(c) { return c.id === id; }); });\n            let iEffIds = iStoredIds.length ? iStoredIds : (active ? [active.id] : []);\n            parts.push({ type: 'text', text: 'Context sources' + (iStoredIds.length ? '' : (active ? ' — using “' + active.title + '”' : ' — project concept only')) + ':', style: { fontSize: '10px', opacity: '0.7', marginBottom: '2px' } });\n            if (chats.length > 0) {\n                chats.forEach(function(pc) {\n                    let onSrc = iStoredIds.indexOf(pc.id) >= 0;\n                    parts.push({ type: 'checkboxInput', label: pc.title, initialValue: onSrc, onChange: async function(val: boolean) {\n                        let curRaw = await api.v1.tempStorage.getOrDefault(iSrcKey, '') as string;\n                        let curIds: string[] = [];\n                        try { let ipj2 = JSON.parse(curRaw || '[]'); if (Array.isArray(ipj2)) curIds = ipj2.filter(Boolean); } catch (eISrc2) { curIds = []; }\n                        if (val && curIds.indexOf(pc.id) < 0) curIds.push(pc.id);\n                        else if (!val) curIds = curIds.filter(function(x) { return x !== pc.id; });\n                        await api.v1.tempStorage.set(iSrcKey, JSON.stringify(curIds));\n                        await redraw();\n                    } } as UIPart);\n                });\n            }\n\n            // [v1.6.3 INTRO-STAGE] Staged workflow: generate a draft, review / edit / regenerate\n            // it in-tab, then commit into the story — matching the other wizard tabs.\n            let introDraft = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_DRAFT, null) as any;\n            let introHasDraft = !!(introDraft && ((introDraft.prose || '') as string).trim());\n\n            parts.push({ type: 'button', text: introHasDraft ? '🔄 Regenerate opening draft' : '🎬 Generate opening draft', style: { width: '100%', margin: '10px 0 0 0', fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.18)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n                let locPick = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_LOC, '') as string;\n                if (!locPick) { api.v1.ui.toast('Pick an intro location first.', { type: 'error', autoClose: 2500 }); return; }\n                api.v1.ui.toast('Writing the opening…', { id: 'wiz-intro', autoClose: false, type: 'info' });\n                let okGen = await generateIntroDraft(locPick, iEffIds);\n                api.v1.ui.toast(okGen ? 'Draft ready — review and edit below.' : 'Intro generation failed.', { id: 'wiz-intro', type: okGen ? 'success' : 'error', autoClose: 3000 });\n                await redraw();\n            } });\n\n            if (introHasDraft) {\n                parts.push({ type: 'text', text: '📝 Draft opening — edit freely, then commit:', style: { fontSize: '11px', fontWeight: 'bold', marginTop: '12px', marginBottom: '4px', color: '#88ccff' } });\n                parts.push({ type: 'multilineTextInput', initialValue: String(introDraft.prose || ''), placeholder: 'The opening prose\\u2026', style: { minHeight: '160px', fontSize: '12px', lineHeight: '1.5' }, onChange: async function(v: string) {\n                    let cur = await api.v1.tempStorage.getOrDefault(STORAGE_WIZ_INTRO_DRAFT, null) as any;\n                    if (!cur || typeof cur !== 'object') cur = { locationId: '', prose: '' };\n                    cur.prose = v;\n                    await api.v1.tempStorage.set(STORAGE_WIZ_INTRO_DRAFT, cur).catch(function() {});\n                } } as UIPart);\n                parts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginTop: '8px' }, content: [\n                    { type: 'button', text: '\\u2705 Commit to story', style: { flex: '2 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.22)', color: '#7ec8a0', border: '1px solid rgba(126,200,160,0.5)' }, disabledWhileCallbackRunning: true, callback: async function() {\n                        api.v1.ui.toast('Inserting the opening\\u2026', { id: 'wiz-intro-commit', autoClose: false, type: 'info' });\n                        let okC = await commitIntroDraft();\n                        api.v1.ui.toast(okC ? 'Opening inserted into the story.' : 'Commit failed.', { id: 'wiz-intro-commit', type: okC ? 'success' : 'error', autoClose: 3000 });\n                        await redraw();\n                    } },\n                    { type: 'button', text: '\\ud83d\\uddd1 Discard', style: { flex: '1 1 0', margin: 0, fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() {\n                        await api.v1.tempStorage.remove(STORAGE_WIZ_INTRO_DRAFT).catch(function() {});\n                        api.v1.ui.toast('Draft discarded.', { type: 'info', autoClose: 1800 });\n                        await redraw();\n                    } }\n                ] });\n            }\n        } else if (activeTab === 'help') {\n            // ── HELP & RULES [v0.9.8.3] ──────────────────────────────────────────────────────────────\n            parts.push({ type: 'text', text: 'Risky actions are resolved by rolling 2d6 and adding the modifier from whichever of the Four Fs the action calls on. The result lands in one of three bands that quietly tell the AI how the scene turns out.', style: { fontSize: '12px', opacity: '0.75', lineHeight: '1.5', marginBottom: '10px' } });\n\n            // — Four Fs —\n            parts.push({ type: 'collapsibleSection', title: 'The Four Fs', iconId: 'user', initialCollapsed: false, storageKey: 'temp:wiz_help_fourfs', content: [\n                { type: 'text', text: 'Every action leans on one attribute. The character\\'s rating in that attribute is the modifier added to the 2d6 roll.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } },\n                { type: 'row', style: { flexWrap: 'wrap', gap: '6px' }, content: [\n                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(136,204,255,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(136,204,255,0.4)' }, content: [\n                        { type: 'text', text: 'Force', style: { fontWeight: 'bold', color: '#88ccff', marginBottom: '3px' } },\n                        { type: 'text', text: 'Raw power and direct pressure — breaking, lifting, intimidating, overpowering, enduring.', style: { fontSize: '10px', opacity: '0.8' } }\n                    ] } as UIPart,\n                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(126,200,160,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(126,200,160,0.4)' }, content: [\n                        { type: 'text', text: 'Finesse', style: { fontWeight: 'bold', color: '#7ec8a0', marginBottom: '3px' } },\n                        { type: 'text', text: 'Precision and control — sleight of hand, stealth, agility, aim, delicate work.', style: { fontSize: '10px', opacity: '0.8' } }\n                    ] } as UIPart,\n                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(232,168,124,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(232,168,124,0.4)' }, content: [\n                        { type: 'text', text: 'Focus', style: { fontWeight: 'bold', color: '#e8a87c', marginBottom: '3px' } },\n                        { type: 'text', text: 'Mind and will — perception, recall, analysis, concentration, resolve.', style: { fontSize: '10px', opacity: '0.8' } }\n                    ] } as UIPart,\n                    { type: 'box', style: { flex: '1 1 120px', padding: '7px', backgroundColor: 'rgba(200,126,200,0.06)', borderRadius: '6px', borderLeft: '3px solid rgba(200,126,200,0.4)' }, content: [\n                        { type: 'text', text: 'Flair', style: { fontWeight: 'bold', color: '#c87ec8', marginBottom: '3px' } },\n                        { type: 'text', text: 'Presence and charm — persuasion, performance, deception, style, improvisation.', style: { fontSize: '10px', opacity: '0.8' } }\n                    ] } as UIPart\n                ] }\n            ] as any });\n\n            // — Stakes —\n            parts.push({ type: 'collapsibleSection', title: '2d6 + Modifier (Stakes)', iconId: 'activity', initialCollapsed: false, storageKey: 'temp:wiz_help_stakes', content: [\n                { type: 'text', text: 'Roll 2d6 and add the relevant F. Higher is better. Even a failure pushes the story forward. A staked resource shifts on partial or strong results.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } },\n                { type: 'box', style: { padding: '7px', marginBottom: '4px', backgroundColor: 'rgba(0,0,0,0.25)', borderRadius: '6px', borderLeft: '3px solid #e74c4c' }, content: [\n                    { type: 'text', text: '2–6  Failure', style: { fontWeight: 'bold', color: '#e74c4c', marginBottom: '3px' } },\n                    { type: 'text', text: 'The attempt fails. Describe the setback honestly — let it create a complication.', style: { fontSize: '11px', opacity: '0.8' } }\n                ] } as UIPart,\n                { type: 'box', style: { padding: '7px', marginBottom: '4px', backgroundColor: 'rgba(0,0,0,0.25)', borderRadius: '6px', borderLeft: '3px solid #e0b341' }, content: [\n                    { type: 'text', text: '7–9  Partial Success', style: { fontWeight: 'bold', color: '#e0b341', marginBottom: '3px' } },\n                    { type: 'text', text: 'Success at a cost. Describe what the protagonist must risk, pay, or sacrifice.', style: { fontSize: '11px', opacity: '0.8' } }\n                ] } as UIPart,\n                { type: 'box', style: { padding: '7px', backgroundColor: 'rgba(0,0,0,0.25)', borderRadius: '6px', borderLeft: '3px solid #7ec8a0' }, content: [\n                    { type: 'text', text: '10+  Strong Hit', style: { fontWeight: 'bold', color: '#7ec8a0', marginBottom: '3px' } },\n                    { type: 'text', text: 'Clean success — no cost, no complication.', style: { fontSize: '11px', opacity: '0.8' } }\n                ] } as UIPart\n            ] as any });\n\n            // — Test Roller (state via tempStorage so it survives redraws) —\n            let rollMod = await api.v1.tempStorage.getOrDefault('temp:wiz_help_mod', 0) as number;\n            let rollD1  = await api.v1.tempStorage.getOrDefault('temp:wiz_help_d1',  0) as number;\n            let rollD2  = await api.v1.tempStorage.getOrDefault('temp:wiz_help_d2',  0) as number;\n            let hasRolled = rollD1 > 0 && rollD2 > 0;\n            let rollTotal = rollD1 + rollD2 + rollMod;\n            let rDist: number[] = [0, 0, 1, 2, 3, 4, 5, 6, 5, 4, 3, 2, 1];\n            let rFail = 0, rPart = 0, rStrong = 0;\n            for (let rs = 2; rs <= 12; rs++) { let rt = rs + rollMod; let rc = rDist[rs]; if (rt <= 6) rFail += rc; else if (rt <= 9) rPart += rc; else rStrong += rc; }\n            let rPct = function(n: number) { return (Math.round(n * 1000 / 36) / 10).toFixed(1); };\n            let rBandLabel = rollTotal <= 6 ? 'Failure' : rollTotal <= 9 ? 'Partial Success' : 'Strong Hit';\n            let rBandColor = rollTotal <= 6 ? '#e74c4c' : rollTotal <= 9 ? '#e0b341' : '#7ec8a0';\n            let modDisp = rollMod === 0 ? '±0' : (rollMod > 0 ? '+' + rollMod : String(rollMod));\n            let modStr3 = rollMod === 0 ? '' : (rollMod > 0 ? ' +' + rollMod : ' ' + rollMod);\n            let rollerParts: UIPart[] = [\n                { type: 'text', text: 'Sandbox — changes nothing in your story. Adjust the modifier and roll to see the outcome band.', style: { fontSize: '11px', opacity: '0.65', marginBottom: '8px' } },\n                { type: 'row', alignment: 'center', style: { gap: '8px', marginBottom: '4px' }, content: [\n                    { type: 'button', text: '−', style: { margin: 0, padding: '2px 12px', fontSize: '16px', fontWeight: 'bold' }, callback: async function() { await api.v1.tempStorage.set('temp:wiz_help_mod', Math.max(-6, rollMod - 1)); await redraw(); } },\n                    { type: 'text', text: 'Modifier ' + modDisp, style: { fontSize: '14px', fontWeight: 'bold', minWidth: '90px', textAlign: 'center' } },\n                    { type: 'button', text: '+', style: { margin: 0, padding: '2px 12px', fontSize: '16px', fontWeight: 'bold' }, callback: async function() { await api.v1.tempStorage.set('temp:wiz_help_mod', Math.min(6, rollMod + 1)); await redraw(); } }\n                ] },\n                { type: 'text', text: 'fail ' + rPct(rFail) + '% · partial ' + rPct(rPart) + '% · strong ' + rPct(rStrong) + '%', style: { fontSize: '10px', opacity: '0.55', textAlign: 'center', marginBottom: '8px' } },\n                { type: 'button', text: 'Roll 2d6', iconId: 'zap', style: { width: '100%', fontSize: '13px', fontWeight: 'bold', backgroundColor: 'rgba(136,204,255,0.18)', color: '#88ccff', marginBottom: '6px' }, callback: async function() {\n                    let d1r = Math.floor(Math.random() * 6) + 1;\n                    let d2r = Math.floor(Math.random() * 6) + 1;\n                    await api.v1.tempStorage.set('temp:wiz_help_d1', d1r);\n                    await api.v1.tempStorage.set('temp:wiz_help_d2', d2r);\n                    await redraw();\n                } },\n                hasRolled\n                    ? ({ type: 'text', text: rollD1 + ' + ' + rollD2 + modStr3 + ' = ' + rollTotal + '  →  ' + rBandLabel, style: { fontSize: '15px', fontWeight: 'bold', textAlign: 'center', color: rBandColor } } as UIPart)\n                    : ({ type: 'text', text: 'Roll to see the result.', style: { fontSize: '12px', opacity: '0.35', textAlign: 'center', fontStyle: 'italic' } } as UIPart)\n            ];\n            parts.push({ type: 'collapsibleSection', title: 'Test Roller', iconId: 'zap', initialCollapsed: false, storageKey: 'temp:wiz_help_roller', content: rollerParts } as any);\n\n            // — Icon Library —\n            let iconIds: string[] = ['play','pause','save','download','upload','edit','delete','trash','add','plus','settings','info','warning','error','alert','success','check','home','user','search','refresh','reload','copy','eye','eye-off','hide','show','lock','unlock','mail','email','file','folder','image','code','send','close','x','chevron-right','chevron-left','chevron-up','chevron-down','right','left','up','down','list','grid','star','heart','favorite','filter','calendar','clock','time','zap','lightning','square','hexagon','help','trending-up','trending-down','file-minus','file-plus','file-text','folder-plus','folder-minus','activity','alertOctagon','alertTriangle','align-center','align-justify','align-left','align-right','anchor','archive','arrow-down','arrow-down-circle','arrow-down-left','arrow-down-right','arrow-left','arrow-left-circle','arrow-right','arrow-right-circle','arrow-up','arrow-up-circle','arrow-up-left','arrow-up-right','at-sign','award','bar-chart','bar-chart-2','battery','batteryCharging','bell','bell-off','bold','book','bookOpen','bookmark','box','breifcase','camera','cameraOff','check-circle','check-square','chevrons-down','chevrons-left','chevrons-right','chevrons-up','circle','clipboard','cloud','cloud-drizzle','cloud-lightning','cloud-off','cloud-rain','cloud-snow','coffee','columns','command','compass','corner-down-left','corner-down-right','corner-left-down','corner-left-up','corner-right-down','corner-right-up','corner-up-left','corner-up-right','cpu','crop','crosshair','database','disc','divide','divide-circle','divide-square','dollar-sign','download-cloud','droplet','edit-2','edit-3','external-link','fast-forward','feather','film','flag','frown','gift','globe','hard-drive','hash','headphones','help-circle','inbox','italic','key','layers','layout','life-buoy','link','link-2','loader','login','logout','map','map-pin','maximize','maximize-2','meh','menu','message-circle','message-square','mic','mic-off','minimize','minimize-2','minus','minus-circle','minus-square','monitor','moon','more-horizontal','more-vertical','mouse-pointer','move','music','navigation-2','navigation','octagon','package','paperclip','pause-circle','pen-tool','percent','phone','pie-chart','play-circle','plus-circle','plus-square','pocket','power','printer','radio','refresh-cw','refresh-ccw','repeat','rewind','rotate-ccw','rotate-cw','rss','scissors','server','share','share-2','shield','shield-off','shopping-bag','shopping-cart','shuffle','sidebar','skip-back','skip-forward','slash','sliders','smartphone','smile','speaker','stop-circle','sun','sunrise','sunset','tablet','tag','target','terminal','thermometer','thumbs-down','thumbs-up','toggle-left','toggle-right','tool','trash-2','triangle','truck','tv','type','x-square','x-octagon','zap-off','zoom-in','zoom-out'];\n            let iconBtns: UIPart[] = iconIds.map(function(ic) {\n                return { type: 'button', iconId: ic as any, text: ic, style: { margin: '2px', fontSize: '10px', padding: '3px 7px', textAlign: 'left', backgroundColor: 'transparent', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '4px', opacity: '0.8' }, callback: async function() {} } as UIPart;\n            });\n            parts.push({ type: 'collapsibleSection', title: 'Icon Library (' + iconIds.length + ' icons)', iconId: 'grid', initialCollapsed: true, storageKey: 'temp:wiz_help_icons', content: [\n                { type: 'text', text: 'All Feather icons available via the NAI iconId enum. Use these string values for iconId on tabs, buttons, and collapsible sections.', style: { fontSize: '10px', opacity: '0.6', marginBottom: '8px' } },\n                { type: 'row', style: { flexWrap: 'wrap', gap: '2px' }, content: iconBtns }\n            ] as any });\n        }\n        return parts;\n    }\n\n    let initialContent = await buildWizardContent();\n    pm = await openEngineModal({ id: 'ae-wizard', title: 'World-Build Wizard', size: 'large', content: initialContent });\n}\n\nasync function openWorldbuildingModal(): Promise<void> {\n    if (worldbuildingModalHandle && !worldbuildingModalHandle.isClosed()) worldbuildingModalHandle.close();\n    worldbuildingModalHandle = await openEngineModal({ id: 'ae-worldbuilding', size: 'full', fillWidth: true, title: '🌍 Adventure Engine: Worldbuilding', content: await buildWorldbuildingContent() });\n}\n\nasync function buildWorldbuildingContent(): Promise<UIPart[]> {\n    const cfg = await loadConfig(); const parts: UIPart[] = [];\n\n    // 1. Introduction\n    parts.push({ type: 'collapsibleSection', title: '📖 Introduction & Setup', initialCollapsed: false, storageKey: 'temp:wb_intro', content: [\n        { type: 'text', text: 'Welcome to Adventure Engine!', style: { fontWeight: 'bold', fontSize: '14px', marginBottom: '8px', color: '#88ccff' } },\n        { type: 'text', text: '1. A toast should have popped up saying the bridge connected, and a 🗺️AE widget should appear to open the HUD. If it doesn\\'t after refreshing the browser, notify AmbiProp on the NovelAI Discord for troubleshooting.', style: { fontSize: '12px', marginBottom: '6px' } },\n        { type: 'text', text: '2. The settings below let you define the rules, species, factions, and sheet categories of your world.', style: { fontSize: '12px', marginBottom: '6px' } },\n        { type: 'text', text: '3. Character data is recorded in the Characters tab, but their physical \"body\" is automatically created in the Worlds tab. The player interacts via the HUD and also has a body in the world graph.', style: { fontSize: '12px', marginBottom: '6px' } },\n        { type: 'text', text: '4. Check the ⚙️ Settings menu for configurable generation and timing behaviors.', style: { fontSize: '12px', marginBottom: '6px' } },\n        { type: 'text', text: '5. The Worlds tab uses a nested, nodular hierarchy. Locations can contain items, narratives, and characters. You navigate this tree to build your map.', style: { fontSize: '12px', marginBottom: '6px' } },\n        { type: 'text', text: '6. The Actions tab provides interactive mechanics that roll dice against stats and execute outcomes.', style: { fontSize: '12px', marginBottom: '6px' } },\n        { type: 'text', text: '7. All player interfaces, player character info, and images exist inside the Bridge HUD.', style: { fontSize: '12px', marginBottom: '6px' } },\n        { type: 'text', text: '💡 Suggestion: Start by creating a character, then go to the Worlds tab to see where they (and you) are located. Explore the HUD to see how it reflects the character and worlds tabs!', style: { fontSize: '12px', fontStyle: 'italic', marginTop: '8px', color: '#e8a87c' } }\n    ]});\n\n    // 2. Species\n    parts.push({ type: 'collapsibleSection', title: `🧬 Species (${(cfg.species || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_species', content: await (async function() {\n        const spParts: UIPart[] = [];\n        spParts.push({ type: 'text', text: 'Define species available as a selector on character cards. Create lorebook entries to give the AI detailed knowledge of each.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });\n        for (var si = 0; si < (cfg.species || []).length; si++) {\n            var sp = cfg.species[si];\n            var captSi = si; var captSpId = sp.id;\n            \n            const tmpSpKey = `wb_tmp_sp_${captSpId}`;\n            const spLbContent: UIPart[] = [];\n            if (sp.lorebookEntryId) {\n                spLbContent.push(\n                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },\n                    { type: 'text', text: `Keys: ${getSpeciesLorebookKeys(sp).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },\n                    { type: 'row', style: { gap: '6px' }, content: [\n                        { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncSpeciesLorebookEntry(captSpId); } },\n                        { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { await unlinkSpeciesLorebookEntry(captSpId); await refreshWorldbuildingModal(); } }\n                    ] }\n                );\n            } else {\n                spLbContent.push(\n                    { type: 'text', text: \"No lorebook entry. Create one to inject this species' profile.\", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },\n                    { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await createLinkedSpeciesLorebookEntry(captSpId); await refreshWorldbuildingModal(); } }\n                );\n            }\n            spLbContent.push({ type: 'text', text: 'Trigger Keys:', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });\n            (sp.lorebookTags || []).forEach(function(tg, ti) {\n                spLbContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [\n                    { type: 'text', text: '• ' + tg, style: { flex: '1 1 0', fontSize: '12px' } },\n                    { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { await mutConfig(function(c) { c.species[captSi].lorebookTags!.splice(ti, 1); }); await refreshWorldbuildingModal(); } }\n                ] } as UIPart);\n            });\n            spLbContent.push({ type: 'row', style: { gap: '4px' }, content: [\n                { type: 'textInput', placeholder: 'Add key...', storageKey: `temp:${tmpSpKey}`, style: { flex: '1 1 0' } },\n                { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpSpKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c) { if (!c.species[captSi].lorebookTags) c.species[captSi].lorebookTags = []; if (!c.species[captSi].lorebookTags!.includes(v.trim())) c.species[captSi].lorebookTags!.push(v.trim()); }); await api.v1.tempStorage.remove(tmpSpKey); await refreshWorldbuildingModal(); } }\n            ] });\n\n            spParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #88ccff' }, content: [\n                { type: 'textInput', label: 'Name', initialValue: sp.name || '', onChange: async function(v: string) { await mutConfig(function(c) { c.species[captSi].name = v; }); } },\n                { type: 'multilineTextInput', label: 'Description', initialValue: sp.description || '', style: { minHeight: '40px', marginTop: '4px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.species[captSi].description = v; }); } },\n                { type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: spLbContent },\n                { type: 'button', text: 'Delete Species', style: { marginTop: '8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { await mutConfig(function(c) { c.species.splice(captSi, 1); }); await refreshWorldbuildingModal(); } }\n            ] } as UIPart);\n        }\n        if ((cfg.species || []).length === 0) spParts.push({ type: 'text', text: 'No species defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });\n        spParts.push({ type: 'button', text: '+ Add Species', style: { marginTop: '4px', width: '100%', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.species) c.species = []; c.species.push({ id: 'sp_' + Date.now(), name: 'New Species', description: '', lorebookTags: [] }); }); await refreshWorldbuildingModal(); } });\n        return spParts;\n    })() });\n\n    // 3. Factions\n    parts.push({ type: 'collapsibleSection', title: `⚔️ Factions (${(cfg.factions || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_factions', content: await (async function() {\n        const facParts: UIPart[] = [];\n        facParts.push({ type: 'text', text: 'Define factions and their relationship tracks. The player\\'s standing with each faction is set on the Player tab.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });\n        for (var fci = 0; fci < (cfg.factions || []).length; fci++) {\n            var fac = cfg.factions[fci];\n            var captFci = fci; var captFacId = fac.id;\n            \n            const tmpFacKey = `wb_tmp_fac_${captFacId}`;\n            const facLbContent: UIPart[] = [];\n            if (fac.lorebookEntryId) {\n                facLbContent.push(\n                    { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '6px' }, content: [{ type: 'text', text: '✓ Lorebook entry linked', style: { fontSize: '12px', color: '#7ec8a0', flex: '1 1 0' } }] },\n                    { type: 'text', text: `Keys: ${getFactionLorebookKeys(fac).join(', ')}`, style: { fontSize: '11px', opacity: '0.55', marginBottom: '8px' } },\n                    { type: 'row', style: { gap: '6px' }, content: [\n                        { type: 'button', text: 'Sync Static Core', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.1)', border: '1px solid rgba(126,200,160,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await syncFactionLorebookEntry(captFacId); } },\n                        { type: 'button', text: 'Unlink', style: { margin: 0, fontSize: '11px' }, callback: async function() { await unlinkFactionLorebookEntry(captFacId); await refreshWorldbuildingModal(); } }\n                    ] }\n                );\n            } else {\n                facLbContent.push(\n                    { type: 'text', text: \"No lorebook entry. Create one to inject this faction's profile.\", style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },\n                    { type: 'button', text: '+ Create & Link Lorebook Entry', style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.1)', border: '1px solid rgba(136,204,255,0.3)' }, disabledWhileCallbackRunning: true, callback: async function() { await createLinkedFactionLorebookEntry(captFacId); await refreshWorldbuildingModal(); } }\n                );\n            }\n            facLbContent.push({ type: 'text', text: 'Trigger Keys:', style: { fontSize: '11px', opacity: '0.6', marginTop: '12px', marginBottom: '4px' } });\n            (fac.lorebookTags || []).forEach(function(tg, ti) {\n                facLbContent.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [\n                    { type: 'text', text: '• ' + tg, style: { flex: '1 1 0', fontSize: '12px' } },\n                    { type: 'button', iconId: 'x', style: { margin: 0, fontSize: '10px' }, callback: async function() { await mutConfig(function(c) { c.factions[captFci].lorebookTags!.splice(ti, 1); }); await refreshWorldbuildingModal(); } }\n                ] } as UIPart);\n            });\n            facLbContent.push({ type: 'row', style: { gap: '4px' }, content: [\n                { type: 'textInput', placeholder: 'Add key...', storageKey: `temp:${tmpFacKey}`, style: { flex: '1 1 0' } },\n                { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(tmpFacKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c) { if (!c.factions[captFci].lorebookTags) c.factions[captFci].lorebookTags = []; if (!c.factions[captFci].lorebookTags!.includes(v.trim())) c.factions[captFci].lorebookTags!.push(v.trim()); }); await api.v1.tempStorage.remove(tmpFacKey); await refreshWorldbuildingModal(); } }\n            ] });\n\n            facParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #e8a87c' }, content: [\n                { type: 'textInput', label: 'Name', initialValue: fac.name || '', onChange: async function(v: string) { await mutConfig(function(c) { c.factions[captFci].name = v; }); } },\n                { type: 'multilineTextInput', label: 'Description', initialValue: fac.description || '', style: { minHeight: '40px', marginTop: '4px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.factions[captFci].description = v; }); } },\n                { type: 'text', text: 'Relationship States (cold \\u2192 warm):', style: { fontSize: '11px', opacity: '0.6', marginTop: '4px', marginBottom: '2px' } },\n                aeRenderIndexedStatesEditor(fac.relationshipStates || [], async function(next) { await mutConfig(function(c) { c.factions[captFci].relationshipStates = next; }); }, refreshWorldbuildingModal, 'Standing'),\n                { type: 'box', style: { borderTop: '1px solid rgba(255,255,255,0.1)', marginTop: '12px', paddingTop: '12px' }, content: facLbContent },\n                { type: 'button', text: 'Delete Faction', style: { marginTop: '8px', fontSize: '11px', color: '#ff6b6b', backgroundColor: 'transparent', border: '1px solid rgba(255,107,107,0.3)' }, callback: async function() { await mutConfig(function(c) { c.factions.splice(captFci, 1); }); await refreshWorldbuildingModal(); } }\n            ] } as UIPart);\n        }\n        if ((cfg.factions || []).length === 0) facParts.push({ type: 'text', text: 'No factions defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });\n        facParts.push({ type: 'button', text: '+ Add Faction', style: { marginTop: '4px', width: '100%', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.factions) c.factions = []; c.factions.push({ id: 'fac_' + Date.now(), name: 'New Faction', description: '', relationshipStates: ['Hostile', 'Wary', 'Neutral', 'Friendly', 'Allied'], lorebookTags: [] }); }); await refreshWorldbuildingModal(); } });\n        return facParts;\n    })() });\n\n    // 4. Relationship Archetypes\n    function buildPresetSection(title: string, items: string[], skBase: string, addKey: string, onAdd: (v: string, c: GlobalConfig) => void, onRemove: (i: number, c: GlobalConfig) => void): UIPart {\n        const rows: UIPart[] = items.filter(Boolean).map(function(item, i) {\n            const pi = i;\n            return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [\n                { type: 'text', text: item, style: { flex: '1 1 0', fontSize: '12px' } },\n                { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { await mutConfig(function(c){ onRemove(pi, c); }); await refreshWorldbuildingModal(); } }\n            ] } as UIPart;\n        });\n        rows.push({ type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [\n            { type: 'textInput', placeholder: `Add ${title}…`, storageKey: `temp:${addKey}`, style: { flex: '1 1 0' } },\n            { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(addKey) as string || ''; if (!v.trim()) return; await mutConfig(function(c){ onAdd(v.trim(), c); }); await api.v1.tempStorage.remove(addKey); await refreshWorldbuildingModal(); } }\n        ] } as UIPart);\n        return { type: 'collapsibleSection', title, initialCollapsed: true, storageKey: `temp:${skBase}`, content: rows };\n    }\n    parts.push({ type: 'collapsibleSection', title: `💞 Relationship Archetypes (${(cfg.relationshipArchetypes || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_rels', content: (function() {\n        const archParts: UIPart[] = [];\n        archParts.push({ type: 'text', text: 'Each archetype has an ordered stage progression (cold → warm). Actions can set the archetype and advance/retreat the stage. Leave stages blank for a label-only archetype.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });\n        (cfg.relationshipArchetypes || []).forEach(function(def, i) {\n            const ai = i;\n            archParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: '3px solid #d88fc0' }, content: [\n                { type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                    { type: 'textInput', initialValue: def.name, placeholder: 'Archetype name', style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold' }, onChange: async function(v: string) { await mutConfig(function(c) { c.relationshipArchetypes[ai].name = v; }); } },\n                    { type: 'button', iconId: 'trash-2', style: { margin: 0, padding: '2px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.relationshipArchetypes.splice(ai, 1); }); await refreshWorldbuildingModal(); } }\n                ] },\n                { type: 'text', text: 'Stages (cold \\u2192 warm):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },\n                aeRenderIndexedStatesEditor(def.stages || [], async function(next) { await mutConfig(function(c) { c.relationshipArchetypes[ai].stages = next; }); }, refreshWorldbuildingModal, 'Stage')\n            ] } as UIPart);\n        });\n        if (!(cfg.relationshipArchetypes || []).length) archParts.push({ type: 'text', text: 'No archetypes defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });\n        archParts.push({ type: 'button', text: '+ Add Archetype', style: { width: '100%', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.relationshipArchetypes.push({ id: 'arch_' + Date.now(), name: 'New Archetype', stages: ['Stage 1', 'Stage 2', 'Stage 3'] }); }); await refreshWorldbuildingModal(); } });\n        return archParts;\n    })() });\n\n    // 5. Global Resources\n    parts.push({ type: 'collapsibleSection', title: `📦 Global Resources (${(cfg.resources || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_res', content: await (async function() {\n        const resParts: UIPart[] = [];\n        resParts.push({ type: 'text', text: 'Configure resource bounds and tracks.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });\n\n        for (let i = 0; i < (cfg.resources || []).length; i++) {\n            const res = cfg.resources[i];\n            const editorParts: UIPart[] = [];\n\n            editorParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                { type: 'textInput', label: 'Name', initialValue: res.name || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].name = v; }); } },\n                { type: 'textInput', label: 'Tag', initialValue: res.tag || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].tag = v; }); } },\n                { type: 'textInput', label: 'Icon', placeholder: '💎', initialValue: res.icon || '', style: { width: '52px', flexShrink: '0', textAlign: 'center' }, onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].icon = v.trim() || undefined; }); } }\n            ] });\n            editorParts.push({ type: 'button', text: 'Delete Resource', style: { margin: '0 0 8px 0', backgroundColor: 'transparent', color: '#ff6b6b', border: '1px solid #ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.resources.splice(i, 1); }); await refreshWorldbuildingModal(); } });\n\n            if (res.type === 'pool') {\n                editorParts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [\n                    { type: 'textInput', label: 'Minimum', initialValue: res.min !== undefined ? res.min.toString() : '0', onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].min = parseInt(v, 10) || 0; }); } },\n                    { type: 'textInput', label: 'Maximum', initialValue: res.max !== undefined ? res.max.toString() : '100', onChange: async function(v: string) { await mutConfig(function(c) { c.resources[i].max = parseInt(v, 10) || 100; }); } }\n                ] });\n            } else if (res.type === 'track') {\n                // [PATCH v0998] indexed editor replaces the comma-separated field —\n                // the index is always visible, so authors (and conditions/effects\n                // referencing this track by index) never have to count commas.\n                editorParts.push({ type: 'text', text: 'States (low \\u2192 high):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });\n                editorParts.push(aeRenderIndexedStatesEditor(res.states || [], async function(next) { await mutConfig(function(c) { c.resources[i].states = next; }); }, refreshWorldbuildingModal, 'State'));\n                editorParts.push({ type: 'text', text: 'Example: Rested, Tired, Exhausted', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });\n            } else if (res.type === 'discrete') {\n                editorParts.push({ type: 'text', text: 'Conditions:', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });\n                editorParts.push(aeRenderIndexedStatesEditor(res.states || [], async function(next) { await mutConfig(function(c) { c.resources[i].states = next; }); }, refreshWorldbuildingModal, 'Condition'));\n                editorParts.push({ type: 'text', text: 'First entry (index 0) = clear/none (bridge hides when index 0). Example: None, Poisoned, Cursed, Blessed', style: { fontSize: '10px', opacity: '0.5', marginBottom: '8px' } });\n            }\n            let resBorderCol = res.type === 'pool' ? '3px solid #88ccff' : res.type === 'track' ? '3px solid #e8a87c' : '3px solid #b388ff';\n            resParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: resBorderCol }, content: editorParts } as UIPart);\n        }\n\n        if (cfg.resources.length === 0) resParts.push({ type: 'text', text: 'No resources defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });\n\n        resParts.push({ type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [\n            { type: 'button', text: '+ Add Pool', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.resources.push({ id: 'res_' + Date.now(), name: 'New Pool', type: 'pool', tag: '#new_pool', hasBounds: true, min: 0, max: 100 }); }); await refreshWorldbuildingModal(); } },\n            { type: 'button', text: '+ Add Track', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.resources.push({ id: 'res_' + Date.now(), name: 'New Track', type: 'track', tag: '#new_track', hasBounds: false, states: ['State 1', 'State 2', 'State 3'] }); }); await refreshWorldbuildingModal(); } },\n            { type: 'button', text: '+ Add Condition', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.resources.push({ id: 'res_' + Date.now(), name: 'New Condition', type: 'discrete', tag: '#condition', hasBounds: false, states: ['None', 'State 1', 'State 2'] }); }); await refreshWorldbuildingModal(); } }\n        ] });\n        return resParts;\n    })() });\n\n    // 5a2. [v0.9.9.2] Time & Calendar\n    parts.push({ type: 'collapsibleSection', title: '\\ud83d\\udd52 Time & Calendar', initialCollapsed: true, storageKey: 'temp:wb_cfg_time', content: await (async function() {\n        const tParts: UIPart[] = [];\n        tParts.push({ type: 'text', text: 'A 28-day cycle (4 weeks x 7 days) over a 24-hour clock. The clock tracks whole hours; bands are named views layered on top.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });\n\n        let _tShow = (cfg.timeShowInAN !== false);\n        tParts.push({ type: 'button', text: (_tShow ? 'Show date in story context: ON' : 'Show date in story context: OFF'), style: { width: '100%', marginBottom: '4px', fontSize: '11px', backgroundColor: (_tShow ? 'rgba(136,204,255,0.12)' : 'rgba(255,255,255,0.04)'), color: (_tShow ? '#88ccff' : '#a8a8b8') }, callback: async function() { await mutConfig(function(c) { c.timeShowInAN = (c.timeShowInAN === false); }); await refreshWorldbuildingModal(); } });\n\n        tParts.push({ type: 'textInput', label: 'Fresh-story start hour (0-23)', initialValue: String(cfg.timeStartHours !== undefined ? cfg.timeStartHours : 8), onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); c.timeStartHours = isNaN(n) ? 8 : Math.max(0, Math.min(23, n)); }); } });\n\n        let _tAuto = (cfg.timeAutoAdvanceEnabled === true);\n        tParts.push({ type: 'button', text: (_tAuto ? 'Auto-advance each turn: ON' : 'Auto-advance each turn: OFF'), style: { width: '100%', margin: '6px 0 4px 0', fontSize: '11px', backgroundColor: (_tAuto ? 'rgba(166,227,161,0.14)' : 'rgba(255,255,255,0.04)'), color: (_tAuto ? '#a6e3a1' : '#a8a8b8') }, callback: async function() { await mutConfig(function(c) { c.timeAutoAdvanceEnabled = !(c.timeAutoAdvanceEnabled === true); }); await refreshWorldbuildingModal(); } });\n        tParts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [\n            { type: 'textInput', label: 'Hours per tick', initialValue: String(cfg.timeAdvanceHours !== undefined ? cfg.timeAdvanceHours : 1), onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); c.timeAdvanceHours = (isNaN(n) || n < 1) ? 1 : n; }); } },\n            { type: 'textInput', label: 'Every N generations', initialValue: String(cfg.timeAdvanceEveryGens !== undefined ? cfg.timeAdvanceEveryGens : 3), onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); c.timeAdvanceEveryGens = (isNaN(n) || n < 1) ? 3 : n; }); } }\n        ] });\n\n        tParts.push({ type: 'text', text: 'Time bands (named hour ranges; a band whose start is later than its end wraps past midnight, e.g. 22 to 6):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '4px' } });\n        if (!cfg.timeBands) cfg.timeBands = [];\n        for (let bi = 0; bi < cfg.timeBands.length; bi++) {\n            const bnd = cfg.timeBands[bi];\n            tParts.push({ type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '4px' }, content: [\n                { type: 'textInput', label: 'Band', initialValue: bnd.label || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { if (c.timeBands && c.timeBands[bi]) c.timeBands[bi].label = v; }); } },\n                { type: 'textInput', label: 'From', initialValue: String(bnd.startHour), style: { width: '54px', flexShrink: '0' }, onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); if (c.timeBands && c.timeBands[bi]) c.timeBands[bi].startHour = isNaN(n) ? 0 : ((n % 24 + 24) % 24); }); } },\n                { type: 'textInput', label: 'To', initialValue: String(bnd.endHour), style: { width: '54px', flexShrink: '0' }, onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); if (c.timeBands && c.timeBands[bi]) c.timeBands[bi].endHour = isNaN(n) ? 0 : ((n % 24 + 24) % 24); }); } },\n                { type: 'button', iconId: 'x', style: { margin: 0, flexShrink: '0' }, callback: async function() { await mutConfig(function(c) { if (c.timeBands) c.timeBands.splice(bi, 1); }); await refreshWorldbuildingModal(); } }\n            ] });\n        }\n        tParts.push({ type: 'button', text: '+ Add Band', style: { width: '100%', marginBottom: '8px', fontSize: '11px' }, callback: async function() { await mutConfig(function(c) { if (!c.timeBands) c.timeBands = []; c.timeBands.push({ label: 'New Band', startHour: 0, endHour: 6 }); }); await refreshWorldbuildingModal(); } });\n\n        tParts.push({ type: 'textInput', label: 'Weekday names (7, comma-separated; blank = Day N)', initialValue: (cfg.timeDayNames || []).join(', '), onChange: async function(v: string) { await mutConfig(function(c) { c.timeDayNames = v.split(',').map(function(s) { return s.trim(); }).filter(Boolean).slice(0, 7); }); } });\n        tParts.push({ type: 'textInput', label: 'Week names (4, comma-separated; blank = Week N)', initialValue: (cfg.timeWeekNames || []).join(', '), style: { marginBottom: '8px' }, onChange: async function(v: string) { await mutConfig(function(c) { c.timeWeekNames = v.split(',').map(function(s) { return s.trim(); }).filter(Boolean).slice(0, 4); }); } });\n\n        if (cfg.tierTravelDefaults && cfg.tierTravelDefaults.length) {\n            tParts.push({ type: 'text', text: 'Travel time cost per tier (hours added to the clock on entering a location at that tier):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '4px' } });\n            for (let ti = 0; ti < cfg.tierTravelDefaults.length; ti++) {\n                const tier = cfg.tierTravelDefaults[ti];\n                tParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                    { type: 'text', text: tier.label || ('Tier ' + ti), style: { flex: '1 1 0', fontSize: '11px' } },\n                    { type: 'textInput', label: 'Hours', initialValue: String(tier.timeCostHours || 0), style: { width: '72px', flexShrink: '0' }, onChange: async function(v: string) { await mutConfig(function(c) { let n = parseInt(v, 10); if (c.tierTravelDefaults && c.tierTravelDefaults[ti]) { c.tierTravelDefaults[ti].timeCostHours = (isNaN(n) || n < 0) ? 0 : n; syncTierTemplate(c, ti); } }); } }\n                ] });\n            }\n        }\n\n        return tParts;\n    })() });\n\n    // 5b. [v0.9.69] Character Resources — configurable template for personal (per-character)\n    // resources. New characters are seeded from this automatically; Sync adds any missing\n    // template resources to characters that predate a template change.\n    parts.push({ type: 'collapsibleSection', title: `\\ud83e\\uddec Character Resources (${(cfg.characterResourceDefs || []).length})`, initialCollapsed: true, storageKey: 'temp:wb_cfg_cres', content: await (async function() {\n        const cresParts: UIPart[] = [];\n        cresParts.push({ type: 'text', text: 'Personal resources every new character starts with (e.g. Health, Wealth, Luck). Edit freely \\u2014 a resource here is skipped for a character if a Global Resource already uses the same tag.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } });\n        if (!cfg.characterResourceDefs) cfg.characterResourceDefs = [];\n\n        for (let ci = 0; ci < cfg.characterResourceDefs.length; ci++) {\n            const cres = cfg.characterResourceDefs[ci];\n            const cEditorParts: UIPart[] = [];\n\n            cEditorParts.push({ type: 'row', alignment: 'center', style: { gap: '6px', marginBottom: '4px' }, content: [\n                { type: 'textInput', label: 'Name', initialValue: cres.name || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].name = v; }); } },\n                { type: 'textInput', label: 'Tag', initialValue: cres.tag || '', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].tag = v; }); } }\n            ] });\n            cEditorParts.push({ type: 'button', text: 'Delete Resource', style: { margin: '0 0 8px 0', backgroundColor: 'transparent', color: '#ff6b6b', border: '1px solid #ff6b6b' }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.splice(ci, 1); }); await refreshWorldbuildingModal(); } });\n\n            if (cres.type === 'pool') {\n                cEditorParts.push({ type: 'row', style: { gap: '4px', marginBottom: '8px' }, content: [\n                    { type: 'textInput', label: 'Minimum', initialValue: cres.min !== undefined ? cres.min.toString() : '0', onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].min = parseInt(v, 10) || 0; }); } },\n                    { type: 'textInput', label: 'Maximum', initialValue: cres.max !== undefined ? cres.max.toString() : '100', onChange: async function(v: string) { await mutConfig(function(c) { c.characterResourceDefs[ci].max = parseInt(v, 10) || 100; }); } }\n                ] });\n            } else if (cres.type === 'track') {\n                cEditorParts.push({ type: 'text', text: 'States (low \\u2192 high):', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });\n                cEditorParts.push(aeRenderIndexedStatesEditor(cres.states || [], async function(next) { await mutConfig(function(c) { c.characterResourceDefs[ci].states = next; }); }, refreshWorldbuildingModal, 'State'));\n            } else if (cres.type === 'discrete') {\n                cEditorParts.push({ type: 'text', text: 'Conditions:', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } });\n                cEditorParts.push(aeRenderIndexedStatesEditor(cres.states || [], async function(next) { await mutConfig(function(c) { c.characterResourceDefs[ci].states = next; }); }, refreshWorldbuildingModal, 'Condition'));\n            }\n            let cresBorderCol = cres.type === 'pool' ? '3px solid #88ccff' : cres.type === 'track' ? '3px solid #e8a87c' : '3px solid #b388ff';\n            cresParts.push({ type: 'box', style: { padding: '8px', marginBottom: '6px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '4px', borderLeft: cresBorderCol }, content: cEditorParts } as UIPart);\n        }\n\n        if (cfg.characterResourceDefs.length === 0) cresParts.push({ type: 'text', text: 'No character resources defined.', style: { fontSize: '11px', opacity: '0.5', marginBottom: '8px' } });\n\n        cresParts.push({ type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [\n            { type: 'button', text: '+ Add Pool', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.push({ id: 'cres_' + Date.now(), name: 'New Pool', type: 'pool', tag: '#new_pool', hasBounds: true, min: 0, max: 100 }); }); await refreshWorldbuildingModal(); } },\n            { type: 'button', text: '+ Add Track', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.push({ id: 'cres_' + Date.now(), name: 'New Track', type: 'track', tag: '#new_track', hasBounds: true, states: ['State 1', 'State 2', 'State 3'] }); }); await refreshWorldbuildingModal(); } },\n            { type: 'button', text: '+ Add Condition', style: { flex: '1 1 0', fontSize: '11px', margin: 0 }, callback: async function() { await mutConfig(function(c) { c.characterResourceDefs.push({ id: 'cres_' + Date.now(), name: 'New Condition', type: 'discrete', tag: '#condition', hasBounds: false, states: ['None', 'State 1', 'State 2'] }); }); await refreshWorldbuildingModal(); } }\n        ] });\n        cresParts.push({ type: 'button', text: '\\ud83d\\udd04 Sync to All Characters', style: { width: '100%', marginTop: '8px', fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.12)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {\n            api.v1.ui.toast('Syncing character resources...', { id: 'cres-sync', autoClose: false });\n            const currentCfg = await loadConfig(); const allCharacters = await loadAllCharacters(); let updatedCount = 0;\n            for (const char of allCharacters) {\n                const initialDefCount = (char.charResourceDefs || []).length;\n                const updatedChar = seedPersonalResourcesToCharacter(char, currentCfg);\n                if (updatedChar.charResourceDefs.length > initialDefCount) { await saveCharacter(updatedChar); updatedCount++; }\n            }\n            api.v1.ui.toast(`Synced character resources to ${updatedCount} character(s).`, { id: 'cres-sync', type: 'success', autoClose: 3000 });\n        }});\n\n        return cresParts;\n    })() });\n\n    // 6. Character Sheet Categories\n    const catItems: UIPart[] = cfg.sheetCategories.filter(Boolean).map(function(cat, ci) {\n        const fieldRows: UIPart[] = cat.fields.filter(Boolean).map(function(field, fi) {\n            return { type: 'row', alignment: 'center', style: { gap: '4px', marginBottom: '2px' }, content: [\n                { type: 'textInput', initialValue: field.name, placeholder: 'Field name', style: { flex: '1 1 0' }, onChange: async function(v: string) { await mutConfig(function(c){ c.sheetCategories[ci].fields[fi].name = v; }); } },\n                { type: 'button', iconId: 'x', style: { margin: 0 }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fields.splice(fi, 1); }); await refreshWorldbuildingModal(); } }\n            ] } as UIPart;\n        });\n        const addFk = `wb_cfg_cat_af_${cat.id}`;\n        const catContent: UIPart[] = [\n            { type: 'textInput', label: 'Category Name', initialValue: cat.name, onChange: async function(v: string) { await mutConfig(function(c){ c.sheetCategories[ci].name = v; }); } },\n            { type: 'row', style: { gap: '4px', marginTop: '6px', marginBottom: '4px' }, content: [\n                { type: 'button', text: 'Text', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: cat.fieldType === 'text' ? 'rgba(126,200,160,0.22)' : undefined }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fieldType = 'text'; }); await refreshWorldbuildingModal(); } },\n                { type: 'button', text: 'Number', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: cat.fieldType === 'number' ? 'rgba(126,200,160,0.22)' : undefined }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fieldType = 'number'; }); await refreshWorldbuildingModal(); } },\n                { type: 'button', text: 'Enum', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: cat.fieldType === 'enum' ? 'rgba(126,200,160,0.22)' : undefined }, callback: async function() { await mutConfig(function(c){ c.sheetCategories[ci].fieldType = 'enum'; }); await refreshWorldbuildingModal(); } }\n            ] },\n            { type: 'text', text: 'Fields:', style: { fontSize: '11px', opacity: '0.6', marginBottom: '2px' } },\n            ...fieldRows,\n            { type: 'row', style: { gap: '4px', marginTop: '4px' }, content: [\n                { type: 'textInput', placeholder: 'Add field…', storageKey: `temp:${addFk}`, style: { flex: '1 1 0' } },\n                { type: 'button', iconId: 'plus', style: { margin: 0 }, callback: async function() { const v = await api.v1.tempStorage.get(addFk) as string || ''; if (!v.trim()) return; await mutConfig(function(c){ c.sheetCategories[ci].fields.push({ id: api.v1.uuid(), name: v.trim() }); }); await api.v1.tempStorage.remove(addFk); await refreshWorldbuildingModal(); } }\n            ] }\n        ].filter(Boolean) as UIPart[];\n        if (cat.fieldType === 'enum') {\n            // [PATCH v0998] indexed rung editor — index 0 is always the lowest rung,\n            // matches how char_skill.amount now compares against this array by index.\n            catContent.push({ type: 'text', text: 'Ladder Rungs (0 = lowest):', style: { fontSize: '11px', opacity: '0.6', marginTop: '8px', marginBottom: '2px' } });\n            catContent.push(aeRenderIndexedStatesEditor(cat.enumValues || [], async function(next) { await mutConfig(function(c) { c.sheetCategories[ci].enumValues = next; }); }, refreshWorldbuildingModal, 'Rung'));\n        }\n        catContent.push({ type: 'button', text: '🗑 Remove Category', style: { fontSize: '11px', marginTop: '10px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c){ c.sheetCategories.splice(ci, 1); }); await refreshWorldbuildingModal(); } } as UIPart);\n        return { type: 'collapsibleSection', title: cat.name || 'Category', initialCollapsed: true, storageKey: `temp:wb_cfg_cat_${cat.id}`, content: catContent } as UIPart;\n    });\n    catItems.push({ type: 'button', text: '+ Add Category', iconId: 'plus', style: { marginTop: '8px' }, callback: async function() { await mutConfig(function(c){ c.sheetCategories.push({ id: api.v1.uuid(), name: 'New Category', fieldType: 'text', enumValues: [], fields: [] }); }); await refreshWorldbuildingModal(); } } as UIPart);\n    parts.push({ type: 'collapsibleSection', title: '📊 Character Sheet Categories', initialCollapsed: true, storageKey: 'temp:wb_cfg_sheet', content: catItems });\n\n    // 7. Adventure Module Management [v0.9.7.11: lorebook-only; v0.98: +JSON]\n    parts.push({ type: 'text', text: '📦 Adventure Module Management', style: { fontSize: '14px', fontWeight: 'bold', marginTop: '16px', marginBottom: '8px', color: '#7ec8a0' } });\n    parts.push({ type: 'text', text: 'Pack the full world into a hidden lorebook entry that travels with your .scenario export. Use the picker to import any AE pack found in the lorebook.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } });\n    parts.push({ type: 'row', style: { gap: '8px', marginBottom: '10px' }, content: [\n        { type: 'button', text: '📦 Pack to Lorebook', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(126,200,160,0.12)', border: '1px solid rgba(126,200,160,0.35)', color: '#7ec8a0' }, disabledWhileCallbackRunning: true, callback: async function() {\n            await packConfigToLorebook();\n        } },\n        { type: 'button', text: '📥 Import from Lorebook', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(136,204,255,0.12)', border: '1px solid rgba(136,204,255,0.35)', color: '#88ccff' }, disabledWhileCallbackRunning: true, callback: async function() {\n            await pickAndImportFromLorebook();\n        } }\n    ] });\n    parts.push({ type: 'text', text: 'Export to a plain JSON file for backups or external tools. Import a previously exported JSON file.', style: { fontSize: '11px', opacity: '0.7', marginBottom: '8px' } });\n    parts.push({ type: 'row', style: { gap: '8px', marginBottom: '24px' }, content: [\n        { type: 'button', text: '⬇ Export JSON', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(232,168,124,0.12)', border: '1px solid rgba(232,168,124,0.35)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {\n            await exportAll();\n        } },\n        { type: 'button', text: '⬆ Import JSON', style: { flex: '1 1 0', margin: 0, backgroundColor: 'rgba(232,168,124,0.12)', border: '1px solid rgba(232,168,124,0.35)', color: '#e8a87c' }, disabledWhileCallbackRunning: true, callback: async function() {\n            await importData();\n        } }\n    ] });\n\n        return parts.filter(Boolean) as UIPart[];\n}\n\n// ============================================================================\n// SECTION 24 — CONFIG MODAL (Engine Tweaks Only)\n// ============================================================================\n\nasync function mutConfig(fn: (c: GlobalConfig) => void): Promise<void> {\n    const c = await loadConfig(); fn(c); await saveConfig(c);\n}\nasync function refreshConfigModal(): Promise<void> {\n    if (!configModalHandle || configModalHandle.isClosed()) return;\n    await configModalHandle.update({ content: await buildConfigContent() });\n}\nasync function openConfigModal(): Promise<void> {\n    if (configModalHandle && !configModalHandle.isClosed()) configModalHandle.close();\n    configModalHandle = await openEngineModal({ id: 'ae-config', size: 'full', fillWidth: true, title: '⚙ Adventure Engine Settings', content: await buildConfigContent() });\n}\n\nasync function buildConfigContent(): Promise<UIPart[]> {\n    const cfg = await loadConfig(); const parts: UIPart[] = [];\n\n    // 1. Engine Timing\n    parts.push({ type: 'collapsibleSection', title: '⚡️Dynamic Updates Timing', initialCollapsed: true, storageKey: 'temp:ce_cfg_timing', content: [\n        { type: 'text', text: 'How many context tokens must pass before each update type fires.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '10px' } },\n        { type: 'sliderInput', label: 'Ephemeral (Thoughts) Interval', min: 1, max: 20, step: 1, initialValue: cfg.thoughtIntervalGens, suffix: ' gens', defaultValue: 2, onChange: async function(v: number) { await mutConfig(function(c){ c.thoughtIntervalGens = v; }); } },\n        { type: 'sliderInput', label: 'Mid-Range State Interval', min: 1, max: 40, step: 1, initialValue: cfg.dynamicIntervalGens, suffix: ' gens', defaultValue: 4, onChange: async function(v: number) { await mutConfig(function(c){ c.dynamicIntervalGens = v; }); } },\n        { type: 'sliderInput', label: 'Primary Relationship Interval', min: 2, max: 50, step: 1, initialValue: cfg.arcIntervalGens, suffix: ' gens', defaultValue: 10, onChange: async function(v: number) { await mutConfig(function(c){ c.arcIntervalGens = v; }); } },\n        { type: 'sliderInput', label: 'Hook Scan Interval', min: 1, max: 30, step: 1, initialValue: cfg.hookIntervalGens, suffix: ' gens', defaultValue: 6, onChange: async function(v: number) { await mutConfig(function(c){ c.hookIntervalGens = v; }); } },\n        { type: 'sliderInput', label: 'Max Ephemeral Injections per Generation', min: 1, max: 6, step: 1, initialValue: cfg.ephemeralCap, defaultValue: 3, onChange: async function(v: number) { await mutConfig(function(c){ c.ephemeralCap = v; }); } },\n        { type: 'text', text: 'Dynamic character cap: how many present characters stay dynamic at once (0 = no cap). Ranked characters fill slots first by rank, then unranked present characters. Set each character\\u2019s rank from their card or edit panel.', style: { fontSize: '11px', opacity: '0.6', marginTop: '10px', marginBottom: '4px' } },\n        { type: 'sliderInput', label: 'Max Dynamic Characters', min: 0, max: 20, step: 1, initialValue: Number(cfg.maxDynamicCharacters) || 0, suffix: ' (0 = off)', defaultValue: 0, onChange: async function(v: number) { await mutConfig(function(c){ (c as any).maxDynamicCharacters = Math.max(0, Math.floor(v || 0)); }); } },\n    ] });\n\n    // 2. Generation Style\n    parts.push({ type: 'collapsibleSection', title: '✍ Generation Style', initialCollapsed: true, storageKey: 'temp:ce_cfg_style', content: [\n        { type: 'text', text: 'Injected at the top of every generation prompt. Controls overall tone and register. Tip: add \"Ignore any game mechanic formatting in the story text — numbered choice lists, > action markers, ## headers, {} or () notes, LOREBOOK: references. Treat only prose narrative as story content.\"', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px' } },\n        { type: 'multilineTextInput', initialValue: cfg.generalStyle, style: { minHeight: '100px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.generalStyle = v; }); } },\n        { type: 'button', text: 'Reset to Default', style: { fontSize: '11px', marginTop: '6px' }, callback: async function() { await mutConfig(function(c){ c.generalStyle = DEFAULT_GENERAL_STYLE; }); await refreshConfigModal(); } }\n    ] });\n\n    // 3. Static Field Settings\n    const fieldSections: UIPart[] = [\n        { type: 'checkboxInput', label: 'Show field headers in context injection', initialValue: cfg.showFieldHeaders, onChange: async function(v: boolean) { await mutConfig(function(c){ c.showFieldHeaders = v; }); } } as UIPart\n    ];\n    STATIC_FIELD_DEFS.forEach(function(def) {\n        fieldSections.push({ type: 'collapsibleSection', title: cfg.fieldLabels[def.key] || def.label, initialCollapsed: true, storageKey: `temp:ce_cfg_f_${def.key}`, content: [\n            { type: 'textInput', label: 'Display Label', initialValue: cfg.fieldLabels[def.key] || def.label, onChange: async function(v: string) { await mutConfig(function(c){ c.fieldLabels[def.key] = v; }); } },\n            { type: 'multilineTextInput', label: 'Generation Instructions', initialValue: cfg.fieldInstructions[def.key] || def.defaultInstructions, style: { minHeight: '80px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.fieldInstructions[def.key] = v; }); } },\n            { type: 'sliderInput', label: 'Generation Token Budget', min: 50, max: 500, step: 25, initialValue: cfg.fieldBudgets[def.key] || def.defaultBudget, suffix: ' tokens', defaultValue: def.defaultBudget, onChange: async function(v: number) { await mutConfig(function(c){ c.fieldBudgets[def.key] = v; }); } },\n            { type: 'button', text: 'Reset Instructions', style: { fontSize: '11px', marginTop: '4px' }, callback: async function() { await mutConfig(function(c){ c.fieldInstructions[def.key] = def.defaultInstructions; c.fieldBudgets[def.key] = def.defaultBudget; }); await refreshConfigModal(); } }\n        ] } as UIPart);\n    });\n    parts.push({ type: 'collapsibleSection', title: '📝 Static Field Settings', initialCollapsed: true, storageKey: 'temp:ce_cfg_fields', content: fieldSections });\n\n    // 4. Custom Static Fields\n    const customFieldRows: UIPart[] = cfg.customStaticFields.filter(Boolean).map(function(cf, i) {\n        const ci = i;\n        return { type: 'collapsibleSection', title: cf.label || `Custom Field ${ci + 1}`, initialCollapsed: true, storageKey: `temp:ce_cfg_cuf_${cf.id}`, content: [\n            { type: 'textInput', label: 'Label', initialValue: cf.label, onChange: async function(v: string) { await mutConfig(function(c){ c.customStaticFields[ci].label = v; }); } },\n            { type: 'textInput', label: 'Placeholder', initialValue: cf.placeholder || '', onChange: async function(v: string) { await mutConfig(function(c){ c.customStaticFields[ci].placeholder = v; }); } },\n            { type: 'multilineTextInput', label: 'Generation Instructions', initialValue: cf.instructions, style: { minHeight: '70px' }, onChange: async function(v: string) { await mutConfig(function(c){ c.customStaticFields[ci].instructions = v; }); } },\n            { type: 'sliderInput', label: 'Generation Token Budget', min: 50, max: 500, step: 25, initialValue: cfg.fieldBudgets[cf.id] || 150, suffix: ' tokens', defaultValue: 150, onChange: async function(v: number) { await mutConfig(function(c){ c.fieldBudgets[cf.id] = v; }); } },\n            { type: 'button', text: '🗑 Remove Field', style: { fontSize: '11px', marginTop: '6px', color: '#ff6b6b' }, callback: async function() { await mutConfig(function(c){ c.customStaticFields.splice(ci, 1); }); await refreshConfigModal(); } }\n        ] } as UIPart;\n    });\n    customFieldRows.push({ type: 'button', text: '+ Add Custom Field', iconId: 'plus', style: { marginTop: '8px' }, callback: async function() { await mutConfig(function(c){ c.customStaticFields.push({ id: api.v1.uuid(), label: 'Custom Field', placeholder: '', instructions: 'Provide relevant information for this field.' }); }); await refreshConfigModal(); } });\n    parts.push({ type: 'collapsibleSection', title: '🔧 Custom Static Fields', initialCollapsed: true, storageKey: 'temp:ce_cfg_custom', content: customFieldRows });\n\n    // 5. Scene Default Background\n    parts.push({ type: 'collapsibleSection', title: '🖼 Scene Default Background', initialCollapsed: true, storageKey: 'temp:ce_cfg_bg', content: [\n        { type: 'text', text: 'URL of the fallback image shown in the scene banner when a location has no portrait. Stored in the module config — anyone who loads this story sees the same background. Leave blank for the CSS gradient fallback.', style: { fontSize: '11px', opacity: '0.6', marginBottom: '8px', lineHeight: '1.5' } },\n        { type: 'textInput', label: 'Image URL', initialValue: (cfg as any).defaultBackgroundUrl || '', onChange: async function(v: string) { await mutConfig(function(c) { (c as any).defaultBackgroundUrl = v.trim(); }); } },\n        { type: 'button', text: '✕ Clear', style: { fontSize: '11px', marginTop: '4px', color: 'var(--ae-color-danger)' }, callback: async function() { await mutConfig(function(c) { (c as any).defaultBackgroundUrl = ''; }); await refreshConfigModal(); api.v1.ui.toast('Scene background cleared.', { type: 'success', autoClose: 2000 }); } }\n    ] } as any);\n\n    parts.push({ type: 'text', text: ' ', style: { marginBottom: '48px' } });\n    return parts.filter(Boolean) as UIPart[];\n}\n\nasync function confirmDeleteChar(id: string, name: string): Promise<void> {\n    const m = await openEngineModal({ title: 'Confirm Delete', size: 'small', content: [\n        { type: 'text', text: `Delete \"${name}\"? This cannot be undone.`, style: { marginBottom: '16px' } },\n        { type: 'row', style: { gap: '8px' }, content: [\n            { type: 'button', text: 'Delete', style: { flex: '1 1 0', margin: 0, color: '#ff6b6b' }, callback: async function() { await deleteCharacter(id); m.close(); await refreshSidebar(); } },\n            { type: 'button', text: 'Cancel', style: { flex: '1 1 0', margin: 0 }, callback: function() { m.close(); } }\n        ] }\n    ] });\n}\n\n\n\n// ============================================================================\n// SMART IMPORTER\n// ============================================================================\n// importPayload(data) — accepts a parsed JSON object and imports whatever\n// recognizable blocks it finds. Returns a summary of what was imported.\n// All import entry-points (module button, config modal, new-story prompt)\n// funnel through this single function so behaviour is always identical.\n//\n// Recognised top-level blocks (any combination, all optional):\n//   config          — GlobalConfig object  → replaces current settings\n//   characters      — CharacterRecord[]    → merged into character index\n//   character       — CharacterRecord      → single character (not bundle)\n//   entities        — EntityRecord[]       → merged into entity index\n//   locations       — EntityRecord[]       → backwards-compat alias for entities\n//   entity          — EntityRecord         → single entity node\n//   npcWeb          — NpcWebEntry[]        → replaces NPC drama web\n//   partyState      — PartyState           → replaces party resources\n//\n// Special typed wrappers (detected first, return early):\n//   { type: 'character_bundle', character, entity? }\n//\n// Bare root-level records (no top-level array key):\n//   { id, name, ...CharacterRecord }  — no `type` field  → single character\n//   { id, name, type, ... }           — has `type` field → single entity\n// ============================================================================\n\n// ImportResult interface defined in Section 1 (types block).\n\n\n// ── Import Payload (full module importer) ────────────────────────────────────\nasync function importPayload(data: any): Promise<ImportResult> {\n    const result: ImportResult = {\n        charCount: 0, entityCount: 0,\n        configImported: false, npcWebImported: false, partyStateImported: false\n    };\n\n    // 1. Config block — merge over defaults so missing new fields get defaults\n    if (data.config && typeof data.config === 'object' && !Array.isArray(data.config)) {\n        const newCfg = migrateConfig({ ...makeDefaultConfig(), ...data.config });\n        await saveConfig(newCfg);\n        result.configImported = true;\n    }\n\n    const activeCfg = await loadConfig();\n\n    // 2. Character bundle — typed single-export format (char + optional entity)\n    //    Detected first and returns early so its keys don't fall through to the\n    //    generic `character` / `entity` checks below.\n    if (data.type === 'character_bundle' && data.character) {\n        await saveCharacter(migrateCharacter(data.character, activeCfg));\n        result.charCount = 1;\n        if (data.entity && typeof data.entity === 'object') {\n            await saveEntity(migrateEntity(data.entity));\n            result.entityCount = 1;\n        }\n        return result;\n    }\n\n    // 3. Characters — array, singular block, or bare root record\n    if (data.characters && Array.isArray(data.characters)) {\n        for (const c of data.characters.filter(Boolean)) {\n            await saveCharacter(migrateCharacter(c, activeCfg));\n            result.charCount++;\n        }\n    } else if (data.character && typeof data.character === 'object' && !Array.isArray(data.character)) {\n        await saveCharacter(migrateCharacter(data.character, activeCfg));\n        result.charCount = 1;\n    } else if (data.id && data.name && !data.type && !data.entities && !data.locations && !data.characters) {\n        // Bare root-level CharacterRecord — no `type` field distinguishes it from entity\n        await saveCharacter(migrateCharacter(data, activeCfg));\n        result.charCount = 1;\n    }\n\n    // 4. Entities — array (with backwards-compat alias), singular block, or bare root record\n    const rawNodes: any[] = Array.isArray(data.entities) ? data.entities\n                          : Array.isArray(data.locations) ? data.locations   // pre-v0.9 exports\n                          : [];\n    if (rawNodes.length > 0) {\n        for (const n of rawNodes.filter(Boolean)) {\n            await saveEntity(migrateEntity(n));\n            result.entityCount++;\n        }\n    } else if (data.entity && typeof data.entity === 'object' && !Array.isArray(data.entity)) {\n        await saveEntity(migrateEntity(data.entity));\n        result.entityCount = 1;\n    } else if (data.id && data.name && data.type && !data.characters && !data.entities && !data.locations) {\n        // Bare root-level EntityRecord — presence of `type` (entity kind) is the signal\n        await saveEntity(migrateEntity(data));\n        result.entityCount = 1;\n    }\n\n    // 5. NPC Web\n    if (data.npcWeb && Array.isArray(data.npcWeb)) {\n        if (typeof saveNpcWeb === 'function') await saveNpcWeb(data.npcWeb);\n        result.npcWebImported = true;\n    }\n\n    // 6. Party State\n    if (data.partyState && typeof data.partyState === 'object' && !Array.isArray(data.partyState)) {\n        if (typeof savePartyState === 'function') await savePartyState(data.partyState);\n        result.partyStateImported = true;\n    }\n\n    return result;\n}\n\n// ── Image / Architect Settings helpers ───────────────────────────────────────\n// [NEW] Merged from auto-illustrator-sb engine. These functions were previously\n//       in the AI engine's standalone modal. Now part of the AE config modal.\n\nasync function injectNote(type: string, isAdding: boolean): Promise<void> {\n    // Inserts or removes the image System Note from Memory or Author's Note.\n    try {\n        const note = (globalSettings.systemNote || DEFAULT_NOTE).trim();\n        if (!note) { api.v1.ui.toast('No System Note defined in Image Settings.'); return; }\n        if (type === 'memory') {\n            const text = (await api.v1.memory.get()) || '';\n            if (isAdding && !text.includes(note)) {\n                await api.v1.memory.set(text ? text + '\\n\\n' + note : note);\n                api.v1.ui.toast('✅ Image note inserted into Memory.');\n            } else if (!isAdding && text.includes(note)) {\n                await api.v1.memory.set(text.replace('\\n\\n' + note, '').replace('\\n' + note, '').replace(note, '').trim());\n                api.v1.ui.toast('🗑 Image note removed from Memory.');\n            } else {\n                api.v1.ui.toast(isAdding ? 'Note already in Memory.' : 'Note not found in Memory.');\n            }\n        } else if (type === 'an') {\n            const text = (await api.v1.an.get()) || '';\n            if (isAdding && !text.includes(note)) {\n                await api.v1.an.set(text ? text + '\\n\\n' + note : note);\n                api.v1.ui.toast('✅ Image note inserted into Author\\'s Note.');\n            } else if (!isAdding && text.includes(note)) {\n                await api.v1.an.set(text.replace('\\n\\n' + note, '').replace('\\n' + note, '').replace(note, '').trim());\n                api.v1.ui.toast('🗑 Image note removed from Author\\'s Note.');\n            } else {\n                api.v1.ui.toast(isAdding ? 'Note already in Author\\'s Note.' : 'Note not found.');\n            }\n        }\n    } catch (e) {\n        api.v1.ui.toast('Injection failed — ensure storyEdit permission is granted.');\n    }\n}\n\n// ============================================================================\n// SECTION 26 — HOOK REGISTRATIONS\n// All api.v1.hooks.register() calls.\n//\n//    ADVENTURE ENGINE PIPELINE:\n//    onBeforeContextBuild  → world-state AN injection (AE context builder S13)\n//    onLorebookEntrySelected → lore ID tracking\n//    onContextBuilt        → imperative block + background drama + probability\n//    onGenerationEnd       → token count + runDynamicEngine (S15)\n//    onHistoryNavigated    → retry/undo skip flag\n//\n// ============================================================================\n\nconst AE_AN_SENTINEL = '[ Scene State ]';\n// [v0.9.7.3 AN-FIX] Sentinel bracketing the wizard-owned region of the persisted AN.\n// Final layout of the AN slot at generation time:\n//   [user manual content, if any]\n//   \\n\\n[ World Style ]          <- AE_WIZ_AN_SENTINEL (persisted by commitWizardMemory)\n//   [wizard style/tone AN sections]\n//   \\n\\n[ Scene State ]          <- AE_AN_SENTINEL (ephemeral, appended per-generation)\n//   [quest line + world state + drama]\n// Style first so the model frames itself before reading the immediate scene.\n// Scene last so it carries the highest recency weight inside the AN slot.\nconst AE_WIZ_AN_SENTINEL = '[ World Style ]';\n\napi.v1.hooks.register('onBeforeContextBuild', async function(params: any) {\n\n    // [vNEXT] Yoink hijack active — leave the context alone; our prompt is swapped\n    // in at onContextBuilt. Returning nothing means no world-state AN injection.\n    if (_aeYoink.active) return;\n\n    // ── AE path: Authors Note world-state injection ──────────────────────────\n    if (params.dryRun) return;\n    await api.v1.tempStorage.set(STORAGE_LORE_IDS, '[]').catch(function() {});\n\n    // [v0.9.8.5] Scene lorebook activation (static identity + ephemeral equipment).\n    // Returned regardless of whether an AN block is produced below.\n    let aeResult: any = {};\n    try {\n        const sceneAct = await buildSceneLorebookActivation();\n        if (sceneAct.lorebookEntries.length > 0) aeResult.lorebookEntries = sceneAct.lorebookEntries;\n        if (sceneAct.temporaryLorebookEntries.length > 0) aeResult.temporaryLorebookEntries = sceneAct.temporaryLorebookEntries;\n    } catch (eAct) { api.v1.error('[AE] scene activation:', eAct); }\n\n    try {\n        const anIdx = await loadIndex();\n        const anProtagMeta = anIdx.find(function(m: any) { return m.isProtagonist; });\n        const anProtag = anProtagMeta ? await loadCharacter(anProtagMeta.id) : null;\n        const worldStateBlock = await buildWorldStateBlock(anProtag);\n\n        // [v0.9.28 INJ1] Tracked narrative now renders via the trackedNarrative\n        // context template (buildTrackedNarrativeBlock) — the old hardcoded\n        // [Current objective: …] string is removed to stop double-injection.\n        let questLine = '';\n        try {\n            const trackedNarrId2 = await api.v1.storyStorage.getOrDefault(STORAGE_TRACKED_NARRATIVE, '') as string;\n            if (trackedNarrId2) {\n                const anCfgForTracked = await loadConfig();\n                questLine = await buildTrackedNarrativeBlock(trackedNarrId2, anCfgForTracked);\n            }\n        } catch (e) { api.v1.error('[AE] Quest AN injection:', e); }\n\n        let dramaBlock = '';\n        try { dramaBlock = await buildDramaContextBlock(); } catch (e) { api.v1.error('[AE] Drama AN injection:', e); }\n\n        // [v0.9.30 NARR-ORDER] Tracked narrative (questLine) now leads the block, above\n        // the location/world-state, so the current objective sits at the top of the\n        // injected Author's Note rather than below the scene description.\n        const fullBlock = [questLine, worldStateBlock.trim(), dramaBlock.trim()].filter(Boolean).join('\\n');\n        if (fullBlock) {\n            // [v0.9.38 AN-IDEMPOTENT] Strip any prior AE region before re-appending.\n            // We always append our block LAST, sentinel-prefixed, so the sentinel (or\n            // the '\\n\\n'+sentinel join that precedes it) marks the trailing AE region.\n            // Removing it first means N hook passes / N engine copies converge on one copy.\n            let existingANraw = (params.authorsNote && params.authorsNote.content) ? params.authorsNote.content : '';\n            let anMarker = '\\n\\n' + AE_AN_SENTINEL;\n            let anMarkerIdx = existingANraw.lastIndexOf(anMarker);\n            let baseAN = (anMarkerIdx >= 0)\n                ? existingANraw.substring(0, anMarkerIdx)\n                : ((existingANraw.indexOf(AE_AN_SENTINEL) === 0) ? '' : existingANraw);\n            baseAN = baseAN.replace(/\\s+$/, '');\n            let wrappedBlock = AE_AN_SENTINEL + '\\n' + fullBlock;\n            aeResult.authorsNote = {\n                active: true,\n                content: baseAN ? (baseAN + '\\n\\n' + wrappedBlock) : wrappedBlock\n            };\n        }\n    } catch (e) { api.v1.error('[AE] Author\\'s Note injection error:', e); }\n\n    return Object.keys(aeResult).length > 0 ? aeResult : undefined;\n});\n\napi.v1.hooks.register('onLorebookEntrySelected', async function(params: any) {\n    try {\n        if (!params.entryId) return;\n        const raw = await api.v1.tempStorage.getOrDefault(STORAGE_LORE_IDS, '[]') as string;\n        const ids: string[] = JSON.parse(raw);\n        if (!ids.includes(params.entryId)) {\n            ids.push(params.entryId);\n            await api.v1.tempStorage.set(STORAGE_LORE_IDS, JSON.stringify(ids));\n        }\n    } catch (e) { api.v1.error('[AE] LoreTracking error:', e); }\n});\n\n\napi.v1.hooks.register('onResponse', async function(params: any) {\n    // [vNEXT] While a yoink generation is active, buffer the streamed chunks and\n    // swallow them so nothing reaches the user's document. Inert otherwise.\n    if (_aeYoink.active) {\n        if (params && params.text && Array.isArray(params.text)) {\n            _aeYoink.responseText += params.text.join('');\n        }\n        return { text: [''] };\n    }\n});\n\napi.v1.hooks.register('onContextBuilt', async function(params: any) {\n\n    // [vNEXT] Yoink hijack — replace the whole context with our prompt. Runs before\n    // the dryRun gate and all normal injection so the wizard gen is fully isolated.\n    if (_aeYoink.active) {\n        return { messages: _aeYoink.messages };\n    }\n\n    // ── AE normal path: gate on dryRun ────────────────────────────────────────\n    if (params.dryRun) return;\n    const { messages } = params;\n    if (!messages || messages.length === 0) return;\n\n    // ── IMPERATIVE BLOCK ─────────────────────────────────────────────────────\n    try {\n        const impIdx = await loadIndex();\n        const impLines: string[] = [];\n        // [v0.9.25 E4] pendingEncounter injection removed — STORAGE_PENDING_ENCOUNTER is now a tombstone\n        const pendingKnowledge = await api.v1.tempStorage.get(STORAGE_PENDING_KNOWLEDGE) as any;\n        if (pendingKnowledge && pendingKnowledge.charName && pendingKnowledge.snapshot) {\n            await api.v1.tempStorage.remove(STORAGE_PENDING_KNOWLEDGE);\n            impLines.push('[' + pendingKnowledge.charName + '\\'s established knowledge of ' + pendingKnowledge.entityName + ': ' + pendingKnowledge.snapshot + ']');\n        }\n        const pendingInject = await api.v1.tempStorage.get(STORAGE_PENDING_INJECT) as string | undefined;\n        if (pendingInject && pendingInject.trim()) {\n            await api.v1.tempStorage.remove(STORAGE_PENDING_INJECT);\n            impLines.push('[GM: ' + pendingInject.trim() + ']');\n        }\n        for (const meta of impIdx.filter(Boolean)) {\n            if (!meta.active || !meta.scenePresent) continue;\n            if ((meta as any).npcClass === 'minor') continue;\n            const impChar = await loadCharacter(meta.id);\n            if (!impChar || !impChar.hooks || impChar.hooks.length === 0) continue;\n            const h = impChar.hooks[0];\n            if (!h.resolved && h.pressureLevel >= 85 && h.description && h.description.trim()) {\n                impLines.push('[' + impChar.name + ': ' + h.description.trim() + ']');\n            }\n        }\n        const impWeb = await loadNpcWeb();\n        const impAllChars = await loadAllCharacters();\n        const impPresentIds = new Set(impIdx.filter(function(m) { return m.scenePresent; }).map(function(m) { return m.id; }));\n        const impHighLinks = impWeb.filter(function(link) { return link.priority >= 70 && impPresentIds.has(link.charA_id) && impPresentIds.has(link.charB_id) && link.dynamic.trim() !== ''; }).sort(function(a, b) { return b.priority - a.priority; });\n        for (const link of impHighLinks) {\n            const cA = impAllChars.find(function(c) { return c.id === link.charA_id; });\n            const cB = impAllChars.find(function(c) { return c.id === link.charB_id; });\n            if (cA && cB) impLines.push('[' + cA.name + ' and ' + cB.name + ': ' + link.dynamic.trim() + ']');\n        }\n        if (impLines.length > 0) {\n            const impBlock = impLines.join('\\n');\n            const lastUserForImp = messages.map(function(m: any) { return m.role; }).lastIndexOf('user');\n            const insertAtImp = lastUserForImp >= 0 ? lastUserForImp : messages.length;\n            messages.splice(insertAtImp, 0, { role: 'user', content: impBlock });\n        }\n    } catch (e) { api.v1.error('[AE] Imperative injection error:', e); }\n\n    // ── BACKGROUND DRAMA ─────────────────────────────────────────────────────\n    // [WP-0] Background drama moved to the Author's Note block in\n\n    // ── EQUIPMENT DESCRIPTIONS ────────────────────────────────────────────────\n    // [WP-0] Removed. Full equipped-item descriptions now live on each character's\n    // lorebook entry (buildLorebookContent \"Wearing/Carrying\" section), activating\n    // with the character's keys instead of loading on every generation.\n\n    // [RETIRED vNEXT] Legacy freeform #tag 1d6 probability engine removed — all skill\n    // checks now run through the Quick Action composer (2d6 fail-forward + Stakes).\n    return { messages };\n});\n\n// ── onGenerationEnd ───────────────────────────────────────────────────────────\napi.v1.hooks.register('onGenerationEnd', async function(params: any) {\n    try {\n        // [vNEXT] Yoink generation finished — hand the captured text back to the\n        // awaiting caller and STOP. Must return before the gen counter, auto-triggers,\n        // and dynamic engine so a wizard gen never advances story state.\n        if (_aeYoink.active) {\n            ae_genInFlight = false;\n            if (_aeYoink.resolve) _aeYoink.resolve(_aeYoink.responseText);\n            _aeYoink.active = false;\n            _aeYoink.resolve = null;\n            _aeYoink.reject = null;\n            return;\n        }\n\n        ae_genInFlight = false; // [v0.9.36] generation finished — release the generate guard\n        // Skip on inline generations (tooltips, etc.) and retry/undo flagged turns\n        if (params?.inlineGeneration) return;\n        const skipFlag = await api.v1.tempStorage.get(STORAGE_ENGINE_SKIP) as string | undefined;\n        if (skipFlag === 'true') {\n            await api.v1.tempStorage.remove(STORAGE_ENGINE_SKIP);\n            api.v1.log('[AE] Engine skipped this turn (retry/undo).');\n            return;\n        }\n\n        // [v0.9.24 E1] Increment persistent generation count (replaces token estimation).\n        try {\n            let _genC = await api.v1.storyStorage.getOrDefault(STORAGE_GEN_COUNT, 0) as number;\n            _genC = (Number(_genC) || 0) + 1;\n            await api.v1.storyStorage.set(STORAGE_GEN_COUNT, _genC);\n            api.v1.log('[AE] Generation count: ' + _genC);\n        } catch (e) { api.v1.error('[AE] Gen count increment error:', e); }\n\n        // [v0.9.9.2] Time auto-advance. OFF by default. Clock + cadence counter both\n        // live in HISTORY storage, so an undo rewinds them together and replaying\n        // forward reproduces the identical clock. Runs AFTER the skip/yoink guards\n        // above (undo navigations and wizard yoinks never tick) and BEFORE auto-\n        // triggers (so time-gated actions evaluate against the new hour).\n        try {\n            let taCfg = await loadConfig();\n            if (taCfg.timeAutoAdvanceEnabled) {\n                let taEvery = (Number(taCfg.timeAdvanceEveryGens) > 0) ? Math.floor(Number(taCfg.timeAdvanceEveryGens)) : 3;\n                let taHours = (Number(taCfg.timeAdvanceHours) > 0) ? Math.floor(Number(taCfg.timeAdvanceHours)) : 1;\n                let taClk = await loadClock(taCfg);\n                taClk.gensSinceTick = (Number(taClk.gensSinceTick) || 0) + 1;\n                if (taClk.gensSinceTick >= taEvery) {\n                    taClk.hours = Math.max(0, taClk.hours + taHours);\n                    taClk.gensSinceTick = 0;\n                    api.v1.log('[AE] Time auto-advanced to: ' + clockFormatStamp(taClk.hours, taCfg));\n                }\n                await saveClock(taClk);\n                queueSceneStateBroadcast();\n            }\n        } catch (e) { api.v1.error('[AE] Time auto-advance error:', e); }\n\n        api.v1.log('[AE] Generation complete — running auto-triggers...');\n        await runAutoTriggers();\n        api.v1.log('[AE] Generation complete — engaging dynamic engine...');\n        await runDynamicEngine();\n    } catch (e) {\n        api.v1.error('[AE] onGenerationEnd error:', e);\n        // [vNEXT] Failsafe — never leave the yoink lock stuck on error.\n        if (_aeYoink.active) {\n            if (_aeYoink.reject) _aeYoink.reject(e);\n            _aeYoink.active = false;\n            _aeYoink.resolve = null;\n            _aeYoink.reject = null;\n        }\n    }\n});\n\n// Skip engine on retry and undo — token stamps shouldn't update when story reverts\napi.v1.hooks.register('onHistoryNavigated', async function(params: any) {\n    ae_genInFlight = false; // [v0.9.36] safety release if a generation was aborted/navigated\n    if (params?.cause === 'retry' || params?.cause === 'undo') {\n        await api.v1.tempStorage.set(STORAGE_ENGINE_SKIP, 'true');\n    }\n});\n\n\n// ============================================================================\n// SECTION 27 — STARTUP\n// showNewStoryPrompt, ensureProtagonistExists, and the onScriptsLoaded hook.\n//\n// [CHANGE] onScriptsLoaded startup sequence:\n//   1. Register sidebarPanel only (no ae-scene-hud scriptPanel — bridge owns HUD)\n//   2. Request permissions\n//   3. loadImageSettings() — seeds profiles[], globalSettings from storage\n//   4. buildCharacterDataPayload() — seeds cachedCharVisuals before bridge connects\n//   5. initMessaging() — sends HANDSHAKE_REQUEST; bridge ACK triggers state push\n//   6. isFreshStory path → showNewStoryPrompt() | returning story → normal init\n// ============================================================================\n\nasync function showNewStoryPrompt(): Promise<void> {\n    // [v0.9.7.11] Scan lorebook for AE packs to offer inline import buttons.\n    let nspPacks: { entry: any; data: any }[] = [];\n    try {\n        const nspAll = await api.v1.lorebook.entries();\n        for (const nspE of nspAll) {\n            if (!nspE.text) continue;\n            try { const nspD = JSON.parse(nspE.text); if (nspD && nspD.aeVersion) nspPacks.push({ entry: nspE, data: nspD }); }\n            catch (eNspP) {}\n        }\n    } catch (eNspL) { api.v1.log('[AE] new-story lorebook scan error:', eNspL); }\n\n    const nspContent: any[] = [\n        { type: 'text', text: nspPacks.length > 0\n            ? 'A world pack was found in this lorebook. Select it to restore the full world, or start fresh.'\n            : 'This looks like a new story. Start fresh, or import from a lorebook pack if one is available.',\n          style: { marginBottom: '14px', lineHeight: '1.5', fontSize: '12px' } }\n    ];\n    for (let nspI = 0; nspI < nspPacks.length; nspI++) {\n        (function(nspEnt: any, nspDat: any) {\n            const nspCC = Object.keys(nspDat.charRecords || {}).length;\n            const nspEC = Object.keys(nspDat.entRecords  || {}).length;\n            const nspLbl = (nspEnt.displayName || '[AE World]') + ' — ' + nspCC + ' chars, ' + nspEC + ' locations';\n            nspContent.push({ type: 'button', text: '📥 Import: ' + nspLbl,\n              style: { width: '100%', marginBottom: '8px', backgroundColor: 'rgba(136,204,255,0.15)', border: '1px solid rgba(136,204,255,0.4)', color: '#88ccff', fontWeight: 'bold' },\n              disabledWhileCallbackRunning: true,\n              callback: async function() {\n                  try { await importFromLorebookPack(nspDat); } catch (eNspImp) { api.v1.error('[AE] new-story import failed:', eNspImp); }\n                  pm.close(); await ensureProtagonistExists(); await refreshSidebar(); queueSceneStateBroadcast();\n              }\n            });\n        })(nspPacks[nspI].entry, nspPacks[nspI].data);\n    }\n    nspContent.push({ type: 'button', text: '✨ Start Fresh', style: { width: '100%' },\n        callback: async function() { pm.close(); await ensureProtagonistExists(); await refreshSidebar(); queueSceneStateBroadcast(); }\n    });\n    nspContent.push({ type: 'text', text: 'Pack or import a world anytime via ⚙ Settings → Adventure Module Management.',\n        style: { fontSize: '10px', opacity: '0.45', marginTop: '10px', textAlign: 'center' } });\n    const pm = await openEngineModal({ id: 'ae-new-story-prompt', title: '🗺 Adventure Engine', size: 'small', content: nspContent });\n}\n\n// ============================================================================\n// INITIALIZATION\n// ============================================================================\n\n\nasync function ensureProtagonistExists(): Promise<void> {\n    try {\n        const idx = await loadIndex();\n        if (idx.some(function(m) { return !!m.isProtagonist; })) return;\n\n        const cfg = await loadConfig();\n\n        // 1. Create a default starting location node so the story begins in a valid room\n        const startLoc = makeDefaultEntity('Starting Area');\n        startLoc.type = 'location';\n        startLoc.parentId = null;\n        startLoc.description = 'Where your adventure begins... Customize this location in the Worlds tab.';\n        startLoc.atmosphere = 'The air is still, ripe with the potential of a new story.';\n        await saveEntity(startLoc);\n\n        // 2. Create the player's physical body entity and nest it inside the starting area\n        const playerBody = makeDefaultEntity('Player');\n        playerBody.type = 'character';\n        playerBody.parentId = startLoc.id;\n        playerBody.storyState = 'active';\n        await saveEntity(playerBody);\n\n        // 3. Create the protagonist character record, link it, and focus the HUD camera\n        const char = makeDefaultCharacter('Player', cfg);\n        char.isProtagonist = true;\n        char.active = true;\n        char.scenePresent = true;\n        char.entityId = playerBody.id;\n        char.currentLocationId = startLoc.id; // Sets active HUD camera focus to the starting area\n        await saveCharacter(char);\n\n        try { await createLinkedLorebookEntry(char.id); } catch (lbErr) { /* non-fatal */ }\n\n        api.v1.log('[AE] Protagonist and Starting Area auto-created.');\n    } catch (e) {\n        api.v1.error('[AE] ensureProtagonistExists failed:', e);\n    }\n}\n\n// [v0.9.22 E5] Intercepts direct player TA-box input and composes any pending\n// player flavor into inputText before it is written to the story document.\n// Only fires for actual player key-submissions; not triggered by generate().\napi.v1.hooks.register('onTextAdventureInput', async function(params: any) {\n    try {\n        let taFlavor = await api.v1.tempStorage.get(STORAGE_PENDING_FLAVOR) as string | undefined;\n        if (taFlavor && taFlavor.trim()) {\n            await api.v1.tempStorage.remove(STORAGE_PENDING_FLAVOR);\n            let taInput = String((params && params.inputText) || '');\n            return { inputText: composeActionPrompt(taInput, taFlavor.trim()) };\n        }\n    } catch (_e) {}\n});\n\n// ============================================================================\n// SECTION 27 — NATIVE TOOLBAR HUD (bridge-less interface)\n// A toolbar tray whose five buttons each open a native modal rendering the same\n// SceneStatePayload the bridge consumes. Gated by cfg.interfaceMode. Renderer-only:\n// every verb is shared with the bridge. NAI has no dropdown UIPart, so the bridge's\n// three side-by-side <select>s become full-width picker-buttons via openPickerModal.\n// ============================================================================\n\n// Persistent Goal & Approach composer state — mirrors the bridge _composer* vars\n// so picks survive a modal reopen within a session.\nvar _aeNavGoal: string = '';\nvar _aeNavAttr: string | null = null;\nvar _aeNavStake: string | null = null;\nvar _aeNavStakeAuto: boolean = true;\nvar _aeNavTarget: string = 'none';\nvar _aeNavLuck: number = 0;\nvar _aeMapInspectId: string = '';   // [v0.9.9.5] native map \"Looking at\" inspected location id\nvar _aeNavInit: boolean = false;    // [v0.9.9.6] action composer defaults applied once (so 'No check' persists)\n\nfunction _aeHudHeader(text: string): UIPart {\n    return { type: 'text', text: text, style: { fontSize: '12px', fontWeight: 'bold', color: '#7ec8a0', marginTop: '10px', marginBottom: '4px' } } as UIPart;\n}\nfunction _aeHudInfo(text: string): UIPart {\n    return { type: 'text', text: text, style: { fontSize: '11px', opacity: '0.65', marginBottom: '6px', lineHeight: '1.4' } } as UIPart;\n}\nfunction _aeHudSub(text: string): UIPart {\n    return { type: 'text', text: text, style: { fontSize: '11px', fontWeight: 'bold', opacity: '0.7', marginTop: '6px', marginBottom: '2px', color: '#a9d4f5' } } as UIPart;\n}\nfunction _aeHudRow(content: UIPart[]): UIPart {\n    return { type: 'row', style: { gap: '5px', marginBottom: '4px', alignItems: 'stretch' }, content: content } as UIPart;\n}\nfunction _aeHudClose(handleGetter: () => any): UIPart {\n    return { type: 'button', text: 'Close', style: { marginTop: '12px' }, callback: async function() {\n        let h = handleGetter(); try { if (h && !h.isClosed()) await h.close(); } catch (e) {}\n    } } as UIPart;\n}\n\n// Smart Stakes default: the StakeDef whose defaultForAttrs includes the attr tag\n// (# normalized on both sides). Mirrors the bridge composer exactly.\nfunction _aeDefaultStakeFor(state: any, attrTag: string | null): string {\n    let tag = String(attrTag || '').replace(/^#/, '').toLowerCase();\n    if (!tag) return '';\n    let match = (state.stakeDefs || []).filter(function(sd: any) {\n        return (sd.defaultForAttrs || []).some(function(a: string) { return String(a).replace(/^#/, '').toLowerCase() === tag; });\n    })[0];\n    return match ? match.id : '';\n}\n\n// ── SHARED INSPECT / ITEM / NARRATIVE HELPERS ──────────────────────────────\n// [v0.9.9.7] Used by the character inspection view, the top-level Inspect modal,\n// and the Player modal's Inventory/Quests tabs -- one render path for \"a list of\n// items\" or \"a list of narratives\" everywhere they appear in the native HUD.\n\nfunction _aePressureLabel(p: number): string {\n    if (p < 25) return 'Latent';\n    if (p < 60) return 'Building';\n    if (p < 85) return 'Urgent';\n    return 'Critical';\n}\n\n// One-line dramatis persona for a single character: \"Name (species, age, role) — brief\".\nfunction _aeCharDramatis(char: any): string {\n    let idParts = [char.species, char.age, char.occupationRole].filter(function(x: any) { return x && String(x).trim(); });\n    let header = idParts.length ? (char.name + ' (' + idParts.join(', ') + ')') : char.name;\n    let brief = (char.briefDescription && String(char.briefDescription).trim()) ? '  \\u2014  ' + String(char.briefDescription).trim() : '';\n    return header + brief;\n}\n\n// [v0.9.9.7] Shared action-instance executor for any entity-attached action button\n// (Action tab, item rows, narrative rows). Resolves the live instance, detects\n// whether it needs a target picker, and runs it -- same resolve path RUN_ACTION_INSTANCE\n// uses. closeFn (if given) is called right before the action actually runs, matching\n// the close-then-act pattern used elsewhere in the native HUD.\nasync function aeRunEntityAction(entityId: string, instId: string, closeFn?: () => (void | Promise<void>)): Promise<void> {\n    try {\n        let ent = await loadEntity(entityId);\n        if (!ent) { api.v1.ui.toast('Action source missing.', { type: 'warning' }); return; }\n        let cfg2 = await loadConfig();\n        let found = (((ent as any).actionInstances || []) as any[]).find(function(x: any) { return x.id === instId; })\n                  || ((cfg2.actionTemplates || []) as any[]).find(function(x: any) { return x.id === instId; });\n        if (!found) { api.v1.ui.toast('Action not found.', { type: 'warning' }); return; }\n        let requiresTarget = (found as any).targetMode === 'player_pick';\n        if (requiresTarget) {\n            let state: any = await getSceneState();\n            let cands: any[] = [];\n            ((state && state.presentCharacters) || []).forEach(function(c: any) { if (!c.isProtagonist && c.entityId) cands.push({ tid: c.entityId, label: c.name }); });\n            ((state && state.presentItems) || []).forEach(function(it: any) { cands.push({ tid: it.id, label: it.name }); });\n            ((state && state.presentMinorNpcs) || []).forEach(function(n: any) { if (n.id) cands.push({ tid: n.id, label: n.name }); });\n            if (cands.length === 0) { api.v1.ui.toast('No valid targets present.', { type: 'warning' }); return; }\n            await openPickerModal({\n                title: 'Choose Target', items: cands, size: 'small',\n                getId: function(t: any) { return t.tid; }, getLabel: function(t: any) { return t.label; },\n                onSelect: async function(t: any) {\n                    let tEnt = await loadEntity(t.tid);\n                    if (closeFn) { try { await closeFn(); } catch (e0) {} }\n                    try { await runActionInstance(found, ent, cfg2, { target: tEnt || null }); } catch (eRun) { api.v1.error('[AE:hud] avail action:', eRun); }\n                }\n            });\n            return;\n        }\n        if (closeFn) { try { await closeFn(); } catch (e0) {} }\n        try { await runActionInstance(found, ent, cfg2, { target: null }); } catch (eRun2) { api.v1.error('[AE:hud] avail action:', eRun2); }\n    } catch (e) { api.v1.error('[AE:hud] aeRunEntityAction:', e); }\n}\n\n// Active-hooks list content (caller wraps in one 'Active Hooks (N)' collapsibleSection).\nfunction _aeHookRows(hooks: any[], charId: string, refreshFn: () => Promise<void>): UIPart[] {\n    if (!hooks || hooks.length === 0) return [_aeHudInfo('No active hooks.')];\n    return hooks.map(function(h: any) {\n        let targetLabel = h.targetName === '__player__' ? 'Player' : (h.targetName || 'Unknown');\n        return { type: 'box', style: { padding: '8px 10px', marginBottom: '6px', backgroundColor: 'rgba(217,138,138,0.08)', border: '1px solid rgba(217,138,138,0.25)', borderRadius: '6px' }, content: [\n            { type: 'text', text: '\\ud83e\\ude9d ' + targetLabel, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '2px' } } as UIPart,\n            { type: 'text', text: h.description || '', style: { fontSize: '11px', opacity: '0.85', lineHeight: '1.4', marginBottom: '4px' } } as UIPart,\n            { type: 'text', text: _aePressureLabel(h.pressureLevel) + '  (' + h.pressureLevel + ')', style: { fontSize: '10px', opacity: '0.6', marginBottom: '4px' } } as UIPart,\n            { type: 'button', text: 'Resolve Hook', iconId: 'check', style: { width: '100%', fontSize: '11px', margin: 0 }, callback: async function() { await resolveCharHook(charId, h.id); await refreshFn(); } } as UIPart\n        ] } as UIPart;\n    });\n}\n\n// One collapsibleSection per item, always defaults closed. Equip toggle only ever\n// targets the item's own owner/parent -- ownerCharId is resolved by the caller\n// (the character whose inventory this is, or undefined for ownerless location items,\n// which hides the toggle since there is no parent entity to toggle to).\nfunction _aeItemSection(items: any[], ownerCharId: string | undefined, refreshFn: () => Promise<void>): UIPart[] {\n    return (items || []).map(function(item: any) {\n        let body: UIPart[] = [];\n        body.push({ type: 'text', text: item.description || 'No description.', style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);\n        let equipTarget = item.isEquipped ? (item.equippedToCharId || ownerCharId) : ownerCharId;\n        if (equipTarget) {\n            body.push({ type: 'button', text: item.isEquipped ? 'Equipped' : 'Equip', iconId: item.isEquipped ? 'check-circle' : 'package', style: { width: '100%', fontSize: '11px', marginBottom: '4px', backgroundColor: item.isEquipped ? 'rgba(126,200,160,0.15)' : undefined, color: item.isEquipped ? '#7ec8a0' : undefined }, callback: async function() { await setItemEquip(equipTarget, item.id, !item.isEquipped); await refreshFn(); } } as UIPart);\n        }\n        (item.actionInstances || []).forEach(function(inst: any) {\n            body.push({ type: 'button', text: inst.name, iconId: 'zap', style: { width: '100%', fontSize: '11px', marginBottom: '3px' }, callback: async function() { await aeRunEntityAction(item.id, inst.id); await refreshFn(); } } as UIPart);\n        });\n        body.push({ type: 'button', text: 'Edit Entity', iconId: 'tool', style: { width: '100%', fontSize: '11px', marginTop: '2px', opacity: '0.75' }, callback: async function() { try { await openEntityEditModal(item.id); } catch (e) {} } } as UIPart);\n        return { type: 'collapsibleSection', title: aeIconPfx(item.icon) + item.name, initialCollapsed: true, storageKey: 'temp:ae_item_' + item.id, content: body } as UIPart;\n    });\n}\n\n// One collapsibleSection per narrative, always defaults closed. storyState, tracked\n// toggle (same STORAGE_TRACKED_NARRATIVE flag the bridge uses), target destination\n// and a due-date countdown (from eventDayTarget), entity-attached actions, and an\n// edit-modal button. curAbsDay is the clock's current absolute day (loaded once by\n// the caller so a long list doesn't reload the clock per row).\nfunction _aeNarrativeSection(narrs: any[], curAbsDay: number, refreshFn: () => Promise<void>): UIPart[] {\n    return (narrs || []).map(function(n: any) {\n        let body: UIPart[] = [];\n        let stateLabel = n.storyState === 'active' ? '\\ud83d\\udd25 Active' : n.storyState === 'completed' ? '\\u2705 Completed' : '\\ud83d\\udd12 Locked';\n        if (n.isTracked) stateLabel = '\\ud83c\\udfaf Tracked  \\u00b7  ' + stateLabel;\n        body.push({ type: 'text', text: stateLabel, style: { fontSize: '11px', fontWeight: 'bold', marginBottom: '4px', color: n.isTracked ? '#7ec8a0' : '#a8a8b8' } } as UIPart);\n        if (n.description) body.push({ type: 'text', text: n.description, style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);\n        if (n.questTargetName) body.push({ type: 'text', text: 'Target:  ' + n.questTargetName, style: { fontSize: '11px', opacity: '0.7', marginBottom: '2px' } } as UIPart);\n        if (typeof n.eventDayTarget === 'number') {\n            let due = Math.floor(n.eventDayTarget) - curAbsDay;\n            let dueStr = due > 1 ? (due + ' days remaining') : due === 1 ? '1 day remaining' : due === 0 ? 'due today' : ('overdue by ' + (-due) + (due === -1 ? ' day' : ' days'));\n            body.push({ type: 'text', text: 'Due:  ' + dueStr, style: { fontSize: '11px', marginBottom: '6px', color: due < 0 ? '#d98a8a' : '#e8c07d' } } as UIPart);\n        }\n        body.push({ type: 'button', text: n.isTracked ? 'Stop Tracking' : 'Track Quest', iconId: 'navigation', style: { width: '100%', fontSize: '11px', marginBottom: '4px', backgroundColor: n.isTracked ? undefined : 'rgba(126,200,160,0.15)', color: n.isTracked ? undefined : '#7ec8a0' }, callback: async function() { await toggleNarrativeTracking(n.id); await refreshFn(); } } as UIPart);\n        (n.actionInstances || []).forEach(function(inst: any) {\n            body.push({ type: 'button', text: inst.name, iconId: 'zap', style: { width: '100%', fontSize: '11px', marginBottom: '3px' }, callback: async function() { await aeRunEntityAction(n.id, inst.id); await refreshFn(); } } as UIPart);\n        });\n        body.push({ type: 'button', text: 'Edit Entity', iconId: 'tool', style: { width: '100%', fontSize: '11px', marginTop: '2px', opacity: '0.75' }, callback: async function() { try { await openEntityEditModal(n.id); } catch (e) {} } } as UIPart);\n        return { type: 'collapsibleSection', title: aeIconPfx(n.icon) + n.name, initialCollapsed: true, storageKey: 'temp:ae_narr_' + n.id, content: body } as UIPart;\n    });\n}\n\n// Personal (per-character) resource rows with inline +/- steppers -- adjustCharResource\n// runs directly in-worker, so there is no round-trip latency native has an edge here.\nfunction _aeResourceRows(charId: string, resources: any[], refreshFn: () => Promise<void>): UIPart[] {\n    if (!resources || resources.length === 0) return [_aeHudInfo('No personal resources.')];\n    return resources.map(function(r: any) {\n        let valLabel: string;\n        if (r.type === 'pool') valLabel = String(r.value) + (typeof r.max === 'number' ? ' / ' + r.max : '');\n        else valLabel = (r.states && r.states[r.value]) ? r.states[r.value] : String(r.value);\n        return _aeHudRow([\n            { type: 'text', text: r.name, style: { flex: '1 1 0', fontSize: '12px', alignSelf: 'center' } } as UIPart,\n            { type: 'button', text: '\\u2212', style: { width: '30px', margin: 0 }, callback: async function() { await adjustCharResource(charId, r.tag, -1); await broadcastSceneState(); await refreshFn(); } } as UIPart,\n            { type: 'text', text: valLabel, style: { width: '70px', fontSize: '11px', textAlign: 'center', alignSelf: 'center' } } as UIPart,\n            { type: 'button', text: '+', style: { width: '30px', margin: 0 }, callback: async function() { await adjustCharResource(charId, r.tag, 1); await broadcastSceneState(); await refreshFn(); } } as UIPart\n        ]);\n    });\n}\n\n// ── MAP ─────────────────────────────────────────────────────────────────────\nasync function openCalendarModal(): Promise<void> {\n    let calHandle: any = null;\n    let setOpen = false;\n    let setDayVal = 0;\n    let setHourVal = 0;\n\n    async function renderCal() {\n        let state: any = await getSceneState();\n        let parts: UIPart[] = [];\n        let clk: any = state ? state.clock : null;\n\n        if (!clk) {\n            parts.push(_aeHudInfo('No clock available. Enable \"Show date in context\" in World Settings > Time & Calendar.'));\n            parts.push(_aeHudClose(function() { return calHandle; }));\n            try { if (calHandle && !calHandle.isClosed()) { await calHandle.update({ content: parts }); return; } } catch (e) {}\n            calHandle = await openEngineModal({ id: 'ae-calendar', title: 'Calendar', size: 'medium', content: parts });\n            return;\n        }\n\n        parts.push(_aeHudHeader('Clock'));\n        parts.push({ type: 'text', text: clk.stamp || '', style: { fontSize: '15px', fontWeight: 'bold', marginBottom: '6px' } } as UIPart);\n        parts.push(_aeHudRow([\n            { type: 'button', text: '+1 Hour', iconId: 'clock', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {\n                let c2 = await loadClock(); await applyClockChange(c2.hours + 1); await renderCal();\n            } } as UIPart,\n            { type: 'button', text: '+1 Day', iconId: 'calendar', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {\n                let c2 = await loadClock(); await applyClockChange(c2.hours + 24); await renderCal();\n            } } as UIPart,\n            { type: 'button', text: setOpen ? 'Cancel' : 'Set', iconId: 'edit', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {\n                if (!setOpen) { setDayVal = clk.absoluteDay; setHourVal = clk.hourOfDay; }\n                setOpen = !setOpen; await renderCal();\n            } } as UIPart\n        ]));\n        if (setOpen) {\n            parts.push(_aeHudRow([\n                { type: 'text', text: 'Day', style: { fontSize: '11px', opacity: '0.6', alignSelf: 'center' } } as UIPart,\n                { type: 'numberInput', initialValue: setDayVal, style: { width: '70px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) { setDayVal = Math.max(0, Math.floor(Number(v) || 0)); } } as UIPart,\n                { type: 'text', text: 'Hour', style: { fontSize: '11px', opacity: '0.6', alignSelf: 'center' } } as UIPart,\n                { type: 'numberInput', initialValue: setHourVal, style: { width: '70px', margin: 0, fontSize: '12px' }, onChange: async function(v: number) { let h = Math.floor(Number(v) || 0); if (h < 0) h = 0; if (h > 23) h = 23; setHourVal = h; } } as UIPart,\n                { type: 'button', text: 'Apply', style: { margin: 0, fontSize: '12px', backgroundColor: 'rgba(126,200,160,0.15)' }, callback: async function() {\n                    await applyClockChange(setDayVal * 24 + setHourVal); setOpen = false; await renderCal();\n                } } as UIPart\n            ]));\n        }\n\n        // [v1.6.1] Mirrors the World-Build Wizard's Characters tab button (same\n        // text, icon, and target modal) so schedules are reachable from the\n        // calendar too, not just the wizard.\n        parts.push({ type: 'button', text: '\\ud83d\\udd52 View All Schedules', iconId: 'clock' as any, style: { width: '100%', marginTop: '4px', marginBottom: '10px', fontSize: '11px', backgroundColor: 'rgba(136,204,255,0.10)' }, callback: async function() { await openAllSchedulesModal(); } } as UIPart);\n\n        parts.push(_aeHudHeader('Upcoming (Narrative)'));\n        let timed: any[] = (clk.timedActions || []);\n        let dayNames: string[] = (clk.dayNames || []);\n        let todayCycle: number = clk.dayOfCycle;\n\n        let dayBuckets: any = {};\n        let dailyActions: any[] = [];\n        function pushBucket(d: number, a: any) { if (!dayBuckets[d]) dayBuckets[d] = []; dayBuckets[d].push(a); }\n        for (let i = 0; i < timed.length; i++) {\n            let a = timed[i];\n            let placed = false;\n            if (typeof a.dayOfCycle === 'number' && a.dayOfCycle >= 1 && a.dayOfCycle <= 28) { pushBucket(a.dayOfCycle, a); placed = true; }\n            if (typeof a.dayOfWeek === 'number' && a.dayOfWeek >= 1 && a.dayOfWeek <= 7) {\n                for (let w = 0; w < 4; w++) { pushBucket(w * 7 + a.dayOfWeek, a); } placed = true;\n            }\n            if (!placed && typeof a.absoluteDay === 'number') {\n                let cyc = ((a.absoluteDay % 28) + 28) % 28 + 1;\n                let curCycleStart = (clk.absoluteDay - (todayCycle - 1));\n                if (a.absoluteDay >= curCycleStart && a.absoluteDay < curCycleStart + 28) { pushBucket(cyc, a); placed = true; }\n            }\n            if (!placed) dailyActions.push(a);\n        }\n\n        let header: UIPart[] = [];\n        for (let c = 0; c < 7; c++) {\n            let nm = dayNames[c] ? String(dayNames[c]).slice(0, 3) : String(c + 1);\n            header.push({ type: 'text', text: nm, style: { flex: '1 1 0', fontSize: '10px', opacity: '0.6', textAlign: 'center', fontWeight: 'bold' } } as UIPart);\n        }\n        parts.push({ type: 'row', style: { gap: '3px', marginBottom: '3px' }, content: header } as UIPart);\n\n        for (let wk = 0; wk < 4; wk++) {\n            let rowCells: UIPart[] = [];\n            for (let c = 0; c < 7; c++) {\n                let dnum = wk * 7 + c + 1;\n                let has = !!(dayBuckets[dnum] && dayBuckets[dnum].length);\n                let isToday = (dnum === todayCycle);\n                let cnt = has ? dayBuckets[dnum].length : 0;\n                let bg = has ? 'rgba(126,200,160,0.22)' : 'rgba(255,255,255,0.03)';\n                let bord = isToday ? '2px solid #7ec8a0' : (has ? '1px solid rgba(126,200,160,0.4)' : '1px solid rgba(255,255,255,0.06)');\n                let label = String(dnum) + (cnt ? ' \\u2022' : '');\n                let capturedDay = dnum;\n                rowCells.push({ type: 'button', text: label, style: { flex: '1 1 0', margin: 0, fontSize: '11px', padding: '6px 0', backgroundColor: bg, border: bord, color: has ? '#cfeede' : undefined, opacity: (has || isToday) ? '1' : '0.55' }, callback: async function() {\n                    let acts = dayBuckets[capturedDay] || [];\n                    let dParts: UIPart[] = [];\n                    let dh: any = null;\n                    dParts.push({ type: 'text', text: 'Day ' + capturedDay + ' of 28', style: { fontSize: '13px', fontWeight: 'bold', marginBottom: '6px' } } as UIPart);\n                    if (acts.length === 0) {\n                        dParts.push(_aeHudInfo('Nothing tied to this day.'));\n                    } else {\n                        for (let z = 0; z < acts.length; z++) {\n                            let act = acts[z];\n                            dParts.push({ type: 'box', style: { padding: '6px 8px', marginBottom: '4px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '6px', borderLeft: act.auto ? '3px solid #88ccff' : '3px solid #e8a87c' }, content: [\n                                { type: 'text', text: (act.auto ? '\\u26a1 ' : '') + (act.name || 'Action'), style: { fontSize: '12px', fontWeight: 'bold' } } as UIPart,\n                                { type: 'text', text: act.summary || '', style: { fontSize: '10px', opacity: '0.65', marginTop: '2px' } } as UIPart\n                            ] } as UIPart);\n                        }\n                    }\n                    dParts.push({ type: 'button', text: 'Close', style: { marginTop: '8px' }, callback: async function() { try { if (dh && !dh.isClosed()) await dh.close(); } catch (e) {} } } as UIPart);\n                    dh = await openEngineModal({ id: 'ae-cal-day', title: 'Day ' + capturedDay, size: 'small', content: dParts });\n                } } as UIPart);\n            }\n            parts.push({ type: 'row', style: { gap: '3px', marginBottom: '3px' }, content: rowCells } as UIPart);\n        }\n\n        if (dailyActions.length > 0) {\n            parts.push(_aeHudHeader('Every Day'));\n            for (let i = 0; i < dailyActions.length; i++) {\n                let a = dailyActions[i];\n                parts.push({ type: 'box', style: { padding: '5px 8px', marginBottom: '3px', backgroundColor: 'rgba(255,255,255,0.03)', borderRadius: '5px', borderLeft: a.auto ? '3px solid #88ccff' : '3px solid #e8a87c' }, content: [\n                    { type: 'text', text: (a.auto ? '\\u26a1 ' : '') + (a.name || 'Action') + '  \\u2014  ' + (a.summary || ''), style: { fontSize: '11px' } } as UIPart\n                ] } as UIPart);\n            }\n        }\n        if (timed.length === 0) parts.push(_aeHudInfo('No actions are tied to the calendar yet. Add a time condition (Day of Cycle, Day of Week, ...) to a library action.'));\n\n        parts.push(_aeHudClose(function() { return calHandle; }));\n        try { if (calHandle && !calHandle.isClosed()) { await calHandle.update({ content: parts }); return; } } catch (e) {}\n        calHandle = await openEngineModal({ id: 'ae-calendar', title: 'Calendar', size: 'medium', content: parts });\n    }\n    await renderCal();\n}\n\n// ── CALENDAR / CLOCK ───────────────────────────────────────────────────────\nasync function openMapModal(): Promise<void> {\n    let mapHandle: any = null;\n\n    // Resolve the outbound edge (child / sibling / connection) for a destination id.\n    // Parent (return trip) has no edge and is free.\n    function _mapEdge(g: any, id: string): any {\n        let all: any[] = ([] as any[]).concat(g.children || [], g.siblings || [], g.connections || []);\n        return all.filter(function(e: any) { return e.id === id; })[0] || null;\n    }\n    // Human cost string: time first (\"2h\"), then resource (\"5 currency\").\n    function _mapCost(edge: any): string {\n        if (!edge) return '';\n        let bits: string[] = [];\n        if (edge.timeCost && edge.timeCost > 0) bits.push(edge.timeCost + 'h');\n        if (edge.resourceCost && edge.resourceTag) bits.push(edge.resourceCost + ' ' + String(edge.resourceTag).replace('#', ''));\n        return bits.join('  +  ');\n    }\n\n    async function renderMap() {\n        let state: any = await getSceneState();\n        let parts: UIPart[] = [];\n        if (!state) {\n            parts.push(_aeHudInfo('No scene state available.'));\n            parts.push(_aeHudClose(function() { return mapHandle; }));\n            try { if (mapHandle && !mapHandle.isClosed()) { await mapHandle.update({ content: parts }); return; } } catch (e) {}\n            mapHandle = await openEngineModal({ id: 'ae-nav-map', title: 'Map', size: 'medium', content: parts });\n            return;\n        }\n        let g: any = state.locationGraph || {};\n\n        // Current location header + body + atmosphere.\n        parts.push({ type: 'text', text: (g.currentIcon ? g.currentIcon + ' ' : '') + (state.locationName || 'Unknown location'), style: { fontSize: '15px', fontWeight: 'bold', marginBottom: '2px' } } as UIPart);\n        if (state.locationDescription) parts.push({ type: 'text', text: state.locationDescription, style: { fontSize: '11px', opacity: '0.75', lineHeight: '1.4', marginBottom: '3px' } } as UIPart);\n        if (state.locationAtmosphere) parts.push({ type: 'text', text: state.locationAtmosphere, style: { fontSize: '11px', opacity: '0.5', fontStyle: 'italic', marginBottom: '3px' } } as UIPart);\n\n        // \"Looking at\" panel: the inspected destination, its cost, and the Travel /\n        // Teleport actions. Sits directly under the current location so the buttons\n        // have the full modal width and room for the cost line.\n        if (_aeMapInspectId && _aeMapInspectId !== state.locationId) {\n            let insEnt: any = null;\n            try { insEnt = await loadEntity(_aeMapInspectId); } catch (eIns) { insEnt = null; }\n            if (insEnt) {\n                let edge = _mapEdge(g, _aeMapInspectId);\n                let isParent = (g.parentId === _aeMapInspectId);\n                let costLine = _mapCost(edge);\n                let gated = edge ? !!edge.gated : false;\n                let panel: UIPart[] = [];\n                panel.push({ type: 'text', text: 'Looking at', style: { fontSize: '10px', opacity: '0.55', fontWeight: 'bold', marginBottom: '2px' } } as UIPart);\n                panel.push({ type: 'text', text: aeIconPfx(insEnt.icon) + (insEnt.name || ''), style: { fontSize: '14px', fontWeight: 'bold', color: '#a9d4f5', marginBottom: '3px' } } as UIPart);\n                panel.push({ type: 'text', text: insEnt.description || 'No description recorded.', style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.4', marginBottom: '6px' } } as UIPart);\n                if (costLine) panel.push({ type: 'text', text: 'Travel cost:  ' + costLine, style: { fontSize: '11px', color: '#e8c07d', marginBottom: '6px' } } as UIPart);\n                else if (isParent) panel.push({ type: 'text', text: 'Return trip \\u2014 no cost.', style: { fontSize: '11px', opacity: '0.55', marginBottom: '6px' } } as UIPart);\n                else panel.push({ type: 'text', text: 'No travel cost.', style: { fontSize: '11px', opacity: '0.55', marginBottom: '6px' } } as UIPart);\n                if (gated) panel.push({ type: 'text', text: '\\ud83d\\udd12 Locked \\u2014 travel unavailable.', style: { fontSize: '11px', color: '#d98a8a', marginBottom: '6px' } } as UIPart);\n                panel.push(_aeHudRow([\n                    { type: 'button', text: 'Travel' + (costLine ? '  (' + costLine + ')' : ''), iconId: 'corner-down-right', disabled: gated, style: { flex: '2 1 0', fontSize: '12px', margin: 0, fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, callback: async function() {\n                        let dest = _aeMapInspectId;\n                        try { if (mapHandle && !mapHandle.isClosed()) await mapHandle.close(); } catch (e0) {}\n                        try { await performTravelRequest(dest); } catch (eTrav) { api.v1.error('[AE:hud] travel:', eTrav); }\n                    } } as UIPart,\n                    { type: 'button', text: 'Teleport', iconId: 'navigation', style: { flex: '1 1 0', fontSize: '12px', margin: 0 }, callback: async function() {\n                        let dest = _aeMapInspectId;\n                        try { await commitTravel(dest, true); } catch (eTp) {}\n                        _aeMapInspectId = '';\n                        await renderMap();\n                    } } as UIPart\n                ]));\n                parts.push({ type: 'box', style: { padding: '9px 11px', marginTop: '8px', marginBottom: '2px', backgroundColor: 'rgba(136,204,255,0.08)', border: '1px solid rgba(136,204,255,0.25)', borderRadius: '8px' }, content: panel } as UIPart);\n            }\n        }\n\n        // Destination list: each location is a full-width name button that loads it\n        // into the \"Looking at\" panel above. Grouped Above / Nearby / Inside.\n        function navBtn(id: string, label: string, icon: any): UIPart {\n            let sel = (_aeMapInspectId === id);\n            return { type: 'button', text: aeIconPfx(icon) + label, iconId: 'eye', style: { width: '100%', textAlign: 'left', fontSize: '12px', marginBottom: '3px', backgroundColor: sel ? 'rgba(136,204,255,0.15)' : undefined, border: sel ? '1px solid rgba(136,204,255,0.4)' : undefined }, callback: async function() { _aeMapInspectId = id; await renderMap(); } } as UIPart;\n        }\n\n        parts.push(_aeHudHeader('Travel'));\n        let anyConn = false;\n\n        if (g.parentId) {\n            parts.push(_aeHudSub('Above'));\n            parts.push(navBtn(g.parentId, g.parentName || 'Up one level', g.parentIcon));\n            anyConn = true;\n        }\n\n        let nearby: any[] = [];\n        (g.siblings || []).forEach(function(s: any) { nearby.push({ id: s.id, name: s.name, icon: s.icon }); });\n        (g.connections || []).forEach(function(c: any) { nearby.push({ id: c.id, name: c.name + (c.label ? '  \\u2014 ' + c.label : ''), icon: c.icon }); });\n        if (nearby.length > 0) {\n            parts.push(_aeHudSub('Nearby'));\n            nearby.forEach(function(n: any) { parts.push(navBtn(n.id, n.name, n.icon)); });\n            anyConn = true;\n        }\n\n        if ((g.children || []).length > 0) {\n            parts.push(_aeHudSub('Inside'));\n            (g.children || []).forEach(function(c: any) { parts.push(navBtn(c.id, c.name, c.icon)); });\n            anyConn = true;\n        }\n\n        if (!anyConn) parts.push(_aeHudInfo('No connected locations.'));\n\n        parts.push(_aeHudClose(function() { return mapHandle; }));\n        try { if (mapHandle && !mapHandle.isClosed()) { await mapHandle.update({ content: parts }); return; } } catch (e) {}\n        mapHandle = await openEngineModal({ id: 'ae-nav-map', title: 'Map', size: 'medium', content: parts });\n    }\n    await renderMap();\n}\n\n// ── CHARACTER INSPECTION VIEW ──────────────────────────────────────────────────\n// [v0.9.9.7] Full character detail view opened by tapping a name in Inspect. Reads\n// buildEntityDetailPayload directly (in-worker, no message round-trip) -- the SAME\n// data source the bridge focus banner uses, so both stay in lockstep by construction.\nasync function openCharInspectModal(charId: string): Promise<void> {\n    let ciHandle: any = null;\n\n    async function renderCI() {\n        let parts: UIPart[] = [];\n        let char = await loadCharacter(charId);\n        if (!char) {\n            parts.push(_aeHudInfo('Character not found.'));\n            parts.push(_aeHudClose(function() { return ciHandle; }));\n            try { if (ciHandle && !ciHandle.isClosed()) { await ciHandle.update({ content: parts }); return; } } catch (e) {}\n            ciHandle = await openEngineModal({ id: 'ae-char-inspect', title: 'Character', size: 'medium', content: parts });\n            return;\n        }\n        let ent = char.entityId ? await loadEntity(char.entityId) : null;\n        let cfg = await loadConfig();\n        let detail = await buildEntityDetailPayload(charId, char, ent);\n        let clk = await loadClock(cfg);\n        let curAbsDay = clockAbsoluteDay(clk.hours);\n\n        // Name + Edit Profile.\n        parts.push(_aeHudRow([\n            { type: 'text', text: char.name || 'Character', style: { flex: '1 1 0', fontSize: '15px', fontWeight: 'bold', alignSelf: 'center' } } as UIPart,\n            { type: 'button', text: 'Edit Profile', iconId: 'edit-3', style: { fontSize: '11px', margin: 0 }, callback: async function() { try { await openCharEditModal(charId); } catch (e) {} } } as UIPart\n        ]));\n\n        // Dramatis persona + thoughts line.\n        parts.push({ type: 'text', text: _aeCharDramatis(char), style: { fontSize: '11px', opacity: '0.75', lineHeight: '1.4', marginBottom: '3px' } } as UIPart);\n        let thought = (char.ephemeral && char.ephemeral.compressedLine) ? char.ephemeral.compressedLine : '';\n        if (thought) parts.push({ type: 'text', text: '\\ud83d\\udcad ' + thought, style: { fontSize: '11px', opacity: '0.6', fontStyle: 'italic', marginBottom: '6px' } } as UIPart);\n\n        // Snapshot -- collapsible, defaults closed. Generates/regenerates the written\n        // appearance snapshot via the same GLM pipeline the bridge's Snapshots section uses.\n        let snapText = await api.v1.storyStorage.getOrDefault(STORAGE_CHAR_SNAP_PFX + charId, '') as string;\n        let snapBody: UIPart[] = [];\n        snapBody.push({ type: 'button', text: snapText ? 'Regenerate Snapshot' : 'Generate Snapshot', iconId: 'edit-3', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() {\n            if (!ent) { api.v1.ui.toast('No scene context for snapshot.', { type: 'warning' }); return; }\n            try {\n                let text = await generateCharacterSnapshot(char, ent, cfg);\n                if (text) { await api.v1.storyStorage.set(STORAGE_CHAR_SNAP_PFX + charId, text); api.v1.ui.toast('\\u270d\\ufe0f Snapshot ready', { type: 'success', autoClose: 1500 }); }\n                else { api.v1.ui.toast('Snapshot generation failed.', { type: 'warning' }); }\n            } catch (eSnap) { api.v1.error('[AE:hud] snapshot:', eSnap); }\n            await renderCI();\n        } } as UIPart);\n        if (snapText) snapBody.push({ type: 'text', text: snapText, style: { fontSize: '11px', opacity: '0.8', lineHeight: '1.5', whiteSpace: 'pre-wrap' } } as UIPart);\n        else snapBody.push(_aeHudInfo('No snapshot generated yet.'));\n        parts.push({ type: 'collapsibleSection', title: 'Snapshot' + (snapText ? ' \\u2014 ready' : ''), initialCollapsed: true, storageKey: 'temp:ae_char_snap_' + charId, content: snapBody } as UIPart);\n\n        // Follow Me / Stay Here -- non-protagonist only, identical rule to the bridge toggle.\n        if (!detail.isProtagonist && detail.isFollowing !== undefined) {\n            parts.push({ type: 'button', text: detail.isFollowing ? '\\ud83d\\udc64 Stay here' : '\\ud83d\\udc65 Follow me', iconId: detail.isFollowing ? 'user' : 'users', style: { width: '100%', fontSize: '12px', marginBottom: '8px', backgroundColor: detail.isFollowing ? undefined : 'rgba(126,200,160,0.15)', color: detail.isFollowing ? undefined : '#7ec8a0' }, callback: async function() { await toggleCharFollow(charId); await renderCI(); } } as UIPart);\n        }\n\n        let hooks = detail.hooks || [];\n        parts.push({ type: 'collapsibleSection', title: 'Active Hooks (' + hooks.length + ')', initialCollapsed: false, storageKey: 'temp:ae_char_hooks_' + charId, content: _aeHookRows(hooks, charId, renderCI) } as UIPart);\n\n        let children = detail.children || [];\n        let items = children.filter(function(c: any) { return c.type === 'item'; });\n        parts.push({ type: 'collapsibleSection', title: 'Inventory (' + items.length + ')', initialCollapsed: false, storageKey: 'temp:ae_char_inv_' + charId, content: items.length ? _aeItemSection(items, charId, renderCI) : [_aeHudInfo('No carried items.')] } as UIPart);\n\n        let narrs = children.filter(function(c: any) { return c.type === 'narrative'; });\n        parts.push({ type: 'collapsibleSection', title: 'Narratives (' + narrs.length + ')', initialCollapsed: false, storageKey: 'temp:ae_char_narr_' + charId, content: narrs.length ? _aeNarrativeSection(narrs, curAbsDay, renderCI) : [_aeHudInfo('No narrative threads.')] } as UIPart);\n\n        let cres = detail.charResources || [];\n        parts.push({ type: 'collapsibleSection', title: 'Resources (' + cres.length + ')', initialCollapsed: true, storageKey: 'temp:ae_char_res_' + charId, content: _aeResourceRows(charId, cres, renderCI) } as UIPart);\n\n        parts.push(_aeHudClose(function() { return ciHandle; }));\n        try { if (ciHandle && !ciHandle.isClosed()) { await ciHandle.update({ content: parts }); return; } } catch (e) {}\n        ciHandle = await openEngineModal({ id: 'ae-char-inspect', title: 'Character', size: 'medium', content: parts });\n    }\n    await renderCI();\n}\n\n// ── INSPECT ───────────────────────────────────────────────────────────────────\nasync function openInspectModal(): Promise<void> {\n    let insHandle: any = null;\n\n    async function renderInspect() {\n        let parts: UIPart[] = [];\n        let state: any = await getSceneState();\n        if (!state) {\n            parts.push(_aeHudInfo('No scene state available.'));\n            parts.push(_aeHudClose(function() { return insHandle; }));\n            try { if (insHandle && !insHandle.isClosed()) { await insHandle.update({ content: parts }); return; } } catch (e) {}\n            insHandle = await openEngineModal({ id: 'ae-nav-inspect', title: 'Inspect', size: 'medium', content: parts });\n            return;\n        }\n\n        let chars = (state.presentCharacters || []).filter(function(c: any) { return !c.isProtagonist; });\n        parts.push({ type: 'row', style: { alignItems: 'center', gap: '6px', marginTop: '4px', marginBottom: '2px' }, content: [\n            { type: 'text', text: 'Characters', style: { flex: '1 1 0', fontWeight: 'bold', fontSize: '12px' } },\n            { type: 'button', text: '\\u27f3 Detect', iconId: 'refresh-cw', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 8px', opacity: '0.8' }, callback: async function() { await aeRefreshPresence(); await renderInspect(); } }\n        ] } as UIPart);\n        parts.push({ type: 'button', text: '+ Add Character to Scene', iconId: 'user-plus', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() {\n            const acAll = await loadAllCharacters();\n            const acPresent = new Set((state.presentCharacters || []).map(function(pc: any) { return pc.id; }));\n            const acCands = acAll.filter(function(ac) { return ac.active && !ac.isProtagonist && (ac as any).npcClass !== 'minor' && !acPresent.has(ac.id); });\n            // Pre-resolve each candidate's current location name for the picker sublabel.\n            const acIdx = await loadEntityIndex();\n            const acLocById: { [k: string]: string } = {};\n            for (const ac of acCands) {\n                let locName = 'no location';\n                if (ac.entityId) {\n                    let room = getEffectiveRoomId(ac.entityId, acIdx);\n                    if (room) { let rn = acIdx.find(function(m) { return m.id === room; }); if (rn && rn.name) locName = rn.name; }\n                }\n                acLocById[ac.id] = locName;\n            }\n            await openPickerModal({\n                title: 'Add Character to Scene',\n                items: acCands,\n                getId: function(it: any) { return it.id; },\n                getLabel: function(it: any) { return it.name; },\n                getSublabel: function(it: any) { return '\\ud83d\\udccd ' + (acLocById[it.id] || 'no location'); },\n                searchable: true,\n                emptyText: 'Everyone active is already here.',\n                onSelect: async function(it: any) { await aeMoveCharToScene(it.id); await renderInspect(); }\n            });\n        } } as UIPart);\n        if (chars.length === 0) parts.push(_aeHudInfo('No one else is here.'));\n        chars.forEach(function(c: any) {\n            parts.push({ type: 'row', style: { gap: '4px', marginBottom: '3px', alignItems: 'center' }, content: [\n                { type: 'button', text: c.name + (c.compressedLine ? '  \\u2014  ' + c.compressedLine : ''), iconId: 'user', style: { flex: '1 1 0', textAlign: 'left', fontSize: '12px' }, callback: async function() { try { await openCharInspectModal(c.id); } catch (e) {} } },\n                { type: 'button', text: 'Exclude', style: { flex: '0 0 auto', margin: 0, fontSize: '10px', padding: '3px 7px', opacity: '0.8' }, callback: async function() { await aeSetCharScenePresent(c.id, false); await renderInspect(); } }\n            ] } as UIPart);\n        });\n\n        // Items / narratives native to THIS location -- pulled from the same\n        // buildEntityDetailPayload children the character inventory view uses, so\n        // descriptions/actions/state are real instead of the old name-only buttons.\n        let locEnt = state.locationId ? await loadEntity(state.locationId) : null;\n        let locDetail = state.locationId ? await buildEntityDetailPayload(state.locationId, null, locEnt) : null;\n        let locChildren = locDetail ? (locDetail.children || []) : [];\n        let items = locChildren.filter(function(c: any) { return c.type === 'item'; });\n        let narrs = locChildren.filter(function(c: any) { return c.type === 'narrative'; });\n\n        // [vNEXT] Minor NPCs present at this location, rendered like items (brief +\n        // actions + promote), plus a quick drop-in creator scoped to this location.\n        let minorIds = new Set((state.presentMinorNpcs || []).map(function(n: any) { return n.id; }));\n        let minors = locChildren.filter(function(c: any) { return minorIds.has(c.id); });\n        parts.push(_aeHudHeader('Present NPCs (' + minors.length + ')'));\n        parts.push({ type: 'button', text: '+ Add NPC Here', iconId: 'user-plus', style: { width: '100%', fontSize: '11px', marginBottom: '6px' }, callback: async function() { await openAddMinorNpcModal(state.locationId, renderInspect); } } as UIPart);\n        if (minors.length === 0) parts.push(_aeHudInfo('No minor NPCs here.'));\n        else parts.push.apply(parts, _aeMinorNpcSection(minors, renderInspect));\n\n        parts.push(_aeHudHeader('Items (' + items.length + ')'));\n        if (items.length === 0) parts.push(_aeHudInfo('Nothing here.'));\n        else parts.push.apply(parts, _aeItemSection(items, undefined, renderInspect));\n\n        if (narrs.length > 0) {\n            let cfg = await loadConfig();\n            let clk = await loadClock(cfg);\n            parts.push(_aeHudHeader('Narratives (' + narrs.length + ')'));\n            parts.push.apply(parts, _aeNarrativeSection(narrs, clockAbsoluteDay(clk.hours), renderInspect));\n        }\n\n        parts.push(_aeHudClose(function() { return insHandle; }));\n        try { if (insHandle && !insHandle.isClosed()) { await insHandle.update({ content: parts }); return; } } catch (e) {}\n        insHandle = await openEngineModal({ id: 'ae-nav-inspect', title: 'Inspect', size: 'medium', content: parts });\n    }\n    await renderInspect();\n}\n\n// ── ACTION (Goal & Approach) ──────────────────────────────────────────────────\nasync function openActionModal(prefillGoal?: string): Promise<void> {\n    let actHandle: any = null;\n    if (typeof prefillGoal === 'string' && prefillGoal.length > 0) _aeNavGoal = prefillGoal;\n\n    function composeInstance(): any {\n        let tt = (_aeNavTarget === 'none') ? 'none' : (_aeNavTarget === 'self' ? 'self' : 'entity');\n        return {\n            id: 'qi_' + Date.now().toString(36) + Math.floor(Math.random() * 1000000).toString(36),\n            name: (_aeNavGoal.trim().slice(0, 32) || 'Quick Action'),\n            prompt: _aeNavGoal.trim(),\n            targetType: tt,\n            targetId: (tt === 'entity') ? _aeNavTarget : null,\n            skillTag: _aeNavAttr || null,\n            stakeDefId: _aeNavStake || null,\n            luckSpend: _aeNavLuck || 0\n        };\n    }\n\n    async function renderAction() {\n        let state: any = await getSceneState();\n        if (!state) state = { protagSkills: [], stakeDefs: [], presentCharacters: [], presentItems: [], protagResources: [], quickInstances: [] } as any;\n        let skills = state.protagSkills || [];\n        let stakes = state.stakeDefs || [];\n\n        // Defaults on first open: first skill + its smart stake.\n        // [v0.9.9.6] Apply composer defaults exactly once per session. Using a distinct\n        // init flag (not _aeNavAttr === null) so that an explicit 'No check' (null) sticks.\n        if (!_aeNavInit) {\n            if (skills.length) _aeNavAttr = '#' + String(skills[0].name).toLowerCase();\n            _aeNavStake = _aeDefaultStakeFor(state, _aeNavAttr);\n            _aeNavStakeAuto = true;\n            _aeNavInit = true;\n        }\n\n        let silent = await getSilentMode();\n        let parts: UIPart[] = [];\n\n        // Header + Story/Silent toggle.\n        parts.push(_aeHudRow([\n            { type: 'text', text: 'Goal & Approach', style: { flex: '1 1 0', fontSize: '13px', fontWeight: 'bold', color: '#7ec8a0' } } as UIPart,\n            { type: 'button', text: silent ? 'Silent' : 'Story', iconId: silent ? 'bell-off' : 'bell', style: { width: '90px', margin: 0, fontSize: '11px' }, callback: async function() { await setSilentMode(!silent); await renderAction(); } } as UIPart\n        ]));\n\n        parts.push({ type: 'multilineTextInput', placeholder: 'Describe your goal and how you attempt to accomplish it. This informs what success or failure looks like.', initialValue: _aeNavGoal, style: { minHeight: '54px', marginBottom: '6px' }, onChange: async function(v: string) { _aeNavGoal = v; } } as UIPart);\n\n        // [v0.9.9.6] Skill / Stakes / Target -- one compact row of three pickers.\n        // Button text is the current value; the empty state IS the label\n        // (\"No check\" / \"No stake\" / \"No target\"). No leading header prefix.\n        let skillLabel = 'No check';\n        if (_aeNavAttr) { let sk = skills.filter(function(s: any) { return '#' + String(s.name).toLowerCase() === _aeNavAttr; })[0]; if (sk) skillLabel = sk.name + ' (' + (sk.sheetMod >= 0 ? '+' : '') + sk.sheetMod + ')'; }\n        let skillBtn = { type: 'button', text: skillLabel, iconId: 'target', style: { flex: '1 1 0', textAlign: 'left', fontSize: '11px', margin: 0 }, callback: async function() {\n            await openPickerModal({\n                title: 'Skill / Attribute', items: skills, size: 'small',\n                getId: function(s: any) { return '#' + String(s.name).toLowerCase(); },\n                getLabel: function(s: any) { return s.name + ' (' + (s.sheetMod >= 0 ? '+' : '') + s.sheetMod + ')'; },\n                selectedId: _aeNavAttr || undefined,\n                pinnedOptions: [{ id: '__nocheck__', label: 'No check', onSelect: async function() { _aeNavAttr = null; if (_aeNavStakeAuto) _aeNavStake = ''; await renderAction(); } }],\n                onSelect: async function(s: any) { _aeNavAttr = '#' + String(s.name).toLowerCase(); if (_aeNavStakeAuto) _aeNavStake = _aeDefaultStakeFor(state, _aeNavAttr); await renderAction(); }\n            });\n        } } as UIPart;\n\n        let stakeLabel = 'No stake';\n        if (_aeNavStake) { let sd = stakes.filter(function(s: any) { return s.id === _aeNavStake; })[0]; if (sd) stakeLabel = sd.name; }\n        let stakeBtn = { type: 'button', text: stakeLabel, iconId: 'award', style: { flex: '1 1 0', textAlign: 'left', fontSize: '11px', margin: 0 }, callback: async function() {\n            await openPickerModal({\n                title: 'Stakes', items: stakes, size: 'small',\n                getId: function(s: any) { return s.id; }, getLabel: function(s: any) { return s.name; },\n                selectedId: _aeNavStake || undefined,\n                pinnedOptions: [{ id: '__nostake__', label: 'No stake', onSelect: async function() { _aeNavStake = ''; _aeNavStakeAuto = false; await renderAction(); } }],\n                onSelect: async function(s: any) { _aeNavStake = s.id; _aeNavStakeAuto = false; await renderAction(); }\n            });\n        } } as UIPart;\n\n        let tgtItems: any[] = [];\n        if (state.locationId) tgtItems.push({ tid: state.locationId, label: 'Here \\u2014 ' + (state.locationName || ''), icon: 'map-pin' });\n        (state.presentCharacters || []).forEach(function(c: any) { if (!c.isProtagonist && c.entityId) tgtItems.push({ tid: c.entityId, label: c.name, icon: 'user' }); });\n        (state.presentItems || []).forEach(function(it: any) { tgtItems.push({ tid: it.id, label: it.name, icon: 'package' }); });\n        (state.presentMinorNpcs || []).forEach(function(n: any) { if (n.id) tgtItems.push({ tid: n.id, label: n.name, icon: 'user' }); });\n        let tgtLabel = 'No target';\n        if (_aeNavTarget === 'self') tgtLabel = 'Self';\n        else if (_aeNavTarget !== 'none') { let ti = tgtItems.filter(function(t: any) { return t.tid === _aeNavTarget; })[0]; tgtLabel = ti ? ti.label : 'No target'; }\n        let tgtBtn = { type: 'button', text: tgtLabel, iconId: 'crosshair', style: { flex: '1 1 0', textAlign: 'left', fontSize: '11px', margin: 0 }, callback: async function() {\n            await openPickerModal({\n                title: 'Target', items: tgtItems, size: 'small',\n                getId: function(t: any) { return t.tid; }, getLabel: function(t: any) { return t.label; }, getIcon: function(t: any) { return undefined; },\n                selectedId: (_aeNavTarget !== 'none' && _aeNavTarget !== 'self') ? _aeNavTarget : undefined,\n                pinnedOptions: [\n                    { id: '__none__', label: 'No target', onSelect: async function() { _aeNavTarget = 'none'; await renderAction(); } },\n                    { id: '__self__', label: 'Self', onSelect: async function() { _aeNavTarget = 'self'; await renderAction(); } }\n                ],\n                onSelect: async function(t: any) { _aeNavTarget = t.tid; await renderAction(); }\n            });\n        } } as UIPart;\n\n        parts.push(_aeHudRow([skillBtn, stakeBtn, tgtBtn]));\n\n        // Luck stepper (only when a #luck personal resource is positive).\n        let luckRes = (state.protagResources || []).filter(function(r: any) { return r.tag === '#luck'; })[0];\n        let luckMax = luckRes ? (luckRes.value || 0) : 0;\n        if (luckMax > 0) {\n            if (_aeNavLuck > luckMax) _aeNavLuck = luckMax;\n            parts.push(_aeHudRow([\n                { type: 'text', text: 'Spend Luck (max ' + luckMax + ')', style: { flex: '1 1 0', fontSize: '11px', opacity: '0.7' } } as UIPart,\n                { type: 'numberInput', initialValue: _aeNavLuck, style: { width: '70px', margin: 0 }, onChange: async function(v: number) { _aeNavLuck = Math.max(0, Math.min(luckMax, Math.floor(v || 0))); } } as UIPart\n            ]));\n        } else { _aeNavLuck = 0; }\n\n        // Save / Execute.\n        parts.push(_aeHudRow([\n            { type: 'button', text: 'Save Preset', iconId: 'save', style: { flex: '1 1 0', margin: 0, fontSize: '12px' }, callback: async function() {\n                if (!_aeNavGoal.trim()) { api.v1.ui.toast('Describe your goal first.', { type: 'warning' }); return; }\n                try { let list = await loadQuickInstances(); let rec: any = composeInstance(); list.push(rec); await saveQuickInstances(list); api.v1.ui.toast('Preset saved.', { type: 'success', autoClose: 1500 }); await renderAction(); }\n                catch (e) { api.v1.error('[AE:hud] save preset:', e); }\n            } } as UIPart,\n            { type: 'button', text: 'Execute', iconId: 'zap', style: { flex: '1 1 0', margin: 0, fontSize: '12px', fontWeight: 'bold', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0', border: '1px solid #7ec8a0' }, callback: async function() {\n                if (!_aeNavGoal.trim()) { api.v1.ui.toast('Describe your goal first.', { type: 'warning' }); return; }\n                try { if (actHandle && !actHandle.isClosed()) await actHandle.close(); } catch (e0) {}\n                try { await runQuickInstance(composeInstance(), { silentOverride: silent }); } catch (eRun) { api.v1.error('[AE:hud] execute:', eRun); }\n            } } as UIPart\n        ]));\n\n        // [v0.9.9.7] Available actions, grouped by WHERE each one comes from (Player /\n        // Location / a present character / an item) instead of one flat list. Runs\n        // through the shared aeRunEntityAction resolver (same RUN_ACTION_INSTANCE path;\n        // target-gated actions pick a target first). Source is the group header now,\n        // so it is no longer repeated in the button label.\n        function availActionRow(inst: any): UIPart {\n            let costStr = inst.hasCost ? ('  [' + inst.costAmount + ' ' + String(inst.costTag || '').replace('#', '') + ']') : '';\n            let label = inst.name + (inst.requiresTarget ? '  (target)' : '') + costStr;\n            return { type: 'button', text: label, iconId: inst.silent ? 'eye-off' : 'play', style: { width: '100%', textAlign: 'left', fontSize: '12px', marginBottom: '3px' }, callback: async function() {\n                await aeRunEntityAction(inst.entityId, inst.id, async function() { try { if (actHandle && !actHandle.isClosed()) await actHandle.close(); } catch (e0) {} });\n            } } as UIPart;\n        }\n        let avails = state.availableInstances || [];\n        if (avails.length > 0) {\n            let protagEntry = (state.presentCharacters || []).find(function(c: any) { return c.isProtagonist; });\n            let protagEntId = protagEntry ? protagEntry.entityId : '';\n            function availSourceLabel(entId: string, entName: string): string {\n                if (entId === protagEntId) return 'Player';\n                if (entId === state.locationId) return 'Location';\n                let pc = (state.presentCharacters || []).find(function(c: any) { return c.entityId === entId && !c.isProtagonist; });\n                if (pc) return pc.name;\n                return entName || 'Other';\n            }\n            let availGroups: { key: string; label: string; insts: any[] }[] = [];\n            avails.forEach(function(inst: any) {\n                let grp = availGroups.filter(function(g) { return g.key === inst.entityId; })[0];\n                if (!grp) { grp = { key: inst.entityId, label: availSourceLabel(inst.entityId, inst.entityName), insts: [] }; availGroups.push(grp); }\n                grp.insts.push(inst);\n            });\n            parts.push(_aeHudHeader('Available Actions (' + avails.length + ')'));\n            availGroups.forEach(function(g) {\n                parts.push(_aeHudSub(g.label));\n                g.insts.forEach(function(inst: any) { parts.push(availActionRow(inst)); });\n            });\n        }\n\n        // Saved presets.\n        let qis = state.quickInstances || [];\n        if (qis.length > 0) {\n            parts.push(_aeHudHeader('Saved Presets (' + qis.length + ')'));\n            qis.forEach(function(qi: any) {\n                parts.push(_aeHudRow([\n                    { type: 'button', text: qi.name + (qi.targetId ? '  (target)' : ''), iconId: 'zap', style: { flex: '1 1 0', textAlign: 'left', fontSize: '12px', margin: 0 }, callback: async function() {\n                        try { if (actHandle && !actHandle.isClosed()) await actHandle.close(); } catch (e0) {}\n                        try { let l = await loadQuickInstances(); let found = l.filter(function(x: any) { return x.id === qi.id; })[0]; if (found) await runQuickInstance(found); } catch (eP) { api.v1.error('[AE:hud] preset run:', eP); }\n                    } } as UIPart,\n                    { type: 'button', text: '', iconId: 'trash-2', style: { width: '34px', margin: 0, color: '#d98a8a' }, callback: async function() {\n                        try { let l = await loadQuickInstances(); l = l.filter(function(x: any) { return x.id !== qi.id; }); await saveQuickInstances(l); await renderAction(); } catch (eD) {}\n                    } } as UIPart\n                ]));\n            });\n        }\n\n        parts.push(_aeHudClose(function() { return actHandle; }));\n        try { if (actHandle && !actHandle.isClosed()) { await actHandle.update({ content: parts }); return; } } catch (e) {}\n        actHandle = await openEngineModal({ id: 'ae-nav-action', title: 'Action', size: 'medium', content: parts });\n    }\n    await renderAction();\n}\n\n// ── PLAYER ────────────────────────────────────────────────────────────────────\n// [v0.9.9.7] Tabbed: Resources / Stats / Factions / Inventory / Quests. Inventory\n// and Quests read buildEntityDetailPayload(protagId).children -- the exact same\n// data source and row renderer as the Character Inspection view and the top-level\n// Inspect modal, so a carried item or quest looks and behaves identically everywhere.\nasync function openPlayerModal(): Promise<void> {\n    let plHandle: any = null;\n\n    async function renderPlayer() {\n        let parts: UIPart[] = [];\n        let protagId = await getProtagonistId();\n        let state: any = await getSceneState();\n        if (!state || !protagId) {\n            parts.push(_aeHudInfo('No scene state available.'));\n            parts.push(_aeHudClose(function() { return plHandle; }));\n            try { if (plHandle && !plHandle.isClosed()) { await plHandle.update({ content: parts }); return; } } catch (e) {}\n            plHandle = await openEngineModal({ id: 'ae-nav-player', title: 'Player', size: 'medium', content: parts });\n            return;\n        }\n        let pid: string = protagId;\n        let protagChar = await loadCharacter(pid);\n        let protagEnt = (protagChar && protagChar.entityId) ? await loadEntity(protagChar.entityId) : null;\n        let detail = await buildEntityDetailPayload(pid, protagChar, protagEnt);\n        let cfg = await loadConfig();\n        let clk = await loadClock(cfg);\n        let curAbsDay = clockAbsoluteDay(clk.hours);\n\n        parts.push(_aeHudRow([\n            { type: 'text', text: (protagChar ? protagChar.name : 'Player'), style: { flex: '1 1 0', fontSize: '15px', fontWeight: 'bold', alignSelf: 'center' } } as UIPart,\n            { type: 'button', text: 'Journal', iconId: 'book', style: { fontSize: '11px', margin: 0 }, callback: async function() { try { await openJournalModal(); } catch (e) { api.v1.error('[AE:hud] journal:', e); } } } as UIPart,\n            { type: 'button', text: 'Edit Profile', iconId: 'edit-3', style: { fontSize: '11px', margin: 0 }, callback: async function() { try { await openCharEditModal(pid); } catch (e) {} } } as UIPart\n        ]));\n\n        let activeTab = await api.v1.tempStorage.getOrDefault('temp:ae_player_tab', 'resources') as string;\n        function tabBtn(id: string, label: string): UIPart {\n            let on = activeTab === id;\n            return { type: 'button', text: label, style: { flex: '1 1 0', margin: 0, fontSize: '11px', fontWeight: on ? 'bold' : 'normal', backgroundColor: on ? 'rgba(126,200,160,0.15)' : 'transparent', color: on ? '#7ec8a0' : undefined, border: on ? '1px solid #7ec8a0' : '1px solid rgba(255,255,255,0.1)' }, callback: async function() { await api.v1.tempStorage.set('temp:ae_player_tab', id); await renderPlayer(); } } as UIPart;\n        }\n        parts.push(_aeHudRow([tabBtn('resources', 'Resources'), tabBtn('stats', 'Stats'), tabBtn('factions', 'Factions')]));\n        parts.push(_aeHudRow([tabBtn('inventory', 'Inventory'), tabBtn('quests', 'Quests')]));\n\n        if (activeTab === 'resources') {\n            let cres = detail.charResources || [];\n            if (cres.length === 0) parts.push(_aeHudInfo('No personal resources.'));\n            else parts.push.apply(parts, _aeResourceRows(pid, cres, renderPlayer));\n        } else if (activeTab === 'stats') {\n            let skills = state.protagSkills || [];\n            if (skills.length === 0) parts.push(_aeHudInfo('No skills defined.'));\n            else skills.forEach(function(s: any) { parts.push({ type: 'text', text: s.name + '   ' + (s.sheetMod >= 0 ? '+' : '') + s.sheetMod, style: { fontSize: '12px', marginBottom: '4px' } } as UIPart); });\n        } else if (activeTab === 'factions') {\n            let facs = state.factionRelationships || [];\n            if (facs.length === 0) parts.push(_aeHudInfo('No faction relationships tracked.'));\n            else facs.forEach(function(f: any) { parts.push({ type: 'text', text: f.name + '  \\u2014  ' + (f.stateLabel || ''), style: { fontSize: '12px', marginBottom: '4px' } } as UIPart); });\n        } else if (activeTab === 'inventory') {\n            let items = (detail.children || []).filter(function(c: any) { return c.type === 'item'; });\n            if (items.length === 0) parts.push(_aeHudInfo('No items carried.'));\n            else parts.push.apply(parts, _aeItemSection(items, pid, renderPlayer));\n        } else if (activeTab === 'quests') {\n            let narrs = (detail.children || []).filter(function(c: any) { return c.type === 'narrative'; });\n            if (narrs.length === 0) parts.push(_aeHudInfo('No active quests.'));\n            else parts.push.apply(parts, _aeNarrativeSection(narrs, curAbsDay, renderPlayer));\n        }\n\n        parts.push(_aeHudClose(function() { return plHandle; }));\n        try { if (plHandle && !plHandle.isClosed()) { await plHandle.update({ content: parts }); return; } } catch (e) {}\n        plHandle = await openEngineModal({ id: 'ae-nav-player', title: 'Player', size: 'medium', content: parts });\n    }\n    await renderPlayer();\n}\n\n// ── JOURNAL ─────────────────────────────────────────────────────────────────────\n// [v1.7.0 JOURNAL] Native Player Journal UI. Opens from the Player modal. Renderer\n// only — every verb lives in Section 10b so the bridge HUD can reuse them later.\n// Draft text is held in module-level vars (updated via onChange, never mid-render)\n// so re-rendering the modal after an action never clobbers what the user is typing.\nvar _aeJrnlEditingId: string | null = null;   // id of the bubble currently in edit mode\nvar _aeJrnlBusy: boolean = false;             // generation in flight (disables buttons)\nvar _aeJrnlShowArchived: boolean = false;     // archived list visibility toggle\nvar _aeJrnlCompose: string = '';              // draft for the \"new entry\" box\nvar _aeJrnlEditDraft: string = '';            // draft for the bubble being edited\nvar _aeJrnlStampNew: boolean = false;         // stamp-on-add toggle\n\nasync function openJournalModal(): Promise<void> {\n    let jHandle: any = null;\n\n    // Kick a rewrite/compress: seed edit mode, run story-aware generation, then load\n    // the result into the edit draft for review. Never commits without an explicit Save.\n    async function runJrnlGen(kind: string, b: JournalBubble): Promise<void> {\n        if (_aeJrnlBusy) return;\n        const srcText = (_aeJrnlEditingId === b.id) ? (_aeJrnlEditDraft || b.text) : b.text;\n        _aeJrnlBusy = true; _aeJrnlEditingId = b.id;\n        await renderJournal();\n        let out: string | null = null;\n        try { out = (kind === 'rewrite') ? await journalGenerateRewrite(srcText) : await journalGenerateCompress(srcText); }\n        catch (e) { api.v1.error('[AE:hud] journal gen:', e); }\n        _aeJrnlBusy = false;\n        if (out) { _aeJrnlEditDraft = out; api.v1.ui.toast(kind === 'rewrite' ? 'Rewritten \\u2014 review and Save.' : 'Compressed \\u2014 review and Save.', { type: 'success' }); }\n        else { api.v1.ui.toast('Generation failed or returned nothing.', { type: 'error' }); }\n        await renderJournal();\n    }\n\n    function renderBubble(b: JournalBubble, isArchived: boolean, cfg: GlobalConfig): UIPart {\n        const editing = _aeJrnlEditingId === b.id;\n        const body: UIPart[] = [];\n\n        // Header line: in-story stamp (if any) or an \"Archived\" tag.\n        body.push({ type: 'row', style: { marginBottom: '4px' }, content: [\n            { type: 'text', text: (b.stamped ? journalStampFromHours(b.storyHours, cfg) : (isArchived ? 'Archived' : '')), style: { fontSize: '10px', opacity: '0.6', flex: '1 1 0', alignSelf: 'center' } } as UIPart\n        ] } as UIPart);\n\n        if (editing && _aeJrnlBusy) {\n            body.push(_aeHudInfo('Working\\u2026'));\n        } else if (editing) {\n            body.push({ type: 'multilineTextInput', initialValue: _aeJrnlEditDraft, placeholder: 'Edit this entry\\u2026', onChange: function(v: string) { _aeJrnlEditDraft = v; }, style: { minHeight: '120px', marginBottom: '6px' } } as UIPart);\n            body.push(_aeHudRow([\n                { type: 'button', text: 'Save', iconId: 'save', style: { flex: '1 1 0', margin: 0, fontSize: '11px', backgroundColor: 'rgba(126,200,160,0.15)', color: '#7ec8a0' }, callback: async function() { await journalUpdateBubble(b.id, _aeJrnlEditDraft); _aeJrnlEditingId = null; api.v1.ui.toast('Saved.', { type: 'success' }); await renderJournal(); } } as UIPart,\n                { type: 'button', text: 'Cancel', iconId: 'x', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlEditingId = null; await renderJournal(); } } as UIPart\n            ]));\n            body.push(_aeHudRow([\n                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] jrnl rewrite:', e); }); } } as UIPart,\n                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] jrnl compress:', e); }); } } as UIPart\n            ]));\n        } else {\n            // Reading surface: grows with content, then scrolls — never squished/clipped.\n            body.push({ type: 'box', style: { maxHeight: '240px', overflowY: 'auto', padding: '8px 10px', backgroundColor: 'rgba(255,255,255,0.03)', border: '1px solid rgba(255,255,255,0.08)', borderRadius: '6px', marginBottom: '6px' }, content: [\n                { type: 'text', text: (b.text && b.text.trim()) ? b.text : '(empty)', noTemplate: true, style: { fontSize: '12px', lineHeight: '1.5', whiteSpace: 'pre-wrap', wordBreak: 'break-word' } } as UIPart\n            ] } as UIPart);\n            body.push(_aeHudRow([\n                { type: 'button', text: 'Edit', iconId: 'edit-3', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlEditDraft = b.text || ''; _aeJrnlEditingId = b.id; await renderJournal(); } } as UIPart,\n                { type: 'button', text: b.stamped ? 'Unstamp' : 'Stamp', iconId: 'clock', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalToggleStamp(b.id); await renderJournal(); } } as UIPart,\n                isArchived\n                    ? { type: 'button', text: 'Unarchive', iconId: 'refresh', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalSetArchived(b.id, false); api.v1.ui.toast('Restored to Always-On.', { type: 'success' }); await renderJournal(); } } as UIPart\n                    : { type: 'button', text: 'Archive', iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { await journalSetArchived(b.id, true); api.v1.ui.toast('Archived \\u2014 removed from context.', { type: 'success' }); await renderJournal(); } } as UIPart\n            ]));\n            body.push(_aeHudRow([\n                { type: 'button', text: 'Rewrite', iconId: 'feather', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('rewrite', b).catch(function(e) { api.v1.error('[AE:hud] jrnl rewrite:', e); }); } } as UIPart,\n                { type: 'button', text: 'Compress', iconId: 'file-minus', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: function() { runJrnlGen('compress', b).catch(function(e) { api.v1.error('[AE:hud] jrnl compress:', e); }); } } as UIPart,\n                { type: 'button', text: 'Delete', iconId: 'trash', disabled: _aeJrnlBusy, style: { flex: '0 0 auto', margin: 0, fontSize: '11px', color: '#d98a8a' }, callback: async function() { await journalDeleteBubble(b.id); if (_aeJrnlEditingId === b.id) _aeJrnlEditingId = null; api.v1.ui.toast('Deleted.', { type: 'success' }); await renderJournal(); } } as UIPart\n            ]));\n        }\n\n        return { type: 'box', style: { padding: '8px', marginBottom: '8px', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '8px', opacity: isArchived ? '0.55' : '1', backgroundColor: isArchived ? 'rgba(255,255,255,0.01)' : 'rgba(126,200,160,0.04)' }, content: body } as UIPart;\n    }\n\n    async function renderJournal(): Promise<void> {\n        const state = await loadJournal();\n        const cfg = await loadConfig();\n        const active   = state.bubbles.filter(function(b) { return !b.archived; });\n        const archived = state.bubbles.filter(function(b) { return b.archived; });\n        const parts: UIPart[] = [];\n\n        parts.push(_aeHudInfo('Your running record. Active entries stay Always-On in the lorebook as \\u201CThe story so far\\u201D, so they survive context. Archived entries are kept but never injected.'));\n\n        // Compose new entry\n        parts.push(_aeHudSub('New entry'));\n        parts.push({ type: 'multilineTextInput', initialValue: _aeJrnlCompose, placeholder: 'Write what just happened\\u2026', onChange: function(v: string) { _aeJrnlCompose = v; }, style: { minHeight: '80px', marginBottom: '6px' } } as UIPart);\n        parts.push(_aeHudRow([\n            { type: 'checkboxInput', label: 'Stamp with date/time', initialValue: _aeJrnlStampNew, onChange: function(v: boolean) { _aeJrnlStampNew = v; }, style: { flex: '1 1 0', alignSelf: 'center', fontSize: '11px' } } as UIPart,\n            { type: 'button', text: 'Add', iconId: 'plus', disabled: _aeJrnlBusy, style: { margin: 0, fontSize: '11px' }, callback: async function() {\n                const txt = (_aeJrnlCompose || '').trim();\n                if (!txt) { api.v1.ui.toast('Nothing to add.', { type: 'warning' }); return; }\n                _aeJrnlCompose = '';\n                await journalAddBubble(txt, _aeJrnlStampNew);\n                api.v1.ui.toast('Added to journal.', { type: 'success' });\n                await renderJournal();\n            } } as UIPart\n        ]));\n\n        // Toolbar: merge-down + archived visibility\n        const tools: UIPart[] = [];\n        if (active.length > 1) {\n            tools.push({ type: 'button', text: 'Merge all', iconId: 'chevrons-down', disabled: _aeJrnlBusy, style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() {\n                const n = active.length;\n                await journalMergeDown();\n                _aeJrnlEditingId = null;\n                api.v1.ui.toast('Merged ' + n + ' entries into one.', { type: 'success' });\n                await renderJournal();\n            } } as UIPart);\n        }\n        if (archived.length > 0) {\n            tools.push({ type: 'button', text: (_aeJrnlShowArchived ? 'Hide archived (' + archived.length + ')' : 'Show archived (' + archived.length + ')'), iconId: 'archive', style: { flex: '1 1 0', margin: 0, fontSize: '11px' }, callback: async function() { _aeJrnlShowArchived = !_aeJrnlShowArchived; await renderJournal(); } } as UIPart);\n        }\n        if (tools.length > 0) parts.push(_aeHudRow(tools));\n\n        // Active entries\n        parts.push(_aeHudSub('Entries (' + active.length + ')'));\n        if (active.length === 0) parts.push(_aeHudInfo('No entries yet. Add one above.'));\n        else active.forEach(function(b) { parts.push(renderBubble(b, false, cfg)); });\n\n        // Archived entries (optional)\n        if (_aeJrnlShowArchived && archived.length > 0) {\n            parts.push(_aeHudSub('Archived (' + archived.length + ')'));\n            archived.forEach(function(b) { parts.push(renderBubble(b, true, cfg)); });\n        }\n\n        parts.push(_aeHudClose(function() { return jHandle; }));\n        try { if (jHandle && !jHandle.isClosed()) { await jHandle.update({ content: parts }); return; } } catch (e) {}\n        jHandle = await openEngineModal({ id: 'ae-nav-journal', title: 'Journal', size: 'medium', content: parts });\n    }\n\n    await renderJournal();\n}\n\n// ── CYOA ──────────────────────────────────────────────────────────────────────\nasync function openCyoaModal(): Promise<void> {\n    let cyHandle: any = null;\n    let lastOptions: any[] = [];\n    async function renderCyoa(loading: boolean) {\n        let parts: UIPart[] = [];\n        parts.push(_aeHudInfo('Generate intent-based options, then pick one to load into the Action composer (you choose the skill/stakes).'));\n        function modeBtn(mode: string, label: string): UIPart {\n            return { type: 'button', text: label, style: { flex: '1 1 0', margin: 0, fontSize: '12px' }, disabled: loading, callback: async function() {\n                await renderCyoa(true);\n                try { let r = await prepareCyoaOptions(mode); lastOptions = r.options || []; } catch (e) { lastOptions = []; api.v1.error('[AE:hud] cyoa gen:', e); }\n                await renderCyoa(false);\n            } } as UIPart;\n        }\n        parts.push(_aeHudRow([ modeBtn('action', 'Action'), modeBtn('dialog', 'Dialog'), modeBtn('mix', 'Mix') ]));\n        if (loading) {\n            parts.push(_aeHudInfo('Generating choices\\u2026'));\n        } else if (lastOptions.length > 0) {\n            parts.push(_aeHudHeader('Options'));\n            lastOptions.forEach(function(opt: any) {\n                parts.push({ type: 'button', text: opt.text, style: { width: '100%', textAlign: 'left', fontSize: '12px', marginBottom: '4px', lineHeight: '1.3' }, callback: async function() {\n                    try { if (cyHandle && !cyHandle.isClosed()) await cyHandle.close(); } catch (e0) {}\n                    await openActionModal(opt.text);\n                } } as UIPart);\n            });\n        }\n        parts.push(_aeHudClose(function() { return cyHandle; }));\n        try { if (cyHandle && !cyHandle.isClosed()) { await cyHandle.update({ content: parts }); return; } } catch (e) {}\n        cyHandle = await openEngineModal({ id: 'ae-nav-cyoa', title: 'CYOA', size: 'medium', content: parts });\n    }\n    await renderCyoa(false);\n}\n\n// ── Registration + mode switch ─────────────────────────────────────────────────\n// Builds the script UI extension set (sidebar panel + optional toolbar tray) from\n// the current cfg.interfaceMode and registers it. Re-callable to apply a mode change.\nasync function registerEngineUI(): Promise<void> {\n    let cfg = await loadConfig();\n    let mode = (cfg as any).interfaceMode || 'native';\n    let ext: any[] = [\n        { type: 'sidebarPanel', id: 'ce-panel', name: '\\ud83d\\uddfa Adventure', iconId: 'users', content: [{ type: 'text', text: 'Loading\\u2026' }] }\n    ];\n    if (mode === 'native' || mode === 'both') {\n        ext.push({ type: 'toolbarButton', id: 'ae-tb-map',     text: 'Map',     iconId: 'map',     callback: function() { openMapModal().catch(function(e) { api.v1.error('[AE:hud] map:', e); }); } });\n        ext.push({ type: 'toolbarButton', id: 'ae-tb-inspect', text: 'Inspect', iconId: 'search',  callback: function() { openInspectModal().catch(function(e) { api.v1.error('[AE:hud] inspect:', e); }); } });\n        ext.push({ type: 'toolbarButton', id: 'ae-tb-action',  text: 'Action',  iconId: 'zap',     callback: function() { openActionModal().catch(function(e) { api.v1.error('[AE:hud] action:', e); }); } });\n        ext.push({ type: 'toolbarButton', id: 'ae-tb-player',  text: 'Player',  iconId: 'user',    callback: function() { openPlayerModal().catch(function(e) { api.v1.error('[AE:hud] player:', e); }); } });\n        ext.push({ type: 'toolbarButton', id: 'ae-tb-cyoa',    text: 'CYOA',    iconId: 'compass', callback: function() { openCyoaModal().catch(function(e) { api.v1.error('[AE:hud] cyoa:', e); }); } });\n        ext.push({ type: 'toolbarButton', id: 'ae-tb-clock',   text: 'Calendar', iconId: 'calendar', callback: function() { openCalendarModal().catch(function(e) { api.v1.error('[AE:hud] calendar:', e); }); } });\n    }\n    await api.v1.ui.register(ext);\n}\n\n// [v0.9.9.5] Set a specific HUD mode (native | bridge | both) and re-register UI.\nasync function setInterfaceMode(mode: string): Promise<void> {\n    try {\n        if (mode !== 'native' && mode !== 'bridge' && mode !== 'both') mode = 'bridge';\n        let cfg = await loadConfig();\n        if (((cfg as any).interfaceMode || 'native') === mode) return;\n        (cfg as any).interfaceMode = mode;\n        await saveConfig(cfg);\n        await registerEngineUI();\n        await refreshSidebar();\n        api.v1.ui.toast('HUD mode: ' + mode, { type: 'info', autoClose: 1500 });\n    } catch (e) { api.v1.error('[AE:hud] setInterfaceMode:', e); }\n}\n\n// Cycles bridge -> native -> both -> bridge and re-registers the UI immediately.\nasync function cycleInterfaceMode(): Promise<void> {\n    try {\n        let cfg = await loadConfig();\n        let cur = (cfg as any).interfaceMode || 'native';\n        let next = (cur === 'bridge') ? 'native' : ((cur === 'native') ? 'both' : 'bridge');\n        (cfg as any).interfaceMode = next;\n        await saveConfig(cfg);\n        await registerEngineUI();\n        await refreshSidebar();\n        api.v1.ui.toast('HUD mode: ' + next, { type: 'info', autoClose: 1800 });\n    } catch (e) { api.v1.error('[AE:hud] cycleInterfaceMode:', e); }\n}\n\napi.v1.hooks.register('onScriptsLoaded', async function() {\n    try {\n        // 1. Register NAI UI: sidebar panel + (when cfg.interfaceMode is native/both)\n        //    the native toolbar HUD tray. Bridge mode registers the panel only.\n        await registerEngineUI();\n\n        // 2. Permissions\n        await api.v1.permissions.request(['fileInput', 'fileDownload', 'lorebookEdit', 'storyEdit', 'documentEdit', 'editorDecorations']);\n        await api.v1.timers.sleep(300);\n\n        // 3. [CHANGE] Load image settings before bridge connects so auto-snap is ready.\n        await loadImageSettings();\n\n        // 3b. [v0.9.7.9] Lorebook world-pack auto-import. Runs only when storyStorage\n        //     has no config (fresh story created from a packed scenario). Non-destructive:\n        //     existing stories are always skipped. Runs before bridge handshake so the\n        //     first SCENE_STATE_UPDATE already reflects the imported world.\n        try { await loadConfigFromLorebook(); } catch (eLcInit) { api.v1.log('[AE:pack] init import error:', eLcInit); }\n\n        // 4. [CHANGE] Pre-seed cachedCharVisuals from storage so getCharacterData() works\n        //    immediately on the first generation, even before bridge handshake completes.\n        await buildCharacterDataPayload();\n\n        // 5. [CHANGE] initMessaging() — sends HANDSHAKE_REQUEST to bridge. When bridge\n        //    ACKs, handleBridgeMessage → broadcastCharacterData + broadcastSceneState.\n        await initMessaging();\n\n        // 6. Story init path\n        const rawIndex = await api.v1.storyStorage.get(STORAGE_INDEX);\n        const isFreshStory = !rawIndex || (Array.isArray(rawIndex) && (rawIndex as any[]).length === 0);\n\n        if (isFreshStory) {\n            await showNewStoryPrompt();\n            // Modal callbacks own ensureProtagonistExists + refreshSidebar + queueSceneStateBroadcast.\n        } else {\n            await ensureProtagonistExists();\n            await refreshSidebar();\n            queueSceneStateBroadcast();\n\n            // 6b. [UNIFY] One-time migration of faction-standing args on entity-attached\n            // action instances (action TEMPLATES are already migrated on every loadConfig\n            // call above). Only relevant for existing stories — a fresh one has no entities\n            // yet. Gated internally by a storyStorage flag so it only ever runs once.\n            try { await migrateFactionArgsOnEntities(await loadConfig()); } catch (eFacMig) { api.v1.log('[AE:migrate] entity faction-arg migration skipped:', eFacMig); }\n        }\n\n        api.v1.log('[AE] Adventure Engine initialized.');\n    } catch (e) {\n        api.v1.error('[AE] Init error:', e);\n    }\n});\n",
