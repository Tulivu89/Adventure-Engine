":\"mqchar10000000005\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"childCount\":0,\"presentCharacterCount\":0,\"state\":\"default\",\"icon\":\"⚡️\",\"gated\":false,\"isVehicle\":false,\"hasGlobalAutoTrigger\":false},{\"id\":\"mqih810slb28m1f1vsi\",\"name\":\"Diet Sleep-n-a-Can!\",\"type\":\"item\",\"parentId\":\"mqchar10000000005\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"childCount\":0,\"presentCharacterCount\":0,\"state\":\"default\",\"icon\":\"⚡️\",\"gated\":false,\"isVehicle\":false,\"hasGlobalAutoTrigger\":false},{\"id\":\"mqkguvv7vjooltpk1cw\",\"name\":\"Key\",\"type\":\"item\",\"parentId\":\"mqchar10000000001\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"childCount\":0,\"presentCharacterCount\":0,\"state\":\"default\",\"icon\":\"🗝\",\"gated\":false,\"isVehicle\":false,\"hasGlobalAutoTrigger\":false},{\"id\":\"mqkh3gfykl35ry8dgxp\",\"name\":\"A Key\",\"type\":\"item\",\"parentId\":\"mqdy7wjnylhq952kyj6\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"childCount\":0,\"presentCharacterCount\":0,\"state\":\"default\",\"icon\":\"🗝\",\"gated\":false,\"isVehicle\":false,\"hasGlobalAutoTrigger\":false},{\"id\":\"mqkhj6qch1a4ef38gea\",\"name\":\"B Key\",\"type\":\"item\",\"parentId\":\"mqd2m0avcev0kgoydbr\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"childCount\":0,\"presentCharacterCount\":0,\"state\":\"default\",\"icon\":\"🗝\",\"gated\":false,\"isVehicle\":false,\"hasGlobalAutoTrigger\":false},{\"id\":\"mqkhjmu263py14h8cms\",\"name\":\"C Key\",\"type\":\"item\",\"parentId\":\"mqd4d9ot178fv22cpc1p\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"childCount\":0,\"presentCharacterCount\":0,\"state\":\"default\",\"icon\":\"🗝\",\"gated\":false,\"isVehicle\":false,\"hasGlobalAutoTrigger\":false}],\"entRecords\":{\"mqcrt141rxefmvdl3p\":{\"id\":\"mqcrt141rxefmvdl3p\",\"name\":\"Must-hav Motel\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A seedy, dilapidated motel catering to the damned who are barely scraping by. The doors lack locks and the walls offer no privacy. The constant sound of wailing torment echoes through the thin floors at all hours.\",\"atmosphere\":\"\",\"state\":\"morning\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in burgeoning scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, and the shadows lengthen as the predatory nightlife of Hell takes over.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"Must-hav Motel\"],\"lorebookText\":\"The cheapest roof in this corner of Hell and the closest thing the local damned have to a neighborhood. Long-term residents, drifters, and the freshly fallen rot side by side in identical grimy rooms with doors that don't lock. Everything nearby orbits the motel - its lot, its noise, and its permanent smell of mildew and brimstone.\",\"locationVisuals\":\"Location, exterior, a run-down two-story roadside motel in Hell. Peeling paint, a flickering broken vacancy sign, cracked asphalt lot under a red blood-sun sky, grimy doors along a sagging balcony walkway, smog and distant hellfire on the horizon.\",\"questTarget\":\"\",\"createdAt\":1781380249057,\"updatedAt\":1783185551255,\"icon\":\"🏚\",\"tagSubscriptions\":[],\"actionInstances\":[],\"lorebookEntryId\":\"fd14f5f9-0a3f-429b-9588-28d6b64891bc\"},\"mqcrt14y79xpioohtvf\":{\"id\":\"mqcrt14y79xpioohtvf\",\"name\":\"Player\",\"type\":\"character\",\"parentId\":\"mqh06ogj3npwvb5q29k\",\"narrativeParentId\":null,\"storyState\":\"active\",\"description\":\"\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"questTarget\":\"\",\"createdAt\":1781380249090,\"updatedAt\":1783198325466,\"actionInstances\":[],\"icon\":\"👑\",\"tagSubscriptions\":[\"player\"]},\"mqcz6aoypbqg66uykx5\":{\"id\":\"mqcz6aoypbqg66uykx5\",\"name\":\"The Grimoire: You're late!\",\"type\":\"narrative\",\"parentId\":\"mqh06ogj3npwvb5q29k\",\"narrativeParentId\":null,\"storyState\":\"active\",\"description\":\"You need to get to work before Morbus chews your ass again. Those rodents of unusual size infesting the basement aren't going to whack themselves.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"questTarget\":\"mqiewgg5p14phvi6zgv\",\"createdAt\":1781392625314,\"updatedAt\":1783185432499,\"icon\":\"⏰️\",\"actionInstances\":[{\"id\":\"mqh6r82g0yjr4ax8av4n\",\"name\":\"Accept Quest\",\"conditions\":[],\"successEffects\":[{\"id\":\"mqh6r82g6lqzv9z8ng1\",\"type\":\"set_entity_parent\",\"args\":{\"scope\":\"__self__\",\"parentId\":\"__player__\"}},{\"id\":\"mqh6r82gg94colk6zu3\",\"type\":\"set_entity_story_state\",\"args\":{\"scope\":\"__self__\",\"value\":\"active\"}},{\"id\":\"mqh6r82gfasozi61cgq\",\"type\":\"pop_up\",\"args\":{\"title\":\"Turn on tracking\",\"text\":\"You can click on the narrative to track its target if it has one.\"}}],\"alwaysEffects\":[],\"failureEffects\":[],\"silent\":true,\"oneShot\":true,\"tags\":[\"narratives\"],\"templateId\":\"mqh6mhtgekffw831utu\"}],\"tagSubscriptions\":[]},\"mqd1f1ap7okbbymns4o\":{\"id\":\"mqd1f1ap7okbbymns4o\",\"name\":\"The Cubicle Wastes\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A sprawling, endless expanse of beige office cubicles under flickering fluorescent lights. Mindless drones shuffle through the labyrinthine aisles, processing the infernal paperwork required to keep the bureaucracy of Hell moving.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, and the fluorescent hum of the office becomes the only source of light.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"The Cubicle Wastes\"],\"lorebookText\":\"The administrative engine of the underworld: an infinite beige floor of cubicles where the damned process the paperwork that keeps Hell's bureaucracy grinding. Exits and hours blur in the fluorescent sameness, and people wander the aisles for years without finding a door. Soul-crushing in the most literal, clerical sense.\",\"locationVisuals\":\"Location, interior, an endless office wasteland. Flickering orange fluorescent lights cast long shadows across a maze of beige cubicles while dark shambling figures shuffle the aisles. Modern hellscape bureaucracy stretching to the horizon.\",\"questTarget\":\"\",\"createdAt\":1781396392273,\"updatedAt\":1783185551401,\"icon\":\"🏢\",\"entryCostAmount\":0,\"tagSubscriptions\":[],\"actionInstances\":[],\"lorebookEntryId\":\"ef520989-42c4-4412-902d-0dc2aa85ff34\"},\"mqd1x27uyoqz55te5qr\":{\"id\":\"mqd1x27uyoqz55te5qr\",\"name\":\"The Velvet Hole-in-the-Wall\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A dark, cramped club catering to every conceivable vice. Patrons indulge in drugs, sulphursnuff, gambling, and exotic hookers. Neon signs cut through the haze of smoke, reflecting off the sweat-slicked skin of the clientele.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, and the club comes alive with a pulse of neon and heavy bass.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"The Velvet Hole-in-the-Wall\"],\"lorebookText\":\"A cramped basement club devoted to every vice on offer in Hell at once - drink, smoke, gambling, sulphursnuff, and company for hire. It runs day and night with no real difference between them, packed with the kind of clientele who have nothing left to lose and intend to lose it here. Loud, hazy, and sticky underfoot.\",\"locationVisuals\":\"Location, interior, a dark cramped underground vice den. Hazy smoke lit by red and purple neon, sweat-slicked patrons crowded around gambling tables and a small stage, bottles and sulphursnuff everywhere, low grimy ceiling.\",\"questTarget\":\"\",\"createdAt\":1781397233274,\"updatedAt\":1783198356557,\"icon\":\"🏩\",\"entryCostAmount\":0,\"actionInstances\":[{\"id\":\"mqiivk8c57ahghm4mv1\",\"name\":\"Train charisma\",\"conditions\":[{\"id\":\"mqiiu3qusehos7o5x4z\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\">=\",\"amount\":2}},{\"id\":\"mqiiu3qu1pstddlwdkv\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\">=\",\"amount\":1}}],\"successEffects\":[{\"id\":\"mqiiu3qu2nzpsclgiin\",\"type\":\"modify_char_skill\",\"args\":{\"scope\":\"__player__\",\"fieldRef\":\"cat_attr.fld_flair\",\"op\":\"add\",\"amount\":1}},{\"id\":\"mqiiu3quepylp4qn6o4\",\"type\":\"pop_up\",\"args\":{\"title\":\"Success!\",\"text\":\"Your Flair sharpens.\"}}],\"alwaysEffects\":[{\"id\":\"mqiiu3quavmyzed9ma3\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\"subtract\",\"amount\":2}},{\"id\":\"mqiiu3qu350glz13bzc\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\"subtract\",\"amount\":1}},{\"id\":\"mqiiu3qul4iex557m5g\",\"type\":\"ask_text\",\"args\":{\"instructions\":\"Describe how you train to improve your charisma.\"}}],\"failureEffects\":[{\"id\":\"mqiiu3quuyt0vlxb6ur\",\"type\":\"pop_up\",\"args\":{\"title\":\"Failure!\",\"text\":\"You wasted your time and money, you dumb oaf.\"}}],\"tags\":[\"player\"],\"resolution\":{\"type\":\"custom_1d6\",\"useDC\":true,\"dc\":4,\"args\":{},\"bands\":[]},\"templateId\":\"mqiiu3qt9uc70ii5nb5\"},{\"id\":\"mqikmhemsd05fqfq66p\",\"name\":\"Roll the dice! (1d6, +1🪙 on 🎲5, +3 on 6)\",\"conditions\":[{\"id\":\"mqik7qrqj73gu3aw4dd\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\">=\",\"amount\":1}}],\"successEffects\":[],\"alwaysEffects\":[{\"id\":\"mqikg3abvp8798m4mp7\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\"subtract\",\"amount\":1}}],\"failureEffects\":[],\"tags\":[\"wealth\"],\"silent\":true,\"resolution\":{\"type\":\"custom_1d6\",\"useDC\":false,\"dc\":4,\"args\":{},\"bands\":[{\"id\":\"mqika4hbrbytkefo1q7\",\"min\":0,\"max\":3,\"label\":\"Outcome\",\"effects\":[{\"id\":\"mqikakf6wru87nblftf\",\"type\":\"pop_up\",\"args\":{\"title\":\"Sorry!\",\"text\":\"No dice.\"}}]},{\"id\":\"mqikb87aepvyw1a2h1h\",\"min\":4,\"max\":4,\"label\":\"Outcome\",\"effects\":[{\"id\":\"mqikbsmzg7qdv9dvkw7\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\"add\",\"amount\":1}},{\"id\":\"mqikc5uu6aawetm05at\",\"type\":\"pop_up\",\"args\":{\"title\":\"Draw!\",\"text\":\"Even Steven.\"}}]},{\"id\":\"mqikd2n7ggq0y1in4ar\",\"min\":5,\"max\":5,\"label\":\"Outcome\",\"effects\":[{\"id\":\"mqikdit8393t0u87oa7\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\"add\",\"amount\":2}},{\"id\":\"mqikdubyz4lbicf5gto\",\"type\":\"pop_up\",\"args\":{\"title\":\"Success!\",\"text\":\"You netted one currency!\"}}]},{\"id\":\"mqiker9669ttzlhs46d\",\"min\":6,\"max\":6,\"label\":\"Outcome\",\"effects\":[{\"id\":\"mqikf6lqdmu7vw7kzql\",\"type\":\"pop_up\",\"args\":{\"title\":\"Wooo!\",\"text\":\"You netted three currency!\"}},{\"id\":\"mqikfrdbq5r5nx3e91q\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\"add\",\"amount\":4}}]}],\"skillTag\":\"\"},\"templateId\":\"mqik68s64ojmvubql1u\"}],\"tagSubscriptions\":[],\"lorebookEntryId\":\"b255d755-2dbd-481e-b67c-4d20b6f1bfd4\"},\"mqd2m0avcev0kgoydbr\":{\"id\":\"mqd2m0avcev0kgoydbr\",\"name\":\"Depravitae\",\"type\":\"character\",\"parentId\":\"mqd1f1ap7okbbymns4o\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"questTarget\":\"\",\"createdAt\":1781398397191,\"updatedAt\":1783185432811,\"actionInstances\":[],\"icon\":\"😈\",\"tagSubscriptions\":[\"relationships\"]},\"mqd1q1j4fprzxu3kvqq\":{\"id\":\"mqd1q1j4fprzxu3kvqq\",\"name\":\"The Hexagon\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A brutalist structure serving as both a high-end gym and a gladiatorial arena. Bloodstains coat the fighting pits where demons and sinners alike tear each other apart for sport and social status.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, and the arena floodlights ignite to illuminate the blood on the floor.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"The Hexagon\"],\"lorebookText\":\"Part hardcore gym, part blood-sport arena, where local status is settled with fists, claws, and worse. Fighters train in the open pits and then maim each other in them for an audience; the line between a workout and a death-match is thin and frequently crossed. Loud with impact and bravado.\",\"locationVisuals\":\"Location, interior, a brutalist concrete gym and gladiatorial arena. Bloodstained fighting pits ringed by iron weight racks and training equipment, harsh overhead lights, scuffed floors, demons and sinners sparring under a grimy high ceiling.\",\"questTarget\":\"\",\"createdAt\":1781396905792,\"updatedAt\":1783185551658,\"icon\":\"🏟\",\"entryCostAmount\":0,\"entryCostTag\":\"\",\"actionInstances\":[{\"id\":\"mqiirrvdj7dp711f6zw\",\"name\":\"Train physique\",\"conditions\":[{\"id\":\"mqiirrvdofddx5ebfo8\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\">=\",\"amount\":2}},{\"id\":\"mqiirrvdprhbc9r8tgt\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\">=\",\"amount\":1}}],\"successEffects\":[{\"id\":\"mqiirrvdvbm2ekhstqr\",\"type\":\"modify_char_skill\",\"args\":{\"scope\":\"__player__\",\"fieldRef\":\"cat_attr.fld_force\",\"op\":\"add\",\"amount\":1}},{\"id\":\"mqiirrvdzvrybd5jnei\",\"type\":\"pop_up\",\"args\":{\"title\":\"Success!\",\"text\":\"Your physique improved.\"}}],\"alwaysEffects\":[{\"id\":\"mqiirrvd9f1vhe2zwn8\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\"subtract\",\"amount\":2}},{\"id\":\"mqiirrvdt614omd61w7\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\"subtract\",\"amount\":1}},{\"id\":\"mqiirrvdn270ej8509r\",\"type\":\"ask_text\",\"args\":{\"instructions\":\"Describe how you train to improve your physique. \"}}],\"failureEffects\":[{\"id\":\"mqiirrvdy3vgkj9gmar\",\"type\":\"pop_up\",\"args\":{\"title\":\"Failure!\",\"text\":\"You wasted your time and money, you dumb oaf.\"}}],\"tags\":[\"player\"],\"resolution\":{\"type\":\"custom_1d6\",\"useDC\":true,\"dc\":4,\"args\":{},\"bands\":[]},\"templateId\":\"mqiigy1x7w53frbdmnv\"}],\"tagSubscriptions\":[],\"lorebookEntryId\":\"ccec2035-a0b7-45cb-bdba-d0d62d974ef3\"},\"mqd24uiz5cfbuayinjh\":{\"id\":\"mqd24uiz5cfbuayinjh\",\"name\":\"The Fourth Circle\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A chaotic, multi-level strip mall where absolutely anything can be bought or sold. Vendors operate seedy black markets out of storefronts, while high rollers attend glitzy, secure auctions to bid on rare hell-beasts and contraband.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, and the illicit night markets open their shutters.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"The Fourth Circle\"],\"lorebookText\":\"A sprawling, many-tiered marketplace where anything in Hell can be had for the right price or the right favor. The lower levels run open black markets and back-alley deals; the upper floors host secured auctions for rare hell-beasts and contraband. Crowded, garish, and transactional to the bone.\",\"locationVisuals\":\"Location, interior, a chaotic multi-level infernal strip mall. Crowded storefronts and black-market stalls stacked along grimy escalators, garish signage, caged hell-beasts and contraband on display, throngs of demon shoppers under buzzing lights.\",\"questTarget\":\"\",\"createdAt\":1781397596555,\"updatedAt\":1783185551793,\"icon\":\"🛒\",\"entryCostAmount\":0,\"tagSubscriptions\":[],\"actionInstances\":[],\"lorebookEntryId\":\"18425333-811d-447c-bfdd-0b8fe76baa5a\"},\"mqd28yemhy9v6xb048x\":{\"id\":\"mqd28yemhy9v6xb048x\",\"name\":\"Waffle House\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A glaring yellow beacon of corporate franchising imported directly to Hell. Unstable denizens pack the sticky booths at all hours. Patrons eat their scattered and smothered hashbrowns while actively avoiding being stabbed by the waitstaff or each other.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, but the glaring yellow sign buzzes brightly against the dark.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"Waffle House\"],\"lorebookText\":\"An outpost of corporate fast-food franchising that somehow reaches into the underworld, open every hour of eternity. The booths stay packed with the unstable and the unhinged, drawn by cheap hot food and the dim comfort of a familiar yellow sign. Greasy, tense, and never more than one wrong word from a brawl.\",\"locationVisuals\":\"Location, a glaring yellow Waffle House franchise dropped into Hell. Bright yellow signage cutting through red gloom outside, sticky vinyl booths and a worn counter inside, unstable demon patrons and a grim waitstaff under flat fluorescent light.\",\"questTarget\":\"\",\"createdAt\":1781397788206,\"updatedAt\":1783185551935,\"icon\":\"🧇\",\"entryCostAmount\":0,\"actionInstances\":[],\"tagSubscriptions\":[],\"lorebookEntryId\":\"2e531403-689a-48ad-828d-4d750bef8276\"},\"mqdyz1bn27n93tun32e\":{\"id\":\"mqdyz1bn27n93tun32e\",\"name\":\"the Lake of Fire\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A vast sea of roiling magma and hellfire. The shores are surprisingly scenic, marred only by the constant, distant splashing of screaming souls plunging into the boiling lake from unseen heights above.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, leaving the shores illuminated only by the glowing magma of the lake.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"the Lake of Fire\"],\"lorebookText\":\"A vast inland sea of molten fire that doubles, improbably, as scenic waterfront. Its black shores are calm and almost pleasant, if one ignores the steady rain of damned souls dropping into the boil from somewhere high above. The most coveted real estate in the area looks out over it. Hot, bright, and ringed with screaming.\",\"locationVisuals\":\"Location, exterior, a vast lake of roiling orange magma and hellfire under a red sky. Surprisingly scenic black-sand shores in the foreground, heat-shimmer over the surface, distant figures plunging in from far above, embers drifting on the air.\",\"questTarget\":\"\",\"createdAt\":1781452752755,\"updatedAt\":1783185552119,\"icon\":\"⛱️\",\"entryCostAmount\":0,\"actionInstances\":[{\"id\":\"mqi7ko82bcbzvqael9x\",\"name\":\"Search beach for items\",\"conditions\":[{\"id\":\"mqi7ko82qjsciz0jxax\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\">=\",\"amount\":1}}],\"successEffects\":[{\"id\":\"mqi7ko82y5cwy8guvbj\",\"type\":\"set_entity_parent\",\"args\":{\"scope\":\"mqitem10000000015\",\"parentId\":\"__player__\"}},{\"id\":\"mqi7ko82g8s3jgdeffe\",\"type\":\"inject_narrative\",\"args\":{\"text\":\"You walk along the beach, looking for anything of value, and come across a pretty shell. From a certain angle, it could be a fragment of skull, but it is neat looking regardless of origin.\"}}],\"alwaysEffects\":[],\"failureEffects\":[],\"tags\":[\"inventory\"],\"oneShot\":true,\"silent\":true,\"templateId\":\"mqi7918cns789vt6o9s\"},{\"id\":\"mqi7kuuxzk260iynqet\",\"name\":\"Search beach for oddities\",\"conditions\":[{\"id\":\"mqi7kuux4025m12lcax\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\">=\",\"amount\":1}}],\"successEffects\":[{\"id\":\"mqi7kuuxexj5jeln2tw\",\"type\":\"set_entity_parent\",\"args\":{\"scope\":\"mqitem10000000014\",\"parentId\":\"__player__\"}},{\"id\":\"mqi7kuux6zyg75oes4m\",\"type\":\"inject_narrative\",\"args\":{\"text\":\"You walk along the beach, looking for anything of interest, and come across a weeping giant. It rests, exhausted, having just pulled itself from the lake. It cannot even respond as you collect a vial of its tears. Surely someone would appreciate them.\"}}],\"alwaysEffects\":[],\"failureEffects\":[],\"tags\":[\"inventory\"],\"oneShot\":true,\"silent\":true,\"templateId\":\"mqi7fd2z9t5b0z1r6pf\"}],\"tagSubscriptions\":[],\"lorebookEntryId\":\"c800c501-6fe8-4712-8153-501ea8ca97c9\"},\"mqchar10000000001\":{\"id\":\"mqchar10000000001\",\"name\":\"Morbus\",\"type\":\"character\",\"parentId\":\"mqd1f1ap7okbbymns4o\",\"storyState\":\"locked\",\"description\":\"\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628000000,\"updatedAt\":1783185433211,\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"state\":\"default\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"actionInstances\":[],\"tagSubscriptions\":[],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqd4d9ot178fv22cpc1p\":{\"id\":\"mqd4d9ot178fv22cpc1p\",\"name\":\"Violencia\",\"type\":\"character\",\"parentId\":\"mqcrt141rxefmvdl3p\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"questTarget\":\"\",\"createdAt\":1781401348686,\"updatedAt\":1783185433313,\"actionInstances\":[],\"tagSubscriptions\":[\"relationships\"]},\"mqdy7wjnylhq952kyj6\":{\"id\":\"mqdy7wjnylhq952kyj6\",\"name\":\"Lilibeth\",\"type\":\"character\",\"parentId\":\"mqd1tb13y2sesuxidpw\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"questTarget\":\"\",\"createdAt\":1781451486851,\"updatedAt\":1783185433398,\"actionInstances\":[],\"tagSubscriptions\":[\"relationships\"]},\"mqdzum2k6z45w4z7d9o\":{\"id\":\"mqdzum2k6z45w4z7d9o\",\"name\":\"Cowzits Academy of Witchcraft and Warlockery\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A prestigious and highly lethal academy of magic. The gothic architecture houses a renowned library containing the most wicked, forbidden grimoires in existence, alongside an extensive collection of highly dangerous smutty romance novels.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, and enchanted candles flare to life in the gothic windows.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":true,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"Cowzits Academy of Witchcraft and Warlockery\"],\"lorebookText\":\"A prestigious and extremely dangerous school of infernal magic, where students learn the wicked arts at a frequently fatal tuition of life and limb. Its gothic halls hold both the most forbidden grimoires in existence and an equally guarded collection of filthy romance novels. Ancient, lethal, and weirdly horny.\",\"locationVisuals\":\"Location, exterior, a sprawling gothic magic academy in Hell. Black spires and flying buttresses, stained-glass windows glowing with eerie light, torch-lined stone halls, an ominous red sky behind looming towers.\",\"questTarget\":\"\",\"createdAt\":1781454225980,\"updatedAt\":1783198355775,\"icon\":\"🏰\",\"entryCostAmount\":0,\"actionInstances\":[{\"id\":\"mqiivwfllnairdns9tz\",\"name\":\"Train intelligence\",\"conditions\":[{\"id\":\"mqiisbrpex7s7oc3pik\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\">=\",\"amount\":2}},{\"id\":\"mqiisbrppwcifo99kqy\",\"type\":\"char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\">=\",\"amount\":1}}],\"successEffects\":[{\"id\":\"mqiisbrpq67oftl6h0e\",\"type\":\"modify_char_skill\",\"args\":{\"scope\":\"__player__\",\"fieldRef\":\"cat_attr.fld_focus\",\"op\":\"add\",\"amount\":1}},{\"id\":\"mqiisbrp7yzdznxntpj\",\"type\":\"pop_up\",\"args\":{\"title\":\"Success!\",\"text\":\"Your Focus sharpens.\"}}],\"alwaysEffects\":[{\"id\":\"mqiisbrp0bf9n8okxyzh\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#stamina\",\"op\":\"subtract\",\"amount\":2}},{\"id\":\"mqiisbrpkqun2ktx904\",\"type\":\"modify_char_resource\",\"args\":{\"scope\":\"__player__\",\"tag\":\"#currency\",\"op\":\"subtract\",\"amount\":1}},{\"id\":\"mqiisbrpipplnl90qk8\",\"type\":\"ask_text\",\"args\":{\"instructions\":\"Describe how you train to improve your intelligence. \"}}],\"failureEffects\":[{\"id\":\"mqiisbrpstawf0ijavc\",\"type\":\"pop_up\",\"args\":{\"title\":\"Failure!\",\"text\":\"You wasted your time and money, you dumb oaf.\"}}],\"tags\":[\"player\"],\"resolution\":{\"type\":\"custom_1d6\",\"useDC\":true,\"dc\":4,\"args\":{},\"bands\":[]},\"templateId\":\"mqiisbrprrjuuzwv6wd\"}],\"tagSubscriptions\":[],\"lorebookEntryId\":\"90d72dea-c3ce-4cf4-a7b2-97771f32646d\"},\"mqehbtj9s02op10w3z1\":{\"id\":\"mqehbtj9s02op10w3z1\",\"name\":\"Chatty Grimoire\",\"type\":\"item\",\"parentId\":\"mqloca10000000004\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"An ancient book of unknown origin, bound in human flesh. Has an authentic fleshy feel to it. Whispers not-so-sweet nothings in your ear.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[{\"skillTag\":\"#focus\",\"modifier\":1}],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"questTarget\":\"\",\"createdAt\":1781483582277,\"updatedAt\":1783189452249,\"icon\":\"📕\",\"isEquipped\":false,\"actionInstances\":[],\"tagSubscriptions\":[\"spell\"],\"equippedToCharId\":\"\"},\"mqgy1b283pkblocdt2b\":{\"id\":\"mqgy1b283pkblocdt2b\",\"name\":\"Graveyard\",\"type\":\"location\",\"parentId\":null,\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A sprawling necropolis of leaning headstones, cracked crypts, and freshly turned earth, where Hell buries whatever can still be buried. Unnervingly quiet, the silence broken only by shifting soil and the occasional thing clawing its way back up.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"Graveyard\"],\"lorebookText\":\"Hell's burial ground - the place where the truly destroyed are interred, the dead of a realm already full of the dead. Crooked headstones and crypts sprawl in untended rows, visited by almost no one. It is the rare genuinely quiet corner of the underworld, which is exactly why a few seek it out and most stay away.\",\"locationVisuals\":\"Location, exterior, a vast eerie graveyard in Hell. Rows of crooked weathered headstones and broken mausoleums, skeletal dead trees, low ground-fog, a red blood-moon overhead, faint green grave-light glowing between the stones.\",\"questTarget\":\"\",\"createdAt\":1781632577600,\"updatedAt\":1783185552414,\"tagSubscriptions\":[],\"actionInstances\":[],\"icon\":\"🪦\",\"lorebookEntryId\":\"fea3828f-50a1-4e56-904c-d458794c1828\"},\"mqloca10000000001\":{\"id\":\"mqloca10000000001\",\"name\":\"Depravitae's Van\",\"type\":\"location\",\"parentId\":\"mqcrt141rxefmvdl3p\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A beat-up van parked permanently in the Must-hav Motel lot. The interior is cramped for a normal demon but surprisingly roomy for an imp, crammed with organized hoardings of corporate survival gear and cheap comforts.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. Sunlight bleeds through the cracked windshield.\",\"afternoon\":\"Time: afternoon. The metal exterior bakes in the hellish afternoon heat.\",\"evening\":\"Time: evening. Shadows cloak the van, offering a small sliver of privacy.\"},\"connectedEntityIds\":[],\"createdAt\":1781628000010,\"updatedAt\":1783191760367,\"icon\":\"🚐\",\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[\"Depravitae's Van\"],\"lorebookText\":\"Depravitae's home and fortress: a permanently parked van in the motel lot, packed with scavenged survival gear and small comforts. Tight quarters for anything bigger than an imp, but meticulously organized and fiercely hers. Cozy, cluttered, and defensible - a foxhole dressed up as a home.\",\"locationVisuals\":\"Location, interior, the inside of a cluttered lived-in van. Neatly organized hoards of scavenged survival gear, blankets and cheap comforts, strings of fairy lights and small trinkets, cramped cozy quarters in warm low light.\",\"gated\":true,\"tagSubscriptions\":[\"bedroom\"],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"lorebookEntryId\":\"e12b0cf0-e508-47bf-b583-023f7ecf36ad\"},\"mqloca10000000002\":{\"id\":\"mqloca10000000002\",\"name\":\"Violencia's Room\",\"type\":\"location\",\"parentId\":\"mqcrt141rxefmvdl3p\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A stark, spartan room within the Must-hav Motel. It lacks any personal touches save for a collection of heavy, worn fitness equipment and a hidden stash of dog-eared smutty romance novels.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The blood-sun forces its way through the cheap blinds.\",\"afternoon\":\"Time: afternoon. Dust motes dance in the sweltering afternoon light.\",\"evening\":\"Time: evening. The room is dark, illuminated only by the neon motel sign buzzing outside the window.\"},\"connectedEntityIds\":[],\"createdAt\":1781628000011,\"updatedAt\":1783191793820,\"icon\":\"🚪\",\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[\"Violencia's Room\"],\"lorebookText\":\"Violencia's room in the motel, kept as bare and disciplined as a cell. There is nothing personal in it but a rack of battered fitness equipment - and, hidden out of sight, a guilty stash of dog-eared romance novels. Austere, sweat-worn, and quietly contradictory.\",\"locationVisuals\":\"Location, interior, a stark spartan motel room. Bare walls, heavy worn fitness equipment in one corner, a plainly made bed, minimal furnishings under dim light, disciplined and impersonal.\",\"gated\":true,\"tagSubscriptions\":[\"bedroom\"],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"lorebookEntryId\":\"730503d7-663d-4de2-bd27-3651f1649357\"},\"mqloca10000000003\":{\"id\":\"mqloca10000000003\",\"name\":\"Lilibeth's Penthouse\",\"type\":\"location\",\"parentId\":\"mqdyz1bn27n93tun32e\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A posh high-rise apartment with floor-to-ceiling windows overlooking the Lake of Fire. The decor is fiercely opulent, designed strictly to intimidate guests and reinforce her superiority.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The scarlet dawn reflects perfectly off the polished marble floors.\",\"afternoon\":\"Time: afternoon. The glare from the Lake of Fire below casts shifting, fiery patterns on the ceiling.\",\"evening\":\"Time: evening. The apartment is lit by the ambient glow of the magma lake and pristine, modern chandeliers.\"},\"connectedEntityIds\":[],\"createdAt\":1781628000012,\"updatedAt\":1783191778923,\"icon\":\"🏙️\",\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[\"Lilibeth's Penthouse\"],\"lorebookText\":\"Lilibeth's high-rise penthouse above the Lake of Fire, all floor-to-ceiling glass and aggressive luxury. Every furnishing is chosen to overawe whoever is allowed inside and remind them of their place. Opulent, immaculate, and cold - a home built less to be lived in than to be impressed by.\",\"locationVisuals\":\"Location, interior, a posh high-rise penthouse with floor-to-ceiling windows overlooking a lake of fire. Fiercely opulent modern decor, sharp luxury, orange glow rising from the lava below, cold and intimidating elegance.\",\"gated\":false,\"entryActionId\":\"mqgzyl0z26jjufw4025\",\"tagSubscriptions\":[\"bedroom\"],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"lorebookEntryId\":\"d3e35f87-2b9d-4420-b725-096085ec0933\"},\"mqd1tb13y2sesuxidpw\":{\"id\":\"mqd1tb13y2sesuxidpw\",\"name\":\"The 9th Floor\",\"type\":\"location\",\"parentId\":\"mqd1f1ap7okbbymns4o\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"An opulent executive suite reserved for the most treacherous devils who have clawed their way to the top of the corporate hierarchy. Marble floors, mahogany desks, and panoramic windows display their dominance over the wastes below.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The morning blood-sun begins its ascent, casting the sky in scarlet.\",\"afternoon\":\"Time: afternoon. The afternoon blood-sun irradiates the landscape and those not protected from it.\",\"evening\":\"Time: evening. The blood-sun sets, and the opulent lighting of the executive suites kicks on.\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":true,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"The 9th Floor\"],\"lorebookText\":\"The executive summit of the Cubicle Wastes, reserved for the devils ruthless enough to claw to the top of Hell's corporate ladder. Marble, mahogany, and panoramic glass look down on the drones far below, every detail tuned to display dominance. Lavish, frigid, and lethal in a tailored suit.\",\"locationVisuals\":\"Location, interior, an opulent executive suite atop an infernal corporate tower. Marble floors, mahogany desks, panoramic windows over a bleak office wasteland far below, cold expensive lighting, predatory corporate grandeur.\",\"questTarget\":\"\",\"createdAt\":1781397058071,\"updatedAt\":1783185552994,\"icon\":\"📈\",\"entryActionId\":\"mqijzohyhi55zb23ujh\",\"tagSubscriptions\":[],\"actionInstances\":[],\"lorebookEntryId\":\"fb79c5e2-c4e8-492a-a0ea-5df99b5a28d1\"},\"mqchar10000000002\":{\"id\":\"mqchar10000000002\",\"name\":\"Gildra\",\"type\":\"character\",\"parentId\":\"mqdzum2k6z45w4z7d9o\",\"storyState\":\"locked\",\"description\":\"\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628000001,\"updatedAt\":1783185434032,\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"state\":\"default\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqchar10000000003\":{\"id\":\"mqchar10000000003\",\"name\":\"Hairy Patters\",\"type\":\"character\",\"parentId\":\"mqh0q8hsswi7sr3vu61\",\"storyState\":\"locked\",\"description\":\"\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628000002,\"updatedAt\":1783185434107,\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"state\":\"default\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqchar10000000004\":{\"id\":\"mqchar10000000004\",\"name\":\"Snive\",\"type\":\"character\",\"parentId\":\"mqd24uiz5cfbuayinjh\",\"storyState\":\"locked\",\"description\":\"\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628000003,\"updatedAt\":1783185434200,\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"state\":\"default\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"actionInstances\":[],\"tagSubscriptions\":[\"vendor\",\"theft\"],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqchar10000000005\":{\"id\":\"mqchar10000000005\",\"name\":\"Brozak\",\"type\":\"character\",\"parentId\":\"mqd28yemhy9v6xb048x\",\"storyState\":\"locked\",\"description\":\"\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628000004,\"updatedAt\":1783185434288,\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"state\":\"default\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[\"vendor\"],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqchar10000000006\":{\"id\":\"mqchar10000000006\",\"name\":\"Fera\",\"type\":\"character\",\"parentId\":\"mqd1q1j4fprzxu3kvqq\",\"storyState\":\"locked\",\"description\":\"\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628000005,\"updatedAt\":1783185798878,\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"state\":\"default\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[\"theft\"],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqchar10000000007\":{\"id\":\"mqchar10000000007\",\"name\":\"Barghest\",\"type\":\"character\",\"parentId\":\"mqdyz1bn27n93tun32e\",\"storyState\":\"locked\",\"description\":\"\",\"stateDescriptions\":{\"default\":\"\",\"collared\":\"The Translation Collar sits fastened at his throat, its rune tag aglow. He speaks now — a low, articulate growl — and will hold a conversation, though his loyalty is still Lilibeth’s.\"},\"createdAt\":1781628000006,\"updatedAt\":1783185434449,\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"state\":\"default\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqh06ogj3npwvb5q29k\":{\"id\":\"mqh06ogj3npwvb5q29k\",\"name\":\"your room\",\"type\":\"location\",\"parentId\":\"mqcrt141rxefmvdl3p\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"Your room isn't much, but it's... not much. A sagging bed, a bare bulb, and a door that technically shuts - your own grimy square of the Must-hav Motel.\",\"atmosphere\":\"\",\"state\":\"morning\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"your room\"],\"lorebookText\":\"The cheapest room in the Must-hav Motel, home to whoever currently can't afford better. A single grimy box with a bed, a bulb, and a door that almost locks - barely a home, but private-ish, which in this part of Hell counts for something.\",\"locationVisuals\":\"Location, interior, a cheap grimy motel room. Sagging single bed, peeling wallpaper, a bare flickering bulb, battered minimal furniture, a small dirty window leaking red light, lived-in squalor.\",\"questTarget\":\"\",\"createdAt\":1781636187475,\"updatedAt\":1783191746352,\"icon\":\"🚪\",\"entryActionId\":\"mqh0diazswomfag1g9v\",\"actionInstances\":[],\"tagSubscriptions\":[\"rest\",\"bedroom\"],\"lorebookEntryId\":\"36fcc4eb-b107-4d7d-bb08-b1969b44bc03\"},\"mqh0q8hsswi7sr3vu61\":{\"id\":\"mqh0q8hsswi7sr3vu61\",\"name\":\"sub-basement D\",\"type\":\"location\",\"parentId\":\"mqd1f1ap7okbbymns4o\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"The forgotten depths of sub-basement D are infested with various rodents of unusual size, discarded toxic waste, and a lonely red stapler.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[\"sub-basement D\"],\"lorebookText\":\"The bottom of the Cubicle Wastes, a damp utility level everyone above has forgotten on purpose. Rodents of unusual size nest among leaking toxic waste and decades of discarded office junk. Dripping, lightless, and unloved - the kind of place things get lost in and stay lost.\",\"locationVisuals\":\"Location, interior, a grimy forgotten sub-basement. Flickering dying fluorescent light, dripping pipes, leaking toxic-waste barrels, scattered debris, oversized rats lurking in the shadows, a single red stapler on a dusty crate.\",\"questTarget\":\"\",\"createdAt\":1781637099904,\"updatedAt\":1783185553331,\"icon\":\"🪤\",\"entryActionId\":\"mqh0vcz9aos5zsdz6rv\",\"tagSubscriptions\":[],\"actionInstances\":[{\"id\":\"mqratspawn00001\",\"name\":\"Disturb the rat nest\",\"tags\":[\"combat\"],\"targetMode\":\"none\",\"conditions\":[],\"successEffects\":[{\"id\":\"rs_e1\",\"type\":\"spawn_minor_npc\",\"args\":{\"archetypeId\":\"npc_demonrat\",\"count\":2}},{\"id\":\"rs_e2\",\"type\":\"inject_message\",\"args\":{\"text\":\"Something stirs in the dark of the sub-basement. Describe the demon rats boiling out of the nest toward {Actor}.\"}}],\"failureEffects\":[],\"alwaysEffects\":[]}],\"lorebookEntryId\":\"812f6fb9-1c4a-4485-9ff8-872ac3ea6f3d\"},\"mqh7726i2fdnojk3a64\":{\"id\":\"mqh7726i2fdnojk3a64\",\"name\":\"The Grimoire: A fancy letter\",\"type\":\"narrative\",\"parentId\":\"mqchar10000000003\",\"narrativeParentId\":\"mqiewgg5p14phvi6zgv\",\"storyState\":\"active\",\"description\":\"The Rat King of Sub-basement D dropped a fancy letter. It looks like he had just fulfilled his dream to be accepted to Cowzits Academy of Witchcraft and Warlockery. Too bad, Hairy. You should see if the letter gets you admitted.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"rules\":[],\"skillBonuses\":[],\"inventoryIds\":[],\"showActionWidget\":false,\"isVehicle\":false,\"gated\":false,\"notes\":\"\",\"knowledgeString\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"questTarget\":\"mqehbtj9s02op10w3z1\",\"createdAt\":1781647962571,\"updatedAt\":1783185434694,\"icon\":\"✉️\",\"actionInstances\":[{\"id\":\"mqif9y0flrlq0j4takn\",\"name\":\"Accept Quest\",\"conditions\":[],\"successEffects\":[{\"id\":\"mqif9y0fzcqvly8qfgc\",\"type\":\"set_entity_parent\",\"args\":{\"scope\":\"__self__\",\"parentId\":\"__player__\"}},{\"id\":\"mqif9y0fguuk6a4gsjv\",\"type\":\"set_entity_story_state\",\"args\":{\"scope\":\"__self__\",\"value\":\"active\"}},{\"id\":\"mqif9y0fv6ice4kbf41\",\"type\":\"pop_up\",\"args\":{\"title\":\"Turn on tracking\",\"text\":\"You can click on the narrative to track its target if it has one.\"}}],\"alwaysEffects\":[],\"failureEffects\":[],\"silent\":true,\"oneShot\":true,\"tags\":[\"narratives\"],\"templateId\":\"mqh6mhtgekffw831utu\"},{\"id\":\"mqkd7kx7rtx99cmtbpv\",\"name\":\"Write your name over Hairy's\",\"conditions\":[],\"successEffects\":[{\"id\":\"mqkd7kx7ry5euthqtb3\",\"type\":\"set_entity_locked\",\"args\":{\"scope\":\"mqdzum2k6z45w4z7d9o\",\"value\":\"false\"}}],\"alwaysEffects\":[],\"failureEffects\":[],\"tags\":[\"narratives\"],\"oneShot\":true,\"silent\":true,\"templateId\":\"mqkd07q73rka8ohzco1\"}],\"tagSubscriptions\":[]},\"mqloca10000000004\":{\"id\":\"mqloca10000000004\",\"name\":\"Cowzits Grand Library\",\"type\":\"location\",\"parentId\":\"mqdzum2k6z45w4z7d9o\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A vast, gothic library housing Cowzits Academy's collection of forbidden grimoires. The books constantly chatter amongst themselves, gossiping with neighboring tomes and harshly mocking anyone attempting to browse the shelves.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. Sunlight struggles to pierce the dusty stained glass.\",\"afternoon\":\"Time: afternoon. The chatter of the books reaches a dull roar as students shuffle through.\",\"evening\":\"Time: evening. The aisles are dark, and the books whisper sinister secrets in the quiet.\"},\"connectedEntityIds\":[],\"createdAt\":1781628500000,\"updatedAt\":1783185553507,\"icon\":\"📚\",\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[\"Cowzits Grand Library\"],\"lorebookText\":\"The heart of Cowzits Academy and the largest collection of forbidden grimoires in existence, shelved alongside its notorious smut. The books are sentient, opinionated, and rude - they gossip among themselves and heckle anyone who dares browse. Vast, dim, and deafening with literary insults.\",\"locationVisuals\":\"Location, interior, a vast gothic library of forbidden grimoires. Towering shelves vanishing into shadow, dusty stained-glass windows, floating candlelight, leather tomes crammed on every shelf, ominous scholarly gloom.\",\"gated\":false,\"entryActionId\":\"mqi72d16smqcoyctxso\",\"actionInstances\":[],\"tagSubscriptions\":[\"vendor\"],\"knowledgeString\":\"\",\"questTarget\":\"\",\"lorebookEntryId\":\"d1dd9fb9-f53c-48c3-8eaf-59f267df209f\"},\"mqloca10000000005\":{\"id\":\"mqloca10000000005\",\"name\":\"Hexagon Hot Springs & Lockers\",\"type\":\"location\",\"parentId\":\"mqd1q1j4fprzxu3kvqq\",\"narrativeParentId\":null,\"storyState\":\"locked\",\"description\":\"A steamy, cavernous locker room and natural hot spring situated directly beneath the arena floor. Fighters and trainers come here to wash off fresh blood, soothe battered muscles in the sulfurous waters, and size up their competition.\",\"atmosphere\":\"\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\",\"morning\":\"Time: morning. The waters are relatively clear before the day's first bouts.\",\"afternoon\":\"Time: afternoon. The room is packed with bruised fighters nursing injuries.\",\"evening\":\"Time: evening. Thick steam limits visibility as the victors celebrate and soak.\"},\"connectedEntityIds\":[],\"createdAt\":1781628500001,\"updatedAt\":1783185553657,\"icon\":\"♨️\",\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[\"Hexagon Hot Springs & Lockers\"],\"lorebookText\":\"The fighters' baths beneath the Hexagon's floor, where the arena's combatants wash off fresh blood and soak battered bodies in the sulfurous springs. Equal parts recovery room and rumor mill, it is where rivalries cool, scheme, and reheat between bouts. Steamy, low-lit, and thick with sweat and posturing.\",\"locationVisuals\":\"Location, interior, a steamy cavernous locker room over a natural hot spring. Glowing sulfurous pools beneath the arena, rough stone walls, rows of battered lockers, thick rolling steam, bruised fighters soaking in dim warm light.\",\"gated\":false,\"entryActionId\":\"mqi6xzmky4m3ddynegj\",\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"lorebookEntryId\":\"66a18e0f-414a-4caf-806f-6235605356da\"},\"mqitem10000000001\":{\"id\":\"mqitem10000000001\",\"name\":\"Arena Championship Belt\",\"type\":\"item\",\"parentId\":\"mqchar10000000006\",\"storyState\":\"locked\",\"description\":\"A massive, heavy championship belt made of blackened steel and studded with sharp spikes. It marks the wearer as the reigning champion of The Hexagon.\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628500002,\"updatedAt\":1783185434931,\"icon\":\"🏆\",\"isEquipped\":true,\"equippedToCharId\":\"mquser10000000006\",\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[{\"skillTag\":\"#physique\",\"modifier\":1},{\"skillTag\":\"#charisma\",\"modifier\":1}],\"isVehicle\":false,\"atmosphere\":\"\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\"},\"mqitem10000000002\":{\"id\":\"mqitem10000000002\",\"name\":\"Executive Skirt Suit\",\"type\":\"item\",\"parentId\":\"mqchar10000000004\",\"storyState\":\"locked\",\"description\":\"A luxurious, sharply tailored blazer paired with a clingy, high-waisted pencil skirt. Projects power and absolute authority.\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628500003,\"updatedAt\":1783185832584,\"icon\":\"🧥\",\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"isEquipped\":false,\"equippedToCharId\":\"\"},\"mqitem10000000003\":{\"id\":\"mqitem10000000003\",\"name\":\"Punk Outfit\",\"type\":\"item\",\"parentId\":\"mqchar10000000004\",\"storyState\":\"locked\",\"description\":\"An edgy ensemble featuring a ripped, off-the-shoulder \\\"Rat King\\\" band shirt, a charcoal pleated skirt, and torn fishnet stockings.\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628500004,\"updatedAt\":1783185841208,\"icon\":\"👕\",\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"isEquipped\":false,\"equippedToCharId\":\"\"},\"mqitem10000000004\":{\"id\":\"mqitem10000000004\",\"name\":\"Yellow Sundress\",\"type\":\"item\",\"parentId\":\"mqchar10000000004\",\"storyState\":\"locked\",\"description\":\"A cheerful, bright yellow sundress made of light, flowing fabric. Starkly contrasts with the general atmosphere of Hell.\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628500005,\"updatedAt\":1783185849762,\"icon\":\"👗\",\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"isEquipped\":false,\"equippedToCharId\":\"\"},\"mqitem10000000005\":{\"id\":\"mqitem10000000005\",\"name\":\"Black Lace Lingerie Set\",\"type\":\"item\",\"parentId\":\"mqchar10000000004\",\"storyState\":\"locked\",\"description\":\"A matching black lingerie set consisting of a tight lace corset, a thong, and sheer thigh-high stockings.\",\"state\":\"default\",\"stateDescriptions\":{\"default\":\"\"},\"createdAt\":1781628500006,\"updatedAt\":1783185859246,\"icon\":\"🖤\",\"narrativeParentId\":null,\"rules\":[],\"skillBonuses\":[],\"isVehicle\":false,\"atmosphere\":\"\",\"connectedEntityIds\":[],\"presentCharacterIds\":[],\"awareCharacterIds\":[],\"actions\":[],\"inventoryIds\":[],\"showActionWidget\":true,\"notes\":\"\",\"lorebookTags\":[],\"lorebookText\":\"\",\"locationVisuals\":\"\",\"gated\":false,\"tagSubscriptions\":[],\"actionInstances\":[],\"knowledgeString\":\"\",\"questTarget\":\"\",\"isEquipped\":false,\"equippedToCharId\":\"\"},\"mqitem10000000006\":{\"id\":\"mqitem10000000006\",\"name\":\"Purple Pajama Set\",\"type\":\"item\",\"parentId\":\"mqchar10000000004\",\"storyState\":\"locked\",\"description\":\"A comfortable sleepwear set including a soft purple crop top and loose-fitting, thin pajama bottoms.\",\"state\":\"default\",\"stateDescriptions